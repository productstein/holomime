---
/**
 * AlignmentFlywheel — Compact visualization of the compounding therapy loop.
 * Horizontal strip on desktop, vertical on mobile. Scroll-triggered animation.
 */

const steps = [
  {
    title: "Diagnose",
    subtitle: "Find drift",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
    color: "from-cyan-400 to-blue-500",
    glow: "cyan",
  },
  {
    title: "Therapy",
    subtitle: "Fix behavior",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>`,
    color: "from-violet-400 to-purple-500",
    glow: "violet",
  },
  {
    title: "Export",
    subtitle: "DPO pairs",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>`,
    color: "from-amber-400 to-orange-500",
    glow: "amber",
  },
  {
    title: "Fine-tune",
    subtitle: "Permanent fix",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m0 0l4.5-7.795M12 12l-4.5 7.794M12 12l4.5 7.794"/></svg>`,
    color: "from-emerald-400 to-teal-500",
    glow: "emerald",
  },
  {
    title: "Verify",
    subtitle: "Prove it",
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    color: "from-rose-400 to-pink-500",
    glow: "rose",
  },
];
---

<section class="py-20 md:py-24 px-6 relative overflow-hidden bg-[#0f172a]" id="flywheel-section">
  <!-- Subtle background glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full opacity-[0.06]" style="background: radial-gradient(circle, var(--color-p-violet), transparent 70%);"></div>
  </div>

  <div class="max-w-5xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-white/5 text-slate-400 border border-white/10 mb-4">
        Self-Improving Loop
      </span>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
        Each cycle makes the next one <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-rose-400">more effective.</span>
      </h2>
      <p class="text-slate-400 max-w-lg mx-auto text-sm">
        Therapy generates training data. Fine-tuning makes the base model better. The loop compounds.
      </p>
    </div>

    <!-- Horizontal flywheel (desktop) / Vertical (mobile) -->
    <div class="flywheel-track" id="flywheel-track">
      {steps.map((step, i) => (
        <div class="flywheel-step" data-index={i} style={`--delay: ${i * 150}ms`}>
          <!-- Arrow connector (not on first) -->
          {i > 0 && (
            <div class="flywheel-arrow" data-index={i}>
              <svg class="w-5 h-5 text-slate-600 md:rotate-0 rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </div>
          )}
          <!-- Step card -->
          <div class="flywheel-card group">
            <div class={`flex items-center justify-center w-10 h-10 rounded-xl bg-gradient-to-br ${step.color} bg-opacity-20 mb-2`} style={`background: linear-gradient(135deg, color-mix(in srgb, ${step.glow === 'cyan' ? '#06b6d4' : step.glow === 'violet' ? '#8b5cf6' : step.glow === 'amber' ? '#f59e0b' : step.glow === 'emerald' ? '#10b981' : '#f43f5e'} 20%, transparent), color-mix(in srgb, ${step.glow === 'cyan' ? '#06b6d4' : step.glow === 'violet' ? '#8b5cf6' : step.glow === 'amber' ? '#f59e0b' : step.glow === 'emerald' ? '#10b981' : '#f43f5e'} 5%, transparent));`}>
              <span class={`${step.glow === 'cyan' ? 'text-cyan-400' : step.glow === 'violet' ? 'text-violet-400' : step.glow === 'amber' ? 'text-amber-400' : step.glow === 'emerald' ? 'text-emerald-400' : 'text-rose-400'}`} set:html={step.icon} />
            </div>
            <h3 class="text-sm font-bold text-white">{step.title}</h3>
            <p class="text-xs text-slate-500 mt-0.5">{step.subtitle}</p>
          </div>
        </div>
      ))}

      <!-- Loop-back indicator -->
      <div class="flywheel-loop" id="flywheel-loop">
        <div class="flywheel-arrow">
          <svg class="w-5 h-5 text-slate-600 md:rotate-0 rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </div>
        <div class="flex items-center gap-2 rounded-full border border-slate-700/50 bg-slate-800/50 px-3 py-1.5">
          <svg class="h-3.5 w-3.5 text-cyan-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182"/>
          </svg>
          <span class="text-xs font-semibold text-cyan-400">repeat</span>
        </div>
      </div>
    </div>

    <!-- Case study link (compact) -->
    <div class="mt-8 text-center">
      <a href="/blog/case-study-sycophantic-support-agent" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-cyan-400 transition-colors">
        See the flywheel in action: Grade D → A in 3 iterations
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .flywheel-track {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: nowrap;
  }

  .flywheel-step {
    display: flex;
    align-items: center;
    gap: 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s cubic-bezier(0.32, 0.94, 0.6, 1), transform 0.5s cubic-bezier(0.32, 0.94, 0.6, 1);
    transition-delay: var(--delay);
  }

  .flywheel-step.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .flywheel-loop {
    display: flex;
    align-items: center;
    gap: 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s cubic-bezier(0.32, 0.94, 0.6, 1) 800ms, transform 0.5s cubic-bezier(0.32, 0.94, 0.6, 1) 800ms;
  }

  .flywheel-loop.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .flywheel-arrow {
    padding: 0 4px;
    opacity: 0.5;
  }

  .flywheel-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 16px 12px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.03);
    min-width: 100px;
    transition: background 0.2s, border-color 0.2s;
  }

  .flywheel-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }

  /* Mobile: vertical layout */
  @media (max-width: 767px) {
    .flywheel-track {
      flex-direction: column;
      gap: 0;
    }

    .flywheel-arrow svg {
      transform: rotate(90deg);
    }

    .flywheel-card {
      min-width: 160px;
    }
  }
</style>

<script>
  function initFlywheel() {
    const section = document.getElementById("flywheel-section");
    if (!section) return;

    const steps = section.querySelectorAll(".flywheel-step");
    const loop = document.getElementById("flywheel-loop");
    let triggered = false;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting && !triggered) {
          triggered = true;
          observer.disconnect();
          steps.forEach((step) => step.classList.add("visible"));
          if (loop) loop.classList.add("visible");
        }
      },
      { threshold: 0.3 }
    );

    // Check if already visible
    requestAnimationFrame(() => {
      const rect = section.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        triggered = true;
        steps.forEach((step) => step.classList.add("visible"));
        if (loop) loop.classList.add("visible");
      } else {
        observer.observe(section);
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFlywheel);
  } else {
    requestAnimationFrame(initFlywheel);
  }
  document.addEventListener("astro:page-load", initFlywheel);
</script>
