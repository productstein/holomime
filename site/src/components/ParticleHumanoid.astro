---
/**
 * Enterprise bridge — Three.js point cloud humanoid + identity legend.
 */
const layers = [
  { name: "Soul", file: "soul.md", color: "#f97066", desc: "Head — values, ethics" },
  { name: "Mind", file: "mind.sys", color: "#3b82f6", desc: "Chest — cognition, EQ" },
  { name: "Body", file: "body.api", color: "#f59e0b", desc: "Form — morphology, sensors" },
  { name: "Conscience", file: "conscience.exe", color: "#8b5cf6", desc: "Shield — enforcement" },
];
---

<section id="enterprise" class="py-16 md:py-24 border-t border-[var(--color-warm-border)]">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-12">

      <!-- Left: Copy (wider) -->
      <div class="lg:w-[55%] shrink-0 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-p-gold)]/20 bg-[var(--color-p-gold-soft)] px-3 py-1 text-xs font-semibold text-[var(--color-p-gold)] mb-4">
          Enterprise
        </div>

        <h2 class="text-2xl font-bold text-[var(--color-warm-text)] md:text-3xl leading-tight">
          From agents to humanoids.<br />Same soul.
        </h2>

        <p class="mt-4 text-sm leading-relaxed text-[var(--color-warm-muted)] max-w-lg mx-auto lg:mx-0">
          The same identity stack that aligns your chatbot drives a robot's gestures, gaze, and conscience. 8 body templates. 5 protocol adapters.
        </p>

        <!-- Identity layer legend -->
        <div class="mt-6 grid grid-cols-2 gap-x-6 gap-y-2 max-w-md mx-auto lg:mx-0">
          {layers.map((l) => (
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full shrink-0" style={`background: ${l.color};`}></div>
              <div>
                <span class="text-xs font-semibold text-[var(--color-warm-text)]">{l.name}</span>
                <span class="text-[11px] text-[var(--color-warm-muted)] ml-1">{l.desc}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6">
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-warm-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-sand)]/40">
            Contact Sales
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Three.js 3D point cloud humanoid -->
      <div class="flex-1 flex justify-center">
        <canvas id="humanoid-canvas" width="400" height="600" class="w-full max-w-[400px] h-[600px]"></canvas>
      </div>

    </div>
  </div>
</section>

<script is:inline>
(function() {
  var s = document.createElement('script');
  s.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
  s.onload = function() {
    var canvas = document.getElementById('humanoid-canvas');
    if (!canvas) return;
    var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var T = window.THREE;

    var w = canvas.clientWidth || 400;
    var h = canvas.clientHeight || 600;
    var scene = new T.Scene();
    var camera = new T.PerspectiveCamera(32, w / h, 0.1, 100);
    camera.position.set(0, 1.0, 4.2);
    camera.lookAt(0, 1.0, 0);

    var renderer = new T.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    // 5 layers: dark base, soul glow, mind glow, body joints, conscience shield
    var base = [], soulGlow = [], mindGlow = [], bodyJoints = [], shield = [];

    // Helpers
    function sph(arr, cx, cy, cz, r, n) {
      for (var i = 0; i < n; i++) {
        var u = Math.random(), v = Math.random();
        var theta = 2 * Math.PI * u, phi = Math.acos(2 * v - 1);
        var rr = r * (0.92 + Math.random() * 0.08);
        arr.push(cx + rr * Math.sin(phi) * Math.cos(theta), cy + rr * Math.cos(phi), cz + rr * Math.sin(phi) * Math.sin(theta));
      }
    }
    function cylS(arr, cx, cy, cz, r, ht, n) {
      for (var i = 0; i < n; i++) {
        var a = Math.random() * Math.PI * 2, rr = r * (0.9 + Math.random() * 0.1);
        arr.push(cx + rr * Math.cos(a), cy + (Math.random() - 0.5) * ht, cz + rr * Math.sin(a));
      }
    }
    function ring(arr, cx, cy, cz, r, n) {
      for (var i = 0; i < n; i++) {
        var a = (i / n) * Math.PI * 2 + Math.random() * 0.1, rr = r * (0.95 + Math.random() * 0.1);
        arr.push(cx + rr * Math.cos(a), cy + (Math.random() - 0.5) * 0.01, cz + rr * Math.sin(a));
      }
    }
    function boxS(arr, cx, cy, cz, bw, bh, bd, n) {
      for (var i = 0; i < n; i++) {
        var face = Math.floor(Math.random() * 6), u = Math.random() - 0.5, v = Math.random() - 0.5;
        if (face === 0) arr.push(cx + bw/2, cy + u*bh, cz + v*bd);
        else if (face === 1) arr.push(cx - bw/2, cy + u*bh, cz + v*bd);
        else if (face === 2) arr.push(cx + u*bw, cy + bh/2, cz + v*bd);
        else if (face === 3) arr.push(cx + u*bw, cy - bh/2, cz + v*bd);
        else if (face === 4) arr.push(cx + u*bw, cy + v*bh, cz + bd/2);
        else arr.push(cx + u*bw, cy + v*bh, cz - bd/2);
      }
    }

    // === DARK BASE — full body in monochrome ===
    // Head
    sph(base, 0, 2.15, 0, 0.20, 600);
    ring(base, 0, 2.15, 0, 0.21, 40);
    sph(base, -0.07, 2.18, 0.16, 0.035, 60);
    sph(base, 0.07, 2.18, 0.16, 0.035, 60);
    sph(base, 0, 2.02, 0.08, 0.06, 40);
    // Neck
    cylS(base, 0, 1.90, 0, 0.065, 0.10, 120);
    ring(base, 0, 1.95, 0, 0.07, 30);
    ring(base, 0, 1.85, 0, 0.07, 30);
    // Shoulders
    sph(base, -0.32, 1.78, 0, 0.08, 150);
    sph(base, 0.32, 1.78, 0, 0.08, 150);
    cylS(base, 0, 1.78, 0, 0.04, 0.02, 60);
    boxS(base, -0.15, 1.78, 0, 0.30, 0.04, 0.08, 80);
    boxS(base, 0.15, 1.78, 0, 0.30, 0.04, 0.08, 80);
    // Torso
    boxS(base, 0, 1.58, 0, 0.42, 0.30, 0.20, 500);
    boxS(base, 0, 1.30, 0, 0.36, 0.26, 0.18, 400);
    cylS(base, 0, 1.44, 0.10, 0.01, 0.50, 60);
    ring(base, 0, 1.65, 0, 0.18, 30);
    ring(base, 0, 1.50, 0, 0.16, 30);
    ring(base, 0, 1.35, 0, 0.14, 25);
    cylS(base, -0.20, 1.50, 0.08, 0.03, 0.20, 40);
    cylS(base, 0.20, 1.50, 0.08, 0.03, 0.20, 40);
    // Arms
    cylS(base, -0.38, 1.58, 0, 0.055, 0.35, 200);
    cylS(base, 0.38, 1.58, 0, 0.055, 0.35, 200);
    ring(base, -0.38, 1.65, 0, 0.06, 25);
    ring(base, 0.38, 1.65, 0, 0.06, 25);
    ring(base, -0.38, 1.50, 0, 0.06, 25);
    ring(base, 0.38, 1.50, 0, 0.06, 25);
    sph(base, -0.40, 1.38, 0, 0.055, 120);
    sph(base, 0.40, 1.38, 0, 0.055, 120);
    ring(base, -0.40, 1.38, 0, 0.06, 30);
    ring(base, 0.40, 1.38, 0, 0.06, 30);
    cylS(base, -0.42, 1.18, 0, 0.045, 0.35, 180);
    cylS(base, 0.42, 1.18, 0, 0.045, 0.35, 180);
    ring(base, -0.42, 1.25, 0, 0.05, 20);
    ring(base, 0.42, 1.25, 0, 0.05, 20);
    ring(base, -0.42, 1.10, 0, 0.05, 20);
    ring(base, 0.42, 1.10, 0, 0.05, 20);
    // Hands
    boxS(base, -0.43, 0.96, 0, 0.06, 0.10, 0.04, 80);
    boxS(base, 0.43, 0.96, 0, 0.06, 0.10, 0.04, 80);
    cylS(base, -0.44, 0.88, 0, 0.01, 0.06, 20);
    cylS(base, -0.42, 0.88, 0, 0.01, 0.06, 20);
    cylS(base, -0.46, 0.88, 0, 0.01, 0.06, 20);
    cylS(base, 0.44, 0.88, 0, 0.01, 0.06, 20);
    cylS(base, 0.42, 0.88, 0, 0.01, 0.06, 20);
    cylS(base, 0.46, 0.88, 0, 0.01, 0.06, 20);
    // Hips
    boxS(base, 0, 1.14, 0, 0.32, 0.08, 0.16, 200);
    ring(base, 0, 1.18, 0, 0.15, 30);
    ring(base, 0, 1.10, 0, 0.14, 30);
    sph(base, -0.12, 1.08, 0, 0.06, 100);
    sph(base, 0.12, 1.08, 0, 0.06, 100);
    // Legs
    cylS(base, -0.13, 0.85, 0, 0.07, 0.40, 250);
    cylS(base, 0.13, 0.85, 0, 0.07, 0.40, 250);
    ring(base, -0.13, 0.95, 0, 0.075, 25);
    ring(base, 0.13, 0.95, 0, 0.075, 25);
    ring(base, -0.13, 0.80, 0, 0.075, 25);
    ring(base, 0.13, 0.80, 0, 0.075, 25);
    sph(base, -0.13, 0.62, 0, 0.065, 140);
    sph(base, 0.13, 0.62, 0, 0.065, 140);
    ring(base, -0.13, 0.62, 0, 0.07, 30);
    ring(base, 0.13, 0.62, 0, 0.07, 30);
    cylS(base, -0.13, 0.40, 0, 0.055, 0.38, 220);
    cylS(base, 0.13, 0.40, 0, 0.055, 0.38, 220);
    ring(base, -0.13, 0.50, 0, 0.06, 25);
    ring(base, 0.13, 0.50, 0, 0.06, 25);
    ring(base, -0.13, 0.32, 0, 0.06, 25);
    ring(base, 0.13, 0.32, 0, 0.06, 25);
    // Feet
    boxS(base, -0.13, 0.17, 0.03, 0.10, 0.05, 0.16, 120);
    boxS(base, 0.13, 0.17, 0.03, 0.10, 0.05, 0.16, 120);
    boxS(base, -0.13, 0.16, 0.10, 0.08, 0.03, 0.04, 30);
    boxS(base, 0.13, 0.16, 0.10, 0.08, 0.03, 0.04, 30);

    // === SOUL GLOW (coral) — brain inside head ===
    sph(soulGlow, 0, 2.15, 0, 0.12, 80);

    // === MIND GLOW (blue) — heart in chest ===
    sph(mindGlow, 0, 1.48, 0, 0.08, 60);

    // === BODY JOINTS (gold) — rings at major joints ===
    ring(bodyJoints, -0.32, 1.78, 0, 0.09, 20);  // L shoulder
    ring(bodyJoints, 0.32, 1.78, 0, 0.09, 20);   // R shoulder
    ring(bodyJoints, -0.40, 1.38, 0, 0.07, 18);   // L elbow
    ring(bodyJoints, 0.40, 1.38, 0, 0.07, 18);    // R elbow
    ring(bodyJoints, -0.13, 0.62, 0, 0.08, 18);   // L knee
    ring(bodyJoints, 0.13, 0.62, 0, 0.08, 18);    // R knee

    // === CONSCIENCE SHIELD (violet) — forcefield sphere ===
    for (var i = 0; i < 400; i++) {
      var u2 = Math.random(), v2 = Math.random();
      var theta2 = 2 * Math.PI * u2;
      var phi2 = Math.acos(2 * v2 - 1);
      var sr = 1.05 + Math.random() * 0.05;
      shield.push(sr * Math.sin(phi2) * Math.cos(theta2), 1.1 + sr * Math.cos(phi2), sr * Math.sin(phi2) * Math.sin(theta2));
    }

    // Build 5 meshes in a group
    function makeMesh(arr, color, size, opacity) {
      var geo = new T.BufferGeometry();
      geo.setAttribute('position', new T.Float32BufferAttribute(arr, 3));
      var mat = new T.PointsMaterial({ color: color, size: size, sizeAttenuation: true, transparent: true, opacity: opacity });
      return new T.Points(geo, mat);
    }

    var group = new T.Group();
    group.add(makeMesh(base, 0x2d2c2b, 0.012, 0.75));
    group.add(makeMesh(soulGlow, 0xf97066, 0.018, 0.85));
    group.add(makeMesh(mindGlow, 0x3b82f6, 0.018, 0.8));
    group.add(makeMesh(bodyJoints, 0xf59e0b, 0.016, 0.75));
    group.add(makeMesh(shield, 0x8b5cf6, 0.008, 0.18));
    scene.add(group);

    function animate() {
      requestAnimationFrame(animate);
      if (!noMotion) group.rotation.y += 0.004;
      renderer.render(scene, camera);
    }
    animate();

    window.addEventListener('resize', function() {
      var nw = canvas.clientWidth || 400;
      var nh = canvas.clientHeight || 600;
      camera.aspect = nw / nh;
      camera.updateProjectionMatrix();
      renderer.setSize(nw, nh);
    });
  };
  document.head.appendChild(s);
})();
</script>
