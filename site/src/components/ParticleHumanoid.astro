---
/**
 * ParticleHumanoid — Dark enterprise bridge section with Three.js rotating particle cloud humanoid.
 */
---

<section id="humanoid" class="py-20 md:py-28 relative overflow-hidden bg-gradient-to-b from-[var(--color-warm-cream)] to-white border-t border-[var(--color-warm-border)]">
  <div class="max-w-6xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Left: Copy -->
      <div class="flex-1 text-center lg:text-left">
        <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-p-gold)] mb-3">
          Enterprise
        </p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[var(--color-warm-text)] leading-[1.15] mb-4">
          From agents to humanoids. Same soul.
        </h2>
        <p class="text-[var(--color-warm-muted)] leading-relaxed max-w-md mx-auto lg:mx-0 mb-8">
          The same identity stack that aligns your chatbot drives a robot's gestures, gaze, and conscience. 7 body templates. 5 protocol adapters. When you're ready for physical AI, we're already there.
        </p>

        <div class="flex items-center gap-4 lg:justify-start justify-center">
          <a href="/contact" class="btn-press inline-flex items-center gap-2 rounded-xl border-2 border-[var(--color-p-gold)] px-6 py-3 text-sm font-semibold text-[var(--color-p-gold)] transition-colors hover:bg-[var(--color-p-gold)] hover:text-white">
            Contact Sales
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Three.js particle humanoid -->
      <div class="flex-1 flex justify-center">
        <canvas id="humanoid-canvas" width="500" height="500" class="w-full max-w-[500px] h-[500px]"></canvas>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
    s.onload = function() {
      var canvas = document.getElementById('humanoid-canvas');
      if (!canvas) return;

      var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var T = window.THREE;
      var scene = new T.Scene();
      var w = canvas.clientWidth || 500;
      var h = canvas.clientHeight || 500;
      var camera = new T.PerspectiveCamera(45, w / h, 0.1, 100);
      camera.position.set(0, 1, 3.5);
      camera.lookAt(0, 1, 0);

      var renderer = new T.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
      renderer.setSize(w, h);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setClearColor(0x000000, 0);

      // Helpers
      function sphere(arr, cx, cy, cz, r, n) {
        for (var i = 0; i < n; i++) {
          var t = Math.random() * Math.PI * 2;
          var p = Math.acos(2 * Math.random() - 1);
          var rad = r * (0.7 + Math.random() * 0.3);
          arr.push(cx + rad * Math.sin(p) * Math.cos(t), cy + rad * Math.sin(p) * Math.sin(t), cz + rad * Math.cos(p));
        }
      }
      function cyl(arr, cx, cy, cz, r, ht, n) {
        for (var i = 0; i < n; i++) {
          var a = Math.random() * Math.PI * 2;
          var rad = r * Math.sqrt(Math.random());
          arr.push(cx + rad * Math.cos(a), cy + (Math.random() - 0.5) * ht, cz + rad * Math.sin(a));
        }
      }
      function box(arr, cx, cy, cz, bw, bh, bd, n) {
        for (var i = 0; i < n; i++) {
          arr.push(cx + (Math.random() - 0.5) * bw, cy + (Math.random() - 0.5) * bh, cz + (Math.random() - 0.5) * bd);
        }
      }

      // Soul (coral) — head
      var soul = [];
      sphere(soul, 0, 2.05, 0, 0.22, 350);

      // Psyche (blue) — torso, chest, shoulders, neck
      var psyche = [];
      cyl(psyche, 0, 1.78, 0, 0.08, 0.12, 40);
      box(psyche, 0, 1.35, 0, 0.55, 0.7, 0.25, 550);
      box(psyche, 0, 1.65, 0, 0.7, 0.1, 0.2, 120);

      // Body (gold) — arms, legs, hands, feet, hips
      var body = [];
      cyl(body, -0.42, 1.4, 0, 0.07, 0.45, 120);
      cyl(body, 0.42, 1.4, 0, 0.07, 0.45, 120);
      cyl(body, -0.45, 0.95, 0, 0.06, 0.4, 100);
      cyl(body, 0.45, 0.95, 0, 0.06, 0.4, 100);
      sphere(body, -0.46, 0.72, 0, 0.06, 40);
      sphere(body, 0.46, 0.72, 0, 0.06, 40);
      box(body, 0, 0.95, 0, 0.45, 0.15, 0.22, 100);
      cyl(body, -0.15, 0.6, 0, 0.09, 0.5, 150);
      cyl(body, 0.15, 0.6, 0, 0.09, 0.5, 150);
      cyl(body, -0.15, 0.15, 0, 0.07, 0.4, 120);
      cyl(body, 0.15, 0.15, 0, 0.07, 0.4, 120);
      box(body, -0.15, -0.05, 0.03, 0.12, 0.06, 0.18, 50);
      box(body, 0.15, -0.05, 0.03, 0.12, 0.06, 0.18, 50);

      // Conscience (violet) — outer halo ring
      var conscience = [];
      for (var i = 0; i < 200; i++) {
        var angle = Math.random() * Math.PI * 2;
        var radius = 0.9 + Math.random() * 0.15;
        var yy = 0.9 + Math.random() * 1.2;
        conscience.push(Math.cos(angle) * radius, yy, Math.sin(angle) * radius);
      }

      function makeMesh(arr, color, size, opacity) {
        var geo = new T.BufferGeometry();
        geo.setAttribute('position', new T.Float32BufferAttribute(arr, 3));
        var mat = new T.PointsMaterial({ color: color, size: size, sizeAttenuation: true, transparent: true, opacity: opacity });
        return new T.Points(geo, mat);
      }

      var group = new T.Group();
      group.add(makeMesh(soul, 0xf97066, 0.025, 0.8));
      group.add(makeMesh(psyche, 0x3b82f6, 0.02, 0.7));
      group.add(makeMesh(body, 0xf59e0b, 0.02, 0.65));
      group.add(makeMesh(conscience, 0x8b5cf6, 0.015, 0.35));
      scene.add(group);

      scene.fog = new T.Fog(0xfaf6f1, 3, 7);

      function animate() {
        requestAnimationFrame(animate);
        if (!reducedMotion) group.rotation.y += 0.006;
        renderer.render(scene, camera);
      }
      animate();

      window.addEventListener('resize', function() {
        var nw = canvas.clientWidth || 500;
        var nh = canvas.clientHeight || 500;
        camera.aspect = nw / nh;
        camera.updateProjectionMatrix();
        renderer.setSize(nw, nh);
      });
    };
    document.head.appendChild(s);
  })();
</script>
