---
/**
 * Enterprise bridge — robot image + identity layer legend.
 */
const layers = [
  { name: "Soul", file: "soul.md", color: "#f97066", desc: "Head — values, ethics" },
  { name: "Psyche", file: "psyche.sys", color: "#3b82f6", desc: "Chest — cognition, EQ" },
  { name: "Body", file: "body.api", color: "#f59e0b", desc: "Form — morphology, sensors" },
  { name: "Conscience", file: "conscience.exe", color: "#8b5cf6", desc: "Shield — enforcement" },
];
---

<section id="enterprise" class="py-16 md:py-24 border-t border-[var(--color-warm-border)]">
  <div class="mx-auto max-w-5xl px-6">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">

      <!-- Left: Copy -->
      <div class="flex-1 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-p-gold)]/20 bg-[var(--color-p-gold-soft)] px-3 py-1 text-xs font-semibold text-[var(--color-p-gold)] mb-4">
          Enterprise
        </div>

        <h2 class="text-2xl font-bold text-[var(--color-warm-text)] md:text-3xl leading-tight">
          From agents to humanoids.<br />Same soul.
        </h2>

        <p class="mt-4 text-sm leading-relaxed text-[var(--color-warm-muted)] max-w-md mx-auto lg:mx-0">
          The same identity stack that aligns your chatbot drives a robot's gestures, gaze, and conscience. 7 body templates. 5 protocol adapters.
        </p>

        <!-- Identity layer legend -->
        <div class="mt-6 grid grid-cols-2 gap-2 max-w-sm mx-auto lg:mx-0">
          {layers.map((l) => (
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full shrink-0" style={`background: ${l.color};`}></div>
              <div>
                <span class="text-xs font-semibold text-[var(--color-warm-text)]">{l.name}</span>
                <span class="text-[11px] text-[var(--color-warm-muted)] ml-1">{l.desc}</span>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-6">
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-warm-border)] px-5 py-2.5 text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-sand)]/40">
            Contact Sales
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Robot image with slow 3D rotation -->
      <div class="flex-1 flex justify-center" style="perspective: 1000px;">
        <img
          src="/robot-humanoid.png"
          alt="Humanoid robot point cloud — identity stack visualization"
          class="robot-spin w-full max-w-[280px] h-auto"
          loading="lazy"
          width="730"
          height="1598"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .robot-spin {
    animation: robotRotate 18s ease-in-out infinite;
  }
  @keyframes robotRotate {
    0%, 100% { transform: rotateY(0deg); }
    50% { transform: rotateY(25deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .robot-spin { animation: none; }
  }
</style>
