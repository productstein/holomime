---

<section id="features" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      The Full Treatment
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      Diagnosis. Therapy. Cure.<br/>
      <span class="text-gradient-warm">The behavioral stack no one else has.</span>
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      Not monitoring. Not guardrails. Behavioral therapy that actually fixes your agents — and generates the training data so the fix sticks.
    </p>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f, i) => (
        <div class="group relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] bg-white p-8 shadow-sm transition-all hover:shadow-md hover:border-transparent w-full"
          style={`--hover-color: ${f.color};`}
        >
          <!-- Colored accent line at top -->
          <div class="absolute top-0 left-0 right-0 h-1 opacity-0 group-hover:opacity-100 transition-opacity"
            style={`background: ${f.color};`}></div>

          <div class="flex items-start justify-between">
            <div class="inline-flex rounded-xl p-3" style={`background: ${f.color}12; color: ${f.color};`}>
              <Fragment set:html={f.icon} />
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-semibold" style={`background: ${f.color}12; color: ${f.color};`}>
              {f.stat}
            </span>
          </div>

          <h3 class="mt-5 text-xl font-bold text-[var(--color-warm-text)]"><Fragment set:html={f.title} /></h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
            {f.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
