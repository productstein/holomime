---
const features = [
  { name: "11 drift detectors", desc: "Rule-based, zero LLM cost", color: "var(--color-p-blue)" },
  { name: "Adversarial benchmarking", desc: "Grade A-F across 8 scenarios", color: "var(--color-p-blue)" },
  { name: "Self-improvement loop", desc: "Diagnose, treat, export, fine-tune, verify", color: "var(--color-p-blue)" },
  { name: "DPO/RLHF export", desc: "Every therapy session generates training data", color: "var(--color-p-blue)" },
  { name: "soul.md", desc: "Immutable values and ethics", color: "var(--color-p-coral)" },
  { name: "psyche.sys", desc: "Big Five personality + EQ", color: "var(--color-p-coral)" },
  { name: "body.api", desc: "Swap identity across any robot", color: "var(--color-p-gold)" },
  { name: "conscience.exe", desc: "Deterministic moral enforcement", color: "var(--color-p-violet)" },
  { name: "5 protocol adapters", desc: "ROS2, gRPC, MQTT, WebSocket, REST", color: "var(--color-p-violet)" },
  { name: "7 OEM body templates", desc: "Figure, Unitree, Sanctuary, Asimov, Spot", color: "var(--color-p-gold)" },
  { name: "Hot body swap", desc: "Same soul, different hardware, one command", color: "var(--color-p-gold)" },
  { name: "3D brain visualization", desc: "Watch behavioral patterns fire in real time", color: "var(--color-p-blue)" },
];
---

<section id="features" class="py-16 md:py-24 bg-white">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-2xl font-bold text-[var(--color-warm-text)] md:text-3xl">
      What's included
    </h2>
    <p class="mt-2 text-sm text-[var(--color-warm-muted)]">
      Open source. MIT licensed. Everything below is free.
    </p>

    <div class="mt-10 grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="flex items-start gap-3">
          <div class="mt-1.5 h-1.5 w-1.5 rounded-full shrink-0" style={`background: ${f.color};`}></div>
          <div>
            <div class="font-mono text-sm font-semibold text-[var(--color-warm-text)]">{f.name}</div>
            <div class="mt-0.5 text-[13px] text-[var(--color-warm-muted)]">{f.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
