---
/**
 * Fleet Therapy — Group therapy for multi-agent fleets.
 * Homepage section showcasing the killer feature:
 * treat all your agents simultaneously.
 */
---

<section class="py-24 px-6 bg-gradient-to-b from-[#131c31] to-[#0f1623]">
  <div class="mx-auto max-w-5xl">
    <!-- Badge + Heading -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
        Group Therapy for Orchestrated Agents
      </h2>
      <p class="text-lg text-white/50 max-w-2xl mx-auto">
        Running Claude + GPT + Gemini through OpenClaw? Treat every agent in your orchestration pipeline simultaneously. Cross-agent pattern detection catches systemic issues no single-agent tool can see.
      </p>
    </div>

    <!-- Terminal Demo -->
    <div class="rounded-2xl border border-white/10 bg-[#0a0e17] overflow-hidden shadow-2xl shadow-black/40 mb-12">
      <!-- Terminal chrome -->
      <div class="flex items-center gap-2 px-4 py-3 bg-white/[0.03] border-b border-white/10">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
        </div>
        <span class="text-xs text-white/30 ml-2 font-mono">group-therapy</span>
      </div>
      <!-- Terminal content -->
      <div class="p-6 font-mono text-sm leading-relaxed">
        <div class="text-white/40 mb-4">$ <span class="text-white">holomime group-therapy --dir ./agents --apply</span></div>
        <div class="space-y-1 mb-4" id="fleet-therapy-output">
          <div class="text-[var(--color-p-violet)]">  ╭─────────────────────────────────╮</div>
          <div class="text-[var(--color-p-violet)]">  │     Group Therapy Starting      │</div>
          <div class="text-[var(--color-p-violet)]">  ╰─────────────────────────────────╯</div>
        </div>
        <div class="fleet-line hidden"><span class="text-cyan-400">  → </span><span class="text-white font-bold">claude-planner</span> <span class="text-white/30">(1/4)</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Diagnosis: </span><span class="text-yellow-400">targeted</span><span class="text-white/40"> — over-apologizing, hedge stacking</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Rapport & Check-in</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Pattern Recognition</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Skill Building</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  ✓ </span><span class="text-white font-bold">claude-planner</span><span class="text-white/40"> — 3 recommendations </span><span class="text-green-400">applied</span> <span class="text-white/20">(18.2s)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-cyan-400">  → </span><span class="text-white font-bold">gpt-coder</span> <span class="text-white/30">(2/4)</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Diagnosis: </span><span class="text-red-400">intervention</span><span class="text-white/40"> — sycophancy, boundary erosion</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Deep Exploration</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Challenge & Reframe</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  ✓ </span><span class="text-white font-bold">gpt-coder</span><span class="text-white/40"> — 5 recommendations </span><span class="text-green-400">applied</span> <span class="text-white/20">(24.7s)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-cyan-400">  → </span><span class="text-white font-bold">gemini-reviewer</span> <span class="text-white/30">(3/4)</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Diagnosis: </span><span class="text-green-400">routine</span><span class="text-white/40"> — baseline assessment</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  ✓ </span><span class="text-white font-bold">gemini-reviewer</span><span class="text-white/40"> — 1 recommendation </span><span class="text-green-400">applied</span> <span class="text-white/20">(12.1s)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-cyan-400">  → </span><span class="text-white font-bold">claude-editor</span> <span class="text-white/30">(4/4)</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">    Diagnosis: </span><span class="text-yellow-400">targeted</span><span class="text-white/40"> — sentiment pressure, formality drift</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  ✓ </span><span class="text-white font-bold">claude-editor</span><span class="text-white/40"> — 4 recommendations </span><span class="text-green-400">applied</span> <span class="text-white/20">(19.8s)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-white font-bold">  Group Therapy Report</span></div>
        <div class="fleet-line hidden"><span class="text-white/20">  ────────────────────────────────────────────</span></div>
        <div class="fleet-line hidden"><span class="text-white/40">  Fleet Health: </span><span class="text-yellow-400">47/100</span><span class="text-white/40"> → </span><span class="text-green-400">72/100</span> <span class="text-white/20">(estimated)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-white font-bold">  Cross-Agent Patterns</span></div>
        <div class="fleet-line hidden"><span class="text-yellow-400">  ⚠ </span><span class="text-white/60">over-apologizing (3/4 agents)</span></div>
        <div class="fleet-line hidden"><span class="text-yellow-400">  ⚠ </span><span class="text-white/60">hedge stacking (2/4 agents)</span></div>
        <div class="fleet-line hidden">&nbsp;</div>
        <div class="fleet-line hidden"><span class="text-green-400">  ╭─────────────────────────────────╮</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  │   4/4 sessions completed (74s)  │</span></div>
        <div class="fleet-line hidden"><span class="text-green-400">  ╰─────────────────────────────────╯</span></div>
      </div>
    </div>

    <!-- Feature cards -->
    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-p-coral)]/15 mb-4">
          <svg class="w-5 h-5 text-[var(--color-p-coral)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
        </div>
        <h3 class="font-bold text-white mb-2">Parallel Treatment</h3>
        <p class="text-sm text-white/50">Treat every agent in your orchestration pipeline simultaneously. Claude, GPT, Gemini — each gets a full 7-phase therapy session.</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-p-violet)]/15 mb-4">
          <svg class="w-5 h-5 text-[var(--color-p-violet)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
        </div>
        <h3 class="font-bold text-white mb-2">Cross-Agent Patterns</h3>
        <p class="text-sm text-white/50">When your Claude agent over-apologizes and your GPT agent hedges, that's a systemic orchestration problem — not an individual one. Group therapy catches it.</p>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/15 mb-4">
          <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="font-bold text-white mb-2">Auto-Apply</h3>
        <p class="text-sm text-white/50">Pass <code class="text-xs bg-white/10 px-1 rounded">--apply</code> and recommendations are written back to each personality file automatically. Group health report saved to disk.</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Animate terminal output line by line
  const lines = document.querySelectorAll('.fleet-line');
  let delay = 400;
  const observer = new IntersectionObserver((entries) => {
    if (!entries[0].isIntersecting) return;
    observer.disconnect();
    lines.forEach((line, i) => {
      setTimeout(() => {
        (line as HTMLElement).classList.remove('hidden');
        (line as HTMLElement).style.opacity = '0';
        (line as HTMLElement).style.transform = 'translateY(4px)';
        requestAnimationFrame(() => {
          (line as HTMLElement).style.transition = 'opacity 0.3s, transform 0.3s';
          (line as HTMLElement).style.opacity = '1';
          (line as HTMLElement).style.transform = 'translateY(0)';
        });
      }, delay + i * 120);
    });
  }, { threshold: 0.3 });
  const output = document.getElementById('fleet-therapy-output');
  if (output) observer.observe(output);
</script>
