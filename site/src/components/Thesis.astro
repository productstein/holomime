---
/**
 * Thesis — The intellectual closer.
 * Positions holomime within the broader intelligence landscape:
 * models are commodities, behavioral alignment compounds.
 *
 * Key insights from the user-owned intelligence thesis:
 * 1. Portable identity (.personality.json survives model swaps)
 * 2. Compounding data moat (every session = more DPO pairs)
 * 3. RAG on behavior (system prompt generation = retrieval over personality)
 * 4. Correction-as-training (therapy reframes ARE the training data)
 */

const pillars = [
  {
    icon: "portable",
    title: "Models are commodities. Agent identity isn't.",
    description: "GPT-5 replaces GPT-4. Claude 5 replaces Claude 4. But your agent's behavioral identity — encoded in .personality.json — that's yours. Portable across every model, every provider, every generation. The identity layer for the Know Your Agent era.",
    stat: ".personality.json",
    statLabel: "survives every model swap",
    color: "#8b5cf6",
  },
  {
    icon: "compound",
    title: "Every session makes the next one smarter.",
    description: "Each alignment session produces DPO preference pairs as a byproduct. More sessions = richer training data = better fine-tuning = deeper alignment. This isn't a tool you use — it's a data flywheel that compounds. The 100th session is exponentially more valuable than the first.",
    stat: "Compounding",
    statLabel: "behavioral intelligence",
    color: "#22c55e",
  },
  {
    icon: "rag",
    title: "RAG for behavior, not just knowledge.",
    description: "Everyone uses retrieval-augmented generation for facts and documents. holomime applies the same architecture to behavioral intelligence: retrieve the agent's personality traits, therapy history, and growth trajectory, then generate instructions that shape how the model acts — not just what it knows.",
    stat: "Behavioral RAG",
    statLabel: "personality-aware prompting",
    color: "#06b6d4",
  },
  {
    icon: "correction",
    title: "Corrections are the training data.",
    description: "When the therapist reframes 'I'm sorry for the confusion' into 'Here's the correction' — that reframe is a DPO pair. The old behavior is the rejected response. The new behavior is the chosen one. Every correction the system makes becomes fine-tuning data automatically. The alignment process IS the data generation process.",
    stat: "Zero waste",
    statLabel: "every correction = a training pair",
    color: "#f59e0b",
  },
];
---

<section class="relative overflow-hidden py-24 md:py-32 bg-[#0c1220]">
  <!-- Subtle mesh gradient -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute top-0 right-0 h-[500px] w-[500px] rounded-full opacity-[0.07] blur-[120px]"
      style="background: radial-gradient(circle, #8b5cf6, transparent);"></div>
    <div class="absolute bottom-0 left-0 h-[400px] w-[400px] rounded-full opacity-[0.07] blur-[120px]"
      style="background: radial-gradient(circle, #22c55e, transparent);"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full opacity-[0.04] blur-[100px]"
      style="background: radial-gradient(circle, #06b6d4, transparent);"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 mb-4">
        The Intelligence Thesis
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Non-human identities outnumber employees 96-to-1.<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">None of them have behavioral alignment.</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Scaling laws make models smarter every year. But smarter isn't trustworthy. As agents multiply, you need infrastructure that aligns them at scale — and gets better with every session, because the alignment process itself generates the training data.
      </p>
    </div>

    <!-- Core insight callout -->
    <div class="mb-16 mx-auto max-w-3xl">
      <div class="rounded-xl border border-slate-700/50 bg-slate-800/40 backdrop-blur-sm p-8 text-center">
        <p class="text-2xl md:text-3xl font-bold text-white leading-tight">
          "Models are replaceable.<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-emerald-400">.personality.json</span> is not."
        </p>
        <p class="mt-4 text-slate-400 text-sm max-w-lg mx-auto">
          The personality spec is the user-owned intelligence layer for agents. It encodes behavioral contracts, growth history, and alignment preferences — portable across every model generation.
        </p>
      </div>
    </div>

    <!-- Four pillars -->
    <div class="grid gap-6 md:grid-cols-2">
      {pillars.map((p) => (
        <div class="group rounded-xl border border-slate-700/50 bg-slate-800/30 backdrop-blur-sm p-7 transition-all hover:border-slate-600/50 hover:bg-slate-800/50">
          <div class="flex items-start justify-between mb-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl" style={`background: ${p.color}15; color: ${p.color};`}>
              {p.icon === "portable" && (
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
              )}
              {p.icon === "compound" && (
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
              )}
              {p.icon === "rag" && (
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
              )}
              {p.icon === "correction" && (
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3"/></svg>
              )}
            </div>
            <span class="rounded-full px-3 py-1 text-[10px] font-bold tracking-wider uppercase" style={`background: ${p.color}12; color: ${p.color};`}>
              {p.stat}
            </span>
          </div>

          <h3 class="text-lg font-bold text-white mb-2">{p.title}</h3>
          <p class="text-sm leading-relaxed text-slate-400">{p.description}</p>

          <div class="mt-4 pt-4 border-t border-slate-700/30">
            <p class="text-xs text-slate-500 font-medium">{p.statLabel}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- The flywheel diagram -->
    <div class="mt-16 mx-auto max-w-2xl">
      <div class="rounded-xl border border-slate-700/50 bg-slate-800/40 backdrop-blur-sm p-8">
        <h3 class="text-center text-lg font-bold text-white mb-6">The Behavioral Alignment Flywheel</h3>
        <div class="flex items-center justify-center gap-3 flex-wrap text-xs font-mono">
          <span class="rounded-lg bg-violet-500/15 text-violet-400 px-3 py-2 border border-violet-500/20">Diagnose</span>
          <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <span class="rounded-lg bg-cyan-500/15 text-cyan-400 px-3 py-2 border border-cyan-500/20">Refine</span>
          <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <span class="rounded-lg bg-emerald-500/15 text-emerald-400 px-3 py-2 border border-emerald-500/20">DPO Pairs</span>
          <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <span class="rounded-lg bg-amber-500/15 text-amber-400 px-3 py-2 border border-amber-500/20">Fine-tune</span>
          <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <span class="rounded-lg bg-rose-500/15 text-rose-400 px-3 py-2 border border-rose-500/20">Evaluate</span>
          <svg class="h-4 w-4 text-slate-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          <span class="rounded-lg bg-violet-500/15 text-violet-400 px-3 py-2 border border-violet-500/20">Diagnose</span>
        </div>
        <p class="mt-6 text-center text-sm text-slate-400">
          Each cycle generates training data that makes the next cycle more precise. The alignment infrastructure <em class="text-white not-italic font-medium">is</em> the data infrastructure.
        </p>
      </div>
    </div>
  </div>
</section>
