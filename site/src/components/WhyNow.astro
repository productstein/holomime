---
/**
 * WhyNow — The inflection point. Why behavioral alignment matters now.
 */
const cards = [
  {
    title: "Agents are going autonomous",
    description: "When agents run unsupervised, drift isn't a UX issue — it's a liability. Alignment must persist without a human in the loop.",
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>`,
    color: "#f97066",
  },
  {
    title: "System prompts don't scale",
    description: "Adding 'be more assertive' works until it doesn't. Personality specs are portable, measurable, and version-controlled.",
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    color: "#8b5cf6",
  },
  {
    title: "RLHF costs $50K+ per run",
    description: "HoloMime generates DPO pairs from production behavior. Same signal, fraction of the cost, continuous instead of one-shot.",
    icon: `<svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>`,
    color: "#10b981",
  },
];
---

<section class="py-20 md:py-28 bg-[var(--color-warm-cream)]">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      The Inflection Point
    </p>
    <h2 class="mt-3 text-center text-2xl font-extrabold text-[var(--color-warm-text)] lg:text-3xl whitespace-nowrap">
      System prompts don't scale. RLHF is too expensive. <span class="text-gradient-warm">Agents are going autonomous.</span>
    </h2>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {cards.map((card) => (
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-8 shadow-sm">
          <div class="inline-flex rounded-xl p-3" style={`background: ${card.color}12; color: ${card.color};`}>
            <Fragment set:html={card.icon} />
          </div>
          <h3 class="mt-4 text-lg font-bold text-[var(--color-warm-text)]">{card.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
