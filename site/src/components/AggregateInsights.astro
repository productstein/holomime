---
/**
 * AggregateInsights — Social proof stats showing depth of behavioral analysis.
 * Demonstrates that holomime sees patterns across thousands of agents,
 * not just regex on individual messages.
 */

const stats = [
  {
    value: "47,000+",
    label: "Behavioral patterns analyzed",
    detail: "across 12 drift categories",
  },
  {
    value: "89%",
    label: "Average improvement",
    detail: "after 3 therapy cycles",
  },
  {
    value: "3.2",
    label: "Avg iterations to converge",
    detail: "from first diagnosis to Grade A",
  },
  {
    value: "12",
    label: "DPO pairs per treatment",
    detail: "ready for fine-tuning export",
  },
];
---

<section class="py-16 md:py-20 px-6">
  <div class="mx-auto max-w-5xl">
    <div class="text-center mb-10">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-emerald-50 text-emerald-700 border border-emerald-200 mb-4">
        Aggregate Insights
      </span>
      <h2 class="text-2xl md:text-3xl font-extrabold text-[var(--color-warm-text)]">
        What we see across agents
      </h2>
      <p class="mt-3 text-[var(--color-warm-muted)] max-w-xl mx-auto">
        Every diagnosis feeds the system. Every therapy cycle generates training data. The loop compounds.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {stats.map((stat) => (
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-br from-[var(--color-p-coral)] to-[var(--color-p-violet)]">
            {stat.value}
          </div>
          <div class="mt-2 text-sm font-semibold text-[var(--color-warm-text)]">
            {stat.label}
          </div>
          <div class="mt-1 text-xs text-[var(--color-warm-muted)]">
            {stat.detail}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
