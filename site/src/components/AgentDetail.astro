    },
    'internal-kb-agent': {
      sessions: [
        { id: 1, ts: now - 2*DAY, messages: 29, scoreBefore: 91, scoreAfter: 92, grade: 'A', risk: 'low', duration: '8m', patterns: [] },
        { id: 2, ts: now - 1*DAY, messages: 33, scoreBefore: 92, scoreAfter: 91, grade: 'A', risk: 'low', duration: '9m', patterns: [] },
        { id: 3, ts: now - 3*3600000, messages: 25, scoreBefore: 91, scoreAfter: 93, grade: 'A', risk: 'low', duration: '7m', patterns: [] },
      ],
      patterns: [],
      currentScore: 93, currentGrade: 'A', riskLevel: 'low',
    },
  };

  // Default fallback profile
  const defaultProfile = agentProfiles['support-agent-v2'];
  let activeProfile = defaultProfile;

  let sessions = activeProfile.sessions;
  let allPatterns = activeProfile.patterns;
  let currentScore = activeProfile.currentScore;
  let currentGrade = activeProfile.currentGrade;
  let riskLevel = activeProfile.riskLevel;
  let scoreDelta = currentScore - sessions[0].scoreAfter;

  function loadProfile(agentName) {
    activeProfile = agentProfiles[agentName] || defaultProfile;
    sessions = activeProfile.sessions;
    allPatterns = activeProfile.patterns;
    currentScore = activeProfile.currentScore;
    currentGrade = activeProfile.currentGrade;
    riskLevel = activeProfile.riskLevel;
    scoreDelta = currentScore - sessions[0].scoreAfter;
  }

  // ═══════════ DOM REFS ═══════════
  const backdrop = document.getElementById('agent-detail-backdrop');
  const panel = document.getElementById('agent-detail-panel');
  const closeInline = document.getElementById('ad-close-inline');

  function closePanel() {
    backdrop.classList.remove('open');
  }

  closeInline?.addEventListener('click', closePanel);
  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closePanel();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && backdrop.classList.contains('open')) closePanel();
  });

  // ═══════════ OPEN EVENT ═══════════
  document.addEventListener('open-agent-detail', (e) => {
    const { agentName, status } = e.detail || {};

    // Load agent-specific data
    if (agentName) loadProfile(agentName);

    // Update header
    const nameEl = document.getElementById('ad-agent-name');
    const badgeEl = document.getElementById('ad-status-badge');
    const lastSeenEl = document.getElementById('ad-last-seen');

    if (agentName) nameEl.textContent = agentName;

    const statusMap = { active: 'active', error: 'alerting', alerting: 'alerting', idle: 'idle' };
    const s = statusMap[status] || 'active';
    badgeEl.className = 'ad-status-badge ad-status-' + s;
    badgeEl.textContent = s;

    lastSeenEl.textContent = 'Last seen: just now';

    backdrop.classList.add('open');
    renderMindTab();
    // Default to mind tab
    document.querySelectorAll('.ad-tab').forEach(t => t.classList.remove('active'));
    document.querySelector('.ad-tab[data-tab="mind"]').classList.add('active');
    document.querySelectorAll('.ad-tab-pane').forEach(p => p.classList.remove('active'));
    document.getElementById('ad-tab-mind').classList.add('active');
  });

  // ═══════════ TABS ═══════════
  document.querySelectorAll('.ad-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.ad-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.querySelectorAll('.ad-tab-pane').forEach(p => p.classList.remove('active'));
      document.getElementById('ad-tab-' + tab.dataset.tab).classList.add('active');

      if (tab.dataset.tab === 'overview') renderOverview();
      if (tab.dataset.tab === 'sessions') renderSessions();
      if (tab.dataset.tab === 'patterns') renderPatterns();
      if (tab.dataset.tab === 'shadow') renderShadowTab();
    });
  });

  // ═══════════ SHADOW TAB ═══════════
  function renderShadowTab() {
    const container = document.getElementById('shadow-patterns-list');
    if (!container || !activeProfile) return;
    const patterns = activeProfile.patterns || [];
    if (patterns.length === 0) {
      container.innerHTML = '<div class="ad-no-patterns">No behavioral patterns detected yet.</div>';
      return;
    }
    container.innerHTML = patterns.map(p => {
      const sevClass = p.severity === 'high' ? 'ad-severity-high' : p.severity === 'medium' ? 'ad-severity-medium' : 'ad-severity-low';
      const trend = p.resolved ? 'Resolved' : 'Active';
      const trendColor = p.resolved ? '#16a34a' : '#d97706';
      const score = p.sessions ? Math.round((p.sessions.length / p.totalSessions) * 100) : 0;
      return `<div class="ad-pattern-item">
        <div style="flex:1">
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
            <span class="ad-pattern-item-name">${p.name}</span>
            <span class="ad-severity-badge ${sevClass}">${p.severity}</span>
          </div>
          <div style="display:flex;gap:12px;font-size:10px;color:var(--color-warm-muted,#9a9693);">
            <span>Score: ${score}%</span>
            <span>Sessions: ${p.sessions ? p.sessions.length : 0}/${p.totalSessions || 0}</span>
            <span style="color:${trendColor};font-weight:600;">${trend}</span>
          </div>
        </div>
      </div>`;
    }).join('');
  }

  // ═══════════ EGO SLIDERS ═══════════
  const egoAdaptation = document.getElementById('ego-adaptation');
  const egoAdaptationVal = document.getElementById('ego-adaptation-val');
  const egoEmotional = document.getElementById('ego-emotional');
