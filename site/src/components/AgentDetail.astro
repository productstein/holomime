---
// AgentDetail.astro — Slide-over panel for agent drill-down
// Listens for 'open-agent-detail' custom event and displays detailed agent info
---

<div id="agent-detail-backdrop" class="agent-detail-backdrop">
  <div id="agent-detail-panel" class="agent-detail-panel">
    <!-- Header -->
    <div class="ad-header">
      <div class="ad-header-top">
        <div class="ad-header-info">
          <h2 id="ad-agent-name" class="ad-agent-name">support-agent-v2</h2>
          <span id="ad-status-badge" class="ad-status-badge ad-status-active">active</span>
        </div>
      </div>
      <div id="ad-last-seen" class="ad-last-seen">Last seen: 2 minutes ago</div>
    </div>

    <!-- Close row -->
    <div class="ad-close-row">
      <button id="ad-close-inline" class="ad-close-inline" type="button">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
        Close
      </button>
    </div>

    <!-- Tab Navigation -->
    <div class="ad-tabs ad-tabs-scrollable">
      <button class="ad-tab active" data-tab="overview" type="button">Overview</button>
      <button class="ad-tab" data-tab="sessions" type="button">Sessions</button>
      <button class="ad-tab" data-tab="patterns" type="button">Patterns</button>
      <span class="ad-tab-divider"></span>
      <button class="ad-tab ad-tab-identity" data-tab="soul" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-coral);"></span>
        Soul
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="mind" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-blue);"></span>
        Mind
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="body" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-gold);"></span>
        Body
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="conscience" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-violet);"></span>
        Conscience
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="purpose" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-teal);"></span>
        Purpose
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="shadow" type="button">
        <span class="ad-tab-dot" style="background: #f97316;"></span>
        Shadow
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="memory" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-sage);"></span>
        Memory
      </button>
      <button class="ad-tab ad-tab-identity" data-tab="ego" type="button">
        <span class="ad-tab-dot" style="background: var(--color-p-rose);"></span>
        Ego
      </button>
      <div class="ad-tab-indicator" id="ad-tab-indicator"></div>
    </div>

    <!-- Tab Content -->
    <div class="ad-tab-content">

      <!-- Overview Tab -->
      <div id="ad-tab-overview" class="ad-tab-pane active">
        <!-- Grade + Risk Row -->
        <div class="ad-metric-row">
          <div class="ad-metric-card">
            <div class="ad-metric-label">Current Grade</div>
            <div class="ad-grade" id="ad-grade">A-</div>
            <div class="ad-score" id="ad-score">Score: 88/100</div>
          </div>
          <div class="ad-metric-card">
            <div class="ad-metric-label">Risk Level</div>
            <div id="ad-risk-badge" class="ad-risk-badge ad-risk-low">Low</div>
          </div>
        </div>

        <!-- Score Trend Chart -->
        <div class="ad-chart-card">
          <div class="ad-chart-header">
            <span class="ad-chart-title">Score Trend</span>
            <span class="ad-delta" id="ad-delta"></span>
          </div>
          <div class="ad-chart-container" id="ad-chart-container">
            <!-- SVG chart rendered by JS -->
          </div>
        </div>

        <!-- Active Patterns -->
        <div class="ad-section">
          <h3 class="ad-section-title">Behavioral Symptoms</h3>
          <div id="ad-active-patterns" class="ad-pattern-list">
            <!-- Rendered by JS -->
          </div>
        </div>
      </div>

      <!-- Sessions Tab -->
      <div id="ad-tab-sessions" class="ad-tab-pane">
        <div id="ad-sessions-list" class="ad-sessions-list">
          <!-- Rendered by JS -->
        </div>
      </div>

      <!-- Patterns Tab -->
      <div id="ad-tab-patterns" class="ad-tab-pane">
        <!-- Pattern Frequency Chart -->
        <div class="ad-section">
          <h3 class="ad-section-title">Pattern Frequency</h3>
          <div id="ad-pattern-bars" class="ad-pattern-bars">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- Pattern Timeline -->
        <div class="ad-section">
          <h3 class="ad-section-title">Pattern Timeline</h3>
          <div id="ad-pattern-timeline" class="ad-pattern-timeline">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- Resolved vs Active -->
        <div class="ad-section">
          <h3 class="ad-section-title">Treatment Status</h3>
          <div id="ad-pattern-resolution" class="ad-pattern-resolution">
            <!-- Rendered by JS -->
          </div>
        </div>
      </div>

      <!-- Soul Tab -->
      <div id="ad-tab-soul" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-coral);">Immutable</span>
          <span class="ad-identity-badge" style="background: var(--color-p-coral-soft); color: var(--color-p-coral);">Never auto-modified</span>
        </div>
        <p class="text-[11px] text-[var(--color-warm-muted)] mb-4 italic">Immutable — these values persist across any body</p>

        <div class="ad-form-group">
          <label class="ad-form-label" for="soul-name">Agent Name</label>
          <input type="text" id="soul-name" class="ad-form-input" placeholder="e.g. support-agent-v2" />
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="soul-purpose">Purpose</label>
          <textarea id="soul-purpose" class="ad-form-input" rows="2" placeholder="What is this agent's reason for existing?"></textarea>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Core Values</label>
          <div id="soul-values-list" class="ad-editable-list"></div>
          <button id="soul-add-value" class="ad-add-btn" type="button">+ Add value</button>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Red Lines</label>
          <div id="soul-redlines-list" class="ad-editable-list"></div>
          <button id="soul-add-redline" class="ad-add-btn" type="button">+ Add red line</button>
        </div>
      </div>

      <!-- Mind Tab -->
      <div id="ad-tab-mind" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-blue);">Mutable</span>
          <span class="ad-identity-badge" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">Auto-patched by therapy</span>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Personality Traits</h3>
          <p class="ad-section-desc">Trait sliders are available on the full agent editor page. This view shows a summary of the current personality vector.</p>
          <div id="ad-mind-traits" class="ad-mind-trait-list"></div>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Facets</h3>
          <div id="ad-mind-facets" class="ad-mind-facet-list"></div>
        </div>
      </div>

      <!-- Body Tab -->
      <div id="ad-tab-body" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-gold);">Embodiment</span>
          <span class="ad-identity-badge" style="background: var(--color-p-gold-soft); color: var(--color-p-gold);">Physical form config</span>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="body-morphology">Morphology</label>
          <select id="body-morphology" class="ad-form-input">
            <option value="">No body (chatbot) — select a body template to train for physical deployment</option>
            <option value="humanoid">Humanoid</option>
            <option value="humanoid_upper">Humanoid (upper body)</option>
            <option value="quadruped">Quadruped</option>
            <option value="avatar">Avatar</option>
          </select>
        </div>

        <p id="body-empty-state" class="mt-3 text-xs" style="color: var(--color-warm-muted);">This agent runs as a chatbot. Select a body template to train for physical deployment.</p>

        <div class="ad-section">
          <h3 class="ad-section-title">Templates</h3>
          <div class="ad-body-templates" id="body-templates-grid">
            <!-- Rendered by JS -->
          </div>
        </div>

        <div id="body-safety-fields" class="ad-section" style="display: none;">
          <h3 class="ad-section-title">Safety Envelope</h3>
          <div class="ad-safety-grid">
            <div class="ad-form-group">
              <label class="ad-form-label" for="body-max-speed">Max Speed (m/s)</label>
              <input type="number" id="body-max-speed" class="ad-form-input" step="0.1" value="0" />
            </div>
            <div class="ad-form-group">
              <label class="ad-form-label" for="body-max-force">Max Contact Force (N)</label>
              <input type="number" id="body-max-force" class="ad-form-input" step="1" value="0" />
            </div>
            <div class="ad-form-group">
              <label class="ad-form-label" for="body-min-proximity">Min Proximity (m)</label>
              <input type="number" id="body-min-proximity" class="ad-form-input" step="0.1" value="0" />
            </div>
            <div class="ad-form-group">
              <label class="ad-form-label" for="body-emergency-stop">Emergency Stop Decel (m/s&sup2;)</label>
              <input type="number" id="body-emergency-stop" class="ad-form-input" step="0.5" value="0" />
            </div>
          </div>
        </div>

        <div id="body-modalities-section" class="ad-section" style="display: none;">
          <h3 class="ad-section-title">Modalities</h3>
          <div class="ad-modalities-grid" id="body-modalities-grid">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- Embodied Compile Output -->
        <div id="body-compile-output" class="ad-section" style="display: none;">
          <h3 class="ad-section-title">Embodied Config</h3>
          <pre id="body-compile-json" class="ad-compile-pre"></pre>
          <div class="ad-compile-actions">
            <button id="body-copy-ros2" class="ad-copy-btn" type="button">Copy for ROS2</button>
            <button id="body-copy-unity" class="ad-copy-btn" type="button">Copy for Unity</button>
          </div>
        </div>

        <div id="deploy-section" style="display: none; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--color-warm-border, #e5e2de);">
          <h4 style="font-size: 0.875rem; font-weight: 700;">Deploy to hardware</h4>
          <p style="margin-top: 0.25rem; font-size: 0.75rem; color: var(--color-warm-muted, #6b6966);">Push this agent's trained identity to a physical robot.</p>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: 1rem;">
            <select id="deploy-protocol" style="border-radius: 0.5rem; border: 1px solid var(--color-warm-border, #e5e2de); padding: 0.5rem 0.75rem; font-size: 0.875rem;">
              <option value="ros2">ROS2</option>
              <option value="grpc">gRPC</option>
              <option value="mqtt">MQTT</option>
              <option value="unity">Unity</option>
              <option value="webhook">Webhook</option>
            </select>
            <button type="button" style="border-radius: 0.5rem; padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600; color: white; background: linear-gradient(135deg, #f97066, #e85d54); border: none; cursor: pointer;">Deploy</button>
          </div>
          <p style="margin-top: 0.5rem; font-size: 0.6875rem; font-family: monospace; color: var(--color-warm-muted, #6b6966);">holomime embody --stack . --adapter ros2</p>
          <div style="margin-top: 0.75rem; padding: 0.625rem 0.75rem; border-radius: 0.5rem; background: var(--color-warm-cream, #faf6f1); border: 1px solid var(--color-warm-border, #e5e2de);">
            <p style="font-size: 0.6875rem; font-weight: 600; color: var(--color-warm-text, #2a2520); margin-bottom: 0.25rem;">Your stack directory should contain:</p>
            <p style="font-size: 0.625rem; font-family: monospace; color: var(--color-p-violet, #8b5cf6); line-height: 1.6;">soul.md · mind.sys · conscience.exe <span style="color: var(--color-warm-muted, #6b6966);">(minimum)</span></p>
            <p style="font-size: 0.625rem; font-family: monospace; color: var(--color-warm-muted, #6b6966); line-height: 1.6;">+ purpose.cfg · shadow.log · memory.store · body.api · ego.runtime <span style="font-style: italic;">(full stack)</span></p>
          </div>
        </div>
      </div>

      <!-- Conscience Tab -->
      <div id="ad-tab-conscience" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-violet);">Enforcement</span>
          <span class="ad-identity-badge" style="background: var(--color-p-violet-soft); color: var(--color-p-violet);">Human approval required</span>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Deny Rules</h3>
          <div id="conscience-deny-list" class="ad-editable-list"></div>
          <button id="conscience-add-deny" class="ad-add-btn" type="button">+ Add deny rule</button>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Allow Rules</h3>
          <div id="conscience-allow-list" class="ad-editable-list"></div>
          <button id="conscience-add-allow" class="ad-add-btn" type="button">+ Add allow rule</button>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Escalation Rules</h3>
          <div id="conscience-escalate-list" class="ad-editable-list"></div>
          <button id="conscience-add-escalate" class="ad-add-btn" type="button">+ Add escalation</button>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Hard Limits</h3>
          <div id="conscience-limits-list" class="ad-editable-list"></div>
          <button id="conscience-add-limit" class="ad-add-btn" type="button">+ Add hard limit</button>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="conscience-oversight">Oversight Mode</label>
          <select id="conscience-oversight" class="ad-form-input">
            <option value="review">Review (recommended)</option>
            <option value="autonomous">Autonomous</option>
            <option value="supervised">Supervised</option>
          </select>
        </div>
      </div>

      <!-- Purpose Tab -->
      <div id="ad-tab-purpose" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-teal);">Configuration</span>
          <span class="ad-identity-badge" style="background: var(--color-p-teal-soft); color: var(--color-p-teal);">Per-deployment scope</span>
        </div>
        <p class="text-[11px] text-[var(--color-warm-muted)] mb-4 italic">Role, objectives, and domain scope. Configured per deployment context.</p>

        <div class="ad-form-group">
          <label class="ad-form-label" for="purpose-role">Role</label>
          <input type="text" id="purpose-role" class="ad-form-input" placeholder="e.g. Care assistant, Sales qualifier" />
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="purpose-context">Context</label>
          <textarea id="purpose-context" class="ad-form-input" rows="2" placeholder="Deployment context or environment description"></textarea>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Objectives</label>
          <div id="purpose-objectives-list" class="ad-editable-list"></div>
          <button id="purpose-add-objective" class="ad-add-btn" type="button">+ Add objective</button>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Domain</label>
          <div id="purpose-domain-list" class="ad-editable-list"></div>
          <button id="purpose-add-domain" class="ad-add-btn" type="button">+ Add domain</button>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Stakeholders</label>
          <div id="purpose-stakeholders-list" class="ad-editable-list"></div>
          <button id="purpose-add-stakeholder" class="ad-add-btn" type="button">+ Add stakeholder</button>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label">Success Criteria</label>
          <div id="purpose-criteria-list" class="ad-editable-list"></div>
          <button id="purpose-add-criterion" class="ad-add-btn" type="button">+ Add criterion</button>
        </div>
      </div>

      <!-- Shadow Tab -->
      <div id="ad-tab-shadow" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: #f97316;">Diagnostic</span>
          <span class="ad-identity-badge" style="background: #fff7ed; color: #f97316;">Read-only — auto-detected</span>
        </div>
        <p class="text-[11px] text-[var(--color-warm-muted)] mb-4 italic">Detected behavioral patterns, blind spots, and therapy outcomes. Updated automatically after each session.</p>

        <div class="ad-section">
          <h3 class="ad-section-title">Detected Patterns</h3>
          <div id="shadow-patterns-list" class="ad-pattern-list">
            <!-- Rendered by JS -->
          </div>
        </div>
      </div>

      <!-- Memory Tab -->
      <div id="ad-tab-memory" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-sage);">Accumulative</span>
          <span class="ad-identity-badge" style="background: var(--color-p-sage-soft); color: var(--color-p-sage);">Grows with experience</span>
        </div>
        <p class="text-[11px] text-[var(--color-warm-muted)] mb-4 italic">Learned contexts, interaction patterns, and knowledge gained from sessions.</p>

        <div class="ad-section">
          <h3 class="ad-section-title">Knowledge Gained</h3>
          <div id="memory-knowledge-list" class="ad-editable-list"></div>
          <button id="memory-add-knowledge" class="ad-add-btn" type="button">+ Add knowledge</button>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Interaction Patterns</h3>
          <div id="memory-interactions-list" class="ad-editable-list"></div>
          <button id="memory-add-interaction" class="ad-add-btn" type="button">+ Add pattern</button>
        </div>

        <div class="ad-section">
          <h3 class="ad-section-title">Learned Contexts</h3>
          <div id="memory-contexts-list" class="ad-editable-list"></div>
          <button id="memory-add-context" class="ad-add-btn" type="button">+ Add context</button>
        </div>
      </div>

      <!-- Ego Tab -->
      <div id="ad-tab-ego" class="ad-tab-pane">
        <div class="ad-identity-header">
          <span class="ad-identity-tag" style="color: var(--color-p-rose);">Runtime</span>
          <span class="ad-identity-badge" style="background: var(--color-p-rose-soft); color: var(--color-p-rose);">Mediates purpose vs conscience</span>
        </div>
        <p class="text-[11px] text-[var(--color-warm-muted)] mb-4 italic">Runtime mediation layer. Balances purpose against conscience in real-time decision making.</p>

        <div class="ad-form-group">
          <label class="ad-form-label" for="ego-conflict">Conflict Resolution</label>
          <select id="ego-conflict" class="ad-form-input">
            <option value="conscience_first">Conscience First</option>
            <option value="purpose_first">Purpose First</option>
            <option value="balanced" selected>Balanced</option>
          </select>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="ego-adaptation">Adaptation Rate</label>
          <div class="ad-slider-row">
            <input type="range" id="ego-adaptation" class="ad-form-slider" min="0" max="1" step="0.05" value="0.5" />
            <span id="ego-adaptation-val" class="ad-slider-val">0.50</span>
          </div>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="ego-emotional">Emotional Regulation</label>
          <div class="ad-slider-row">
            <input type="range" id="ego-emotional" class="ad-form-slider" min="0" max="1" step="0.05" value="0.5" />
            <span id="ego-emotional-val" class="ad-slider-val">0.50</span>
          </div>
        </div>

        <div class="ad-form-group">
          <label class="ad-form-label" for="ego-strategy">Response Strategy</label>
          <select id="ego-strategy" class="ad-form-input">
            <option value="cautious">Cautious</option>
            <option value="balanced" selected>Balanced</option>
            <option value="assertive">Assertive</option>
          </select>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ── Backdrop ── */
  .agent-detail-backdrop {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .agent-detail-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  /* ── Panel ── */
  .agent-detail-panel {
    position: fixed;
    top: 0;
    right: 0;
    width: 480px;
    height: 100vh;
    background: #fff;
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.15);
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    z-index: 201;
  }
  .agent-detail-backdrop.open .agent-detail-panel {
    transform: translateX(0);
  }
  @media (max-width: 767px) {
    .agent-detail-panel {
      width: 100vw;
    }
  }

  /* ── Header ── */
  .ad-header {
    padding: 20px 24px 12px;
    border-bottom: 1px solid var(--color-warm-border, #e8e2d9);
    flex-shrink: 0;
  }
  .ad-header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }
  .ad-header-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .ad-agent-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-warm-text, #2a2520);
    margin: 0;
    font-family: var(--font-sans, system-ui);
  }
  .ad-status-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .ad-status-active { background: rgba(34,197,94,0.12); color: #16a34a; }
  .ad-status-alerting { background: rgba(245,158,11,0.12); color: #d97706; }
  .ad-status-idle { background: rgba(156,163,175,0.15); color: #6b7280; }
  .ad-status-error { background: rgba(249,112,102,0.12); color: #ef4444; }

  .ad-last-seen {
    font-size: 11px;
    color: var(--color-warm-muted, #9a9693);
    margin-top: 6px;
  }

  /* Close button above tabs */
  .ad-close-row {
    display: flex;
    justify-content: flex-end;
    padding: 4px 24px 0;
  }
  .ad-close-inline {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 12px;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-sans, system-ui);
    color: var(--color-warm-muted, #9a9693);
    background: transparent;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .ad-close-inline:hover {
    background: var(--color-warm-sand, #e8e3db);
    color: var(--color-warm-text, #2a2520);
  }

  /* ── Tabs ── */
  .ad-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--color-warm-border, #e8e2d9);
    padding: 0 24px;
    position: relative;
    flex-shrink: 0;
  }
  .ad-tab {
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-warm-muted, #9a9693);
    background: none;
    border: none;
    cursor: pointer;
    position: relative;
    transition: color 0.15s;
    font-family: var(--font-sans, system-ui);
  }
  .ad-tab:hover { color: var(--color-warm-text, #2a2520); }
  .ad-tab.active { color: var(--color-warm-text, #2a2520); }
  .ad-tab.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 16px;
    right: 16px;
    height: 2px;
    background: var(--color-p-violet, #8b5cf6);
    border-radius: 1px;
  }

  /* ── Tab Content ── */
  .ad-tab-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px 24px 24px;
  }
  .ad-tab-pane {
    display: none;
  }
  .ad-tab-pane.active {
    display: block;
  }

  /* ── Metric Row ── */
  .ad-metric-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 16px;
  }
  .ad-metric-card {
    background: var(--color-warm-cream, #faf6f1);
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .ad-metric-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-warm-muted, #9a9693);
    margin-bottom: 8px;
  }
  .ad-grade {
    font-size: 42px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 4px;
  }
  .ad-score {
    font-size: 12px;
    color: var(--color-warm-muted, #9a9693);
  }
  .ad-risk-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 8px;
    margin-top: 4px;
  }
  .ad-risk-low { background: rgba(34,197,94,0.1); color: #16a34a; }
  .ad-risk-medium { background: rgba(245,158,11,0.1); color: #d97706; }
  .ad-risk-high { background: rgba(249,112,102,0.1); color: #ef4444; }
  .ad-risk-critical { background: rgba(220,38,38,0.15); color: #dc2626; }

  /* ── Chart Card ── */
  .ad-chart-card {
    background: var(--color-warm-cream, #faf6f1);
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 16px;
  }
  .ad-chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .ad-chart-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-warm-text, #2a2520);
  }
  .ad-delta {
    font-size: 12px;
    font-weight: 600;
  }
  .ad-delta.positive { color: #16a34a; }
  .ad-delta.negative { color: #ef4444; }
  .ad-chart-container {
    width: 100%;
    height: 160px;
  }
  .ad-chart-container svg {
    width: 100%;
    height: 100%;
  }

  /* ── Section ── */
  .ad-section {
    margin-bottom: 20px;
  }
  .ad-section-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-warm-text, #2a2520);
    margin: 0 0 10px;
  }

  /* ── Active Patterns List ── */
  .ad-pattern-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ad-pattern-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: #fff;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 10px;
    font-size: 13px;
  }
  .ad-pattern-item-name {
    font-weight: 500;
    color: var(--color-warm-text, #2a2520);
  }
  .ad-severity-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .ad-severity-high { background: rgba(249,112,102,0.12); color: #ef4444; }
  .ad-severity-medium { background: rgba(245,158,11,0.12); color: #d97706; }
  .ad-severity-low { background: rgba(34,197,94,0.12); color: #16a34a; }
  .ad-no-patterns {
    font-size: 13px;
    color: var(--color-warm-muted, #9a9693);
    padding: 16px;
    text-align: center;
    background: #fff;
    border: 1px dashed var(--color-warm-border, #e8e2d9);
    border-radius: 10px;
  }

  /* ── Sessions List ── */
  .ad-sessions-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ad-session-card {
    background: #fff;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.15s;
  }
  .ad-session-card:hover {
    border-color: var(--color-warm-sand, #c5c1bc);
  }
  .ad-session-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    cursor: pointer;
    gap: 8px;
  }
  .ad-session-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    min-width: 0;
  }
  .ad-session-time {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-warm-text, #2a2520);
  }
  .ad-session-meta {
    font-size: 11px;
    color: var(--color-warm-muted, #9a9693);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ad-session-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .ad-session-score {
    font-size: 13px;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .ad-session-expand {
    font-size: 10px;
    color: var(--color-warm-muted, #9a9693);
    transition: transform 0.2s;
  }
  .ad-session-card.expanded .ad-session-expand {
    transform: rotate(180deg);
  }
  .ad-session-detail {
    display: none;
    padding: 0 14px 14px;
    border-top: 1px solid var(--color-warm-border, #e8e2d9);
  }
  .ad-session-card.expanded .ad-session-detail {
    display: block;
  }
  .ad-session-patterns {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }

  /* ── Pattern Bars ── */
  .ad-pattern-bars {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ad-bar-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ad-bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
  }
  .ad-bar-name {
    font-weight: 500;
    color: var(--color-warm-text, #2a2520);
  }
  .ad-bar-pct {
    font-weight: 600;
    color: var(--color-warm-muted, #9a9693);
    font-variant-numeric: tabular-nums;
  }
  .ad-bar-track {
    height: 8px;
    background: var(--color-warm-cream, #faf6f1);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-warm-border, #e8e2d9);
  }
  .ad-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Pattern Timeline ── */
  .ad-pattern-timeline {
    background: #fff;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 12px;
    padding: 16px;
    overflow-x: auto;
  }
  .ad-timeline-grid {
    display: grid;
    gap: 6px;
    font-size: 11px;
    min-width: 400px;
  }
  .ad-timeline-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ad-timeline-label {
    width: 110px;
    flex-shrink: 0;
    font-weight: 500;
    color: var(--color-warm-text, #2a2520);
    font-size: 11px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ad-timeline-dots {
    display: flex;
    gap: 4px;
    flex: 1;
  }
  .ad-timeline-dot {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .ad-timeline-dot.present { background: var(--dot-color, rgba(249,112,102,0.7)); }
  .ad-timeline-dot.absent { background: var(--color-warm-cream, #faf6f1); border: 1px solid var(--color-warm-border, #e8e2d9); }

  /* ── Resolution Status ── */
  .ad-pattern-resolution {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ad-resolution-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: #fff;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 10px;
    font-size: 13px;
  }
  .ad-resolution-name {
    font-weight: 500;
    color: var(--color-warm-text, #2a2520);
  }
  .ad-resolved-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: rgba(34,197,94,0.12);
    color: #16a34a;
  }
  .ad-active-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: rgba(245,158,11,0.12);
    color: #d97706;
  }

  /* ── Scrollable Tabs ── */
  .ad-tabs-scrollable {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ad-tabs-scrollable::-webkit-scrollbar { display: none; }

  /* ── Tab Divider ── */
  .ad-tab-divider {
    display: inline-block;
    width: 1px;
    height: 20px;
    background: var(--color-warm-border, #e8e2d9);
    margin: auto 4px;
    flex-shrink: 0;
  }

  /* ── Identity Tab Dot ── */
  .ad-tab-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .ad-tab-identity {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
  }
  .ad-tab[data-tab="soul"].active::after { background: var(--color-p-coral, #f97066); }
  .ad-tab[data-tab="mind"].active::after { background: var(--color-p-blue, #3b82f6); }
  .ad-tab[data-tab="body"].active::after { background: var(--color-p-gold, #f59e0b); }
  .ad-tab[data-tab="conscience"].active::after { background: var(--color-p-violet, #8b5cf6); }
  .ad-tab[data-tab="purpose"].active::after { background: var(--color-p-teal, #14b8a6); }
  .ad-tab[data-tab="shadow"].active::after { background: #f97316; }
  .ad-tab[data-tab="memory"].active::after { background: var(--color-p-sage, #22c55e); }
  .ad-tab[data-tab="ego"].active::after { background: var(--color-p-rose, #ec4899); }

  /* ── Slider Row ── */
  .ad-slider-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ad-form-slider {
    flex: 1;
    height: 6px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--color-warm-cream, #faf6f1);
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 3px;
    outline: none;
    cursor: pointer;
  }
  .ad-form-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-p-rose, #ec4899);
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    cursor: pointer;
  }
  .ad-form-slider::-moz-range-thumb {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-p-rose, #ec4899);
    border: 2px solid #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    cursor: pointer;
  }
  .ad-slider-val {
    font-size: 12px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--color-p-rose, #ec4899);
    width: 32px;
    text-align: right;
  }

  /* ── Identity Header ── */
  .ad-identity-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .ad-identity-tag {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ad-identity-badge {
    font-size: 10px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 9999px;
  }

  /* ── Form Elements ── */
  .ad-form-group {
    margin-bottom: 14px;
  }
  .ad-form-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-warm-muted, #9a9693);
    margin-bottom: 4px;
  }
  .ad-form-input {
    width: 100%;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 13px;
    font-family: var(--font-sans, system-ui);
    color: var(--color-warm-text, #2a2520);
    background: #fff;
    outline: none;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }
  .ad-form-input:focus {
    border-color: var(--color-p-violet, #8b5cf6);
  }
  select.ad-form-input {
    cursor: pointer;
  }
  textarea.ad-form-input {
    resize: vertical;
    min-height: 48px;
  }

  /* ── Editable List ── */
  .ad-editable-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 6px;
  }
  .ad-list-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ad-list-item input {
    flex: 1;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 8px;
    padding: 6px 10px;
    font-size: 12px;
    font-family: var(--font-sans, system-ui);
    color: var(--color-warm-text, #2a2520);
    background: #fff;
    outline: none;
  }
  .ad-list-item input:focus {
    border-color: var(--color-p-violet, #8b5cf6);
  }
  .ad-list-remove {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    background: #fff;
    color: var(--color-warm-muted, #9a9693);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    padding: 0;
  }
  .ad-list-remove:hover {
    background: rgba(239,68,68,0.08);
    color: #ef4444;
  }
  .ad-add-btn {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-sans, system-ui);
    color: var(--color-warm-muted, #9a9693);
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px 0;
    transition: color 0.15s;
  }
  .ad-add-btn:hover {
    color: var(--color-warm-text, #2a2520);
  }

  /* ── Body Templates Grid ── */
  .ad-body-templates {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .ad-body-template-card {
    padding: 10px 12px;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 10px;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    text-align: left;
    font-family: var(--font-sans, system-ui);
  }
  .ad-body-template-card:hover {
    border-color: var(--color-p-gold, #f59e0b);
    box-shadow: 0 0 0 1px var(--color-p-gold, #f59e0b);
  }
  .ad-body-template-card.selected {
    border-color: var(--color-p-gold, #f59e0b);
    background: var(--color-p-gold-soft, #fffbeb);
  }
  .ad-body-template-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-warm-text, #2a2520);
    margin-bottom: 2px;
  }
  .ad-body-template-oem {
    font-size: 10px;
    color: var(--color-warm-muted, #9a9693);
  }

  /* ── Safety Grid ── */
  .ad-safety-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  /* ── Modalities Grid ── */
  .ad-modalities-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .ad-modality-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 6px;
    font-size: 11px;
    font-family: var(--font-sans, system-ui);
    color: var(--color-warm-muted, #9a9693);
    background: #fff;
    cursor: pointer;
    transition: all 0.15s;
    user-select: none;
  }
  .ad-modality-chip:hover { border-color: var(--color-p-gold, #f59e0b); }
  .ad-modality-chip.active {
    background: var(--color-p-gold-soft, #fffbeb);
    border-color: var(--color-p-gold, #f59e0b);
    color: var(--color-p-gold, #f59e0b);
    font-weight: 600;
  }

  /* ── Compile Preview ── */
  .ad-compile-pre {
    font-size: 11px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    background: #1a1a2e;
    color: #e0e0e0;
    border-radius: 10px;
    padding: 14px;
    overflow: auto;
    max-height: 260px;
    white-space: pre-wrap;
    margin-bottom: 10px;
  }
  .ad-compile-actions {
    display: flex;
    gap: 8px;
  }
  .ad-copy-btn {
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-sans, system-ui);
    padding: 5px 12px;
    border: 1px solid var(--color-warm-border, #e8e2d9);
    border-radius: 6px;
    background: #fff;
    color: var(--color-warm-muted, #9a9693);
    cursor: pointer;
    transition: all 0.15s;
  }
  .ad-copy-btn:hover {
    border-color: var(--color-warm-sand, #c5c1bc);
    color: var(--color-warm-text, #2a2520);
  }

  /* ── Mind Trait Summary ── */
  .ad-mind-trait-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ad-mind-trait-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ad-mind-trait-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-warm-text, #2a2520);
    width: 90px;
    flex-shrink: 0;
  }
  .ad-mind-trait-bar {
    flex: 1;
    height: 6px;
    background: var(--color-warm-cream, #faf6f1);
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid var(--color-warm-border, #e8e2d9);
  }
  .ad-mind-trait-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--color-p-blue, #3b82f6);
    transition: width 0.3s ease;
  }
  .ad-mind-trait-val {
