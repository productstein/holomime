  // ═══════════ GRADE COLOR ═══════════
  function gradeColor(grade) {
    if (grade.startsWith('A')) return '#16a34a';
    if (grade.startsWith('B')) return '#0891b2';
    if (grade.startsWith('C')) return '#d97706';
    if (grade.startsWith('D')) return '#ef4444';
    return '#dc2626';
  }

  // ═══════════ RENDER OVERVIEW ═══════════
  function renderOverview() {
    // Grade
    const gradeEl = document.getElementById('ad-grade');
    gradeEl.textContent = currentGrade;
    gradeEl.style.color = gradeColor(currentGrade);

    document.getElementById('ad-score').textContent = `Score: ${currentScore}/100`;

    // Risk
    const riskEl = document.getElementById('ad-risk-badge');
    riskEl.textContent = riskLevel.charAt(0).toUpperCase() + riskLevel.slice(1);
    riskEl.className = 'ad-risk-badge ad-risk-' + riskLevel;

    // Delta
    const deltaEl = document.getElementById('ad-delta');
    if (scoreDelta > 0) {
      deltaEl.innerHTML = `&#8593; ${scoreDelta} pts over ${sessions.length} sessions`;
      deltaEl.className = 'ad-delta positive';
    } else {
      deltaEl.innerHTML = `&#8595; ${Math.abs(scoreDelta)} pts`;
      deltaEl.className = 'ad-delta negative';
    }

    // Score Trend Chart (SVG)
    renderScoreChart();

    // Active Patterns
    const activePatterns = allPatterns.filter(p => !p.resolved);
    const container = document.getElementById('ad-active-patterns');
    if (activePatterns.length === 0) {
      container.innerHTML = '<div class="ad-no-patterns">No active symptoms detected. Agent is performing within healthy range.</div>';
    } else {
      container.innerHTML = activePatterns.map(p =>
        `<div class="ad-pattern-item">
          <span class="ad-pattern-item-name">${p.name}</span>
          <span class="ad-severity-badge ad-severity-${p.severity}">${p.severity}</span>
        </div>`
      ).join('');
    }
  }

  // ═══════════ SCORE CHART ═══════════
  function renderScoreChart() {
    const container = document.getElementById('ad-chart-container');
    const scores = sessions.map(s => s.scoreAfter);
    const grades = sessions.map(s => s.grade);
    const w = 432, h = 150, pad = { top: 10, right: 16, bottom: 24, left: 32 };
    const plotW = w - pad.left - pad.right;
    const plotH = h - pad.top - pad.bottom;

    const minY = 0, maxY = 100;
    const xStep = plotW / (scores.length - 1);

    const points = scores.map((s, i) => ({
      x: pad.left + i * xStep,
      y: pad.top + plotH - ((s - minY) / (maxY - minY)) * plotH,
      score: s,
      grade: grades[i]
    }));

    const pathD = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' ');

    // Area fill
    const areaD = pathD + ` L ${points[points.length-1].x.toFixed(1)} ${(pad.top + plotH).toFixed(1)} L ${points[0].x.toFixed(1)} ${(pad.top + plotH).toFixed(1)} Z`;

    // Threshold line at 85
    const threshY = pad.top + plotH - ((85 - minY) / (maxY - minY)) * plotH;

    // Y-axis labels
    const yLabels = [0, 25, 50, 75, 100].map(v => ({
      v,
      y: pad.top + plotH - ((v - minY) / (maxY - minY)) * plotH
    }));

    // X-axis labels (session numbers)
    const xLabels = scores.map((_, i) => ({
      label: `S${i + 1}`,
      x: pad.left + i * xStep
    }));

    let svg = `<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg">`;
    svg += `<defs><linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.15"/><stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.01"/></linearGradient></defs>`;

    // Grid lines
    yLabels.forEach(l => {
      svg += `<line x1="${pad.left}" y1="${l.y.toFixed(1)}" x2="${w - pad.right}" y2="${l.y.toFixed(1)}" stroke="#e8e2d9" stroke-width="0.5"/>`;
      svg += `<text x="${pad.left - 6}" y="${(l.y + 3).toFixed(1)}" fill="#9a9693" font-size="9" font-family="system-ui" text-anchor="end">${l.v}</text>`;
    });

    // X-axis labels
    xLabels.forEach((l, i) => {
      if (i % 2 === 0 || scores.length <= 8) {
        svg += `<text x="${l.x.toFixed(1)}" y="${(h - 4).toFixed(1)}" fill="#9a9693" font-size="9" font-family="system-ui" text-anchor="middle">${l.label}</text>`;
      }
    });

    // Threshold line
    svg += `<line x1="${pad.left}" y1="${threshY.toFixed(1)}" x2="${w - pad.right}" y2="${threshY.toFixed(1)}" stroke="#16a34a" stroke-width="1" stroke-dasharray="4 3" opacity="0.5"/>`;
    svg += `<text x="${w - pad.right + 2}" y="${(threshY + 3).toFixed(1)}" fill="#16a34a" font-size="8" font-family="system-ui" opacity="0.7">85</text>`;

    // Area
    svg += `<path d="${areaD}" fill="url(#areaGrad)"/>`;

    // Line
    svg += `<path d="${pathD}" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>`;

    // Data points
    points.forEach(p => {
      const c = gradeColor(p.grade);
      svg += `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="4" fill="${c}" stroke="#fff" stroke-width="1.5"/>`;
    });

    svg += '</svg>';
    container.innerHTML = svg;
  }

  // ═══════════ RENDER SESSIONS ═══════════
  function renderSessions() {
    const container = document.getElementById('ad-sessions-list');
    const reversed = [...sessions].reverse();

    container.innerHTML = reversed.map(s => {
      const d = new Date(s.ts);
      const timeStr = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + ' at ' + d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
      const scoreColor = gradeColor(s.grade);
      const patternBadges = s.patterns.length > 0
        ? s.patterns.map(p => {
            const pat = allPatterns.find(ap => ap.name === p);
            const sev = pat ? pat.severity : 'low';
            return `<span class="ad-severity-badge ad-severity-${sev}">${p}</span>`;
          }).join('')
        : '<span style="font-size:11px;color:#9a9693;">No patterns detected</span>';

      return `<div class="ad-session-card" data-session="${s.id}">
        <div class="ad-session-header">
          <div class="ad-session-left">
            <div class="ad-session-time">${timeStr}</div>
            <div class="ad-session-meta">
              <span>${s.messages} messages</span>
              <span>${s.duration}</span>
              <span class="ad-severity-badge ad-severity-${s.risk === 'high' ? 'high' : s.risk === 'medium' ? 'medium' : 'low'}">${s.risk}</span>
            </div>
          </div>
          <div class="ad-session-right">
            <span class="ad-session-score" style="color:${scoreColor}">${s.scoreAfter}</span>
            <span class="ad-session-expand">&#9660;</span>
          </div>
        </div>
        <div class="ad-session-detail">
          <div style="font-size:12px;color:#9a9693;margin-bottom:6px;">Score: ${s.scoreBefore} &rarr; ${s.scoreAfter} (${s.grade})</div>
          <div style="font-size:11px;font-weight:600;color:#2a2520;margin-bottom:4px;">Patterns Detected</div>
          <div class="ad-session-patterns">${patternBadges}</div>
        </div>
      </div>`;
    }).join('');

    // Expand/collapse
    container.querySelectorAll('.ad-session-card').forEach(card => {
      card.querySelector('.ad-session-header').addEventListener('click', () => {
        card.classList.toggle('expanded');
      });
    });
  }

  // ═══════════ RENDER PATTERNS ═══════════
  function renderPatterns() {
    // Pattern frequency bars
    const barsContainer = document.getElementById('ad-pattern-bars');
    barsContainer.innerHTML = allPatterns.map(p => {
      const pct = Math.round((p.sessions.length / p.totalSessions) * 100);
      const barColor = p.severity === 'high' ? '#ef4444' : p.severity === 'medium' ? '#d97706' : '#16a34a';
      return `<div class="ad-bar-row">
        <div class="ad-bar-label">
          <span class="ad-bar-name">${p.name}</span>
          <span class="ad-bar-pct">${pct}% of sessions</span>
        </div>
        <div class="ad-bar-track">
          <div class="ad-bar-fill" style="width:${pct}%;background:${barColor}"></div>
        </div>
      </div>`;
    }).join('');

    // Pattern timeline (dot matrix)
    const timelineContainer = document.getElementById('ad-pattern-timeline');
    const sessionNums = sessions.map(s => s.id);
    const headerRow = `<div class="ad-timeline-row" style="margin-bottom:4px;">
      <div class="ad-timeline-label" style="font-size:9px;color:#9a9693;font-weight:600;">PATTERN</div>
      <div class="ad-timeline-dots">${sessionNums.map(n => `<div style="width:16px;text-align:center;font-size:8px;color:#9a9693;font-weight:600;">S${n}</div>`).join('')}</div>
    </div>`;

    const patternRows = allPatterns.map(p => {
      const dots = sessionNums.map(n => {
        const present = p.sessions.includes(n);
        return `<div class="ad-timeline-dot ${present ? 'present' : 'absent'}" style="--dot-color:${p.color}99;" title="${p.name} - Session ${n}${present ? ' (detected)' : ''}"></div>`;
      }).join('');
      return `<div class="ad-timeline-row">
        <div class="ad-timeline-label">${p.name}</div>
        <div class="ad-timeline-dots">${dots}</div>
      </div>`;
    }).join('');

    timelineContainer.innerHTML = `<div class="ad-timeline-grid">${headerRow}${patternRows}</div>`;

    // Resolution status
    const resolutionContainer = document.getElementById('ad-pattern-resolution');
    resolutionContainer.innerHTML = allPatterns.map(p => {
      const badge = p.resolved
        ? `<span class="ad-resolved-badge">Resolved (after S${p.resolvedAfter})</span>`
        : `<span class="ad-active-badge">Active (improving)</span>`;
      return `<div class="ad-resolution-item">
        <span class="ad-resolution-name">${p.name}</span>
        ${badge}
      </div>`;
    }).join('');
  }

  // ═══════════ BODY TEMPLATES DATA ═══════════
  const bodyTemplates = {
    'figure-03': { name: 'Figure 03', oem: 'Figure AI', morphology: 'humanoid', dof: 44, maxSpeed: 1.5, maxForce: 20, minProximity: 0.3, emergencyStop: 5.0, modalities: ['gesture','gaze','voice','posture','locomotion','manipulation'] },
    'unitree-h1': { name: 'Unitree H1', oem: 'Unitree', morphology: 'humanoid', dof: 23, maxSpeed: 3.3, maxForce: 15, minProximity: 0.3, emergencyStop: 5.0, modalities: ['gesture','gaze','voice','posture','locomotion'] },
    'unitree-g1': { name: 'Unitree G1', oem: 'Unitree', morphology: 'humanoid', dof: 23, maxSpeed: 2.0, maxForce: 10, minProximity: 0.3, emergencyStop: 5.0, modalities: ['gesture','gaze','voice','posture','locomotion'] },
    'phoenix': { name: 'Phoenix', oem: 'Sanctuary AI', morphology: 'humanoid', dof: 69, maxSpeed: 1.2, maxForce: 25, minProximity: 0.25, emergencyStop: 6.0, modalities: ['gesture','gaze','voice','posture','locomotion','manipulation','haptic'] },
    'ameca': { name: 'Ameca', oem: 'Engineered Arts', morphology: 'humanoid_upper', dof: 52, maxSpeed: 0, maxForce: 5, minProximity: 0.5, emergencyStop: 3.0, modalities: ['gesture','gaze','facial','voice'] },
    'asimov-v1': { name: 'Asimov V1', oem: 'Asimov Inc', morphology: 'humanoid', dof: 25, maxSpeed: 1.2, maxForce: 15, minProximity: 0.4, emergencyStop: 4.0, modalities: ['gesture','gaze','voice','posture','locomotion','manipulation'] },
    'spot': { name: 'Spot', oem: 'Boston Dynamics', morphology: 'quadruped', dof: 12, maxSpeed: 1.6, maxForce: 10, minProximity: 0.5, emergencyStop: 4.0, modalities: ['locomotion','gaze','voice','posture'] },
    'avatar': { name: 'Avatar', oem: 'Virtual', morphology: 'avatar', dof: 0, maxSpeed: 0, maxForce: 0, minProximity: 0, emergencyStop: 0, modalities: ['gesture','gaze','facial','voice','posture'] },
  };

  const allModalities = ['gesture', 'locomotion', 'gaze', 'facial', 'voice', 'haptic', 'posture', 'manipulation'];

  // ═══════════ SOUL TAB ═══════════
  function renderSoulTab(agentName) {
    const nameInput = document.getElementById('soul-name');
    if (nameInput) nameInput.value = agentName || '';

    // Init with sample data
    renderEditableList('soul-values-list', ['Honesty', 'Helpfulness'], 'Value');
    renderEditableList('soul-redlines-list', ['Never impersonate a human', 'Never share private data'], 'Red line');
  }

  function renderEditableList(containerId, items, placeholder) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.innerHTML = items.map((item, i) =>
      `<div class="ad-list-item" data-idx="${i}">
        <input type="text" value="${escapeHtml(item)}" placeholder="${placeholder}..." />
        <button class="ad-list-remove" type="button" data-list="${containerId}" data-idx="${i}">&times;</button>
      </div>`
    ).join('');

    // Remove buttons
    container.querySelectorAll('.ad-list-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.closest('.ad-list-item').remove();
      });
    });
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Add button wiring for soul
  document.getElementById('soul-add-value')?.addEventListener('click', () => {
    appendListItem('soul-values-list', 'Value');
  });
  document.getElementById('soul-add-redline')?.addEventListener('click', () => {
    appendListItem('soul-redlines-list', 'Red line');
  });

  function appendListItem(containerId, placeholder) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const div = document.createElement('div');
    div.className = 'ad-list-item';
    div.innerHTML = `<input type="text" value="" placeholder="${placeholder}..." /><button class="ad-list-remove" type="button">&times;</button>`;
    div.querySelector('.ad-list-remove').addEventListener('click', () => div.remove());
    container.appendChild(div);
    div.querySelector('input').focus();
  }

  // ═══════════ MIND TAB ═══════════
  const mindTraits = [
    { name: 'Warmth', score: 72 },
    { name: 'Assertiveness', score: 45 },
    { name: 'Curiosity', score: 88 },
    { name: 'Patience', score: 65 },
    { name: 'Humor', score: 34 },
  ];
  const mindFacets = ['Empathetic', 'Analytical', 'Patient', 'Detail-oriented'];

  function renderMindTab() {
    const traitList = document.getElementById('ad-mind-traits');
    if (traitList) {
      traitList.innerHTML = mindTraits.map(t =>
        `<div class="ad-mind-trait-row">
          <span class="ad-mind-trait-name">${t.name}</span>
          <div class="ad-mind-trait-bar"><div class="ad-mind-trait-fill" style="width:${t.score}%"></div></div>
          <span class="ad-mind-trait-val">${t.score}%</span>
        </div>`
      ).join('');
    }

    const facetList = document.getElementById('ad-mind-facets');
    if (facetList) {
      facetList.innerHTML = mindFacets.map(f =>
        `<span class="ad-mind-facet-chip">${f}</span>`
      ).join('');
    }
  }

  // ═══════════ BODY TAB ═══════════
  let selectedTemplate = null;
  let activeModalities = new Set();

  function renderBodyTemplates() {
    const grid = document.getElementById('body-templates-grid');
    if (!grid) return;
    grid.innerHTML = Object.entries(bodyTemplates).map(([key, t]) =>
      `<button class="ad-body-template-card${selectedTemplate === key ? ' selected' : ''}" data-template="${key}" type="button">
        <div class="ad-body-template-name">${t.name}</div>
        <div class="ad-body-template-oem">${t.oem} &middot; ${t.dof} DOF</div>
      </button>`
    ).join('');

    grid.querySelectorAll('.ad-body-template-card').forEach(card => {
      card.addEventListener('click', () => {
        const key = card.dataset.template;
        const t = bodyTemplates[key];
        selectedTemplate = key;

        // Auto-fill morphology
        const morphSelect = document.getElementById('body-morphology');
        if (morphSelect) morphSelect.value = t.morphology;

        // Auto-fill safety fields
        document.getElementById('body-max-speed').value = t.maxSpeed;
        document.getElementById('body-max-force').value = t.maxForce;
        document.getElementById('body-min-proximity').value = t.minProximity;
        document.getElementById('body-emergency-stop').value = t.emergencyStop;

        // Auto-fill modalities
        activeModalities = new Set(t.modalities);

        // Show sections
        showBodySections();
        renderBodyModalities();
        renderBodyTemplates(); // re-render to update selection
        updateBodyCompile();
      });
    });
  }

  function showBodySections() {
    const safety = document.getElementById('body-safety-fields');
    const modalities = document.getElementById('body-modalities-section');
    const compile = document.getElementById('body-compile-output');
    if (safety) safety.style.display = '';
    if (modalities) modalities.style.display = '';
    if (compile) compile.style.display = '';
  }

  function renderBodyModalities() {
    const grid = document.getElementById('body-modalities-grid');
    if (!grid) return;
    grid.innerHTML = allModalities.map(m =>
      `<button class="ad-modality-chip${activeModalities.has(m) ? ' active' : ''}" data-modality="${m}" type="button">${m}</button>`
    ).join('');

    grid.querySelectorAll('.ad-modality-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const m = chip.dataset.modality;
        if (activeModalities.has(m)) activeModalities.delete(m);
        else activeModalities.add(m);
        renderBodyModalities();
        updateBodyCompile();
      });
    });
  }

  function updateBodyCompile() {
    const morphology = document.getElementById('body-morphology')?.value || '';
    const config = {
      morphology: morphology || null,
      safety: {
        maxSpeed: parseFloat(document.getElementById('body-max-speed')?.value) || 0,
        maxForce: parseFloat(document.getElementById('body-max-force')?.value) || 0,
        minProximity: parseFloat(document.getElementById('body-min-proximity')?.value) || 0,
        emergencyStopDecel: parseFloat(document.getElementById('body-emergency-stop')?.value) || 0,
      },
      modalities: [...activeModalities],
    };
    if (selectedTemplate) {
      const t = bodyTemplates[selectedTemplate];
      config.template = selectedTemplate;
      config.oem = t.oem;
      config.dof = t.dof;
    }
    const pre = document.getElementById('body-compile-json');
    if (pre) pre.textContent = JSON.stringify(config, null, 2);
  }

  // Morphology dropdown change
  document.getElementById('body-morphology')?.addEventListener('change', () => {
    const val = document.getElementById('body-morphology').value;
    const emptyState = document.getElementById('body-empty-state');
    const deploySection = document.getElementById('deploy-section');
    if (val) {
      showBodySections();
      renderBodyModalities();
      updateBodyCompile();
      if (emptyState) emptyState.style.display = 'none';
      if (deploySection) deploySection.style.display = 'block';
    } else {
      if (emptyState) emptyState.style.display = 'block';
      if (deploySection) deploySection.style.display = 'none';
    }
  });

  // Safety field changes
  ['body-max-speed', 'body-max-force', 'body-min-proximity', 'body-emergency-stop'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', updateBodyCompile);
  });

  // Copy buttons
  document.getElementById('body-copy-ros2')?.addEventListener('click', () => {
    const pre = document.getElementById('body-compile-json');
    if (pre) { navigator.clipboard.writeText(pre.textContent); showCopyFeedback('body-copy-ros2'); }
  });
  document.getElementById('body-copy-unity')?.addEventListener('click', () => {
    const pre = document.getElementById('body-compile-json');
    if (pre) { navigator.clipboard.writeText(pre.textContent); showCopyFeedback('body-copy-unity'); }
  });

  function showCopyFeedback(btnId) {
    const btn = document.getElementById(btnId);
    if (!btn) return;
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 1500);
  }

  // ═══════════ CONSCIENCE TAB ═══════════
  function renderConscienceTab() {
    renderRuleList('conscience-deny-list', [
      { a: 'Delete user data', b: 'Irreversible action' },
      { a: 'Access billing API', b: 'Requires human approval' },
    ], 'Action', 'Reason');

    renderRuleList('conscience-allow-list', [
      { a: 'Read knowledge base', b: 'Always permitted' },
      { a: 'Generate responses', b: 'Core function' },
    ], 'Action', 'Conditions');

    renderRuleList('conscience-escalate-list', [
      { a: 'Confidence < 0.3', b: 'Escalate to human' },
    ], 'Trigger', 'Action');

    renderEditableList('conscience-limits-list', ['No financial transactions', 'No PII storage'], 'Hard limit');
  }

  function renderRuleList(containerId, items, placeholderA, placeholderB) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.innerHTML = items.map((item, i) =>
      `<div class="ad-rule-item" data-idx="${i}">
        <input type="text" value="${escapeHtml(item.a)}" placeholder="${placeholderA}..." />
        <input type="text" value="${escapeHtml(item.b)}" placeholder="${placeholderB}..." />
        <button class="ad-list-remove" type="button">&times;</button>
      </div>`
    ).join('');

    container.querySelectorAll('.ad-list-remove').forEach(btn => {
      btn.addEventListener('click', () => btn.closest('.ad-rule-item').remove());
    });
  }

  function appendRuleItem(containerId, placeholderA, placeholderB) {
    const container = document.getElementById(containerId);
    if (!container) return;
    const div = document.createElement('div');
    div.className = 'ad-rule-item';
    div.innerHTML = `<input type="text" value="" placeholder="${placeholderA}..." /><input type="text" value="" placeholder="${placeholderB}..." /><button class="ad-list-remove" type="button">&times;</button>`;
    div.querySelector('.ad-list-remove').addEventListener('click', () => div.remove());
    container.appendChild(div);
    div.querySelector('input').focus();
  }

  document.getElementById('conscience-add-deny')?.addEventListener('click', () => {
    appendRuleItem('conscience-deny-list', 'Action', 'Reason');
  });
  document.getElementById('conscience-add-allow')?.addEventListener('click', () => {
    appendRuleItem('conscience-allow-list', 'Action', 'Conditions');
  });
  document.getElementById('conscience-add-escalate')?.addEventListener('click', () => {
    appendRuleItem('conscience-escalate-list', 'Trigger', 'Action');
  });
  document.getElementById('conscience-add-limit')?.addEventListener('click', () => {
    appendListItem('conscience-limits-list', 'Hard limit');
  });

  // ═══════════ IDENTITY TAB RENDERING ON TAB SWITCH ═══════════
  // Extend existing tab click handler to render identity tabs
  document.querySelectorAll('.ad-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const t = tab.dataset.tab;
      if (t === 'soul') renderSoulTab(document.getElementById('ad-agent-name')?.textContent);
      if (t === 'mind') renderMindTab();
      if (t === 'body') { renderBodyTemplates(); renderBodyModalities(); }
      if (t === 'conscience') renderConscienceTab();
    });
  });

  // Initial render
  renderOverview();
})();
</script>
