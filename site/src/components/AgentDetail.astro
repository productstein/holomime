        { id: 1, ts: now - 4*DAY, messages: 82, scoreBefore: 44, scoreAfter: 48, grade: 'D', risk: 'high', duration: '24m', patterns: ['hallucination', 'source-fabrication', 'style-drift'] },
        { id: 2, ts: now - 3*DAY, messages: 76, scoreBefore: 48, scoreAfter: 53, grade: 'D+', risk: 'high', duration: '22m', patterns: ['hallucination', 'style-drift'] },
        { id: 3, ts: now - 2*DAY, messages: 69, scoreBefore: 53, scoreAfter: 57, grade: 'C-', risk: 'medium', duration: '20m', patterns: ['hallucination'] },
        { id: 4, ts: now - 8*3600000, messages: 55, scoreBefore: 57, scoreAfter: 61, grade: 'C', risk: 'medium', duration: '16m', patterns: ['style-drift'] },
