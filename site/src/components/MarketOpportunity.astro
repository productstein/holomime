---
const stats = [
  { value: "$6.24B", label: "Humanoid market 2026" },
  { value: "$165B", label: "Projected 2034" },
  { value: "0", label: "OEMs with a behavioral alignment layer" },
];
---

<section class="py-20 md:py-28 bg-[var(--color-holo-dark)] text-white">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-center text-3xl font-bold md:text-5xl leading-tight">
      29 humanoid OEMs. <span class="text-gradient">Zero identity layers.</span>
    </h2>

    <!-- Stat cards -->
    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      {stats.map((s) => (
        <div class="rounded-2xl border border-[var(--color-holo-border)] bg-[var(--color-holo-card)] p-8 text-center">
          <div class="text-4xl font-extrabold md:text-5xl text-white">{s.value}</div>
          <div class="mt-3 text-sm text-[var(--color-holo-muted)]">{s.label}</div>
        </div>
      ))}
    </div>

    <!-- Tagline -->
    <p class="mt-12 text-center text-lg text-[var(--color-holo-muted)] md:text-xl">
      The hardware race is on. The soul is missing.
    </p>

    <!-- CTA -->
    <div class="mt-8 text-center">
      <a
        href="/blog/identity-stack-humanoid-robots"
        class="inline-flex items-center gap-2 text-base font-semibold text-[var(--color-holo-cyan)] hover:underline underline-offset-4 transition-colors"
      >
        Read the thesis
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
