---
/**
 * TrustBar — Verifiable credibility signals via shields.io badges.
 */
---

<div class="bg-[var(--color-warm-cream)] py-8 border-y border-[var(--color-warm-sand)]">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-5 sm:gap-8">
      <!-- GitHub stars -->
      <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="transition-opacity hover:opacity-80">
        <img
          src="https://img.shields.io/github/stars/productstein/holomime?style=flat-square&label=GitHub%20Stars&color=8b5cf6&labelColor=1e1b4b"
          alt="GitHub stars"
          height="20"
          loading="lazy"
        />
      </a>

      <!-- npm downloads -->
      <a href="https://www.npmjs.com/package/holomime" target="_blank" rel="noopener" class="transition-opacity hover:opacity-80">
        <img
          src="https://img.shields.io/npm/dw/holomime?style=flat-square&label=npm%20weekly&color=06b6d4&labelColor=0e1629"
          alt="npm weekly downloads"
          height="20"
          loading="lazy"
        />
      </a>

      <!-- MIT license -->
      <a href="https://github.com/productstein/holomime/blob/main/LICENSE" target="_blank" rel="noopener" class="transition-opacity hover:opacity-80">
        <img
          src="https://img.shields.io/badge/license-MIT-22c55e?style=flat-square&labelColor=0e1629"
          alt="MIT License"
          height="20"
          loading="lazy"
        />
      </a>

      <div class="hidden sm:block h-5 w-px bg-[var(--color-warm-sand)]"></div>

      <!-- Open source tagline -->
      <p class="text-sm text-[var(--color-warm-muted)]">
        Open source. Self-hostable. <span class="font-semibold text-[var(--color-warm-text)]">Your therapist, your rules.</span>
      </p>
    </div>
  </div>
</div>
