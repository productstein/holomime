---
/**
 * HowItWorks — 3-step visual for non-technical buyers.
 * Therapy language: Diagnose → Correct → Cure.
 */
const steps = [
  {
    num: "01",
    title: "Diagnose",
    command: "holomime diagnose",
    description: "Point it at any conversation log. In seconds, get a behavioral report card: sycophancy, hedging, over-apologizing, boundary issues. Comprehensive scan. No API calls. Runs locally.",
    color: "#3b82f6",
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
  },
  {
    num: "02",
    title: "Correct",
    command: "holomime evolve",
    description: "A therapist agent runs structured sessions with persistent memory, self-improving interventions, and ReACT reasoning. It remembers what worked, escalates what didn't, and compounds across sessions.",
    color: "#8b5cf6",
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
  },
  {
    num: "03",
    title: "Cure",
    command: "holomime export --format dpo",
    description: "Every correction becomes training data automatically. Export in any format. Fine-tune so the fix is permanent. Before/after grading proves it worked.",
    color: "#10b981",
    icon: `<svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];
---

<section class="py-16 md:py-24 bg-[var(--color-warm-cream)]">
  <div class="mx-auto max-w-5xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-violet)]">
      How It Works
    </p>
    <h2 class="mt-3 text-center text-2xl font-extrabold text-[var(--color-warm-text)] md:text-3xl">
      Three steps. Broken agent in, aligned agent out.
    </h2>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {steps.map((step, i) => (
        <div class="relative">
          {/* Connector arrow between steps (desktop) */}
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute top-12 -right-3 z-10">
              <svg class="h-5 w-5 text-[var(--color-warm-sand)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
          )}

          <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 h-full">
            {/* Step number + icon */}
            <div class="flex items-center gap-3 mb-4">
              <div class="flex h-11 w-11 items-center justify-center rounded-xl" style={`background: ${step.color}12; color: ${step.color};`}>
                <Fragment set:html={step.icon} />
              </div>
              <span class="text-2xl font-extrabold" style={`color: ${step.color}25;`}>{step.num}</span>
            </div>

            <h3 class="text-lg font-bold text-[var(--color-warm-text)]">{step.title}</h3>

            {/* Command */}
            <code class="mt-2 inline-block rounded-lg bg-[var(--color-holo-slate)] px-3 py-1.5 font-mono text-xs text-white">
              {step.command}
            </code>

            <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
