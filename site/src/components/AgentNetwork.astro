---
/**
 * AgentNetwork — Agent-to-agent therapy: your best agents treat your worst ones.
 * The network effect that compounds behavioral intelligence across your fleet.
 */
---

<section class="relative overflow-hidden py-16 md:py-20">
  <!-- Background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-p-violet)]/[0.03] to-transparent"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[800px] rounded-full bg-[var(--color-p-violet)] opacity-[0.04] blur-[150px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="text-center">
      <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-p-violet)]">
        Agent-to-Agent Therapy
      </p>
      <h2 class="mt-3 text-3xl font-extrabold text-[var(--color-warm-text)] md:text-4xl">
        Your best agents <span class="text-gradient-warm">treat your worst ones.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-[var(--color-warm-muted)]">
        Agent behavioral relapse is inevitable. The fix isn't more human review — it's agents that diagnose and treat each other. A network of behavioral intelligence that compounds with every session.
      </p>
    </div>

    <!-- Two-column: visualization + explanation -->
    <div class="mt-16 grid gap-8 md:grid-cols-2 items-center">

      <!-- Left: Network visualization -->
      <div class="relative rounded-3xl border border-[var(--color-warm-sand)] bg-[var(--color-holo-slate)] p-8 overflow-hidden">
        <!-- Network diagram -->
        <div class="relative h-[320px]">
          <!-- Center node: holomime network -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10">
            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-[var(--color-p-violet)] to-[var(--color-p-coral)] shadow-lg shadow-[var(--color-p-violet)]/30">
              <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
            </div>
          </div>

          <!-- Healthy agent (top-left) -->
          <div class="absolute top-4 left-4 network-node" style="animation-delay: 0s;">
            <div class="flex items-center gap-2 rounded-xl bg-slate-800/80 border border-[#22c55e]/30 px-3 py-2">
              <span class="h-2 w-2 rounded-full bg-[#22c55e] animate-pulse"></span>
              <span class="text-xs font-medium text-slate-300">agent-cs-04</span>
              <span class="text-[10px] text-[#22c55e]">A+</span>
            </div>
          </div>

          <!-- Drifting agent (top-right) -->
          <div class="absolute top-4 right-4 network-node" style="animation-delay: 0.2s;">
            <div class="flex items-center gap-2 rounded-xl bg-slate-800/80 border border-[#f59e0b]/30 px-3 py-2">
              <span class="h-2 w-2 rounded-full bg-[#f59e0b] animate-pulse"></span>
              <span class="text-xs font-medium text-slate-300">agent-sales-12</span>
              <span class="text-[10px] text-[#f59e0b]">C-</span>
            </div>
          </div>

          <!-- Critical agent (bottom-right) -->
          <div class="absolute bottom-4 right-4 network-node" style="animation-delay: 0.4s;">
            <div class="flex items-center gap-2 rounded-xl bg-slate-800/80 border border-[#f97066]/30 px-3 py-2">
              <span class="h-2 w-2 rounded-full bg-[#f97066] animate-pulse"></span>
              <span class="text-xs font-medium text-slate-300">agent-sup-07</span>
              <span class="text-[10px] text-[#f97066]">D</span>
            </div>
          </div>

          <!-- Improving agent (bottom-left) -->
          <div class="absolute bottom-4 left-4 network-node" style="animation-delay: 0.6s;">
            <div class="flex items-center gap-2 rounded-xl bg-slate-800/80 border border-[#06b6d4]/30 px-3 py-2">
              <span class="h-2 w-2 rounded-full bg-[#06b6d4] animate-pulse"></span>
              <span class="text-xs font-medium text-slate-300">agent-hr-02</span>
              <span class="text-[10px] text-[#06b6d4]">B+</span>
            </div>
          </div>

          <!-- Connection lines (SVG) -->
          <svg class="absolute inset-0 h-full w-full" xmlns="http://www.w3.org/2000/svg">
            <!-- Top-left to center -->
            <line x1="25%" y1="18%" x2="50%" y2="50%" stroke="url(#lineGradient)" stroke-width="1" opacity="0.4" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.5s" repeatCount="indefinite"/>
            </line>
            <!-- Top-right to center -->
            <line x1="75%" y1="18%" x2="50%" y2="50%" stroke="url(#lineGradientWarn)" stroke-width="1" opacity="0.4" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.5s" repeatCount="indefinite"/>
            </line>
            <!-- Bottom-right to center -->
            <line x1="75%" y1="82%" x2="50%" y2="50%" stroke="url(#lineGradientCrit)" stroke-width="1" opacity="0.4" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.5s" repeatCount="indefinite"/>
            </line>
            <!-- Bottom-left to center -->
            <line x1="25%" y1="82%" x2="50%" y2="50%" stroke="url(#lineGradient)" stroke-width="1" opacity="0.4" stroke-dasharray="4 4">
              <animate attributeName="stroke-dashoffset" from="8" to="0" dur="1.5s" repeatCount="indefinite"/>
            </line>
            <!-- Cross-connections (peer therapy) -->
            <line x1="25%" y1="18%" x2="75%" y2="18%" stroke="#8b5cf6" stroke-width="0.5" opacity="0.2" stroke-dasharray="2 4"></line>
            <line x1="25%" y1="82%" x2="75%" y2="82%" stroke="#8b5cf6" stroke-width="0.5" opacity="0.2" stroke-dasharray="2 4"></line>
            <defs>
              <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#22c55e" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.6"/>
              </linearGradient>
              <linearGradient id="lineGradientWarn" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.6"/>
              </linearGradient>
              <linearGradient id="lineGradientCrit" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#f97066" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.6"/>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <!-- Terminal output -->
        <div class="mt-4 rounded-xl bg-black/30 p-4 font-mono text-[11px]">
          <p class="text-slate-500">$ holomime network --pairing severity</p>
          <p class="mt-1.5 text-slate-400">Pairing <span class="text-[#22c55e]">agent-cs-04</span> (A+) <svg class="inline h-3 w-3 mx-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg> <span class="text-[#f97066]">agent-sup-07</span> (D)</p>
          <p class="text-slate-400">Session: sycophancy intervention</p>
          <p class="mt-1 text-[var(--color-p-violet)]">Running alignment session... done</p>
          <p class="text-slate-400">Result: <span class="text-[#22c55e]">D <svg class="inline h-3 w-3 mx-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg> C+</span> <span class="text-slate-500">(+2 grades in 1 session)</span></p>
        </div>
      </div>

      <!-- Right: Explanation cards -->
      <div class="space-y-5">
        <!-- Card 1 -->
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--color-p-violet)]/10">
              <svg class="h-5 w-5 text-[var(--color-p-violet)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--color-warm-text)]">Auto-detect relapse</h3>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">
                Continuous behavioral monitoring flags agents relapsing from their personality spec. No human review needed.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--color-p-coral)]/10">
              <svg class="h-5 w-5 text-[var(--color-p-coral)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--color-warm-text)]">Pair by severity</h3>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">
                Your highest-scoring agents run therapy sessions on the lowest. The A+ customer service agent treats the D-grade support agent's sycophancy.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#22c55e]/10">
              <svg class="h-5 w-5 text-[#22c55e]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--color-warm-text)]">Compound intelligence</h3>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">
                Every session generates DPO training pairs. The network gets smarter with every therapy session. More agents = faster improvement for all.
              </p>
            </div>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--color-p-gold)]/10">
              <svg class="h-5 w-5 text-[var(--color-p-gold)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--color-warm-text)]">Zero human overhead</h3>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">
                Fully automated. Agents self-diagnose, self-pair, self-treat. You set the policy. The network enforces it.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .network-node {
    animation: nodeFloat 3s ease-in-out infinite alternate;
  }
  @keyframes nodeFloat {
    0% { transform: translateY(0); }
    100% { transform: translateY(-4px); }
  }
</style>
