---
interface Props {
  user: {
    email?: string;
    user_metadata?: Record<string, any>;
  };
}

const { user } = Astro.props;
const licenseKey = user.user_metadata?.license_key || "";
---

<div id="onboarding-overlay" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/50 backdrop-blur-sm transition-opacity duration-300">
  <div class="relative mx-4 w-full max-w-2xl rounded-2xl bg-white shadow-2xl overflow-hidden" style="max-height: 90vh;">
    <!-- Progress bar -->
    <div class="h-1 bg-[var(--color-warm-sand)]">
      <div id="onboarding-progress" class="h-full bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] transition-all duration-500 ease-out" style="width: 50%;"></div>
    </div>

    <!-- Skip link -->
    <button id="onboarding-skip" class="absolute top-4 right-4 z-10 text-xs text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors">
      Skip onboarding
    </button>

    <!-- Step indicator dots -->
    <div id="onboarding-dots" class="flex justify-center gap-2 pt-6 pb-2">
      <div class="onboarding-dot active" data-dot="0"></div>
      <div class="onboarding-dot" data-dot="1"></div>
    </div>

    <!-- Steps container -->
    <div id="onboarding-steps" class="relative overflow-hidden">

      <!-- Step 1: What are you building? -->
      <div class="onboarding-step active" data-step="0">
        <div class="px-8 pb-8 pt-4 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">What are you building?</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Choose your path to get started with holomime.</p>

          <div class="mt-6 grid gap-4 sm:grid-cols-2 max-w-lg mx-auto">
            <!-- AI Agent card -->
            <button class="path-card group rounded-xl border-2 border-[var(--color-warm-border)] p-6 text-left transition-all hover:border-[#7c3aed] hover:shadow-lg" data-path="agent">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#ede9fe]">
                <svg class="h-6 w-6 text-[#7c3aed]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                </svg>
              </div>
              <p class="text-base font-bold text-[var(--color-warm-text)]">AI Agent</p>
              <p class="mt-1 text-xs text-[var(--color-warm-muted)]">Chatbot, coding agent, support agent, API-based</p>
            </button>

            <!-- Humanoid Robot card -->
            <button class="path-card group rounded-xl border-2 border-[var(--color-warm-border)] p-6 text-left transition-all hover:border-[#f97066] hover:shadow-lg" data-path="robot">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-[#fff1f0]">
                <svg class="h-6 w-6 text-[#f97066]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25v-1.5M8.25 6H6M18 6h-2.25" />
                </svg>
              </div>
              <p class="text-base font-bold text-[var(--color-warm-text)]">Humanoid Robot</p>
              <p class="mt-1 text-xs text-[var(--color-warm-muted)]">Warehouse, healthcare, service, physical deployment</p>
            </button>
          </div>
        </div>
      </div>

      <!-- Step 2: Path-specific steps -->
      <div class="onboarding-step" data-step="1">
        <div class="px-8 pb-8 pt-4">
          <!-- Agent path -->
          <div id="path-agent-steps" class="hidden">
            <h2 class="text-xl font-bold text-[var(--color-warm-text)] text-center">Profile your existing AI agent</h2>
            <p class="mt-2 text-sm text-[var(--color-warm-muted)] text-center">Define target behavior. Diagnose drift. Fix it permanently.</p>
            <div class="mt-6 space-y-3 max-w-md mx-auto">
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#7c3aed] text-xs font-bold text-white">1</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Install</p>
                  <code class="mt-1 block text-xs font-mono text-[#7c3aed]">npm install -g holomime</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#7c3aed] text-xs font-bold text-white">2</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Profile your agent</p>
                  <code class="mt-1 block text-xs font-mono text-[#7c3aed]">holomime personality</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#7c3aed] text-xs font-bold text-white">3</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Diagnose</p>
                  <code class="mt-1 block text-xs font-mono text-[#7c3aed]">holomime diagnose</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#7c3aed] text-xs font-bold text-white">4</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Cure</p>
                  <code class="mt-1 block text-xs font-mono text-[#7c3aed]">holomime cure</code>
                </div>
              </div>
            </div>
          </div>

          <!-- Robot path -->
          <div id="path-robot-steps" class="hidden">
            <h2 class="text-xl font-bold text-[var(--color-warm-text)] text-center">Define your robot's behavioral identity</h2>
            <p class="mt-2 text-sm text-[var(--color-warm-muted)] text-center">Full 8-file identity stack with body.api for physical constraints.</p>
            <div class="mt-6 space-y-3 max-w-md mx-auto">
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f97066] text-xs font-bold text-white">1</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Install</p>
                  <code class="mt-1 block text-xs font-mono text-[#f97066]">npm install -g holomime</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f97066] text-xs font-bold text-white">2</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Define identity</p>
                  <code class="mt-1 block text-xs font-mono text-[#f97066]">holomime identity</code>
                  <p class="mt-0.5 text-[10px] text-[var(--color-warm-muted)]">All 8 files including body.api</p>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f97066] text-xs font-bold text-white">3</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Select body</p>
                  <code class="mt-1 block text-xs font-mono text-[#f97066]">holomime personality --swap-body figure-03</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f97066] text-xs font-bold text-white">4</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Certify</p>
                  <code class="mt-1 block text-xs font-mono text-[#f97066]">holomime certify</code>
                </div>
              </div>
              <div class="flex items-start gap-3 rounded-lg border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#f97066] text-xs font-bold text-white">5</span>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-warm-text)]">Deploy</p>
                  <code class="mt-1 block text-xs font-mono text-[#f97066]">holomime embody --adapter ros2</code>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-6 flex items-center justify-center gap-4">
            <button class="onboarding-back text-sm text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors">Back</button>
            <button id="path-steps-done" class="rounded-full bg-[var(--color-warm-text)] px-8 py-2.5 text-sm font-semibold text-white transition-all hover:opacity-80">
              Done
            </button>
          </div>
        </div>
      </div>

      <!-- Step 3 (hidden): You're Set -->
      <div class="onboarding-step" data-step="2">
        <div class="px-8 pb-8 pt-4 text-center">
          <!-- Checkmark animation -->
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-p-sage-soft)]">
            <svg id="onboarding-check" class="h-8 w-8 text-[var(--color-p-sage)]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path class="checkmark-path" stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>

          <h2 class="text-xl font-bold text-[var(--color-warm-text)]">You're ready to go</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Start monitoring, diagnosing, and aligning your agents.</p>

          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            <button id="onboarding-go-dashboard" class="rounded-xl border-2 border-[var(--color-p-violet)] bg-[var(--color-p-violet-soft)] p-4 transition-all hover:shadow-md">
              <svg class="mx-auto h-6 w-6 text-[var(--color-p-violet)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
              </svg>
              <p class="mt-2 text-sm font-semibold text-[var(--color-p-violet)]">View Dashboard</p>
            </button>

            <a href="/docs" class="rounded-xl border-2 border-[var(--color-warm-border)] bg-white p-4 transition-all hover:border-[var(--color-p-coral)] hover:shadow-md">
              <svg class="mx-auto h-6 w-6 text-[var(--color-warm-text)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              <p class="mt-2 text-sm font-semibold text-[var(--color-warm-text)]">Read the Docs</p>
            </a>

            <a href="/api-docs" class="rounded-xl border-2 border-[var(--color-warm-border)] bg-white p-4 transition-all hover:border-[var(--color-p-coral)] hover:shadow-md">
              <svg class="mx-auto h-6 w-6 text-[var(--color-warm-text)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
              <p class="mt-2 text-sm font-semibold text-[var(--color-warm-text)]">Explore API</p>
            </a>
          </div>

          <div class="mt-6">
            <label class="inline-flex items-center gap-2 cursor-pointer">
              <input id="onboarding-dont-show" type="checkbox" checked class="h-4 w-4 rounded border-[var(--color-warm-border)] text-[var(--color-p-violet)] focus:ring-[var(--color-p-violet)]" />
              <span class="text-xs text-[var(--color-warm-muted)]">Don't show this again</span>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .onboarding-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-warm-sand);
    transition: all 0.3s ease;
  }
  .onboarding-dot.active {
    background: var(--color-p-violet);
    transform: scale(1.25);
  }
  .onboarding-dot.completed {
    background: var(--color-p-sage);
  }

  .onboarding-step {
    display: none;
    animation: onboardingFadeIn 0.35s ease-out;
  }
  .onboarding-step.active {
    display: block;
  }

  @keyframes onboardingFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .path-card.selected[data-path="agent"] {
    border-color: #7c3aed !important;
    background: #ede9fe;
    box-shadow: 0 0 0 2px #7c3aed;
  }
  .path-card.selected[data-path="robot"] {
    border-color: #f97066 !important;
    background: #fff1f0;
    box-shadow: 0 0 0 2px #f97066;
  }

  .checkmark-path {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: checkDraw 0.5s ease-out 0.2s forwards;
  }

  @keyframes checkDraw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes resultReveal {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  import { createClient } from "../lib/supabase";

  const overlay = document.getElementById("onboarding-overlay")!;
  const steps = document.querySelectorAll<HTMLElement>(".onboarding-step");
  const dots = document.querySelectorAll<HTMLElement>(".onboarding-dot");
  const progressBar = document.getElementById("onboarding-progress")!;

  let currentStep = 0;
  let selectedPath = "";

  function goToStep(step: number) {
    if (step < 0 || step >= steps.length) return;
    steps[currentStep].classList.remove("active");
    steps[step].classList.add("active");

    // Only update visible dots (0 and 1)
    dots.forEach((d, i) => {
      d.classList.remove("active", "completed");
      if (i === step) d.classList.add("active");
      else if (i < step) d.classList.add("completed");
    });

    progressBar.style.width = `${((step + 1) / 2) * 100}%`;
    currentStep = step;
  }

  async function dismiss(saveCompletion: boolean) {
    overlay.style.opacity = "0";
    setTimeout(() => overlay.remove(), 300);

    if (saveCompletion) {
      const supabase = createClient();
      await supabase.auth.updateUser({
        data: {
          onboarding: {
            completed: true,
            use_case: selectedPath,
            completed_at: new Date().toISOString(),
          },
        },
      });
    }
  }

  // ── Step 1: Path selection (Agent vs Robot) ──
  const pathCards = document.querySelectorAll<HTMLElement>(".path-card");

  pathCards.forEach((card) => {
    card.addEventListener("click", () => {
      pathCards.forEach((c) => c.classList.remove("selected"));
      card.classList.add("selected");
      selectedPath = card.dataset.path || "";

      // Show the right steps for the selected path
      const agentSteps = document.getElementById("path-agent-steps")!;
      const robotSteps = document.getElementById("path-robot-steps")!;

      if (selectedPath === "agent") {
        agentSteps.classList.remove("hidden");
        robotSteps.classList.add("hidden");
      } else {
        agentSteps.classList.add("hidden");
        robotSteps.classList.remove("hidden");
      }

      // Go to step 2
      goToStep(1);
    });
  });

  // ── Done button on step 2 ──
  document.getElementById("path-steps-done")?.addEventListener("click", () => {
    dismiss(true);
  });

  // ── Navigation: Back buttons ──
  document.querySelectorAll<HTMLElement>(".onboarding-back").forEach((btn) => {
    btn.addEventListener("click", () => goToStep(currentStep - 1));
  });

  // ── Skip onboarding ──
  document.getElementById("onboarding-skip")?.addEventListener("click", () => dismiss(true));

  // ── Final step: Dashboard ──
  document.getElementById("onboarding-go-dashboard")?.addEventListener("click", () => {
    const dontShow = (document.getElementById("onboarding-dont-show") as HTMLInputElement).checked;
    dismiss(dontShow);
  });
</script>
