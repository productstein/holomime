---
---

<section class="bg-[var(--color-warm-cream)] py-10">
  <div class="mx-auto max-w-6xl px-6">
    <p class="mb-8 text-center text-sm font-medium tracking-wider text-[var(--color-warm-muted)] uppercase">
      Works with every major LLM, voice stack, and ML framework
    </p>
    <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16 opacity-40 hover:opacity-60 transition-opacity">
      <!-- Anthropic -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M13.827 3.52h3.603L24 20.48h-3.603l-6.57-16.96zm-7.257 0h3.604L16.744 20.48h-3.603L3.57 3.52zM0 20.48h3.603"/></svg>
        Anthropic
      </div>
      <!-- OpenAI -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 00-.516-4.91 6.046 6.046 0 00-6.51-2.9A6.065 6.065 0 0011.708.421a6.004 6.004 0 00-5.708 4.156 6.01 6.01 0 00-3.997 2.918 6.042 6.042 0 00.749 7.084 5.98 5.98 0 00.51 4.911 6.05 6.05 0 006.515 2.9A5.999 5.999 0 0013.292 23.579a6.006 6.006 0 005.709-4.156 6.01 6.01 0 003.997-2.918 6.04 6.04 0 00-.716-6.684z"/></svg>
        OpenAI
      </div>
      <!-- Ollama -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-warm-text)] text-white text-xs font-bold">O</div>
        Ollama
      </div>
      <!-- ChatGPT -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#10a37f] text-white text-xs font-bold">G</div>
        ChatGPT
      </div>
      <!-- Claude -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#d4a574] text-white text-xs font-bold">C</div>
        Claude
      </div>
      <!-- LiveKit -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#0f172a] text-white text-xs font-bold">L</div>
        LiveKit
      </div>
      <!-- Deepgram -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#13ef93] text-[#0f172a] text-xs font-bold">D</div>
        Deepgram
      </div>
      <!-- ElevenLabs -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#000000] text-white text-xs font-bold">XI</div>
        ElevenLabs
      </div>
      <!-- Cartesia -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#6366f1] text-white text-xs font-bold">C</div>
        Cartesia
      </div>
      <!-- Hugging Face -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#ffcc00] text-[#1a1a2e] text-xs font-bold">HF</div>
        Hugging Face
      </div>
      <!-- PyTorch -->
      <div class="flex items-center gap-2 text-lg font-semibold text-[var(--color-warm-text)]">
        <div class="flex h-6 w-6 items-center justify-center rounded bg-[#ee4c2c] text-white text-xs font-bold">PT</div>
        PyTorch
      </div>
    </div>
  </div>
</section>
