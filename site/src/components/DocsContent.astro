  safetyEnvelope: { maxLinearSpeed: 1.5, maxContactForce: 50, minProximity: 0.5 },
  denyRules: [{ action: "override_stop", reason: "Safety-critical" }],
  mediationMode: "clamp"
});

const result = gate.evaluate(neuralNetOutput, { humanProximity: 0.8, currentSpeed: 2.0 });
// result.allowed = true, result.modified = true (clamped to safe speed)`}</code></pre>
