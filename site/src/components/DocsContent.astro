  conscienceConfig: { rules: { deny: [{ action: "override_stop", reason: "Safety" }] } },
  safetyEnvelope: { max_linear_speed_m_s: 1.5, min_proximity_m: 0.5 }
});

const result = runtime.evaluate({ action: "approach patient", speed: 1.2, proximity: 0.8 });
// result.allowed = true, result.evalTimeUs = 12 (microseconds)`}</code></pre>
