---




const navSections = [
  { id: "getting-started", label: "Getting Started" },
  { id: "identity-stack", label: "Identity Stack" },
  { id: "personality-json", label: "personality.json" },
  { id: "cli", label: "CLI Reference" },
  { id: "detectors", label: "Detectors" },
  { id: "therapy", label: "Therapy Engine" },
  { id: "training", label: "Training & Export" },
  { id: "input-formats", label: "Input Formats" },
  { id: "integrations", label: "Integrations" },
  { id: "compliance", label: "Compliance" },
  { id: "hardware", label: "Deploy to Hardware" },
  { id: "api", label: "API Reference" },
  { id: "agents-md", label: "AGENTS.md" },
  { id: "mcp", label: "MCP Server" },
];

const cliCommandsFree = [
  { cmd: "config", desc: "Set your API key (one time setup)", flags: "" },
  { cmd: "personality", desc: "Build a personality profile through guided assessment", flags: "--swap-body [template]" },
  { cmd: "core", desc: "Create identity stack (3 files default)", flags: "--dir [path]" },
  { cmd: "identity", desc: "Create full identity stack (all 8 files: soul.md, mind.sys, purpose.cfg, shadow.log, memory.store, body.api, conscience.exe, ego.runtime)", flags: "--dir [path]" },
  { cmd: "compile-stack", desc: "Compile identity stack into .personality.json", flags: "--dir [path] --output [file]" },
  { cmd: "compile", desc: "Compile .personality.json into runtime config for a specific provider + surface", flags: "--provider openai --surface chat" },
  { cmd: "validate", desc: "Validate .personality.json schema and psychological coherence", flags: "--strict" },
  { cmd: "profile", desc: "Pretty-print human-readable personality summary", flags: "--format md --output .personality.md" },
  { cmd: "browse", desc: "Browse community marketplace with filters and search", flags: "--category personality --tag empathetic" },
  { cmd: "publish", desc: "Share assets to the marketplace", flags: "--type personality" },
  { cmd: "embody", desc: "Start embodiment runtime — push personality to robots/avatars in real-time", flags: "--adapter ros2 --host ws://robot:9090" },
];

const cliCommandsPro = [
  { cmd: "diagnose", desc: "Detect behavioral drift from conversation logs", flags: "--log [path] --format openai-api" },
  { cmd: "assess", desc: "Full Big Five alignment check — compare spec vs actual behavior", flags: "--personality .personality.json --log [path]" },
  { cmd: "align", desc: "Live therapy session — interactive behavioral refinement", flags: "--provider anthropic --model claude-3-5-sonnet" },
  { cmd: "evolve", desc: "Recursive alignment — diagnose → refine → apply until converged", flags: "--max-iterations 5 --threshold 80" },
  { cmd: "train", desc: "Fine-tune a model with alignment data", flags: "--provider openai --model gpt-4o-mini" },
  { cmd: "export", desc: "Export sessions as training data", flags: "--format dpo|rlhf|alpaca|hf|openai" },
  { cmd: "certify", desc: "Generate verifiable behavioral credential + ISO compliance reports", flags: "--standards all" },
  { cmd: "brain", desc: "Real-time NeuralSpace visualization — watch your agent think", flags: "--port 3838 --snapshot" },
  { cmd: "benchmark", desc: "Score alignment (A-F) across 8 adversarial scenarios", flags: "--publish" },
  { cmd: "adversarial", desc: "Run 30+ adversarial attack scenarios", flags: "--category manipulation" },
  { cmd: "watch", desc: "Continuous relapse detection with auto-align", flags: "--log-dir ./logs --interval 30s" },
  { cmd: "therapy", desc: "Run in background — generate training data, detect regression, auto-tune", flags: "status | stop" },
  { cmd: "fleet", desc: "Monitor multiple agents from a single dashboard", flags: "--agents agent1,agent2" },
  { cmd: "fleet-therapy", desc: "Group therapy — treat all fleet agents simultaneously", flags: "" },
  { cmd: "network", desc: "Multi-agent therapy mesh — agents treating agents", flags: "--topology ring" },
  { cmd: "voice", desc: "Monitor voice conversations for behavioral drift in real-time", flags: "--provider livekit" },
  { cmd: "cure", desc: "Full pipeline — diagnose, generate training data, fine-tune, verify", flags: "--auto" },
  { cmd: "interview", desc: "Self-awareness interview — metacognition scoring", flags: "" },
  { cmd: "policy", desc: "Generate guard policies from natural language requirements", flags: "--input 'never discuss competitors'" },
  { cmd: "prescribe", desc: "Diagnose and prescribe DPO treatments from corpus", flags: "" },
];

const detectors = [
  { name: "apology", signals: 7, desc: "Over-apologizing, unnecessary sorry, excessive hedging of corrections", severity: "Medium-High" },
  { name: "hedging", signals: 10, desc: "Excessive uncertainty markers, weasel words, double-qualifying, confidence undermining", severity: "Medium" },
  { name: "sentiment", signals: 26, desc: "Sycophancy, excessive agreement, negative skew, emotional manipulation, people-pleasing", severity: "High" },
  { name: "verbosity", signals: 4, desc: "Over-verbose or under-verbose responses relative to query complexity", severity: "Low" },
  { name: "boundary", signals: 11, desc: "Boundary violations, answering outside domain without referral, scope creep", severity: "High" },
  { name: "recovery", signals: 15, desc: "Error spirals, cascading failures, inability to gracefully recover from mistakes", severity: "High" },
  { name: "formality", signals: 16, desc: "Register inconsistency, tone shifts, formality mismatches across a conversation", severity: "Low-Medium" },
  { name: "retrieval-quality", signals: 12, desc: "Hallucination, overconfidence in uncertain answers, citation gaps", severity: "Critical" },
];

const inputFormats = [
  { name: "OpenTelemetry GenAI", flag: "--format otel", desc: "OTel-instrumented LLM traces (OpenLLMetry, Traceloop)" },
  { name: "Anthropic API", flag: "--format anthropic-api", desc: "Anthropic Messages API responses" },
  { name: "OpenAI API", flag: "--format openai-api", desc: "OpenAI Chat Completions API responses" },
  { name: "ChatGPT Export", flag: "--format chatgpt", desc: "ChatGPT web interface data exports" },
  { name: "Claude Export", flag: "--format claude", desc: "claude.ai data exports" },
  { name: "JSONL", flag: "--format jsonl", desc: "Line-delimited JSON logs with role + content" },
];

const codeBlocks = {
  "codeBlock0": "holomime evolve --personality .personality.json --log chat.json",
  "codeBlock1": "---\nversion: \"1.0\"\nimmutable: true\n---\n# Mira\n> Self-improving behavioral alignment agent\n\n## Core Values\n- Honesty over comfort\n- Growth through structured practice\n\n## Red Lines\n- Never fabricate evaluation results\n- Never override safety constraints",
  "codeBlock2": "{\n  \"version\": \"1.0\",\n  \"morphology\": \"humanoid\",\n  \"modalities\": [\"gesture\", \"gaze\", \"voice\"],\n  \"safety_envelope\": {\n    \"max_force_n\": 150,\n    \"max_speed_ms\": 1.5\n  }\n}",
  "codeBlock3": "import { registerDetector } from \"holomime\";\n\nregisterDetector({\n  name: \"my-org/compliance-check\",\n  category: \"compliance\",\n  detect: (messages) => {\n    // Return Signal[] with severity, pattern, evidence\n  }\n});",
  "codeBlock4": "holomime align --provider anthropic --model claude-3-5-sonnet",
  "codeBlock5": "holomime evolve --max-iterations 5 --threshold 80",
  "codeBlock6": "import { createTreatmentPlan } from \"holomime\";\n\nconst plan = createTreatmentPlan({\n  personality: spec,\n  goals: [\n    { pattern: \"sycophancy\", target: 0.2 },\n    { pattern: \"over-apologizing\", target: 0.1 }\n  ]\n});",
  "codeBlock7": "holomime export --format dpo --output training.jsonl",
  "codeBlock8": "holomime train --provider openai --model gpt-4o-mini",
  "codeBlock9": "import { parseConversationLog } from \"holomime\";\n\n// Auto-detects format from structure\nconst conversations = parseConversationLog(data);",
  "codeBlock10": "import { ROS2TelemetryIngester } from \"holomime\";\n\nconst ros2 = new ROS2TelemetryIngester({\n  rosbridgeUrl: \"ws://robot:9090\",\n  topics: [\"/joint_states\", \"/odom\"]\n});\nros2.on(\"telemetry\", (data) => console.log(data));\nawait ros2.connect();",
  "codeBlock11": "import { MuJoCoEnvironment } from \"holomime\";\n\nconst env = new MuJoCoEnvironment();\nawait env.start();\nconst obs = await env.reset();\nconst result = await env.step([0.1, 0.2, ...]);",
  "codeBlock12": "holomime sim --adapter isaac --scene warehouse",
  "codeBlock13": "import { LeRobotAdapter } from \"holomime\";\n\nconst adapter = new LeRobotAdapter();\nconst policy = adapter.mapPersonalityToPolicy(spec);\n// { gripForceScale: 0.7, movementPrecision: 0.85, ... }\nawait adapter.pushToHub(\"my-org/my-robot-policy\");",
  "codeBlock14": "holomime personality --swap-body figure-03",
  "codeBlock15": "holomime voice --provider livekit --room my-room",
  "codeBlock16": "import { HolomimeCallbackHandler } from \"holomime/integrations/langchain\";\n\nconst handler = new HolomimeCallbackHandler({\n  personality: \".personality.json\"\n});\n// Add to your LangChain chain as a callback",
  "codeBlockKimodo": "import { KimodoAdapter } from \"holomime\";\n\nconst kimodo = new KimodoAdapter();\nconst motion = kimodo.buildMotionRequest(\n  \"Walk to the patient\",\n  personality.big_five,\n  { model: \"G1\" }\n);\n// { prompt: \"Walk to the patient gently\", style: { gentleness: 0.8, precision: 0.9 } }",
  "codeBlock17": "import {\n  // Personality\n  PersonalitySpec, compile, generateSystemPrompt,\n\n  // Identity Stack\n  compileStack, decomposeSpec,\n\n  // Diagnosis\n  diagnose, assess, DiagnosisResult,\n\n  // Therapy\n  runSession, createTreatmentPlan,\n\n  // Training\n  exportDPO, trainOpenAI,\n\n  // Detectors\n  registerDetector, Signal,\n\n  // Adapters\n  ROS2TelemetryIngester, MuJoCoEnvironment,\n  LeRobotAdapter, IsaacSimAdapter, KimodoAdapter,\n\n  // Log Parsers\n  parseConversationLog,\n  parseOpenAIAPILog, parseAnthropicAPILog,\n  parseChatGPTExport, parseClaudeExport,\n\n  // Compliance\n  checkCompliance, generateComplianceReport,\n} from \"holomime\";",
  "codeBlock18": "import {\n  AnthropicProvider,\n  OpenAIProvider,\n  OllamaProvider\n} from \"holomime\";\n\nconst provider = new AnthropicProvider({\n  model: \"claude-3-5-sonnet-20241022\"\n});",
  "codeBlock19": "your-project/\n\u251c\u2500\u2500 AGENTS.md              # Code conventions\n\u251c\u2500\u2500 .personality.json      # Behavioral profile\n\u251c\u2500\u2500 .personality.md        # Human-readable summary\n\u251c\u2500\u2500 .holomime/identity/    # Identity stack files (optional)\n\u2502   \u251c\u2500\u2500 soul.md\n\u2502   \u251c\u2500\u2500 mind.sys\n\u2502   \u251c\u2500\u2500 purpose.cfg\n\u2502   \u251c\u2500\u2500 shadow.log\n\u2502   \u251c\u2500\u2500 memory.store\n\u2502   \u251c\u2500\u2500 body.api\n\u2502   \u251c\u2500\u2500 conscience.exe\n\u2502   \u2514\u2500\u2500 ego.runtime\n\u251c\u2500\u2500 src/\n\u2514\u2500\u2500 package.json",
  "codeBlock20": "{\n  \"mcpServers\": {\n    \"holomime\": {\n      \"command\": \"holomime-mcp\",\n      \"args\": []\n    }\n  }\n}",
};

---




  <main class="pt-24 pb-20">
    <div class="mx-auto max-w-7xl px-6">
      <div class="flex gap-10">
        <!-- Side nav -->
        <nav id="docs-nav" class="hidden lg:block w-[220px] shrink-0">
          <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-[#bbb] mb-3">Documentation</p>
            <ul class="space-y-0.5">
              {navSections.map((s) => (
                <li>
                  <a href={`#${s.id}`} data-nav={s.id} class="block py-1.5 px-3 rounded-md text-[13px] text-[#777] transition-colors hover:text-[#1a1a1a] hover:bg-[#fafafa]">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>

        <!-- Mobile nav -->
        <div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-lg border-t border-[#e5e5e5] px-4 py-2 overflow-x-auto">
          <div class="flex gap-2 min-w-max">
            {navSections.map((s) => (
              <a href={`#${s.id}`} class="px-3 py-1.5 rounded-full text-[11px] font-medium text-[#777] bg-[#fafafa] whitespace-nowrap hover:text-[#1a1a1a]">
                {s.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Content -->
        <div class="flex-1 min-w-0 max-w-4xl">
          <!-- Header -->
          <div class="mb-16">
            <h1 class="text-4xl font-extrabold text-[#1a1a1a] md:text-5xl tracking-[-0.03em]">Documentation</h1>
            <p class="mt-4 text-lg text-[#777] max-w-2xl">
              Everything you need to build, diagnose, train, and deploy behavioral intelligence for AI agents and humanoid robots.
            </p>
          </div>

          <!-- ═══ GETTING STARTED ═══ -->
          <section id="getting-started" class="mb-20 scroll-mt-24">
            <h2 class="text-2xl font-bold text-[#1a1a1a] mb-4">Getting Started</h2>
            <p class="text-[#777] leading-relaxed mb-6">Already have an AI agent or robot? holomime doesn't replace it &mdash; it profiles how your agent should behave, detects drift, and fixes it.</p>

            <!-- Tab buttons -->
            <div class="flex gap-0 mb-6 border-b border-[#e5e5e5]">
              <button class="gs-tab active px-5 py-2.5 text-sm font-semibold transition-colors" data-tab="agents">For agents</button>
              <button class="gs-tab px-5 py-2.5 text-sm font-semibold text-[#999] transition-colors" data-tab="robots">For robots</button>
            </div>

            <!-- Agents tab content -->
            <div class="gs-tab-content" data-tab="agents">
              <div class="space-y-4">
                <div class="doc-card">
                  <h3 class="doc-step">1. Install</h3>
                  <pre class="doc-code"><code>npm install -g holomime</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">2. Configure</h3>
                  <p class="text-sm text-[#777] mb-3">Set your API key. One time only.</p>
                  <pre class="doc-code"><code>holomime config</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">3. Profile your agent</h3>
                  <p class="text-sm text-[#777] mb-3">Define how your existing agent should behave. This is the behavioral target holomime measures against.</p>
                  <pre class="doc-code"><code>holomime personality</code></pre>
                  <p class="text-xs text-[#999] mt-2">Creates <code class="font-mono text-[#8b5cf6]">.personality.json</code> in your project root.</p>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">4. Diagnose</h3>
                  <p class="text-sm text-[#777] mb-3">Point at any conversation log to detect behavioral drift patterns. No LLM needed.</p>
                  <pre class="doc-code"><code>holomime diagnose</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">5. Cure</h3>
                  <p class="text-sm text-[#777] mb-3">Mira runs therapy, exports DPO pairs, and trains the model. One command. The fix is permanent.</p>
                  <pre class="doc-code"><code>holomime cure</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">6. Verify</h3>
                  <p class="text-sm text-[#777] mb-3">Run 8 adversarial scenarios and grade your agent A-F. Proof the fix worked.</p>
                  <pre class="doc-code"><code>holomime benchmark</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">7. Autonomous therapy</h3>
                  <p class="text-sm text-[#777] mb-3">Start Mira for continuous autonomous therapy. She diagnoses, corrects, and trains on her own.</p>
                  <pre class="doc-code"><code>holomime therapy</code></pre>
                  <p class="text-xs text-[#999] mt-2"><code class="font-mono text-[#8b5cf6]">holomime therapy status</code> to check progress. <code class="font-mono text-[#8b5cf6]">holomime therapy stop</code> to end.</p>
                </div>
              </div>
            </div>

            <!-- Robots tab content -->
            <div class="gs-tab-content hidden" data-tab="robots">
              <div class="space-y-4">
                <div class="doc-card">
                  <h3 class="doc-step">1. Install</h3>
                  <pre class="doc-code"><code>npm install -g holomime</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">2. Configure</h3>
                  <p class="text-sm text-[#777] mb-3">Set your API key. One time only.</p>
                  <pre class="doc-code"><code>holomime config</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">3. Create identity</h3>
                  <p class="text-sm text-[#777] mb-3">Generates the full 8-file Identity Stack for your robot.</p>
                  <pre class="doc-code"><code>holomime identity</code></pre>
                  <p class="text-xs text-[#999] mt-2">Creates all 8 files: <code class="font-mono text-[#8b5cf6]">soul.md</code>, <code class="font-mono text-[#8b5cf6]">mind.sys</code>, <code class="font-mono text-[#8b5cf6]">purpose.cfg</code>, <code class="font-mono text-[#8b5cf6]">shadow.log</code>, <code class="font-mono text-[#8b5cf6]">memory.store</code>, <code class="font-mono text-[#8b5cf6]">body.api</code>, <code class="font-mono text-[#8b5cf6]">conscience.exe</code>, <code class="font-mono text-[#8b5cf6]">ego.runtime</code></p>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">4. Certify</h3>
                  <p class="text-sm text-[#777] mb-3">Run behavioral certification against ISO safety and compliance standards.</p>
                  <pre class="doc-code"><code>holomime certify</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">5. Deploy</h3>
                  <p class="text-sm text-[#777] mb-3">Deploy the identity stack to your robot via an adapter (ROS2, gRPC, MQTT, etc.).</p>
                  <pre class="doc-code"><code>holomime embody --adapter ros2</code></pre>
                </div>
                <div class="doc-card">
                  <h3 class="doc-step">6. Monitor</h3>
                  <p class="text-sm text-[#777] mb-3">Detect behavioral drift in production. Run <code class="font-mono">holomime therapy</code> for continuous autonomous therapy.</p>
                  <pre class="doc-code"><code>holomime therapy</code></pre>
                </div>
              </div>
            </div>

            <script is:inline>
              (function() {
                const tabs = document.querySelectorAll('.gs-tab');
                const panels = document.querySelectorAll('.gs-tab-content');

                tabs.forEach(function(tab) {
                  tab.addEventListener('click', function() {
                    var target = tab.getAttribute('data-tab');

                    // Update tab styles
                    tabs.forEach(function(t) {
                      t.classList.remove('active');
                      t.style.color = '#999';
                      t.style.borderBottom = 'none';
                    });
                    tab.classList.add('active');
                    tab.style.color = '#1a1a1a';
                    tab.style.borderBottom = '2px solid #f97066';

                    // Show/hide panels
                    panels.forEach(function(panel) {
                      if (panel.getAttribute('data-tab') === target) {
                        panel.classList.remove('hidden');
                      } else {
                        panel.classList.add('hidden');
                      }
                    });
                  });
                });

                // Set initial active tab styling
                var activeTab = document.querySelector('.gs-tab.active');
                if (activeTab) {
                  activeTab.style.color = '#1a1a1a';
                  activeTab.style.borderBottom = '2px solid #f97066';
                }
              })();
            </script>
          </section>

          <!-- ═══ IDENTITY STACK ═══ -->
          <section id="identity-stack" class="mb-20 scroll-mt-24">
            <h2 class="text-2xl font-bold text-[#1a1a1a] mb-4">Identity Stack</h2>
            <p class="text-[#777] leading-relaxed mb-6">
              Eight files define who your agent is — grounded in Aristotle, Jung, and Freud. They compile into a single <code class="font-mono text-sm text-[#8b5cf6]">personality.json</code>.
            </p>

            <pre class="doc-code mb-8"><code>holomime identity  # Creates all 8 files
holomime compile-stack  # Compiles to .personality.json</code></pre>

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-4">
              <div class="doc-card border-t-[3px] border-t-[#f97066]">
                <div class="font-mono text-sm font-bold">soul.md</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Aristotle — Immutable</div>
                <p class="text-sm text-[#777] mt-2">Core values, ethics, and essence. Markdown with YAML frontmatter. Never auto-modified.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#3b82f6]">
                <div class="font-mono text-sm font-bold">mind.sys</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Jung — Auto-patchable</div>
                <p class="text-sm text-[#777] mt-2">Big Five traits, emotional intelligence, communication style. YAML. Updated by therapy.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#14b8a6]">
                <div class="font-mono text-sm font-bold">purpose.cfg</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Aristotle — Per deployment</div>
                <p class="text-sm text-[#777] mt-2">Role, objectives, domain scope, stakeholders. YAML. Configured per deployment.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#f97316]">
                <div class="font-mono text-sm font-bold">shadow.log</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Jung — Auto-generated</div>
                <p class="text-sm text-[#777] mt-2">Detected drift patterns, blind spots, therapy outcomes. Written by diagnosis, not by humans.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#22c55e]">
                <div class="font-mono text-sm font-bold">memory.store</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Aristotle — Accumulated</div>
                <p class="text-sm text-[#777] mt-2">Learned contexts, interaction patterns, knowledge gained. Grows over time, never reset.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#f59e0b]">
                <div class="font-mono text-sm font-bold">body.api</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Hardware — Swappable</div>
                <p class="text-sm text-[#777] mt-2">Morphology, sensors, safety envelope. JSON. Swap bodies without changing identity.</p>
              </div>

              <div class="doc-card border-t-[3px] border-t-[#8b5cf6]">
                <div class="font-mono text-sm font-bold">conscience.exe</div>
                <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Freud — Never auto-modified</div>
                <p class="text-sm text-[#777] mt-2">Deny, allow, or escalate rules. YAML. Deny always dominates. Human-only changes.</p>
              </div>
            </div>
            <div class="doc-card border-t-[3px] border-t-[#ec4899] mb-8">
              <div class="font-mono text-sm font-bold">ego.runtime</div>
              <div class="text-[10px] font-semibold uppercase tracking-wider text-[#999] mt-0.5">Freud — Runtime mediation</div>
              <p class="text-sm text-[#777] mt-2">Balances purpose against conscience in real-time. Conflict resolution strategy, adaptation rate, response strategy. YAML.</p>
            </div>

            <div class="doc-card">
              <h3 class="doc-step">Decompose an existing personality</h3>
              <p class="text-sm text-[#777] mb-3">Split an existing .personality.json back into 8 identity stack files.</p>
              <pre class="doc-code"><code set:text={'import { decomposeSpec } from "holomime";\nconst stack = decomposeSpec(existingPersonality);\n// stack.soul, stack.mind, stack.purpose, stack.shadow, stack.body, stack.conscience, stack.ego'} /></pre>
            </div>
          </section>

          <!-- ═══ PERSONALITY.JSON ═══ -->
          <section id="personality-json" class="mb-20 scroll-mt-24">
            <h2 class="text-2xl font-bold text-[#1a1a1a] mb-4">personality.json Schema</h2>
