---
---

<footer class="border-t border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-5 lg:grid-cols-6">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1 lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/logo-icon.svg" alt="holomime" class="h-7 w-7" />
          <span class="font-bold text-[var(--color-warm-text)]">holomime</span>
        </a>
        <p class="mt-3 max-w-xs text-sm text-[var(--color-warm-muted)]">
          Behavioral alignment for AI agents.
        </p>
        <div class="mt-4 flex items-center gap-4">
          <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]" aria-label="GitHub">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://x.com/holomimeIQ" target="_blank" rel="noopener" class="text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]" aria-label="X / Twitter">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.npmjs.com/package/holomime" target="_blank" rel="noopener" class="text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]" aria-label="npm">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331zM10.665 10H12v2.667h-1.335V10z"/></svg>
          </a>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-warm-text)]">Product</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-warm-muted)]">
          <li><a href="/demo" class="transition-colors hover:text-[var(--color-warm-text)]">Live Demo</a></li>
          <li><a href="/voice" class="transition-colors hover:text-[var(--color-warm-text)]">Voice Demo</a></li>
          <li><a href="/mcp" class="transition-colors hover:text-[var(--color-warm-text)]">MCP Server</a></li>
          <li><a href="/#pricing" class="transition-colors hover:text-[var(--color-warm-text)]">Pricing</a></li>
        </ul>
      </div>

      <!-- Research -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-warm-text)]">Research</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-warm-muted)]">
          <li><a href="/leaderboard" class="transition-colors hover:text-[var(--color-warm-text)]">Leaderboard</a></li>
          <li><a href="/benchmarks" class="transition-colors hover:text-[var(--color-warm-text)]">Benchmarks</a></li>
          <li><a href="/docs" class="transition-colors hover:text-[var(--color-warm-text)]">Documentation</a></li>
          <li><a href="/api-docs" class="transition-colors hover:text-[var(--color-warm-text)]">API Reference</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-warm-text)]">Company</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-warm-muted)]">
          <li><a href="/blog" class="transition-colors hover:text-[var(--color-warm-text)]">Blog</a></li>
          <li><a href="/research" class="transition-colors hover:text-[var(--color-warm-text)]">Research</a></li>
          <li><a href="/contact" class="transition-colors hover:text-[var(--color-warm-text)]">Contact</a></li>
        </ul>
      </div>

      <!-- Legal (on larger screens) -->
      <div class="hidden lg:block">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-warm-text)]">Legal</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-[var(--color-warm-muted)]">
          <li><a href="/terms" class="transition-colors hover:text-[var(--color-warm-text)]">Terms of Service</a></li>
          <li><a href="/privacy" class="transition-colors hover:text-[var(--color-warm-text)]">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-[var(--color-warm-border)] pt-8 sm:flex-row">
      <p class="text-xs text-[var(--color-warm-muted)]">
        &copy; {new Date().getFullYear()} holomime. All rights reserved.
      </p>
      <div class="flex items-center gap-6 text-xs text-[var(--color-warm-muted)] lg:hidden">
        <a href="/terms" class="transition-colors hover:text-[var(--color-warm-text)]">Terms</a>
        <a href="/privacy" class="transition-colors hover:text-[var(--color-warm-text)]">Privacy</a>
      </div>
    </div>
  </div>
</footer>
