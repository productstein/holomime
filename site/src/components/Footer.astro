---
---

<footer class="relative bg-white pt-16 pb-12">
  <!-- Gradient top border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-[#f97066] via-[#f59e0b] to-[#8b5cf6] opacity-40"></div>

  <div class="mx-auto max-w-6xl px-6">
    <!-- Brand + trust metrics -->
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6 mb-14">
      <div>
        <a href="/" class="flex items-center gap-2.5">
          <img src="/logo-icon.svg" alt="holomime" class="h-7 w-7" />
          <span class="text-[15px] font-bold text-[#1a1a1a] tracking-[-0.02em]">holomime</span>
        </a>
        <p class="mt-2.5 text-[13px] text-[#888] max-w-xs leading-relaxed">
          Train the mind. Deploy the body.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-[11px] font-mono text-[#bbb] tracking-wide">
        <span>2,000+ DPO Pairs</span>
        <span class="hidden sm:inline text-[#e5e5e5]">/</span>
        <span>14 Detectors</span>
        <span class="hidden sm:inline text-[#e5e5e5]">/</span>
        <span>8 Body Templates</span>
        <span class="hidden sm:inline text-[#e5e5e5]">/</span>
        <span>MIT Licensed</span>
      </div>
    </div>

    <!-- Link columns -->
    <div class="grid grid-cols-2 gap-10 sm:grid-cols-4">
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Product</h4>
        <ul class="mt-4 space-y-3.5">
          <li><a href="/pricing" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Pricing</a></li>
          <li><a href="/brain" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">NeuralSpace</a></li>
          <li><a href="/demo" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Live Demo</a></li>
          <li><a href="/mcp" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">MCP Server</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Resources</h4>
        <ul class="mt-4 space-y-3.5">
          <li><a href="/docs" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Documentation</a></li>
          <li><a href="/blog" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Blog</a></li>
          <li><a href="/benchmarks" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Benchmarks</a></li>
          <li><a href="/whitepaper" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Whitepaper</a></li>
          <li><a href="/manifesto" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Manifesto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Company</h4>
        <ul class="mt-4 space-y-3.5">
          <li><a href="/contact" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Contact Sales</a></li>
          <li><a href="/research" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Research</a></li>
          <li><a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">GitHub</a></li>
          <li><a href="https://www.npmjs.com/package/holomime" target="_blank" rel="noopener" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">npm</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.08em] text-[#999]">Legal</h4>
        <ul class="mt-4 space-y-3.5">
          <li><a href="/terms" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Terms of Service</a></li>
          <li><a href="/privacy" class="text-[13px] text-[#555] transition-colors hover:text-[#1a1a1a]">Privacy Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 flex items-center justify-between border-t border-[#eee] pt-8">
      <p class="text-[11px] text-[#ccc]">
        &copy; {new Date().getFullYear()} holomime, Inc.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[#ccc] transition-colors hover:text-[#888]" aria-label="GitHub">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://x.com/holomimeIQ" target="_blank" rel="noopener" class="text-[#ccc] transition-colors hover:text-[#888]" aria-label="X">
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
