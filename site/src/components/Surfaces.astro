---
/**
 * Surfaces — Three compilation targets from one .personality.json.
 * Chat/API (text), Voice (prosody + personality-tuned TTS), Embodied (motion + gaze + haptics).
 * Replaces the VoiceAI-only section with the full surface story.
 */
---

<section class="relative overflow-hidden py-16 md:py-20">
  <!-- Background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-p-coral)]/[0.03] to-transparent"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[800px] rounded-full bg-[var(--color-p-coral)] opacity-[0.04] blur-[150px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="text-center">
      <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
        One Spec, Three Surfaces
      </p>
      <h2 class="mt-3 text-3xl font-extrabold text-[var(--color-warm-text)] md:text-4xl">
        Same personality. <span class="text-gradient-warm">Every surface.</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-[var(--color-warm-muted)]">
        <code class="rounded bg-[var(--color-warm-cream)] border border-[var(--color-warm-sand)] px-1.5 py-0.5 text-xs font-mono text-[var(--color-p-violet)]">.personality.json</code>
        compiles to text behavior, voice presence, and physical motion. One identity file. Three compilation targets. Consistent behavior across every modality.
      </p>
    </div>

    <!-- Three cards -->
    <div class="mt-16 grid gap-6 md:grid-cols-3">

      <!-- Card 1: Chat & API -->
      <div class="group relative overflow-hidden rounded-3xl border border-[var(--color-warm-sand)] bg-white shadow-sm transition-all hover:shadow-xl">
        <div class="h-2 bg-gradient-to-r from-[var(--color-p-violet)] to-[var(--color-p-blue)]"></div>
        <div class="p-7">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-violet)]/20 bg-[var(--color-p-violet)]/5 px-3 py-1 text-xs font-semibold text-[var(--color-p-violet)]">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
            Available Now
          </div>
          <h3 class="text-xl font-bold text-[var(--color-warm-text)]">Chat & API</h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
            System prompts, temperature, top_p, and max_tokens tuned to personality. Deploy to Claude, GPT, Gemini, or Ollama. Same agent, consistent behavior, any provider.
          </p>

          <!-- Terminal mockup -->
          <div class="mt-5 rounded-xl bg-[var(--color-holo-slate)] p-4 font-mono text-[11px]">
            <p class="text-slate-500">$ holomime compile --surface chat</p>
            <p class="mt-1.5 text-slate-300">temperature: <span class="text-[var(--color-p-violet)]">0.742</span></p>
            <p class="text-slate-300">top_p: <span class="text-[var(--color-p-violet)]">0.871</span></p>
            <p class="text-slate-300">system_prompt: <span class="text-[var(--color-p-sage)]">2,847 chars</span></p>
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Anthropic</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">OpenAI</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Gemini</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Ollama</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Voice -->
      <div class="group relative overflow-hidden rounded-3xl border border-[var(--color-warm-sand)] bg-white shadow-sm transition-all hover:shadow-xl">
        <div class="h-2 bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)]"></div>
        <div class="p-7">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-coral)]/20 bg-[var(--color-p-coral)]/5 px-3 py-1 text-xs font-semibold text-[var(--color-p-coral)]">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
            Live Demo
          </div>
          <h3 class="text-xl font-bold text-[var(--color-warm-text)]">Voice</h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
            14 personality-tuned voices. Warm and measured for the Counselor. Punchy and direct for the Leader. Real-time behavioral monitoring of every call.
          </p>

          <!-- Waveform visualization -->
          <div class="mt-5 flex items-center justify-center gap-[3px] h-14 rounded-xl bg-[var(--color-warm-cream)] px-4">
            {Array.from({ length: 32 }).map((_, i) => {
              const h = 15 + Math.sin(i * 0.4) * 25 + Math.random() * 20;
              return <div class="w-1 rounded-full bg-gradient-to-t from-[var(--color-p-coral)] to-[var(--color-p-violet)] voice-bar" style={`height: ${h}%; animation-delay: ${i * 0.05}s;`}></div>;
            })}
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">LiveKit</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Cartesia</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">ElevenLabs</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Vapi</span>
          </div>

          <a
            href="/voice"
            class="btn-primary mt-5 inline-flex items-center gap-2 rounded-full"
          >
            Try Voice Demo
          </a>
        </div>
      </div>

      <!-- Card 3: Embodied -->
      <div class="group relative overflow-hidden rounded-3xl border border-[var(--color-warm-sand)] bg-white shadow-sm transition-all hover:shadow-xl">
        <div class="h-2 bg-gradient-to-r from-[var(--color-p-sage)] to-[#14b8a6]"></div>
        <div class="p-7">
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-sage)]/20 bg-[var(--color-p-sage)]/5 px-3 py-1 text-xs font-semibold text-[var(--color-p-sage)]">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
            New
          </div>
          <h3 class="text-xl font-bold text-[var(--color-warm-text)]">Embodied</h3>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
            Big Five maps to 18 motion parameters: gesture speed, postural openness, gaze contact, approach distance. The personality layer for humanoid robots.
          </p>

          <!-- Motion parameters visualization -->
          <div class="mt-5 rounded-xl bg-[var(--color-holo-slate)] p-4 font-mono text-[11px]">
            <p class="text-slate-500">$ holomime compile --surface embodied</p>
            <div class="mt-2 space-y-1.5">
              <div class="flex items-center gap-2">
                <span class="text-slate-400 w-[110px]">gesture speed</span>
                <div class="flex-1 h-2 rounded-full bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--color-p-sage)] to-[#14b8a6]" style="width: 62%;"></div>
                </div>
                <span class="text-[var(--color-p-sage)] w-8 text-right">0.62</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-slate-400 w-[110px]">postural open</span>
                <div class="flex-1 h-2 rounded-full bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--color-p-sage)] to-[#14b8a6]" style="width: 78%;"></div>
                </div>
                <span class="text-[var(--color-p-sage)] w-8 text-right">0.78</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-slate-400 w-[110px]">smile freq</span>
                <div class="flex-1 h-2 rounded-full bg-slate-700 overflow-hidden">
                  <div class="h-full rounded-full bg-gradient-to-r from-[var(--color-p-sage)] to-[#14b8a6]" style="width: 71%;"></div>
                </div>
                <span class="text-[var(--color-p-sage)] w-8 text-right">0.71</span>
              </div>
            </div>
          </div>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Gesture</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Gaze</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Proxemics</span>
            <span class="rounded-full bg-[var(--color-warm-cream)] px-2.5 py-1 text-[10px] font-medium text-[var(--color-warm-muted)]">Haptics</span>
          </div>

          <a
            href="/blog/personality-as-soul"
            class="mt-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-sage)]/30 bg-[var(--color-p-sage)]/5 px-5 py-2.5 text-sm font-semibold text-[var(--color-p-sage)] transition-all hover:bg-[var(--color-p-sage)]/10"
          >
            Read the vision
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .voice-bar {
    animation: barPulse 1.5s ease-in-out infinite alternate;
  }
  @keyframes barPulse {
    0% { transform: scaleY(0.6); opacity: 0.5; }
    100% { transform: scaleY(1); opacity: 1; }
  }
</style>
