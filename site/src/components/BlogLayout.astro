---
import Layout from "../layouts/Layout.astro";
import Nav from "./Nav.astro";
import Footer from "./Footer.astro";

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime?: string;
}

const { title, description, date, category, readTime } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} | holomime Blog`} description={description}>
  <Nav />
  <main class="pt-32 pb-20">
    <article class="mx-auto max-w-3xl px-6">
      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-[var(--color-p-violet)]/10 text-[var(--color-p-violet)] border border-[var(--color-p-violet)]/20">
            {category}
          </span>
          <span class="text-sm text-[var(--color-warm-muted)]">{formattedDate}</span>
          {readTime && <span class="text-sm text-[var(--color-warm-muted)]">&middot; {readTime}</span>}
        </div>
        <h1 class="text-3xl font-extrabold text-[var(--color-warm-text)] md:text-4xl leading-tight">
          {title}
        </h1>
        <p class="mt-4 text-lg text-[var(--color-warm-muted)]">{description}</p>
      </div>

      <!-- Article content -->
      <div class="prose-warm">
        <slot />
      </div>

      <!-- Footer CTA -->
      <div class="mt-16 pt-8 border-t border-[var(--color-warm-border)]">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="flex-1">
            <p class="font-bold text-[var(--color-warm-text)]">Ready to align your agents?</p>
            <p class="text-sm text-[var(--color-warm-muted)]">Install holomime and create your first personality spec in 60 seconds.</p>
          </div>
          <a href="/#pricing" class="rounded-full bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-[var(--color-p-coral)]/20 transition-all hover:shadow-xl hover:scale-[1.02]">
            Get Started
          </a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* Prose styling for blog content using warm design tokens */
  .prose-warm :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-warm-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-warm :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-warm-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-warm :global(p) {
    color: var(--color-warm-muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .prose-warm :global(a) {
    color: var(--color-p-violet);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-warm :global(a:hover) {
    color: var(--color-p-coral);
  }
  .prose-warm :global(ul), .prose-warm :global(ol) {
    color: var(--color-warm-muted);
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-warm :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
  }
  .prose-warm :global(strong) {
    color: var(--color-warm-text);
    font-weight: 600;
  }
  .prose-warm :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-warm-cream);
    border: 1px solid var(--color-warm-sand);
    border-radius: 0.25rem;
    padding: 0.125rem 0.375rem;
    color: var(--color-p-violet);
  }
  .prose-warm :global(pre) {
    background: var(--color-holo-slate);
    border: 1px solid var(--color-holo-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose-warm :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #e2e8f0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }
  .prose-warm :global(blockquote) {
    border-left: 3px solid var(--color-p-violet);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-warm-muted);
  }
  .prose-warm :global(hr) {
    border: none;
    border-top: 1px solid var(--color-warm-border);
    margin: 2rem 0;
  }
  .prose-warm :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .prose-warm :global(th) {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 2px solid var(--color-warm-sand);
    color: var(--color-warm-text);
    font-weight: 600;
  }
  .prose-warm :global(td) {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-warm-sand);
    color: var(--color-warm-muted);
  }
</style>
