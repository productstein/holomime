---
const cards = [
  {
    file: "soul.md",
    philosopher: "Aristotle",
    description: "Immutable values, ethics, and purpose. What this agent stands for.",
    color: "var(--color-p-coral)",
    colorSoft: "var(--color-p-coral-soft)",
  },
  {
    file: "psyche.sys",
    philosopher: "Jung",
    description: "Big Five personality traits, emotional intelligence, communication style.",
    color: "var(--color-p-blue)",
    colorSoft: "var(--color-p-blue-soft)",
  },
  {
    file: "body.api",
    philosopher: "Hardware",
    description: "Morphology, sensors, safety envelope. Swap across any robot.",
    color: "var(--color-p-gold)",
    colorSoft: "var(--color-p-gold-soft)",
  },
  {
    file: "conscience.exe",
    philosopher: "Freud",
    description: "Moral enforcement layer. Deny, allow, or escalate at the action boundary.",
    color: "var(--color-p-violet)",
    colorSoft: "var(--color-p-violet-soft)",
  },
];
---

<section id="identity-stack" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      Architecture
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      The Identity Stack
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      Every agent needs more than a system prompt. Every robot needs more than locomotion.
    </p>

    <!-- Layout: cards + humanoid diagram -->
    <div class="mt-14 flex flex-col lg:flex-row gap-12 items-start">

      <!-- Left: 4 Cards in 2x2 grid -->
      <div class="flex-1 grid gap-6 sm:grid-cols-2">
        {cards.map((c) => (
          <div class="personality-card relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
            <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${c.color};`}></div>
            <div class="font-mono text-lg font-bold text-[var(--color-warm-text)] mt-2">
              {c.file}
            </div>
            <div class="mt-1 text-xs font-medium uppercase tracking-wider text-[var(--color-warm-muted)]">
              {c.philosopher}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
              {c.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Right: Humanoid diagram (desktop only) -->
      <div class="hidden lg:flex flex-col items-center justify-center w-64 shrink-0">
        <svg viewBox="0 0 200 360" class="w-48 h-auto" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Conscience: outer shield/halo -->
          <ellipse cx="100" cy="170" rx="85" ry="155" stroke="var(--color-p-violet)" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.5" />

          <!-- Body: full figure outline -->
          <!-- Head -->
          <circle cx="100" cy="52" r="26" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Neck -->
          <line x1="100" y1="78" x2="100" y2="92" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Torso -->
          <rect x="68" y="92" width="64" height="80" rx="8" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Left arm -->
          <line x1="68" y1="100" x2="38" y2="150" stroke="var(--color-p-gold)" stroke-width="2" />
          <line x1="38" y1="150" x2="30" y2="190" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Right arm -->
          <line x1="132" y1="100" x2="162" y2="150" stroke="var(--color-p-gold)" stroke-width="2" />
          <line x1="162" y1="150" x2="170" y2="190" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Left leg -->
          <line x1="82" y1="172" x2="75" y2="250" stroke="var(--color-p-gold)" stroke-width="2" />
          <line x1="75" y1="250" x2="70" y2="320" stroke="var(--color-p-gold)" stroke-width="2" />
          <!-- Right leg -->
          <line x1="118" y1="172" x2="125" y2="250" stroke="var(--color-p-gold)" stroke-width="2" />
          <line x1="125" y1="250" x2="130" y2="320" stroke="var(--color-p-gold)" stroke-width="2" />

          <!-- Soul: brain glow in head -->
          <circle cx="100" cy="48" r="14" fill="var(--color-p-coral)" opacity="0.15" />
          <circle cx="100" cy="48" r="8" fill="var(--color-p-coral)" opacity="0.3" />

          <!-- Psyche: heart glow in chest -->
          <circle cx="100" cy="120" r="16" fill="var(--color-p-blue)" opacity="0.15" />
          <circle cx="100" cy="120" r="9" fill="var(--color-p-blue)" opacity="0.3" />
        </svg>

        <!-- Labels -->
        <div class="mt-6 space-y-2 text-center">
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-coral);"></span>
            <span class="text-[var(--color-warm-muted)]">soul — brain</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-blue);"></span>
            <span class="text-[var(--color-warm-muted)]">psyche — heart</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-gold);"></span>
            <span class="text-[var(--color-warm-muted)]">body — form</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-violet);"></span>
            <span class="text-[var(--color-warm-muted)]">conscience — shield</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Compile arrow -->
    <div class="mt-10 flex flex-col items-center gap-3">
      <svg class="h-10 w-10 text-[var(--color-warm-muted)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
      <div class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-warm-sand)] bg-white px-5 py-3 shadow-sm">
        <span class="font-mono text-sm font-bold text-[var(--color-warm-text)]">.personality.json</span>
        <span class="text-xs text-[var(--color-warm-muted)]">compiled output</span>
      </div>
    </div>
  </div>
</section>
