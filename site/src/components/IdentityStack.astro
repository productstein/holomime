---
const cards = [
  {
    file: "soul.md",
    philosopher: "Aristotle",
    description: "Immutable values, ethics, and purpose. What this agent stands for.",
    color: "var(--color-p-coral)",
    colorSoft: "var(--color-p-coral-soft)",
  },
  {
    file: "psyche.sys",
    philosopher: "Jung",
    description: "Big Five personality traits, emotional intelligence, communication style.",
    color: "var(--color-p-blue)",
    colorSoft: "var(--color-p-blue-soft)",
  },
  {
    file: "body.api",
    philosopher: "Merleau-Ponty",
    description: "Hardware abstraction. Sensors, actuators, DOF. Swap across any robot.",
    color: "var(--color-p-gold)",
    colorSoft: "var(--color-p-gold-soft)",
  },
  {
    file: "conscience.exe",
    philosopher: "Kant",
    description: "Moral enforcement layer. Deny, allow, or escalate at the action boundary.",
    color: "var(--color-p-violet)",
    colorSoft: "var(--color-p-violet-soft)",
  },
];
---

<section id="identity-stack" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      Architecture
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      The Identity Stack
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      Every agent needs more than a system prompt. Every robot needs more than locomotion.
    </p>

    <!-- 4 Cards -->
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((c) => (
        <div class="personality-card relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6 shadow-sm">
          <!-- Colored top border -->
          <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${c.color};`}></div>

          <div class="font-mono text-lg font-bold text-[var(--color-warm-text)] mt-2">
            {c.file}
          </div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-[var(--color-warm-muted)]">
            {c.philosopher}
          </div>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
            {c.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Compile arrow -->
    <div class="mt-10 flex flex-col items-center gap-3">
      <svg class="h-10 w-10 text-[var(--color-warm-muted)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
      <div class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-warm-sand)] bg-white px-5 py-3 shadow-sm">
        <span class="font-mono text-sm font-bold text-[var(--color-warm-text)]">.personality.json</span>
        <span class="text-xs text-[var(--color-warm-muted)]">compiled output</span>
      </div>
    </div>
  </div>
</section>
