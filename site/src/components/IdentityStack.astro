---
const cards = [
  {
    file: "soul.md",
    label: "Aristotle",
    desc: "Immutable values, ethics, and purpose.",
    color: "var(--color-p-coral)",
    border: "#f97066",
  },
  {
    file: "psyche.sys",
    label: "Jung",
    desc: "Big Five traits, emotional intelligence, communication style.",
    color: "var(--color-p-blue)",
    border: "#3b82f6",
  },
  {
    file: "body.api",
    label: "Hardware",
    desc: "Morphology, sensors, safety envelope. Swap across any form factor.",
    color: "var(--color-p-gold)",
    border: "#f59e0b",
  },
  {
    file: "conscience.exe",
    label: "Freud",
    desc: "Moral enforcement. Deny, allow, or escalate at the boundary.",
    color: "var(--color-p-violet)",
    border: "#8b5cf6",
  },
];
---

<section id="identity-stack" class="py-16 md:py-24 bg-white">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-2xl font-bold text-[var(--color-warm-text)] md:text-3xl">
      The Identity Stack
    </h2>
    <p class="mt-2 max-w-lg text-sm text-[var(--color-warm-muted)] leading-relaxed">
      Four files define who your agent is. They compile into a single <code class="font-mono text-xs bg-[var(--color-warm-sand)]/50 px-1.5 py-0.5 rounded">.personality.json</code>.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((c) => (
        <div
          class="group relative rounded-lg p-5 transition-all duration-200 hover:shadow-lg"
          style={`border-left: 3px solid ${c.border}; background: white; border-top: 1px solid var(--color-warm-border); border-right: 1px solid var(--color-warm-border); border-bottom: 1px solid var(--color-warm-border);`}
        >
          <div class="font-mono text-sm font-bold text-[var(--color-warm-text)]">{c.file}</div>
          <div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-[var(--color-warm-muted)]">{c.label}</div>
          <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-warm-muted)]">{c.desc}</p>
        </div>
      ))}
    </div>

    <!-- Compile indicator -->
    <div class="mt-6 flex items-center gap-3 text-[var(--color-warm-muted)]">
      <div class="h-px flex-1 bg-[var(--color-warm-border)]"></div>
      <span class="font-mono text-xs">compile</span>
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      <code class="font-mono text-xs font-semibold text-[var(--color-warm-text)]">.personality.json</code>
      <div class="h-px flex-1 bg-[var(--color-warm-border)]"></div>
    </div>
  </div>
</section>
