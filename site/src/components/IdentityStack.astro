---
const cards = [
  {
    file: "soul.md",
    philosopher: "Aristotle",
    description: "Immutable values, ethics, and purpose. What this agent stands for.",
    color: "var(--color-p-coral)",
    colorSoft: "var(--color-p-coral-soft)",
    glowClass: "glow-coral",
  },
  {
    file: "psyche.sys",
    philosopher: "Jung",
    description: "Big Five personality traits, emotional intelligence, communication style.",
    color: "var(--color-p-blue)",
    colorSoft: "var(--color-p-blue-soft)",
    glowClass: "glow-blue",
  },
  {
    file: "body.api",
    philosopher: "Hardware",
    description: "Morphology, sensors, safety envelope. Swap across any robot.",
    color: "var(--color-p-gold)",
    colorSoft: "var(--color-p-gold-soft)",
    glowClass: "glow-gold",
  },
  {
    file: "conscience.exe",
    philosopher: "Freud",
    description: "Moral enforcement layer. Deny, allow, or escalate at the action boundary.",
    color: "var(--color-p-violet)",
    colorSoft: "var(--color-p-violet-soft)",
    glowClass: "glow-violet",
  },
];

// Dense particle cloud humanoid — ~450 dots
// Monochrome with varying opacity and size for depth
// Seeded pseudo-random for consistent rendering
function seededRandom(seed: number) {
  let s = seed;
  return () => { s = (s * 16807 + 0) % 2147483647; return s / 2147483647; };
}

type CloudDot = { cx: number; cy: number; r: number; opacity: number; pulse: boolean; delay: string };

const dots: CloudDot[] = [];
const rng = seededRandom(42);

// Helper: scatter dots along a path with density control
function scatterLine(x1: number, y1: number, x2: number, y2: number, count: number, spread: number) {
  for (let i = 0; i < count; i++) {
    const t = i / (count - 1);
    const cx = x1 + (x2 - x1) * t + (rng() - 0.5) * spread;
    const cy = y1 + (y2 - y1) * t + (rng() - 0.5) * spread;
    const r = 0.6 + rng() * 1.4;
    const opacity = 0.2 + rng() * 0.5;
    dots.push({ cx: Math.round(cx * 10) / 10, cy: Math.round(cy * 10) / 10, r: Math.round(r * 10) / 10, opacity: Math.round(opacity * 100) / 100, pulse: false, delay: '0s' });
  }
}

// Helper: fill an ellipse region with scattered dots
function fillEllipse(cx: number, cy: number, rx: number, ry: number, count: number) {
  for (let i = 0; i < count; i++) {
    const angle = rng() * Math.PI * 2;
    const dist = Math.sqrt(rng());
    const x = cx + Math.cos(angle) * rx * dist;
    const y = cy + Math.sin(angle) * ry * dist;
    const edgeDist = dist;
    const r = 0.5 + rng() * 1.2;
    const opacity = edgeDist > 0.7 ? 0.35 + rng() * 0.35 : 0.15 + rng() * 0.25;
    dots.push({ cx: Math.round(x * 10) / 10, cy: Math.round(y * 10) / 10, r: Math.round(r * 10) / 10, opacity: Math.round(opacity * 100) / 100, pulse: false, delay: '0s' });
  }
}

// Helper: outline an ellipse
function outlineEllipse(cx: number, cy: number, rx: number, ry: number, count: number) {
  for (let i = 0; i < count; i++) {
    const angle = (i / count) * Math.PI * 2;
    const x = cx + Math.cos(angle) * rx + (rng() - 0.5) * 2;
    const y = cy + Math.sin(angle) * ry + (rng() - 0.5) * 2;
    const r = 0.7 + rng() * 1.0;
    dots.push({ cx: Math.round(x * 10) / 10, cy: Math.round(y * 10) / 10, r: Math.round(r * 10) / 10, opacity: 0.4 + rng() * 0.3, pulse: false, delay: '0s' });
  }
}

// HEAD — oval, detailed
outlineEllipse(100, 32, 22, 28, 30);
fillEllipse(100, 32, 18, 24, 25);
// Eyes
fillEllipse(90, 28, 4, 3, 6);
fillEllipse(110, 28, 4, 3, 6);

// NECK
scatterLine(100, 58, 100, 72, 8, 6);
scatterLine(94, 60, 94, 70, 5, 3);
scatterLine(106, 60, 106, 70, 5, 3);

// SHOULDERS
scatterLine(72, 78, 100, 74, 18, 4);
scatterLine(100, 74, 128, 78, 18, 4);
// Shoulder joints
outlineEllipse(68, 80, 8, 8, 12);
outlineEllipse(132, 80, 8, 8, 12);

// TORSO — rectangular with panel detail
outlineEllipse(100, 108, 30, 36, 40);
fillEllipse(100, 108, 26, 32, 35);
// Chest plates (panel lines)
scatterLine(78, 85, 100, 82, 10, 2);
scatterLine(100, 82, 122, 85, 10, 2);
scatterLine(78, 100, 122, 100, 12, 2);
// Center line
scatterLine(100, 78, 100, 140, 15, 1.5);

// UPPER ARMS
scatterLine(60, 84, 46, 130, 18, 5);
scatterLine(140, 84, 154, 130, 18, 5);

// ELBOWS
outlineEllipse(44, 132, 6, 6, 10);
outlineEllipse(156, 132, 6, 6, 10);

// FOREARMS
scatterLine(42, 138, 36, 180, 16, 4);
scatterLine(158, 138, 164, 180, 16, 4);

// HANDS
fillEllipse(34, 184, 6, 8, 10);
fillEllipse(166, 184, 6, 8, 10);

// HIP / WAIST
scatterLine(80, 142, 120, 142, 14, 3);
outlineEllipse(100, 148, 22, 8, 16);

// HIP JOINTS
outlineEllipse(84, 154, 7, 7, 10);
outlineEllipse(116, 154, 7, 7, 10);

// UPPER LEGS
scatterLine(82, 160, 78, 220, 22, 5);
scatterLine(118, 160, 122, 220, 22, 5);

// KNEES
outlineEllipse(76, 224, 7, 7, 12);
outlineEllipse(124, 224, 7, 7, 12);

// LOWER LEGS
scatterLine(74, 232, 72, 290, 20, 4);
scatterLine(126, 232, 128, 290, 20, 4);

// FEET
fillEllipse(68, 296, 10, 5, 8);
fillEllipse(132, 296, 10, 5, 8);

// Add subtle pulse to ~20 random dots
let pulseCount = 0;
for (let i = 0; i < dots.length && pulseCount < 20; i++) {
  if (rng() < 0.05) {
    dots[i].pulse = true;
    dots[i].delay = `${(pulseCount * 0.35).toFixed(1)}s`;
    pulseCount++;
  }
}
---

<section id="identity-stack" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      Architecture
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      The Identity Stack
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      Every agent needs more than a system prompt. Every robot needs more than locomotion.
    </p>

    <!-- Layout: cards + humanoid diagram -->
    <div class="mt-14 flex flex-col lg:flex-row gap-12 items-start">

      <!-- Left: 4 Cards in 2x2 grid -->
      <div class="flex-1 grid gap-6 sm:grid-cols-2">
        {cards.map((c) => (
          <div class={`personality-card ${c.glowClass} relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] glass-card p-6 shadow-sm`}>
            <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${c.color};`}></div>
            <div class="font-mono text-lg font-bold text-[var(--color-warm-text)] mt-2">
              {c.file}
            </div>
            <div class="mt-1 text-xs font-medium uppercase tracking-wider text-[var(--color-warm-muted)]">
              {c.philosopher}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
              {c.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Right: Dense particle cloud humanoid (desktop only) -->
      <div class="hidden lg:flex flex-col items-center justify-center w-72 shrink-0">
        <svg viewBox="0 0 200 310" class="w-56 h-auto" xmlns="http://www.w3.org/2000/svg">
          {dots.map((d) => (
            <circle
              cx={d.cx}
              cy={d.cy}
              r={d.r}
              fill="var(--color-warm-text)"
              opacity={d.opacity}
              class={d.pulse ? 'cloud-pulse' : ''}
              style={d.pulse ? `animation-delay: ${d.delay};` : ''}
            />
          ))}
        </svg>

        <!-- Identity legend -->
        <div class="mt-6 flex flex-wrap justify-center gap-x-4 gap-y-2">
          <div class="flex items-center gap-1.5 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-coral);"></span>
            <span class="text-[var(--color-warm-muted)]">soul</span>
          </div>
          <div class="flex items-center gap-1.5 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-blue);"></span>
            <span class="text-[var(--color-warm-muted)]">psyche</span>
          </div>
          <div class="flex items-center gap-1.5 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-gold);"></span>
            <span class="text-[var(--color-warm-muted)]">body</span>
          </div>
          <div class="flex items-center gap-1.5 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-violet);"></span>
            <span class="text-[var(--color-warm-muted)]">conscience</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Compile arrow -->
    <div class="mt-10 flex flex-col items-center gap-3">
      <svg class="h-10 w-10 text-[var(--color-warm-muted)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
      <div class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-warm-sand)] bg-white px-5 py-3 shadow-sm">
        <span class="font-mono text-sm font-bold text-[var(--color-warm-text)]">.personality.json</span>
        <span class="text-xs text-[var(--color-warm-muted)]">compiled output</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cloud-pulse {
    animation: cloudPulse 3.5s ease-in-out infinite;
  }

  @keyframes cloudPulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.7; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cloud-pulse { animation: none !important; }
  }
</style>
