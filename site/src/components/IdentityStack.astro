---
const cards = [
  {
    file: "soul.md",
    philosopher: "Aristotle",
    description: "Immutable values, ethics, and purpose. What this agent stands for.",
    color: "var(--color-p-coral)",
    colorSoft: "var(--color-p-coral-soft)",
    glowClass: "glow-coral",
  },
  {
    file: "psyche.sys",
    philosopher: "Jung",
    description: "Big Five personality traits, emotional intelligence, communication style.",
    color: "var(--color-p-blue)",
    colorSoft: "var(--color-p-blue-soft)",
    glowClass: "glow-blue",
  },
  {
    file: "body.api",
    philosopher: "Hardware",
    description: "Morphology, sensors, safety envelope. Swap across any robot.",
    color: "var(--color-p-gold)",
    colorSoft: "var(--color-p-gold-soft)",
    glowClass: "glow-gold",
  },
  {
    file: "conscience.exe",
    philosopher: "Freud",
    description: "Moral enforcement layer. Deny, allow, or escalate at the action boundary.",
    color: "var(--color-p-violet)",
    colorSoft: "var(--color-p-violet-soft)",
    glowClass: "glow-violet",
  },
];

// Dot-matrix humanoid figure — ~75 dots
// Coordinates are [x, y, color, hasPulse, pulseDelay]
// Colors: coral (head), gold (neck/arms/legs), blue (torso), violet (shield)
const headDots = [
  [88,8],[100,4],[112,8],[84,18],[96,14],[108,14],[116,18],[84,28],[96,24],[108,24],[116,28],[100,32]
];
const neckDots = [
  [100,42],[100,52],[100,62]
];
const torsoDots = [
  [76,72],[88,72],[100,72],[112,72],[124,72],
  [76,84],[88,84],[100,84],[112,84],[124,84],
  [76,96],[88,96],[100,96],[112,96],[124,96],
  [76,108],[88,108],[100,108],[112,108],[124,108],
];
const leftArmDots = [
  [68,76],[58,86],[48,96],[40,108],[34,120],[30,132],[28,144],[26,156]
];
const rightArmDots = [
  [132,76],[142,86],[152,96],[160,108],[166,120],[170,132],[172,144],[174,156]
];
const leftLegDots = [
  [88,122],[84,136],[80,150],[76,164],[74,178],[72,192],[70,206],[68,220],[66,234],[64,248]
];
const rightLegDots = [
  [112,122],[116,136],[120,150],[124,164],[126,178],[128,192],[130,206],[132,220],[134,234],[136,248]
];

// Shield dots — large dashed circle around figure
const shieldDots: [number, number][] = [];
for (let i = 0; i < 16; i++) {
  const angle = (i / 16) * Math.PI * 2 - Math.PI / 2;
  const cx = 100 + Math.cos(angle) * 90;
  const cy = 140 + Math.sin(angle) * 130;
  shieldDots.push([Math.round(cx), Math.round(cy)]);
}

type Dot = { x: number; y: number; color: string; glow: string; pulse: boolean; delay: string };

const allDots: Dot[] = [
  ...headDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-coral)', glow: 'rgba(249,112,102,0.5)', pulse: i % 4 === 0, delay: `${i * 0.3}s` })),
  ...neckDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-gold)', glow: 'rgba(245,158,11,0.4)', pulse: false, delay: '0s' })),
  ...torsoDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-blue)', glow: 'rgba(59,130,246,0.5)', pulse: i % 5 === 0, delay: `${i * 0.2}s` })),
  ...leftArmDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-gold)', glow: 'rgba(245,158,11,0.4)', pulse: i % 4 === 1, delay: `${i * 0.25}s` })),
  ...rightArmDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-gold)', glow: 'rgba(245,158,11,0.4)', pulse: i % 4 === 2, delay: `${i * 0.25}s` })),
  ...leftLegDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-gold)', glow: 'rgba(245,158,11,0.4)', pulse: i % 5 === 0, delay: `${i * 0.2}s` })),
  ...rightLegDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-gold)', glow: 'rgba(245,158,11,0.4)', pulse: i % 5 === 2, delay: `${i * 0.2}s` })),
  ...shieldDots.map(([x, y], i) => ({ x, y, color: 'var(--color-p-violet)', glow: 'rgba(139,92,246,0.3)', pulse: i % 3 === 0, delay: `${i * 0.4}s` })),
];
---

<section id="identity-stack" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
      Architecture
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      The Identity Stack
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      Every agent needs more than a system prompt. Every robot needs more than locomotion.
    </p>

    <!-- Layout: cards + humanoid diagram -->
    <div class="mt-14 flex flex-col lg:flex-row gap-12 items-start">

      <!-- Left: 4 Cards in 2x2 grid -->
      <div class="flex-1 grid gap-6 sm:grid-cols-2">
        {cards.map((c) => (
          <div class={`personality-card ${c.glowClass} relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] glass-card p-6 shadow-sm`}>
            <div class="absolute top-0 left-0 right-0 h-1" style={`background: ${c.color};`}></div>
            <div class="font-mono text-lg font-bold text-[var(--color-warm-text)] mt-2">
              {c.file}
            </div>
            <div class="mt-1 text-xs font-medium uppercase tracking-wider text-[var(--color-warm-muted)]">
              {c.philosopher}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-warm-muted)]">
              {c.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Right: Dot-matrix humanoid (desktop only) -->
      <div class="hidden lg:flex flex-col items-center justify-center w-64 shrink-0">
        <div class="dot-humanoid relative" style="width: 200px; height: 280px;">
          {allDots.map((d) => (
            <div
              class={`dot-point ${d.pulse ? 'dot-pulse-anim' : ''}`}
              style={`left: ${d.x}px; top: ${d.y}px; background: ${d.color}; box-shadow: 0 0 6px 2px ${d.glow}; ${d.pulse ? `animation-delay: ${d.delay};` : ''} ${d.color.includes('violet') ? 'opacity: 0.45;' : ''}`}
            />
          ))}
        </div>

        <!-- Labels -->
        <div class="mt-6 space-y-2 text-center">
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-coral);"></span>
            <span class="text-[var(--color-warm-muted)]">soul — brain</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-blue);"></span>
            <span class="text-[var(--color-warm-muted)]">psyche — heart</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-gold);"></span>
            <span class="text-[var(--color-warm-muted)]">body — form</span>
          </div>
          <div class="flex items-center justify-center gap-2 text-xs">
            <span class="h-2 w-2 rounded-full" style="background: var(--color-p-violet);"></span>
            <span class="text-[var(--color-warm-muted)]">conscience — shield</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Compile arrow -->
    <div class="mt-10 flex flex-col items-center gap-3">
      <svg class="h-10 w-10 text-[var(--color-warm-muted)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
      <div class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-warm-sand)] bg-white px-5 py-3 shadow-sm">
        <span class="font-mono text-sm font-bold text-[var(--color-warm-text)]">.personality.json</span>
        <span class="text-xs text-[var(--color-warm-muted)]">compiled output</span>
      </div>
    </div>
  </div>
</section>

<style>
  .dot-point {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .dot-pulse-anim {
    animation: dotPulse 3s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .dot-pulse-anim { animation: none !important; }
  }
</style>
