---
---

<section class="relative overflow-hidden py-20 md:py-28">
  <!-- Warm gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-p-coral)] via-[var(--color-p-violet)] to-[var(--color-p-blue)]"></div>

  <!-- Decorative shapes -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-20 -left-20 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute -bottom-20 -right-20 h-80 w-80 rounded-full bg-white/10 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-96 w-96 rounded-full bg-white/5 blur-2xl"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-3xl font-extrabold text-white md:text-5xl leading-tight">
      Align your agents.<br/>
      <em>Start with one diagnosis.</em>
    </h2>
    <p class="mx-auto mt-6 max-w-lg text-lg text-white/80">
      Diagnose drift. Run correction sessions. Export training data. The fix is permanent. Open source. Five lines to start.
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/demo"
        class="inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-semibold text-[var(--color-p-violet)] shadow-xl transition-all hover:scale-[1.02] hover:shadow-2xl"
      >
        Try the Live Demo
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>
