---
---

<section class="relative overflow-hidden py-12 md:py-16">
  <!-- Gradient background -->
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-p-coral)] via-[var(--color-p-violet)] to-[var(--color-p-blue)]"></div>

  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-2xl font-extrabold text-white md:text-4xl leading-tight">
      Ship agents that behave. Start with one diagnosis.
    </h2>

    <!-- Install command -->
    <div class="mx-auto mt-5 max-w-md">
      <div class="flex items-center gap-2 rounded-xl bg-black/30 backdrop-blur-sm border border-white/10 px-5 py-3">
        <span class="text-white/40 select-none font-mono text-sm">$</span>
        <code class="flex-1 text-left font-mono text-sm text-white/90">npx holomime init-stack</code>
        <button id="cta-copy-btn" class="shrink-0 text-white/40 hover:text-white transition-colors" aria-label="Copy command">
          <svg id="cta-copy-icon" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
        </button>
      </div>
    </div>

    <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="/docs"
        class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-2.5 text-sm font-semibold text-[var(--color-p-violet)] shadow-xl transition-all hover:scale-[1.02] hover:shadow-2xl"
      >
        Get Started
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
      <a
        href="https://github.com/productstein/holomime"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full border-2 border-white/20 px-6 py-2.5 text-sm font-semibold text-white transition-all hover:bg-white/10"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>

<script>
  document.getElementById("cta-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npx holomime init-stack");
    const icon = document.getElementById("cta-copy-icon");
    if (icon) {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
      icon.style.color = "#10b981";
      setTimeout(() => {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/>';
        icon.style.color = "";
      }, 2000);
    }
  });
</script>
