---
/**
 * Hero — Stripped to essentials. No decoration. Just the pitch.
 */
---

<section class="relative pt-28 pb-16 md:pt-40 md:pb-24">
  <!-- Subtle warm gradient at top -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-1/2 left-1/2 h-[800px] w-[1200px] -translate-x-1/2 rounded-full opacity-[0.07] blur-[120px]"
      style="background: radial-gradient(ellipse, var(--color-p-coral), var(--color-p-violet))"></div>
  </div>

  <div class="relative mx-auto max-w-5xl px-6">
    <!-- Two-column: copy left, terminal right -->
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

      <!-- Left: Copy -->
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-4xl font-extrabold leading-[1.08] tracking-tight text-[var(--color-warm-text)] md:text-5xl lg:text-[3.5rem]">
          Your agent has a personality.
          <span class="text-gradient-warm">We make sure it's the right one.</span>
        </h1>

        <p class="mt-5 max-w-lg text-base leading-relaxed text-[var(--color-warm-muted)] lg:text-lg mx-auto lg:mx-0">
          The behavioral alignment engine for AI agents. Detect drift. Fix it permanently.
        </p>

        <a href="/manifesto" class="mt-3 inline-block text-sm text-[var(--color-p-coral)] hover:underline underline-offset-2 transition-colors">
          From agents to humanoids &rarr;
        </a>

        <div class="mt-8 flex flex-col sm:flex-row items-center gap-3 lg:justify-start justify-center">
          <a href="/docs" class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-white transition-all hover:opacity-90"
            style="background: linear-gradient(135deg, var(--color-p-coral), #e85d54);">
            Get Started
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg px-6 py-3 text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-sand)]/40">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Right: Terminal -->
      <div class="flex-1 w-full max-w-md lg:max-w-none">
        <div class="rounded-xl bg-[var(--color-holo-dark)] p-5 shadow-2xl shadow-black/25 ring-1 ring-white/[0.06]">
          <div class="flex items-center gap-1.5 mb-3">
            <div class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-slate-500 font-mono text-sm select-none">$</span>
            <code class="font-mono text-sm text-emerald-400">npx holomime init-stack</code>
            <span class="cursor-blink text-emerald-400 font-mono text-sm">|</span>
          </div>
          <div class="mt-3 space-y-0.5 font-mono text-[13px]">
            <div class="hero-line text-emerald-400" style="animation-delay: 0.6s">&#10004; Created 3 identity files:</div>
            <div class="hero-line text-slate-300 pl-4" style="animation-delay: 1.0s">
              <span class="text-[var(--color-p-coral)]">soul.md</span>
              <span class="text-slate-600 ml-3">values, ethics, purpose</span>
            </div>
            <div class="hero-line text-slate-300 pl-4" style="animation-delay: 1.4s">
              <span class="text-[var(--color-p-blue)]">mind.sys</span>
              <span class="text-slate-600 ml-3">Big Five, EQ, communication</span>
            </div>
            <div class="hero-line text-slate-300 pl-4" style="animation-delay: 1.8s">
              <span class="text-[var(--color-p-violet)]">conscience.exe</span>
              <span class="text-slate-600 ml-3">deny/allow/escalate</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-line {
    opacity: 0;
    animation: fadeInLine 0.3s ease-out forwards;
  }
  @keyframes fadeInLine {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
