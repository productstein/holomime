---
const personalities = [
  { label: "Empathetic", emoji: "heart", color: "#f97066", x: "8%", y: "18%", delay: "0s" },
  { label: "Analytical", emoji: "brain", color: "#3b82f6", x: "85%", y: "22%", delay: "1s" },
  { label: "Creative", emoji: "sparkle", color: "#8b5cf6", x: "5%", y: "65%", delay: "2.5s" },
  { label: "Bold", emoji: "fire", color: "#f59e0b", x: "88%", y: "60%", delay: "1.5s" },
  { label: "Calm", emoji: "leaf", color: "#22c55e", x: "15%", y: "42%", delay: "3s" },
  { label: "Witty", emoji: "zap", color: "#f97316", x: "82%", y: "42%", delay: "0.5s" },
  { label: "Resilient", emoji: "shield", color: "#14b8a6", x: "20%", y: "12%", delay: "1.8s" },
  { label: "Curious", emoji: "eye", color: "#ec4899", x: "92%", y: "14%", delay: "0.8s" },
  { label: "Patient", emoji: "clock", color: "#6366f1", x: "2%", y: "50%", delay: "2.2s" },
  { label: "Assertive", emoji: "speaker", color: "#10b981", x: "76%", y: "76%", delay: "3.5s" },
  { label: "Authentic", emoji: "diamond", color: "#fb7185", x: "18%", y: "78%", delay: "1.2s" },
];
---

<section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-32">
  <!-- Soft color glow on white -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-1/2 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/4 rounded-full opacity-[0.12] blur-[140px]"
      style="background: radial-gradient(circle, #f97066, #8b5cf6, #06b6d4)"></div>
    <div class="absolute bottom-0 left-1/4 h-80 w-80 rounded-full bg-[var(--color-p-gold)] opacity-[0.08] blur-[100px]"></div>
    <div class="absolute bottom-1/4 right-1/6 h-64 w-64 rounded-full bg-[var(--color-p-sage)] opacity-[0.08] blur-[100px]"></div>
  </div>

  <!-- Floating personality bubbles -->
  {personalities.map((p) => (
    <div
      class="pointer-events-none absolute hidden md:block animate-float"
      style={`left: ${p.x}; top: ${p.y}; animation-delay: ${p.delay}; animation-duration: ${6 + Math.random() * 3}s;`}
    >
      <div
        class="flex items-center gap-2 rounded-full px-4 py-2 text-sm font-medium shadow-lg"
        style={`background: ${p.color}12; border: 1px solid ${p.color}25; color: ${p.color};`}
      >
        {p.emoji === "heart" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z"/></svg>}
        {p.emoji === "brain" && <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>}
        {p.emoji === "sparkle" && <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>}
        {p.emoji === "fire" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 00-1.071-.136 9.742 9.742 0 00-3.539 6.177A7.547 7.547 0 016.648 6.61a.75.75 0 00-1.152.082A9 9 0 1015.68 4.534a7.46 7.46 0 01-2.717-2.248zM15.75 14.25a3.75 3.75 0 11-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 011.925-3.545 3.75 3.75 0 013.255 3.717z" clip-rule="evenodd"/></svg>}
        {p.emoji === "leaf" && <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>}
        {p.emoji === "zap" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.913-.143z" clip-rule="evenodd"/></svg>}
        {p.emoji === "shield" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 00.374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516 11.209 11.209 0 01-7.877-3.08z" clip-rule="evenodd"/></svg>}
        {p.emoji === "eye" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z"/><path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69a.75.75 0 010 .61c-1.49 4.467-5.704 7.69-10.675 7.69-4.973 0-9.19-3.226-10.678-7.693a.75.75 0 010-.6zM12.001 13.5a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" clip-rule="evenodd"/></svg>}
        {p.emoji === "clock" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/></svg>}
        {p.emoji === "speaker" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M13.5 4.06c0-1.336-1.616-2.005-2.56-1.06l-4.5 4.5H4.508c-1.141 0-2.318.664-2.66 1.905A9.76 9.76 0 001.5 12c0 .898.121 1.768.35 2.595.341 1.24 1.518 1.905 2.659 1.905h1.93l4.5 4.5c.945.945 2.561.276 2.561-1.06V4.06zM18.584 5.106a.75.75 0 011.06 0c3.808 3.807 3.808 9.98 0 13.788a.75.75 0 01-1.06-1.06 8.25 8.25 0 000-11.668.75.75 0 010-1.06z"/><path d="M15.932 7.757a.75.75 0 011.061 0 6 6 0 010 8.486.75.75 0 01-1.06-1.061 4.5 4.5 0 000-6.364.75.75 0 010-1.06z"/></svg>}
        {p.emoji === "diamond" && <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 1.5a.75.75 0 01.65.376l5.25 9a.75.75 0 01-.001.748l-5.25 9a.75.75 0 01-1.298 0l-5.25-9a.75.75 0 01-.001-.748l5.25-9A.75.75 0 0112 1.5zM7.428 11.25L12 19.1l4.572-7.85L12 3.4l-4.572 7.85z" clip-rule="evenodd"/></svg>}
        {p.label}
      </div>
    </div>
  ))}

  <div class="relative mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-violet)]/20 bg-[var(--color-p-violet-soft)] px-4 py-1.5 text-sm">
      <span class="h-2 w-2 rounded-full bg-[var(--color-p-violet)] animate-pulse"></span>
      <span class="text-[var(--color-p-violet)] font-medium">Open source &middot; MIT Licensed &middot; npm install holomime</span>
    </div>

    <!-- Headline -->
    <h1 class="mx-auto max-w-5xl text-4xl font-extrabold leading-[1.1] tracking-tight text-[var(--color-warm-text)] md:text-6xl lg:text-7xl">
      Your agents have a personality disorder.
      <span class="text-gradient-warm">Behavioral therapy that rewires the patterns.</span>
    </h1>

    <!-- Subtext -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-warm-muted)] md:text-xl">
      Autonomous therapists for AI agents. Detect drift, run structured sessions, and export the correction as training data.
    </p>

    <!-- CTA: Terminal command -->
    <div class="mt-10 flex flex-col items-center gap-4">
      <div class="group relative flex items-center gap-3 rounded-2xl bg-[var(--color-holo-dark)] px-6 py-4 shadow-2xl shadow-black/20 cursor-pointer transition-all hover:shadow-xl hover:scale-[1.01] sm:px-8" id="hero-cmd">
        <span class="text-[var(--color-warm-muted)]/60 font-mono text-sm select-none">$</span>
        <code class="font-mono text-sm text-emerald-400 sm:text-base">npx holomime diagnose conversation.json</code>
        <button id="hero-copy-btn" class="ml-2 shrink-0 text-white/30 hover:text-white transition-colors" aria-label="Copy command">
          <svg id="hero-copy-icon" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
        </button>
      </div>
      <p class="text-sm text-[var(--color-warm-muted)]">
        Zero install. Paste your agent's conversation log. <a href="/docs" class="font-medium text-[var(--color-p-violet)] hover:underline underline-offset-2">See all formats</a>
      </p>
    </div>

  </div>
</section>

<script>
  const copyBtn = document.getElementById("hero-copy-btn");
  const cmdEl = document.getElementById("hero-cmd");
  const command = "npx holomime diagnose conversation.json";

  function copyCommand() {
    navigator.clipboard.writeText(command);
    const icon = document.getElementById("hero-copy-icon");
    if (icon) {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
      icon.style.color = "#10b981";
      setTimeout(() => {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/>';
        icon.style.color = "";
      }, 2000);
    }
  }

  copyBtn?.addEventListener("click", (e) => { e.stopPropagation(); copyCommand(); });
  cmdEl?.addEventListener("click", copyCommand);
</script>
