---
/**
 * DemoVideo — Product video with therapy-forward narrative.
 */
---

<section id="demo" class="py-12 md:py-16">
  <div class="mx-auto max-w-4xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)] mb-3">
      Watch the Therapy Session
    </p>
    <h2 class="text-center text-2xl font-extrabold text-[var(--color-warm-text)] md:text-3xl mb-2">
      90 seconds. One agent. Grade D to Grade A.
    </h2>
    <p class="text-center text-sm text-[var(--color-warm-muted)] mb-8 max-w-lg mx-auto">
      This agent was over-apologizing on 72% of responses. holomime diagnosed it, ran a structured correction session, and exported 12 DPO training pairs — automatically.
    </p>
    <div class="relative overflow-hidden rounded-2xl border border-[var(--color-warm-sand)] bg-[var(--color-holo-slate)] shadow-2xl shadow-black/10 aspect-video">
      <video
        class="absolute inset-0 w-full h-full object-cover"
        playsinline
        muted
        autoplay
        loop
        preload="auto"
        src="/demo.mp4"
      ></video>
    </div>
    <div class="mt-4 flex items-center justify-center gap-6">
      <a href="/demo" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-p-violet)] hover:underline underline-offset-2 transition-colors">
        Try the interactive demo
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
      <span class="h-3.5 w-px bg-[var(--color-warm-sand)]"></span>
      <a href="/voice" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-p-coral)] hover:underline underline-offset-2 transition-colors">
        Hear the voice demo
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/></svg>
      </a>
    </div>
  </div>
</section>
