---
const tiers = [
  {
    name: "Free Clinic",
    price: "$0",
    period: "forever",
    description: "Open-source CLI. Full local diagnosis, unlimited agents.",
    cta: "Walk In Free",
    ctaAction: "install",
    highlighted: false,
    color: "#22c55e",
    visibleCount: 5,
    features: [
      "CLI tool (npm i -g holomime)",
      "8 rule-based detectors (80+ signals) + custom JSON detectors",
      "Local diagnosis — no API calls, runs in milliseconds",
      "20+ pre-built personality archetypes (5 categories)",
      "Tiered personality loading (L0/L1/L2 — up to 91% token savings)",
      "Personality profiling (Big Five × 4 facets = 20 traits)",
      "Self-awareness interviews (8 metacognition probes)",
      "MCP server integration (6 tools — local)",
      "Unlimited agents, unlimited logs",
      "ChatGPT, Claude, OpenAI, Anthropic, OTEL, and JSONL log import",
      "Guard middleware (monitor / enforce / strict)",
      "Policy generation from plain English",
      "OpenClaw plugin — behavioral monitoring for OpenClaw agents",
      "VS Code extension — 3D brain visualization in your editor",
      "LangChain & CrewAI callback handler",
      "Shareable brain snapshots — one-click share URLs",
    ],
  },
  {
    name: "Practitioner",
    price: "$0.01",
    period: "/session",
    description: "Hosted API for agent pipelines. Pay-per-call pricing.",
    cta: "Get API Key",
    ctaAction: "install",
    highlighted: false,
    color: "#06b6d4",
    visibleCount: 5,
    features: [
      "Everything in Free Clinic",
      "$10 free API credit to start",
      "Hosted diagnose API ($0.01/call)",
      "Hosted assess API ($0.02/call)",
      "Hosted self-audit API ($0.05/call)",
      "Progressive disclosure (summary / standard / full detail)",
      "Webhook integrations (drift.detected events)",
      "Rate limit: 100 calls/minute",
      "14-day data retention",
    ],
    perUnit: "$0.01/diagnose · $0.02/assess · $0.05/audit",
  },
  {
    name: "Practice",
    price: "$149",
    period: "/month",
    description: "Full behavioral correction suite with training data export.",
    cta: "Start Treatment",
    ctaAction: "checkout",
    highlighted: true,
    color: "#8b5cf6",
    visibleCount: 6,
    features: [
      "Everything in Practitioner",
      "Automated behavioral correction (Anthropic, OpenAI, Ollama)",
      "Persistent behavioral memory — sessions that compound",
      "Tiered personality loading for cost-efficient deployments",
      "Agent self-observation via MCP (agents report their own drift)",
      "Self-improving interventions with auto-escalation",
      "Behavioral knowledge graph",
      "ReACT reasoning for evidence-based therapy",
      "Session compaction & fleet knowledge transfer (mergeStores)",
      "Recursive alignment — evolve until converged",
      "Continuous drift detection & auto-correction",
      "Group Therapy — treat all agents simultaneously (up to 10)",
      "Cross-agent knowledge sharing",
      "Before/after outcome evaluation with TES scoring",
      "DPO, RLHF, Alpaca, HuggingFace, OpenAI training data export",
      "8-scenario behavioral stress testing + 30 adversarial attacks",
      "NeuralSpace — real-time 3D agent brain visualization",
      "Behavioral credentials & certify command",
      "Unlimited API calls included",
      "Priority support",
    ],
  },
];
---

<section id="pricing" class="py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase" style="color: var(--color-p-violet);">
      Pricing
    </p>
    <h2 class="mt-3 text-center text-3xl font-extrabold text-[var(--color-warm-text)] md:text-4xl">
      Open source core. Hosted infrastructure for production.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-[var(--color-warm-muted)]">
      The CLI is MIT-licensed and always free. Payment is for hosted API, LLM-powered features, and managed infrastructure.
    </p>
    <p class="mt-3 text-center text-sm text-[var(--color-warm-muted)]">
      Open source. Self-hostable. <span class="font-semibold text-[var(--color-warm-text)]">Your clinic, your rules.</span>
    </p>

    <!-- Billing toggle -->
    <div class="mt-8 flex items-center justify-center gap-3">
      <span id="billing-monthly-label" class="text-sm font-medium text-[var(--color-warm-text)]">Monthly</span>
      <button
        id="billing-toggle"
        role="switch"
        aria-checked="false"
        class="relative inline-flex h-6 w-11 items-center rounded-full border-2 border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] transition-colors focus:outline-none"
      >
        <span id="billing-toggle-thumb" class="inline-block h-4 w-4 translate-x-0.5 rounded-full bg-[var(--color-warm-muted)] transition-transform"></span>
      </button>
      <span id="billing-annual-label" class="text-sm font-medium text-[var(--color-warm-muted)]">
        Annual <span class="ml-1 rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">Save 20%</span>
      </span>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {tiers.map((tier) => (
        <div
          class:list={[
            "personality-card relative flex flex-col rounded-2xl p-8",
            tier.highlighted
              ? "bg-white shadow-xl shadow-[var(--color-p-violet)]/10 ring-2 ring-[var(--color-p-violet)]/20"
              : "bg-white border-2 border-[var(--color-warm-border)]",
          ]}
        >

          <h3 class="text-lg font-bold text-[var(--color-warm-text)]">{tier.name}</h3>
          <div class="mt-4">
            {tier.pricePrefix && <span class="block text-sm font-medium text-[var(--color-warm-muted)]">{tier.pricePrefix}</span>}
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-[var(--color-warm-text)]" {...(tier.ctaAction === "checkout" ? { id: "main-card-price" } : {})}>{tier.price}</span>
              {tier.period && <span class="text-[var(--color-warm-muted)]" {...(tier.ctaAction === "checkout" ? { id: "main-card-period" } : {})}>{tier.period}</span>}
            </div>
          </div>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">{tier.description}</p>
          {tier.perUnit && (
            <p class="mt-2 text-xs font-mono text-[var(--color-warm-muted)] opacity-70">{tier.perUnit}</p>
          )}

          <ul class="mt-6 flex-1 space-y-3">
            {tier.features.map((f, fi) => (
              <li
                class:list={[
                  "flex items-start gap-3 text-sm",
                  fi >= (tier.visibleCount ?? tier.features.length) ? "feature-hidden hidden" : "",
                ]}
                data-tier={tier.name}
              >
                <svg class="mt-0.5 h-4 w-4 shrink-0" style={`color: ${tier.color};`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="text-[var(--color-warm-muted)]">{f}</span>
              </li>
            ))}
          </ul>
          {(tier.visibleCount ?? tier.features.length) < tier.features.length && (
            <button
              class="feature-toggle mt-3 flex items-center gap-1 text-xs font-semibold transition-colors"
              style={`color: ${tier.color};`}
              data-tier={tier.name}
              data-expanded="false"
            >
              <span class="toggle-text">View full treatment plan</span>
              <svg class="toggle-chevron h-3.5 w-3.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </button>
          )}

          {tier.ctaAction === "install" ? (
            <div class="mt-8">
              <button
                class="pricing-cta-btn btn-press w-full rounded-xl py-3.5 text-sm font-semibold transition-colors"
                data-action={tier.ctaAction}
                style={`background: ${tier.color}12; color: ${tier.color}; border: 2px solid ${tier.color}30;`}
              >
                {tier.cta}
              </button>
            </div>
          ) : tier.ctaAction === "checkout" ? (
            <div class="mt-8">
              <div class="mb-3 text-center">
                <span id="pro-price-monthly" class="text-2xl font-extrabold text-[var(--color-warm-text)]">$149<span class="text-sm font-normal text-[var(--color-warm-muted)]">/mo</span></span>
                <span id="pro-price-annual" style="display:none" class="text-2xl font-extrabold text-emerald-600">$119<span class="text-sm font-normal text-[var(--color-warm-muted)]">/mo · billed annually</span></span>
              </div>
              <button
                id="checkout-btn"
                class="pricing-cta-btn btn-press w-full rounded-xl py-3.5 text-sm font-semibold text-white"
                data-action="checkout"
                style="background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet));"
              >
                {tier.cta}
              </button>
            </div>
          ) : (
            <a
              href="/contact"
              class="btn-press mt-8 block w-full rounded-xl border-2 border-[var(--color-warm-border)] py-3.5 text-center text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:border-[var(--color-p-gold)]"
            >
              {tier.cta}
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Enterprise banner -->
    <div class="mt-10 rounded-2xl border-2 border-[var(--color-warm-border)] bg-white px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
      <div>
        <h3 class="text-lg font-bold text-[var(--color-warm-text)]">Need fleet-scale alignment?</h3>
        <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Custom deployments, compliance reporting, unlimited agents, and dedicated infrastructure for enterprise teams.</p>
      </div>
      <a
        href="/contact"
        class="btn-press shrink-0 rounded-xl border-2 border-[var(--color-warm-border)] px-6 py-3 text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:border-[var(--color-p-gold)]"
      >
        Contact Sales
      </a>
    </div>
  </div>
</section>

<!-- Install modal -->
<div id="install-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="install-backdrop"></div>
  <div class="relative z-10 mx-4 w-full max-w-md rounded-2xl bg-white p-8 shadow-2xl">
    <button id="install-close" class="absolute top-4 right-4 text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <h2 class="text-xl font-bold text-[var(--color-warm-text)]">Install HoloMime CLI</h2>
    <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Run this command in your terminal. Requires Node.js 18+.</p>
    <div class="mt-5 flex items-center gap-2 rounded-xl bg-[var(--color-holo-dark)] px-4 py-3">
      <code class="flex-1 font-mono text-sm text-emerald-400">npm install -g holomime</code>
      <button id="install-copy-btn" class="shrink-0 text-[var(--color-warm-muted)] hover:text-white transition-colors">
        <svg id="install-copy-icon" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
      </button>
    </div>
    <p class="mt-4 text-sm text-[var(--color-warm-muted)]">Then run <code class="rounded bg-[var(--color-warm-cream)] px-1 font-mono text-xs">holomime diagnose</code> on any conversation log to get started.</p>
    <a href="/docs" class="mt-5 flex items-center justify-center gap-1 text-sm font-medium text-[var(--color-p-violet)] hover:underline">Read the docs <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>
  </div>
</div>

<script>
  // ─── Billing toggle ───
  let billingPeriod: "monthly" | "annual" = "monthly";
  const toggle = document.getElementById("billing-toggle");
  const thumb = document.getElementById("billing-toggle-thumb");
  const monthlyLabel = document.getElementById("billing-monthly-label");
  const annualLabel = document.getElementById("billing-annual-label");
  const priceMonthly = document.getElementById("pro-price-monthly");
  const priceAnnual = document.getElementById("pro-price-annual");

  toggle?.addEventListener("click", () => {
    billingPeriod = billingPeriod === "monthly" ? "annual" : "monthly";
    const isAnnual = billingPeriod === "annual";

    toggle.setAttribute("aria-checked", String(isAnnual));

    // Toggle thumb position and color via inline styles
    if (thumb) {
      thumb.style.transform = isAnnual ? "translateX(1.25rem)" : "translateX(0.125rem)";
      thumb.style.background = isAnnual ? "var(--color-p-violet)" : "var(--color-warm-muted)";
    }
    toggle.style.borderColor = isAnnual ? "var(--color-p-violet)" : "var(--color-warm-border)";

    // Toggle label colors
    if (monthlyLabel) monthlyLabel.style.color = isAnnual ? "var(--color-warm-muted)" : "var(--color-warm-text)";
    if (annualLabel) annualLabel.style.color = isAnnual ? "var(--color-warm-text)" : "var(--color-warm-muted)";

    // Toggle price displays
    if (priceMonthly) priceMonthly.style.display = isAnnual ? "none" : "";
    if (priceAnnual) priceAnnual.style.display = isAnnual ? "" : "none";

    // Also update the main card price
    const mainPrice = document.getElementById("main-card-price");
    const mainPeriod = document.getElementById("main-card-period");
    if (mainPrice) mainPrice.textContent = isAnnual ? "$119" : "$149";
    if (mainPeriod) mainPeriod.textContent = isAnnual ? "/mo · billed annually" : "/month";
  });

  // ─── Install modal — move to body to avoid nested overlay issues ───
  const installModal = document.getElementById("install-modal");
  if (installModal && installModal.parentElement !== document.body) {
    document.body.appendChild(installModal);
  }
  function openInstallModal() {
    installModal?.classList.remove("hidden");
    installModal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeInstallModal() {
    installModal?.classList.add("hidden");
    installModal?.classList.remove("flex");
    document.body.style.overflow = "";
  }
  document.getElementById("install-close")?.addEventListener("click", closeInstallModal);
  document.getElementById("install-backdrop")?.addEventListener("click", closeInstallModal);
  document.getElementById("install-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npm install -g holomime");
    const icon = document.getElementById("install-copy-icon");
    if (icon) {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
      icon.style.color = "#10b981";
      setTimeout(() => {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/>';
        icon.style.color = "";
      }, 2000);
    }
  });

  // ─── Feature toggle (See all / Show less) ───
  document.querySelectorAll(".feature-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tierName = (btn as HTMLElement).dataset.tier;
      const expanded = (btn as HTMLElement).dataset.expanded === "true";
      const items = document.querySelectorAll(`li.feature-hidden[data-tier="${tierName}"]`);
      const text = btn.querySelector(".toggle-text");
      const chevron = btn.querySelector(".toggle-chevron") as HTMLElement;

      if (expanded) {
        items.forEach((el) => el.classList.add("hidden"));
        if (text) text.textContent = "View full treatment plan";
        if (chevron) chevron.style.transform = "";
        (btn as HTMLElement).dataset.expanded = "false";
      } else {
        items.forEach((el) => el.classList.remove("hidden"));
        if (text) text.textContent = "Summary";
        if (chevron) chevron.style.transform = "rotate(180deg)";
        (btn as HTMLElement).dataset.expanded = "true";
      }
    });
  });

  // "Install Free" → always show install modal
  // "Get API Key" → if logged out: auth modal; if logged in: open pricing modal or go to dashboard
  document.querySelectorAll('.pricing-cta-btn[data-action="install"]').forEach((btn) => {
    const isInstallFree = (btn as HTMLElement).textContent?.trim() === "Walk In Free";
    btn.addEventListener("click", () => {
      if (isInstallFree) {
        openInstallModal();
      } else {
        // "Get API Key"
        if ((window as any).openAuthModal) {
          (window as any).openAuthModal();
        } else if (window.location.pathname === "/dashboard") {
          // Already on dashboard — do nothing, user is looking at pricing already
        } else {
          // Logged in, not on dashboard — go there and open pricing modal
          window.location.href = "https://app.holomime.dev/dashboard?pricing=1";
        }
      }
    });
  });

  // "Start Aligning" (Pro checkout) → auth gate, then checkout
  document.getElementById("checkout-btn")?.addEventListener("click", async () => {
    const btn = document.getElementById("checkout-btn") as HTMLButtonElement;

    if ((window as any).openAuthModal) {
      (window as any).openAuthModal();
      return;
    }

    btn.textContent = "Loading...";
    btn.disabled = true;

    try {
      const res = await fetch("/api/checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ billing: billingPeriod }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        btn.textContent = "Start Treatment";
        btn.disabled = false;
        alert(data.error || "Checkout unavailable. Please contact support.");
      }
    } catch {
      btn.textContent = "Start Treatment";
      btn.disabled = false;
    }
  });
</script>
