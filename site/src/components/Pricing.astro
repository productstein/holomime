---
const tiers = [
  {
    name: "Free",
    price: "$0",
    period: "forever",
    description: "Everything you need to align one agent. Open source · MIT licensed.",
    cta: "Install",
    ctaAction: "install",
    highlighted: false,
    color: "#22c55e",
    visibleCount: 5,
    features: [
      "Identity stack (soul, mind, body, conscience)",
      "Behavioral diagnosis (80+ signals)",
      "Adversarial benchmarking (grade A-F)",
      "8 OEM body templates",
      "All 5 adapters (ROS2, Unity, Webhook, gRPC, MQTT)",
      "Brain visualization",
      "MCP server + Claude Code skill",
    ],
  },
  {
    name: "Pro",
    price: "$49",
    period: "/month",
    description: "Self-improving alignment for production teams.",
    cta: "Start Pro Trial",
    ctaAction: "checkout",
    highlighted: true,
    color: "#8b5cf6",
    visibleCount: 5,
    features: [
      "Everything in Free",
      "Therapy sessions (LLM-driven correction)",
      "Mira — autonomous therapy (continuous practice)",
      "DPO/RLHF training export",
      "Growth tracking over time",
      "Evolve (auto-improve)",
      "Priority support",
    ],
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    description: "Fleet alignment for robotics and enterprise teams.",
    cta: "Contact Sales",
    ctaAction: "contact",
    highlighted: false,
    color: "#3b82f6",
    visibleCount: 5,
    features: [
      "Everything in Pro",
      "Fleet management (multi-robot monitoring)",
      "Compliance reporting & audit trails",
      "Custom body.api development",
      "On-premise deployment",
      "Dedicated support & SLA",
    ],
  },
];
---

<section id="pricing" class="py-24 md:py-32 bg-white">
  <div class="mx-auto max-w-6xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase" style="color: var(--color-p-violet);">
      Pricing
    </p>
    <h2 class="mt-3 text-center text-3xl font-extrabold text-[var(--color-warm-text)] md:text-4xl">
      Open source core. Pro tools for production.
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-[var(--color-warm-muted)]">
      The identity stack is MIT-licensed and always free. Payment is for LLM-powered therapy, self-training, and fleet management.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {tiers.map((tier) => (
        <div class={tier.highlighted ? "rounded-2xl p-[2px] bg-gradient-to-br from-[var(--color-p-coral)] to-[var(--color-p-violet)]" : ""}>
        <div
          class:list={[
            "personality-card relative flex flex-col rounded-2xl p-8",
            tier.highlighted
              ? "bg-white"
              : "bg-white border-2 border-[var(--color-warm-border)]",
            tier.name === "Free" ? "pricing-card-oss" : "",
            tier.name === "Enterprise" ? "pricing-card-enterprise" : "",
          ]}
        >
          {tier.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full text-xs font-semibold text-white bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)]">
              Most Popular
            </div>
          )}

          <h3 class="text-lg font-bold text-[var(--color-warm-text)]">{tier.name}</h3>
          <div class="mt-4">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-[var(--color-warm-text)]">{tier.price}</span>
              {tier.period && <span class="text-[var(--color-warm-muted)]">{tier.period}</span>}
            </div>
          </div>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">{tier.description}</p>

          <ul class="mt-6 flex-1 space-y-3">
            {tier.features.map((f, fi) => (
              <li
                class:list={[
                  "flex items-start gap-3 text-sm",
                  fi >= (tier.visibleCount ?? tier.features.length) ? "feature-hidden hidden" : "",
                ]}
                data-tier={tier.name}
              >
                <svg class="mt-0.5 h-4 w-4 shrink-0" style={`color: ${tier.color};`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="text-[var(--color-warm-muted)]">{f}</span>
              </li>
            ))}
          </ul>
          {(tier.visibleCount ?? tier.features.length) < tier.features.length && (
            <button
              class="feature-toggle mt-3 flex items-center gap-1 text-xs font-semibold transition-colors"
              style={`color: ${tier.color};`}
              data-tier={tier.name}
              data-expanded="false"
            >
              <span class="toggle-text">See all features</span>
              <svg class="toggle-chevron h-3.5 w-3.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </button>
          )}

          {tier.ctaAction === "install" ? (
            <div class="mt-8">
              <button
                class="pricing-cta-btn btn-press w-full rounded-xl py-3.5 text-sm font-semibold transition-colors"
                data-action={tier.ctaAction}
                style={`background: ${tier.color}12; color: ${tier.color}; border: 2px solid ${tier.color}30;`}
              >
                {tier.cta}
              </button>
            </div>
          ) : tier.ctaAction === "checkout" ? (
            <div class="mt-8">
              <button
                id="checkout-btn"
                class="pricing-cta-btn btn-press w-full rounded-xl py-3.5 text-sm font-semibold text-white"
                data-action="checkout"
                style="background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet));"
              >
                {tier.cta}
              </button>
            </div>
          ) : (
            <a
              href="/contact"
              class="btn-press mt-8 block w-full rounded-xl border-2 border-[var(--color-warm-border)] py-3.5 text-center text-sm font-semibold text-[var(--color-warm-text)] transition-colors hover:border-[var(--color-p-gold)]"
            >
              {tier.cta}
            </a>
          )}
        </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-card-oss:hover { box-shadow: 0 0 24px -6px rgba(34, 197, 94, 0.2); }
  .pricing-card-enterprise:hover { box-shadow: 0 0 24px -6px rgba(59, 130, 246, 0.2); }
</style>

<!-- Install modal -->
<div id="install-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="install-backdrop"></div>
  <div class="relative z-10 mx-4 w-full max-w-md rounded-2xl bg-white p-8 shadow-2xl">
    <button id="install-close" class="absolute top-4 right-4 text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <h2 class="text-xl font-bold text-[var(--color-warm-text)]">Install holomime</h2>
    <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Run this command in your terminal. Requires Node.js 18+.</p>
    <div class="mt-5 flex items-center gap-2 rounded-xl bg-[var(--color-holo-dark)] px-4 py-3">
      <code class="flex-1 font-mono text-sm text-emerald-400">npm install holomime</code>
      <button id="install-copy-btn" class="shrink-0 text-[var(--color-warm-muted)] hover:text-white transition-colors">
        <svg id="install-copy-icon" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>
      </button>
    </div>
    <p class="mt-4 text-sm text-[var(--color-warm-muted)]">Then run <code class="rounded bg-[var(--color-warm-cream)] px-1 font-mono text-xs">npx holomime core</code> to create your identity stack.</p>
    <a href="/docs" class="mt-5 flex items-center justify-center gap-1 text-sm font-medium text-[var(--color-p-violet)] hover:underline">Read the docs <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>
  </div>
</div>

<script>
  // ─── Install modal — move to body to avoid nested overlay issues ───
  const installModal = document.getElementById("install-modal");
  if (installModal && installModal.parentElement !== document.body) {
    document.body.appendChild(installModal);
  }
  function openInstallModal() {
    installModal?.classList.remove("hidden");
    installModal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeInstallModal() {
    installModal?.classList.add("hidden");
    installModal?.classList.remove("flex");
    document.body.style.overflow = "";
  }
  document.getElementById("install-close")?.addEventListener("click", closeInstallModal);
  document.getElementById("install-backdrop")?.addEventListener("click", closeInstallModal);
  document.getElementById("install-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npm install holomime");
    const icon = document.getElementById("install-copy-icon");
    if (icon) {
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
      icon.style.color = "#10b981";
      setTimeout(() => {
        icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/>';
        icon.style.color = "";
      }, 2000);
    }
  });

  // ─── Feature toggle (See all / Show less) ───
  document.querySelectorAll(".feature-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tierName = (btn as HTMLElement).dataset.tier;
      const expanded = (btn as HTMLElement).dataset.expanded === "true";
      const items = document.querySelectorAll(`li.feature-hidden[data-tier="${tierName}"]`);
      const text = btn.querySelector(".toggle-text");
      const chevron = btn.querySelector(".toggle-chevron") as HTMLElement;

      if (expanded) {
        items.forEach((el) => el.classList.add("hidden"));
        if (text) text.textContent = "See all features";
        if (chevron) chevron.style.transform = "";
        (btn as HTMLElement).dataset.expanded = "false";
      } else {
        items.forEach((el) => el.classList.remove("hidden"));
        if (text) text.textContent = "Show less";
        if (chevron) chevron.style.transform = "rotate(180deg)";
        (btn as HTMLElement).dataset.expanded = "true";
      }
    });
  });

  // "Install" → show install modal
  document.querySelectorAll('.pricing-cta-btn[data-action="install"]').forEach((btn) => {
    btn.addEventListener("click", () => {
      openInstallModal();
    });
  });

  // "Start Pro Trial" (Pro checkout) → auth gate, then checkout
  document.getElementById("checkout-btn")?.addEventListener("click", async () => {
    const btn = document.getElementById("checkout-btn") as HTMLButtonElement;

    if ((window as any).openAuthModal) {
      (window as any).openAuthModal();
      return;
    }

    btn.textContent = "Loading...";
    btn.disabled = true;

    try {
      const res = await fetch("/api/checkout", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ billing: "monthly" }),
      });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        btn.textContent = "Start Pro Trial";
        btn.disabled = false;
        alert(data.error || "Checkout unavailable. Please contact support.");
      }
    } catch {
      btn.textContent = "Start Pro Trial";
      btn.disabled = false;
    }
  });
</script>
