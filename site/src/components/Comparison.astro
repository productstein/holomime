---
/**
 * Comparison — How holomime differs from other tools.
 * Positioned between TrustBar and Pricing.
 */
const rows = [
  { capability: "Behavioral pattern detection", sub: "Over-apologizing, sycophancy, hedging, error spirals", holomime: true, langfuse: false, arize: "partial", guardrails: false },
  { capability: "Runtime guard middleware", sub: "Intercept + enforce behavioral alignment on every LLM call", holomime: true, langfuse: false, arize: false, guardrails: true },
  { capability: "Automated behavioral correction", sub: "Dual-LLM structured therapy sessions", holomime: true, langfuse: false, arize: false, guardrails: false },
  { capability: "Training data export", sub: "DPO, RLHF, Alpaca from every correction", holomime: true, langfuse: false, arize: false, guardrails: false },
  { capability: "Real-time neural visualization", sub: "3D brain with 9 behavioral regions", holomime: true, langfuse: false, arize: false, guardrails: false },
  { capability: "Personality spec portability", sub: ".personality.json across any model", holomime: true, langfuse: false, arize: false, guardrails: false },
  { capability: "Compliance audit trail", sub: "Tamper-evident logs, EU AI Act reports, monitoring certificates", holomime: true, langfuse: false, arize: false, guardrails: false },
  { capability: "Request tracing & latency", sub: "Trace spans, token counts, cost tracking", holomime: false, langfuse: true, arize: true, guardrails: false },
  { capability: "Agent self-healing via MCP", sub: "Agents diagnose and correct themselves", holomime: true, langfuse: false, arize: false, guardrails: false },
];
---

<section class="py-20 md:py-28 bg-white">
  <div class="mx-auto max-w-5xl px-6">
    <p class="text-center text-sm font-semibold tracking-wider uppercase text-[var(--color-p-violet)]">
      Why Not Just Guardrails?
    </p>
    <h2 class="mt-3 text-center text-3xl font-bold text-[var(--color-warm-text)] md:text-4xl">
      Guardrails filter. HoloMime guards and cures.
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-center text-[var(--color-warm-muted)]">
      Guardrails catch bad outputs after the fact. HoloMime guards in real-time and treats the root cause so bad behavior never returns.
    </p>

    <div class="mt-12 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b-2 border-[var(--color-warm-sand)]">
            <th class="pb-3 pr-4 font-semibold text-[var(--color-warm-text)] min-w-[200px]">Capability</th>
            <th class="pb-3 px-4 text-center font-bold text-[var(--color-p-violet)] min-w-[100px]">
              <span class="inline-flex items-center gap-1.5">
                <img src="/logo-icon.svg" alt="" class="h-4 w-4" />
                holomime
              </span>
            </th>
            <th class="pb-3 px-4 text-center font-medium text-[var(--color-warm-muted)] min-w-[90px]">Langfuse</th>
            <th class="pb-3 px-4 text-center font-medium text-[var(--color-warm-muted)] min-w-[90px]">Arize</th>
            <th class="pb-3 px-4 text-center font-medium text-[var(--color-warm-muted)] min-w-[90px]">Guardrails AI</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-[var(--color-warm-sand)]/60">
              <td class="py-3.5 pr-4">
                <span class="font-medium text-[var(--color-warm-text)]">{row.capability}</span>
                <span class="block text-xs text-[var(--color-warm-muted)] mt-0.5">{row.sub}</span>
              </td>
              <td class="py-3.5 px-4 text-center">
                {row.holomime === true ? (
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100">
                    <svg class="h-3 w-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  </span>
                ) : (
                  <span class="inline-block h-1 w-4 rounded-full bg-[var(--color-warm-sand)]"></span>
                )}
              </td>
              <td class="py-3.5 px-4 text-center">
                {row.langfuse === true ? (
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100">
                    <svg class="h-3 w-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  </span>
                ) : (
                  <span class="inline-block h-1 w-4 rounded-full bg-[var(--color-warm-sand)]"></span>
                )}
              </td>
              <td class="py-3.5 px-4 text-center">
                {row.arize === true ? (
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100">
                    <svg class="h-3 w-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  </span>
                ) : row.arize === "partial" ? (
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-amber-100">
                    <span class="text-[10px] font-bold text-amber-600">~</span>
                  </span>
                ) : (
                  <span class="inline-block h-1 w-4 rounded-full bg-[var(--color-warm-sand)]"></span>
                )}
              </td>
              <td class="py-3.5 px-4 text-center">
                {row.guardrails === true ? (
                  <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-emerald-100">
                    <svg class="h-3 w-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  </span>
                ) : (
                  <span class="inline-block h-1 w-4 rounded-full bg-[var(--color-warm-sand)]"></span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</section>
