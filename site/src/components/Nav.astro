---
import AuthModal from "./AuthModal.astro";

const user = Astro.locals.user;
const avatarUrl = user?.user_metadata?.avatar_url;
const displayName = user?.user_metadata?.full_name || user?.user_metadata?.name || user?.email?.split("@")[0] || "User";
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-warm-sand)] bg-white backdrop-blur-xl">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-[var(--color-warm-text)]">
      <img src="/logo-icon.svg" alt="holomime" class="h-8 w-8" />
      <span>holomime</span>
      <span class="text-[9px] text-[var(--color-warm-muted)] font-normal tracking-wider uppercase block -mt-0.5">behavioral intelligence</span>
    </a>

    <!-- Links -->
    <div class="hidden items-center gap-6 md:flex">
      <a href="/docs" class="text-sm text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]">Docs</a>
      <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-sm text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>

    <!-- Auth area -->
    <div class="flex items-center gap-3">
      {user ? (
        <!-- Logged in: avatar + dropdown -->
        <div class="relative" id="user-menu-wrap">
          <button id="user-menu-btn" class="flex items-center gap-2 rounded-full border border-[var(--color-warm-border)] bg-white px-3 py-1.5 text-sm font-medium text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-cream)]">
            {avatarUrl ? (
              <img src={avatarUrl} alt="" class="h-6 w-6 rounded-full" referrerpolicy="no-referrer" />
            ) : (
              <div class="flex h-6 w-6 items-center justify-center rounded-full bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] text-xs font-bold text-white">
                {displayName.charAt(0).toUpperCase()}
              </div>
            )}
            <span class="hidden sm:inline max-w-[120px] truncate">{displayName}</span>
            <svg class="h-4 w-4 text-[var(--color-warm-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <!-- Dropdown -->
          <div id="user-dropdown" class="absolute right-0 top-full mt-2 hidden w-48 rounded-xl border border-[var(--color-warm-border)] bg-white py-1.5 shadow-xl shadow-black/10">
            <div class="px-3 py-2 border-b border-[var(--color-warm-border)]">
              <p class="text-sm font-medium text-[var(--color-warm-text)] truncate">{displayName}</p>
              <p class="text-xs text-[var(--color-warm-muted)] truncate">{user.email}</p>
            </div>
            <a href="https://app.holomime.dev/dashboard" class="block px-3 py-2 text-sm text-[var(--color-warm-muted)] hover:bg-[var(--color-warm-cream)] hover:text-[var(--color-warm-text)] transition-colors">Dashboard</a>
            <a href="https://app.holomime.dev/agents" class="block px-3 py-2 text-sm text-[var(--color-warm-muted)] hover:bg-[var(--color-warm-cream)] hover:text-[var(--color-warm-text)] transition-colors">Agents</a>
            <a href="https://app.holomime.dev/settings" class="block px-3 py-2 text-sm text-[var(--color-warm-muted)] hover:bg-[var(--color-warm-cream)] hover:text-[var(--color-warm-text)] transition-colors">Settings</a>
            <button id="signout-btn" class="w-full text-left px-3 py-2 text-sm text-red-500 hover:bg-red-50 transition-colors">Sign Out</button>
          </div>
        </div>
      ) : (
        <!-- Logged out: Login + Get Started -->
        <>
          <a href="https://app.holomime.dev/login" class="text-sm font-medium text-[var(--color-warm-muted)] transition-colors hover:text-[var(--color-warm-text)]">
            Login
          </a>
          <button
            id="get-started-btn"
            class="rounded-full bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] px-5 py-2 text-sm font-semibold text-white shadow-lg shadow-[var(--color-p-coral)]/20 transition-all hover:shadow-xl hover:shadow-[var(--color-p-coral)]/30"
          >
            Get Started
          </button>
        </>
      )}
    </div>
  </div>
</nav>

<!-- Auth modal (only rendered when logged out) -->
{!user && <AuthModal />}

<script>
  import { createClient } from "../lib/supabase";

  // "Get Started" opens the auth modal
  const getStartedBtn = document.getElementById("get-started-btn");
  if (getStartedBtn) {
    getStartedBtn.addEventListener("click", () => {
      (window as any).openAuthModal?.();
    });
  }

  // User dropdown toggle
  const menuBtn = document.getElementById("user-menu-btn");
  const dropdown = document.getElementById("user-dropdown");
  if (menuBtn && dropdown) {
    menuBtn.addEventListener("click", () => {
      dropdown.classList.toggle("hidden");
    });
    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!document.getElementById("user-menu-wrap")?.contains(e.target as Node)) {
        dropdown.classList.add("hidden");
      }
    });
  }

  // Sign out
  const signoutBtn = document.getElementById("signout-btn");
  if (signoutBtn) {
    signoutBtn.addEventListener("click", async () => {
      const supabase = createClient();
      await supabase.auth.signOut();
      window.location.href = "/";
    });
  }
</script>
