---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
}

const {
  title = "holomime — Behavioral Intelligence for AI Agents",
  description = "Train agent minds through structured therapy. Diagnose behavioral drift. Fix it permanently. Deploy to any body.",
  ogImage = "https://holomime.com/og-image.png",
  noindex = false,
  structuredData,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OG -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="canonical" href={Astro.url.href} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@holomimeIQ" />
    <meta name="twitter:creator" content="@holomimeIQ" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "holomime",
      "url": "https://holomime.com",
      "logo": "https://holomime.com/logo-icon.svg",
      "description": "Behavioral intelligence for AI agents and humanoid robots.",
      "sameAs": [
        "https://github.com/productstein/holomime",
        "https://x.com/holomimeIQ",
        "https://www.npmjs.com/package/holomime"
      ]
    })} />
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
    <slot name="head" />

    <title>{title}</title>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>

