                View Details
              </button>
            </div>

            <!-- Agent 4: docs-assistant -->
            <div class="agent-card rounded-2xl border p-5 transition-all cursor-pointer" style="border-color: var(--color-warm-border, #e8e2d9); background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.04);" data-agent-name="docs-assistant" data-agent-status="active">
              <div class="flex items-center justify-between mb-3">
