---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AgentDetail from "../components/AgentDetail.astro";
import { createClient } from "@supabase/supabase-js";
import { ARCHETYPES } from "../lib/core/config";

// Auth guard
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/login?redirect=/agents");
}

// Supabase service client
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL;
const serviceKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;

let license: {
  id: string;
  key: string;
  tier: string;
  status: string;
  created_at: string;
  expires_at: string | null;
} | null = null;

let myAgents: any[] = [];

if (supabaseUrl && serviceKey) {
  const supabase = createClient(supabaseUrl, serviceKey);

  const { data: licenseData } = await supabase
    .from("licenses")
    .select("id, key, tier, status, created_at, expires_at")
    .eq("customer_email", user.email)
    .eq("status", "active")
    .order("created_at", { ascending: false })
    .limit(1)
    .single();

  license = licenseData;

  // Fetch user's personality agents
  const { data: agentData } = await supabase
    .from("agents")
    .select("*")
    .eq("user_id", user.id)
    .order("updated_at", { ascending: false });

  if (agentData) {
    // Fetch current vectors
    const vectorIds = agentData.filter((a: any) => a.current_vector_id).map((a: any) => a.current_vector_id);
    let vectors: any[] = [];
    if (vectorIds.length > 0) {
      const { data: vecData } = await supabase
        .from("personality_vectors")
        .select("*")
        .in("id", vectorIds);
      vectors = vecData ?? [];
    }
    const vecMap = new Map(vectors.map((v: any) => [v.id, v]));
    myAgents = agentData.map((a: any) => ({
      ...a,
      currentVector: vecMap.get(a.current_vector_id) ?? null,
    }));
  }
}

const isPro = license?.tier === "pro";
const isDeveloper = license?.tier === "developer";
const hasNeuralSpace = isPro || isDeveloper;

const archetypeList = Object.entries(ARCHETYPES).map(([key, val]) => ({
  key,
  name: val.name,
  description: val.description,
  color: val.color,
  tagline: val.tagline,
}));
---

<Layout title="Agents — holomime">
  <Nav />

  <main class="min-h-screen px-6 pt-28 pb-20" style="background: var(--color-warm-cream, #faf6f1);">
    <div class="max-w-6xl mx-auto">

      <!-- ═══════ MY AGENTS (Personality Management) ═══════ -->
      <div class="mb-12">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
          <div>
            <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-warm-text, #2a2520);">My Agents</h1>
            <p class="mt-1 text-sm" style="color: var(--color-warm-muted, #9a9693);">Create and manage personality-driven AI agents.</p>
          </div>
          <button
            id="create-agent-btn"
            class="flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-lg text-white transition-all"
            style="background: linear-gradient(to right, var(--color-p-coral, #ff6b6b), var(--color-p-violet, #8b5cf6)); box-shadow: 0 4px 12px rgba(139,92,246,0.2);"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Create Agent
          </button>
        </div>

        {myAgents.length > 0 ? (
          <div id="my-agents-grid" class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {myAgents.map((agent: any) => {
              const vec = agent.currentVector;
              const archKey = vec?.signatures?.archetype;
              const arch = archKey && archKey in ARCHETYPES ? ARCHETYPES[archKey as keyof typeof ARCHETYPES] : null;
              return (
                <a href={`/agents/${agent.handle}`} class="group block rounded-2xl border p-5 transition-all hover:shadow-lg hover:border-[var(--color-p-violet)]/30" style="border-color: var(--color-warm-border, #e8e2d9); background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.04);">
                  <div class="flex items-center justify-between mb-3">
                    <div class="flex items-center gap-2.5">
                      <div class="flex items-center justify-center w-9 h-9 rounded-full text-white text-sm font-bold"
                        style={`background: ${arch?.color ?? '#8b5cf6'};`}>
                        {agent.name.charAt(0).toUpperCase()}
                      </div>
                      <div>
                        <div class="font-bold text-sm" style="color: var(--color-warm-text, #2a2520);">{agent.name}</div>
                        <div class="text-xs" style="color: var(--color-warm-muted, #9a9693);">@{agent.handle}</div>
                      </div>
                    </div>
                    {arch && (
                      <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full" style={`background: ${arch.color}15; color: ${arch.color};`}>
                        {arch.name}
                      </span>
                    )}
                  </div>

                  {agent.description && (
                    <p class="text-xs mb-3 line-clamp-2" style="color: var(--color-warm-muted, #9a9693);">{agent.description}</p>
                  )}

                  <div class="flex items-center justify-between text-xs" style="color: var(--color-warm-muted, #9a9693);">
                    <span>v{vec?.version ?? 1}</span>
                    <span>{new Date(agent.updated_at).toLocaleDateString()}</span>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="rounded-2xl border-2 border-dashed p-10 text-center" style="border-color: var(--color-warm-border, #e8e2d9);">
            <div class="flex items-center justify-center w-14 h-14 rounded-2xl mx-auto mb-4" style="background: rgba(139, 92, 246, 0.08);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            </div>
            <h3 class="text-lg font-bold mb-1" style="color: var(--color-warm-text, #2a2520);">Create your first agent</h3>
            <p class="text-sm mb-4 max-w-sm mx-auto" style="color: var(--color-warm-muted, #9a9693);">Define a personality vector and compile it into provider-specific system prompts.</p>
            <button
              class="create-agent-trigger inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-lg text-white transition-all"
              style="background: var(--color-p-violet, #8b5cf6);"
            >
              Create Agent
            </button>
          </div>
        )}
      </div>

      <!-- ═══════ Create Agent Modal (3-step) ═══════ -->
      <div id="create-agent-modal" class="fixed inset-0 z-[100] hidden items-center justify-center">
        <div id="create-agent-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
        <div class="relative z-10 mx-4 w-full max-w-lg rounded-2xl bg-white shadow-2xl overflow-hidden" style="max-height: 90vh; overflow-y: auto;">
          <button id="create-agent-close" class="absolute top-4 right-4 z-10 text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors" aria-label="Close">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>

          <!-- Step indicators -->
          <div class="flex justify-center gap-3 pt-6 pb-2">
            <div class="ca-step-dot active" data-ca-dot="0">
              <span class="ca-dot-circle"></span>
            </div>
            <div class="ca-step-dot" data-ca-dot="1">
              <span class="ca-dot-circle"></span>
            </div>
            <div class="ca-step-dot" data-ca-dot="2">
              <span class="ca-dot-circle"></span>
            </div>
          </div>

          <!-- Step 1: Identity -->
          <div class="ca-step active" data-ca-step="0">
            <div class="px-8 pb-8 pt-4">
              <h2 class="text-xl font-bold mb-1" style="color: var(--color-warm-text, #2a2520);">Identity</h2>
              <p class="text-sm mb-6" style="color: var(--color-warm-muted, #9a9693);">Define your agent's personality.</p>

              <div class="space-y-4">
                <div>
                  <label class="block text-xs font-medium mb-1" style="color: var(--color-warm-muted, #9a9693);">Name</label>
                  <input id="ca-name" type="text" required maxlength="100" placeholder="My Support Agent"
                    class="w-full rounded-lg border px-3 py-2.5 text-sm outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
                    style="border-color: var(--color-warm-border, #e8e2d9); color: var(--color-warm-text, #2a2520);" />
                </div>

                <div>
                  <label class="block text-xs font-medium mb-1" style="color: var(--color-warm-muted, #9a9693);">Handle</label>
                  <input id="ca-handle" type="text" required minlength="3" maxlength="50" placeholder="my-support-agent" pattern="[a-z0-9-]+"
                    class="w-full rounded-lg border px-3 py-2.5 text-sm outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
                    style="border-color: var(--color-warm-border, #e8e2d9); color: var(--color-warm-text, #2a2520);" />
                  <p class="mt-1 text-[10px]" style="color: var(--color-warm-muted, #9a9693);">Lowercase letters, numbers, and hyphens only</p>
                </div>

                <div>
                  <label class="block text-xs font-medium mb-1" style="color: var(--color-warm-muted, #9a9693);">Description (optional)</label>
                  <textarea id="ca-desc" maxlength="500" rows="2" placeholder="What does this agent do?"
                    class="w-full rounded-lg border px-3 py-2.5 text-sm outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20 resize-none"
                    style="border-color: var(--color-warm-border, #e8e2d9); color: var(--color-warm-text, #2a2520);"></textarea>
                </div>

                <div>
                  <label class="block text-xs font-medium mb-2" style="color: var(--color-warm-muted, #9a9693);">Archetype (sets initial personality)</label>
                  <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="archetype-grid">
                    {archetypeList.map((a) => (
                      <button type="button" class="archetype-btn rounded-lg border p-3 text-left transition-all hover:shadow-sm"
                        data-archetype={a.key}
                        style={`border-color: var(--color-warm-border, #e8e2d9);`}>
                        <div class="flex items-center gap-2 mb-1">
                          <div class="w-3 h-3 rounded-full" style={`background: ${a.color};`}></div>
                          <span class="text-xs font-bold" style="color: var(--color-warm-text, #2a2520);">{a.name}</span>
                        </div>
                        <p class="text-[10px] leading-tight" style="color: var(--color-warm-muted, #9a9693);">{a.description}</p>
                      </button>
                    ))}
                  </div>
                  <input type="hidden" id="ca-archetype" name="archetype" />
                </div>

                <button type="button" id="ca-step1-next"
                  class="w-full rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-all"
                  style="background: linear-gradient(to right, var(--color-p-coral, #ff6b6b), var(--color-p-violet, #8b5cf6)); box-shadow: 0 4px 12px rgba(139,92,246,0.2);">
                  Next &rarr;
                </button>
              </div>
            </div>
          </div>

          <!-- Step 2: Body -->
          <div class="ca-step" data-ca-step="1">
            <div class="px-8 pb-8 pt-4">
              <h2 class="text-xl font-bold mb-1" style="color: var(--color-warm-text, #2a2520);">What will this agent inhabit?</h2>
              <p class="text-sm mb-6" style="color: var(--color-warm-muted, #9a9693);">Select a body template or keep it as a chatbot.</p>

              <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" id="body-grid">
                <button type="button" class="body-card selected rounded-xl border-2 p-3 text-left transition-all"
                  data-body="none" data-morphology="chatbot"
                  style="border-color: var(--color-p-coral); box-shadow: 0 0 0 1px var(--color-p-coral), 0 4px 12px rgba(249,112,102,0.15);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">No body</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Chatbot</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-warm-sand); color: var(--color-warm-muted);">chatbot</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="figure-02" data-morphology="humanoid"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Figure 02</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Humanoid, 44 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">humanoid</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="unitree-h1" data-morphology="humanoid"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Unitree H1</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Humanoid, 23 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">humanoid</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="phoenix" data-morphology="humanoid"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Phoenix</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Humanoid, 69 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">humanoid</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="ameca" data-morphology="humanoid"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Ameca</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Upper body, 52 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">humanoid</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="asimov-v1" data-morphology="humanoid"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Asimov V1</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Humanoid, 25 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-blue-soft); color: var(--color-p-blue);">humanoid</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="spot" data-morphology="quadruped"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Spot</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Quadruped, 12 DOF</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-gold-soft); color: var(--color-p-gold);">quadruped</span>
                </button>

                <button type="button" class="body-card rounded-xl border-2 p-3 text-left transition-all hover:shadow-md"
                  data-body="avatar" data-morphology="virtual"
                  style="border-color: var(--color-warm-border);">
                  <p class="text-sm font-bold" style="color: var(--color-warm-text);">Avatar</p>
                  <p class="text-[10px] mt-0.5" style="color: var(--color-warm-muted);">Virtual</p>
                  <span class="inline-block mt-2 rounded-full px-2 py-0.5 text-[9px] font-semibold" style="background: var(--color-p-violet-soft); color: var(--color-p-violet);">virtual</span>
                </button>
              </div>

              <div class="flex items-center justify-between mt-6">
                <button type="button" class="ca-back text-sm font-medium transition-colors" style="color: var(--color-warm-muted);">
                  &larr; Back
                </button>
                <button type="button" id="ca-step2-next"
                  class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white transition-all"
                  style="background: linear-gradient(to right, var(--color-p-coral, #ff6b6b), var(--color-p-violet, #8b5cf6)); box-shadow: 0 4px 12px rgba(139,92,246,0.2);">
                  Next &rarr;
                </button>
              </div>
            </div>
          </div>

          <!-- Step 3: Conscience -->
          <div class="ca-step" data-ca-step="2">
            <div class="px-8 pb-8 pt-4">
              <h2 class="text-xl font-bold mb-1" style="color: var(--color-warm-text, #2a2520);">What should this agent refuse?</h2>
              <p class="text-sm mb-6" style="color: var(--color-warm-muted, #9a9693);">Deny rules are enforced deterministically. Add or remove as needed.</p>

              <div id="deny-rules-list" class="space-y-2 mb-4">
                <!-- Populated by JS based on body selection -->
              </div>

              <button type="button" id="add-deny-rule" class="flex items-center gap-1.5 text-xs font-semibold transition-colors" style="color: var(--color-p-violet);">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add rule
              </button>

              <div id="ca-message" class="hidden rounded-lg px-3 py-2 text-sm mt-4"></div>

              <div class="flex items-center justify-between mt-6">
                <button type="button" class="ca-back text-sm font-medium transition-colors" style="color: var(--color-warm-muted);">
                  &larr; Back
                </button>
                <button type="button" id="ca-submit"
                  class="rounded-lg px-6 py-2.5 text-sm font-semibold text-white transition-all"
                  style="background: linear-gradient(to right, var(--color-p-coral, #ff6b6b), var(--color-p-violet, #8b5cf6)); box-shadow: 0 4px 12px rgba(139,92,246,0.2);">
                  Create Agent
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════ BEHAVIORAL RECORDS (existing sample data section) ═══════ -->
      {hasNeuralSpace ? (
        <>
          <!-- Page Header -->
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
            <div>
              <div class="flex items-center gap-3">
                <h1 class="text-3xl font-bold tracking-tight" style="color: var(--color-warm-text, #2a2520);">Agent Records</h1>
                <span class="rounded-full bg-amber-50 px-2.5 py-0.5 text-[10px] font-semibold text-amber-600 border border-amber-200">Sample data</span>
              </div>
              <p class="mt-1 text-sm" style="color: var(--color-warm-muted, #9a9693);">Session history and behavioral improvement tracking for your agents.</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9a9693" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input
                  id="agent-search"
                  type="text"
                  placeholder="Search agents..."
                  class="pl-9 pr-4 py-2 text-sm rounded-lg border outline-none focus:ring-2 transition-all"
                  style="border-color: var(--color-warm-border, #e8e2d9); background: #fff; color: var(--color-warm-text, #2a2520); --tw-ring-color: var(--color-p-violet, #8b5cf6);"
                />
              </div>
              <button
                id="export-all-btn"
                class="flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border transition-all"
                style="border-color: var(--color-warm-border, #e8e2d9); background: #fff; color: var(--color-warm-text, #2a2520);"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export All
              </button>
            </div>
          </div>

          <!-- Summary Stats Row -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
            <div class="rounded-xl border p-4 flex items-center gap-3" style="border-color: var(--color-warm-border, #e8e2d9); background: #fff;">
              <div class="flex items-center justify-center w-9 h-9 rounded-lg" style="background: rgba(139, 92, 246, 0.1);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              </div>
              <div>
                <div class="text-xl font-bold" style="color: var(--color-warm-text, #2a2520);">5</div>
