                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded" style="background: rgba(34,197,94,0.1); color: #16a34a;">Active</span>
              </div>

              <div class="flex items-end gap-3 mb-3">
                <span class="text-4xl font-extrabold leading-none" style="color: #10b981;">A</span>
                <span class="text-sm font-semibold mb-1" style="color: var(--color-warm-muted, #9a9693);">94/100</span>
              </div>

              <div class="flex items-center gap-1.5 mb-3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#9a9693" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 12 19 12"/></svg>
                <span class="text-xs font-semibold" style="color: #9a9693;">Stable</span>
              </div>

              <div class="flex items-center justify-between mb-3">
                <span class="text-xs" style="color: var(--color-warm-muted, #9a9693);">20 sessions</span>
                <span class="text-xs" style="color: var(--color-warm-muted, #9a9693);">Last seen: 1d ago</span>
              </div>

              <!-- Sparkline -->
              <div class="mb-3" style="height: 32px;">
                <svg viewBox="0 0 120 32" preserveAspectRatio="none" style="width:100%;height:100%;">
                  <polyline points="0,6 13,5 27,6 40,4 53,5 67,4 80,3 93,4 107,3 120,3" fill="none" stroke="#10b981" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="0,6 13,5 27,6 40,4 53,5 67,4 80,3 93,4 107,3 120,3 120,32 0,32" fill="rgba(16,185,129,0.08)" stroke="none"/>
                </svg>
              </div>

              <button class="view-details-btn w-full text-center text-xs font-semibold py-2 rounded-lg transition-all" style="background: var(--color-warm-cream, #faf6f1); color: var(--color-p-violet, #8b5cf6); border: 1px solid var(--color-warm-border, #e8e2d9);">
                View Details
              </button>
            </div>

            <!-- Agent 5: feedback-collector -->
            <div class="agent-card rounded-2xl border p-5 transition-all cursor-pointer" style="border-color: var(--color-warm-border, #e8e2d9); background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.04);" data-agent-name="feedback-collector" data-agent-status="idle">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class="font-bold text-sm" style="color: var(--color-warm-text, #2a2520);">feedback-collector</span>
                  <span class="inline-block w-2 h-2 rounded-full" style="background: #9ca3af;"></span>
                </div>
                <span class="text-xs font-medium px-2 py-0.5 rounded" style="background: rgba(156,163,175,0.1); color: #6b7280;">Idle</span>
              </div>

              <div class="flex items-end gap-3 mb-3">
                <span class="text-4xl font-extrabold leading-none" style="color: #06b6d4;">B</span>
                <span class="text-sm font-semibold mb-1" style="color: var(--color-warm-muted, #9a9693);">78/100</span>
              </div>

              <div class="flex items-center gap-1.5 mb-3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                <span class="text-xs font-semibold" style="color: #16a34a;">Recovering</span>
              </div>

              <div class="flex items-center justify-between mb-3">
                <span class="text-xs" style="color: var(--color-warm-muted, #9a9693);">6 sessions</span>
                <span class="text-xs" style="color: var(--color-warm-muted, #9a9693);">Last seen: 3d ago</span>
              </div>

              <!-- Sparkline -->
              <div class="mb-3" style="height: 32px;">
                <svg viewBox="0 0 120 32" preserveAspectRatio="none" style="width:100%;height:100%;">
                  <polyline points="0,24 15,22 30,20 45,18 60,16 75,13 90,11 105,9 120,8" fill="none" stroke="#16a34a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <polyline points="0,24 15,22 30,20 45,18 60,16 75,13 90,11 105,9 120,8 120,32 0,32" fill="rgba(16,185,129,0.08)" stroke="none"/>
                </svg>
              </div>

              <button class="view-details-btn w-full text-center text-xs font-semibold py-2 rounded-lg transition-all" style="background: var(--color-warm-cream, #faf6f1); color: var(--color-p-violet, #8b5cf6); border: 1px solid var(--color-warm-border, #e8e2d9);">
                View Details
              </button>
            </div>

          </div>
        </>
      ) : (
        <!-- Empty State (free tier / no data) -->
        <div class="flex flex-col items-center justify-center text-center py-32">
          <div class="flex items-center justify-center w-16 h-16 rounded-2xl mb-6" style="background: rgba(139, 92, 246, 0.08);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
              <line x1="12" y1="2" x2="12" y2="4"/>
              <line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="4" y2="12"/>
              <line x1="20" y1="12" x2="22" y2="12"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold mb-2" style="color: var(--color-warm-text, #2a2520);">No agent records yet</h2>
          <p class="text-sm max-w-sm mb-6" style="color: var(--color-warm-muted, #9a9693);">Connect your first agent to start tracking behavioral health.</p>
          <a
            href="/docs"
            class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded-lg text-white transition-all"
            style="background: var(--color-p-violet, #8b5cf6);"
          >
            Get Started
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      )}

    </div>
  </main>

  <AgentDetail />
  <Footer />
</Layout>

<script>
(function() {
  // ═══════════ SAMPLE AGENT DATA ═══════════
  const agents = [
    { name: 'support-agent-v2', status: 'active', grade: 'A-', score: 88, sessions: 12, trend: 'improving', lastSeen: '2h ago' },
    { name: 'onboarding-bot', status: 'active', grade: 'B+', score: 82, sessions: 8, trend: 'stable', lastSeen: '5h ago' },
    { name: 'sales-qualifier', status: 'alerting', grade: 'C', score: 64, sessions: 15, trend: 'declining', lastSeen: '30m ago' },
    { name: 'docs-assistant', status: 'active', grade: 'A', score: 94, sessions: 20, trend: 'stable', lastSeen: '1d ago' },
    { name: 'feedback-collector', status: 'idle', grade: 'B', score: 78, sessions: 6, trend: 'improving', lastSeen: '3d ago' },
  ];

  // ═══════════ SEARCH FILTER ═══════════
  const searchInput = document.getElementById('agent-search');
  const agentCards = document.querySelectorAll('.agent-card');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      agentCards.forEach(card => {
        const name = card.getAttribute('data-agent-name') || '';
        card.style.display = name.toLowerCase().includes(query) ? '' : 'none';
      });
    });
  }

  // ═══════════ VIEW DETAILS ═══════════
  document.querySelectorAll('.view-details-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.agent-card');
      const agentName = card.getAttribute('data-agent-name');
      const status = card.getAttribute('data-agent-status');
      document.dispatchEvent(new CustomEvent('open-agent-detail', {
        detail: { agentName, status }
      }));
    });
  });

  // Also open on card click
  agentCards.forEach(card => {
    card.addEventListener('click', () => {
      const agentName = card.getAttribute('data-agent-name');
      const status = card.getAttribute('data-agent-status');
      document.dispatchEvent(new CustomEvent('open-agent-detail', {
        detail: { agentName, status }
      }));
    });
  });

  // ═══════════ HOVER EFFECTS ═══════════
  agentCards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.boxShadow = '0 4px 12px rgba(0,0,0,0.08)';
      card.style.borderColor = 'rgba(139, 92, 246, 0.3)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.boxShadow = '0 1px 2px rgba(0,0,0,0.04)';
      card.style.borderColor = 'var(--color-warm-border, #e8e2d9)';
    });
  });

  // ═══════════ CREATE AGENT MODAL ═══════════
  const createModal = document.getElementById('create-agent-modal');
  const createBackdrop = document.getElementById('create-agent-backdrop');
  const createCloseBtn = document.getElementById('create-agent-close');
  const createForm = document.getElementById('create-agent-form');
  const createMsg = document.getElementById('ca-message');
  const archetypeBtns = document.querySelectorAll('.archetype-btn');
  const archetypeInput = document.getElementById('ca-archetype');

  function openCreateModal() {
    if (createModal) {
      createModal.classList.remove('hidden');
      createModal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  }
  function closeCreateModal() {
    if (createModal) {
      createModal.classList.add('hidden');
      createModal.classList.remove('flex');
      document.body.style.overflow = '';
      if (createMsg) createMsg.classList.add('hidden');
    }
  }

  document.getElementById('create-agent-btn')?.addEventListener('click', openCreateModal);
  document.querySelectorAll('.create-agent-trigger').forEach(btn => btn.addEventListener('click', openCreateModal));
  createBackdrop?.addEventListener('click', closeCreateModal);
  createCloseBtn?.addEventListener('click', closeCreateModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && createModal && !createModal.classList.contains('hidden')) closeCreateModal();
  });

  // Archetype selection
  let selectedArchetype = '';
  archetypeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      archetypeBtns.forEach(b => {
        b.style.borderColor = 'var(--color-warm-border, #e8e2d9)';
        b.style.background = '';
      });
      btn.style.borderColor = '#8b5cf6';
      btn.style.background = 'rgba(139,92,246,0.05)';
      selectedArchetype = btn.getAttribute('data-archetype') || '';
      if (archetypeInput) archetypeInput.value = selectedArchetype;
    });
  });

  // Auto-generate handle from name
  const nameInput = document.getElementById('ca-name');
  const handleInput = document.getElementById('ca-handle');
  let handleEdited = false;
  handleInput?.addEventListener('input', () => { handleEdited = true; });
  nameInput?.addEventListener('input', () => {
    if (!handleEdited && handleInput) {
      handleInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 50);
    }
  });

  createForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = (document.getElementById('ca-name')).value.trim();
    const handle = (document.getElementById('ca-handle')).value.trim();
    const description = (document.getElementById('ca-desc')).value.trim();
    const submitBtn = document.getElementById('ca-submit');

    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch('/api/agents', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          handle,
          description: description || undefined,
          archetype: selectedArchetype || undefined,
        }),
      });
      const data = await res.json();
      if (!res.ok) {
        if (createMsg) {
          createMsg.textContent = data.error || 'Failed to create agent';
          createMsg.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700');
          createMsg.classList.add('bg-red-50', 'text-red-700');
        }
        return;
      }
      // Redirect to agent detail
      window.location.href = `/agents/${handle}`;
    } catch (err) {
      if (createMsg) {
        createMsg.textContent = 'Network error';
        createMsg.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700');
        createMsg.classList.add('bg-red-50', 'text-red-700');
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  // ═══════════ EXPORT ALL ═══════════
  const exportBtn = document.getElementById('export-all-btn');
  if (exportBtn) {
    exportBtn.addEventListener('click', () => {
      const exportData = {
        exportedAt: new Date().toISOString(),
        totalAgents: agents.length,
        averageScore: Math.round(agents.reduce((sum, a) => sum + a.score, 0) / agents.length),
        agents: agents.map(a => ({
          name: a.name,
          status: a.status,
          grade: a.grade,
          score: a.score,
          sessions: a.sessions,
          trend: a.trend,
          lastSeen: a.lastSeen,
        }))
      };

      const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `agent-records-${new Date().toISOString().slice(0, 10)}.json`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    });
  }
})();
</script>
