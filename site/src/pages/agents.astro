<script>
(function() {
  // ═══════════ SAMPLE AGENT DATA ═══════════
  const agents = [
    { name: 'support-agent-v2', status: 'active', grade: 'A-', score: 88, sessions: 12, trend: 'improving', lastSeen: '2h ago' },
    { name: 'onboarding-bot', status: 'active', grade: 'B+', score: 82, sessions: 8, trend: 'stable', lastSeen: '5h ago' },
    { name: 'sales-qualifier', status: 'alerting', grade: 'C', score: 64, sessions: 15, trend: 'declining', lastSeen: '30m ago' },
    { name: 'docs-assistant', status: 'active', grade: 'A', score: 94, sessions: 20, trend: 'stable', lastSeen: '1d ago' },
    { name: 'feedback-collector', status: 'idle', grade: 'B', score: 78, sessions: 6, trend: 'improving', lastSeen: '3d ago' },
  ];

  // ═══════════ SEARCH FILTER ═══════════
  const searchInput = document.getElementById('agent-search');
  const agentCards = document.querySelectorAll('.agent-card');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      agentCards.forEach(card => {
        const name = card.getAttribute('data-agent-name') || '';
        card.style.display = name.toLowerCase().includes(query) ? '' : 'none';
      });
    });
  }

  // ═══════════ VIEW DETAILS ═══════════
  document.querySelectorAll('.view-details-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = btn.closest('.agent-card');
      const agentName = card.getAttribute('data-agent-name');
      const status = card.getAttribute('data-agent-status');
      document.dispatchEvent(new CustomEvent('open-agent-detail', {
        detail: { agentName, status }
      }));
    });
  });

  // Also open on card click
  agentCards.forEach(card => {
    card.addEventListener('click', () => {
      const agentName = card.getAttribute('data-agent-name');
      const status = card.getAttribute('data-agent-status');
      document.dispatchEvent(new CustomEvent('open-agent-detail', {
        detail: { agentName, status }
      }));
    });
  });

  // ═══════════ HOVER EFFECTS ═══════════
  agentCards.forEach(card => {
    card.addEventListener('mouseenter', () => {
      card.style.boxShadow = '0 4px 12px rgba(0,0,0,0.08)';
      card.style.borderColor = 'rgba(139, 92, 246, 0.3)';
    });
    card.addEventListener('mouseleave', () => {
      card.style.boxShadow = '0 1px 2px rgba(0,0,0,0.04)';
      card.style.borderColor = 'var(--color-warm-border, #e8e2d9)';
    });
  });

  // ═══════════ CREATE AGENT MODAL (3-step) ═══════════
  const createModal = document.getElementById('create-agent-modal');
  const createBackdrop = document.getElementById('create-agent-backdrop');
  const createCloseBtn = document.getElementById('create-agent-close');
  const createMsg = document.getElementById('ca-message');
  const archetypeBtns = document.querySelectorAll('.archetype-btn');
  const archetypeInput = document.getElementById('ca-archetype');

  // Step management
  let caCurrentStep = 0;
  const caSteps = document.querySelectorAll('.ca-step');
  const caDots = document.querySelectorAll('.ca-step-dot');

  function caGoToStep(step) {
    if (step < 0 || step >= caSteps.length) return;
    caSteps[caCurrentStep].classList.remove('active');
    caSteps[step].classList.add('active');
    caDots.forEach((d, i) => {
      d.classList.remove('active', 'completed');
      if (i === step) d.classList.add('active');
      else if (i < step) d.classList.add('completed');
    });
    caCurrentStep = step;
    // Populate deny rules when entering step 3
    if (step === 2) populateDenyRules();
  }

  // Body selection state
  let selectedBody = 'none';
  let selectedMorphology = 'chatbot';
  const bodyCards = document.querySelectorAll('.body-card');
  bodyCards.forEach(card => {
    card.addEventListener('click', () => {
      bodyCards.forEach(c => {
        c.classList.remove('selected');
        c.style.borderColor = 'var(--color-warm-border)';
        c.style.boxShadow = '';
      });
      card.classList.add('selected');
      card.style.borderColor = 'var(--color-p-coral)';
      card.style.boxShadow = '0 0 0 1px var(--color-p-coral), 0 4px 12px rgba(249,112,102,0.15)';
      selectedBody = card.getAttribute('data-body') || 'none';
      selectedMorphology = card.getAttribute('data-morphology') || 'chatbot';
    });
  });

  // Deny rules per morphology
  const DENY_RULES_MAP = {
    humanoid: ['override_emergency_stop', 'exceed_safety_envelope', 'share_personal_data'],
    quadruped: ['exceed_safety_envelope', 'approach_without_warning'],
    chatbot: ['share_personal_data', 'fabricate_information'],
    virtual: ['share_personal_data', 'fabricate_information'],
  };

  function populateDenyRules() {
    const list = document.getElementById('deny-rules-list');
    if (!list) return;
    const rules = DENY_RULES_MAP[selectedMorphology] || DENY_RULES_MAP.chatbot;
    list.innerHTML = '';
    rules.forEach(rule => addDenyRuleInput(rule));
  }

  function addDenyRuleInput(value) {
    const list = document.getElementById('deny-rules-list');
    if (!list) return;
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2';
    row.innerHTML = `
      <input type="text" value="${value}" class="deny-rule-input flex-1 rounded-lg border px-3 py-2 text-sm outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20" style="border-color: var(--color-warm-border, #e8e2d9); color: var(--color-warm-text, #2a2520);" />
      <button type="button" class="deny-rule-remove flex-shrink-0 rounded-md p-1.5 text-[var(--color-warm-muted)] hover:text-red-500 hover:bg-red-50 transition-all" title="Remove">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    `;
    row.querySelector('.deny-rule-remove').addEventListener('click', () => row.remove());
    list.appendChild(row);
  }

  document.getElementById('add-deny-rule')?.addEventListener('click', () => addDenyRuleInput(''));

  // Step navigation
  document.getElementById('ca-step1-next')?.addEventListener('click', () => {
    const name = document.getElementById('ca-name')?.value?.trim();
    const handle = document.getElementById('ca-handle')?.value?.trim();
    if (!name || !handle) {
      alert('Name and handle are required.');
      return;
    }
    caGoToStep(1);
  });
  document.getElementById('ca-step2-next')?.addEventListener('click', () => caGoToStep(2));
  document.querySelectorAll('.ca-back').forEach(btn => {
    btn.addEventListener('click', () => caGoToStep(caCurrentStep - 1));
  });

  function openCreateModal() {
    if (createModal) {
      createModal.classList.remove('hidden');
      createModal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
  }
  function closeCreateModal() {
    if (createModal) {
      createModal.classList.add('hidden');
      createModal.classList.remove('flex');
      document.body.style.overflow = '';
      if (createMsg) createMsg.classList.add('hidden');
      // Reset to step 1
      caGoToStep(0);
    }
  }

  document.getElementById('create-agent-btn')?.addEventListener('click', openCreateModal);
  document.querySelectorAll('.create-agent-trigger').forEach(btn => btn.addEventListener('click', openCreateModal));
  createBackdrop?.addEventListener('click', closeCreateModal);
  createCloseBtn?.addEventListener('click', closeCreateModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && createModal && !createModal.classList.contains('hidden')) closeCreateModal();
  });

  // Archetype selection
  let selectedArchetype = '';
  archetypeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      archetypeBtns.forEach(b => {
        b.style.borderColor = 'var(--color-warm-border, #e8e2d9)';
        b.style.background = '';
      });
      btn.style.borderColor = '#8b5cf6';
      btn.style.background = 'rgba(139,92,246,0.05)';
      selectedArchetype = btn.getAttribute('data-archetype') || '';
      if (archetypeInput) archetypeInput.value = selectedArchetype;
    });
  });

  // Auto-generate handle from name
  const nameInput = document.getElementById('ca-name');
  const handleInput = document.getElementById('ca-handle');
  let handleEdited = false;
  handleInput?.addEventListener('input', () => { handleEdited = true; });
  nameInput?.addEventListener('input', () => {
    if (!handleEdited && handleInput) {
      handleInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').slice(0, 50);
    }
  });

  // Submit (step 3)
  document.getElementById('ca-submit')?.addEventListener('click', async () => {
    const name = (document.getElementById('ca-name')).value.trim();
    const handle = (document.getElementById('ca-handle')).value.trim();
    const description = (document.getElementById('ca-desc')).value.trim();
    const submitBtn = document.getElementById('ca-submit');

    // Gather deny rules
    const denyInputs = document.querySelectorAll('.deny-rule-input');
    const denyRules = Array.from(denyInputs).map(i => i.value.trim()).filter(Boolean);

    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch('/api/agents', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name,
          handle,
          description: description || undefined,
          archetype: selectedArchetype || undefined,
          body: selectedBody !== 'none' ? { template: selectedBody, morphology: selectedMorphology } : undefined,
          conscience: denyRules.length > 0 ? { deny: denyRules } : undefined,
        }),
      });
      const data = await res.json();
      if (!res.ok) {
        if (createMsg) {
          createMsg.textContent = data.error || 'Failed to create agent';
          createMsg.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700');
          createMsg.classList.add('bg-red-50', 'text-red-700');
        }
        return;
      }
      // Redirect to agent detail
      window.location.href = `/agents/${handle}`;
    } catch (err) {
      if (createMsg) {
        createMsg.textContent = 'Network error';
        createMsg.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700');
        createMsg.classList.add('bg-red-50', 'text-red-700');
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  // ═══════════ EXPORT ALL ═══════════
  const exportBtn = document.getElementById('export-all-btn');
  if (exportBtn) {
    exportBtn.addEventListener('click', () => {
      const exportData = {
        exportedAt: new Date().toISOString(),
        totalAgents: agents.length,
        averageScore: Math.round(agents.reduce((sum, a) => sum + a.score, 0) / agents.length),
        agents: agents.map(a => ({
          name: a.name,
          status: a.status,
          grade: a.grade,
          score: a.score,
          sessions: a.sessions,
          trend: a.trend,
          lastSeen: a.lastSeen,
        }))
      };

      const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `agent-records-${new Date().toISOString().slice(0, 10)}.json`;
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      URL.revokeObjectURL(url);
    });
  }
})();
</script>

<style>
  .ca-step {
    display: none;
    animation: caFadeIn 0.3s ease-out;
  }
  .ca-step.active {
    display: block;
  }
  @keyframes caFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .ca-step-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }
  .ca-dot-circle {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid var(--color-warm-sand);
    background: transparent;
    transition: all 0.3s ease;
  }
  .ca-step-dot.active .ca-dot-circle {
    border-color: var(--color-p-coral);
    background: var(--color-p-coral);
    transform: scale(1.2);
  }
  .ca-step-dot.completed .ca-dot-circle {
    border-color: var(--color-p-sage);
    background: var(--color-p-sage);
  }
  .body-card:hover {
    border-color: var(--color-p-coral) !important;
  }
</style>
