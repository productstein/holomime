---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Reset Password — holomime" noindex={true}>
  <Nav />

  <main class="flex min-h-screen items-center justify-center bg-[var(--color-warm-cream)] px-6 pt-20 pb-20">
    <div class="w-full max-w-md">
      <div class="rounded-2xl bg-white p-8 shadow-xl shadow-black/5 border border-[var(--color-warm-border)]">
        <div class="text-center mb-6">
          <img src="/logo-icon.svg" alt="" class="mx-auto mb-3 h-10 w-10" />
          <h1 class="text-xl font-bold text-[var(--color-warm-text)]">Set new password</h1>
          <p id="reset-subtitle" class="mt-1 text-sm text-[var(--color-warm-muted)]">Verifying your reset link...</p>
        </div>

        <!-- Loading state -->
        <div id="reset-loading" class="py-8 text-center">
          <div class="inline-block h-6 w-6 animate-spin rounded-full border-2 border-[var(--color-p-violet)] border-t-transparent"></div>
        </div>

        <!-- Error state -->
        <div id="reset-error" class="hidden">
          <div class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700 mb-4">
            <p id="reset-error-text"></p>
          </div>
          <a href="/login" class="block w-full rounded-lg border border-[var(--color-warm-border)] px-4 py-2.5 text-center text-sm font-medium text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-cream)]">
            Back to login
          </a>
        </div>

        <!-- Form -->
        <form id="reset-form" class="hidden space-y-3">
          <div>
            <label for="new-password" class="block text-xs font-medium text-[var(--color-warm-muted)] mb-1">New password</label>
            <input
              id="new-password"
              type="password"
              required
              minlength="8"
              placeholder="At least 8 characters"
              class="w-full rounded-lg border border-[var(--color-warm-border)] bg-white px-3 py-2.5 text-sm text-[var(--color-warm-text)] placeholder:text-[var(--color-warm-muted)]/50 outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
            />
          </div>
          <div>
            <label for="confirm-password" class="block text-xs font-medium text-[var(--color-warm-muted)] mb-1">Confirm password</label>
            <input
              id="confirm-password"
              type="password"
              required
              minlength="8"
              placeholder="Repeat your password"
              class="w-full rounded-lg border border-[var(--color-warm-border)] bg-white px-3 py-2.5 text-sm text-[var(--color-warm-text)] placeholder:text-[var(--color-warm-muted)]/50 outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
            />
          </div>

          <div id="reset-message" class="hidden rounded-lg px-3 py-2 text-sm"></div>

          <button
            type="submit"
            class="btn-primary w-full rounded-lg"
          >
            Update Password
          </button>
        </form>

        <!-- Debug info (hidden, for troubleshooting) -->
        <pre id="reset-debug" class="hidden mt-4 text-xs text-red-400 bg-red-50 p-2 rounded overflow-auto max-h-32"></pre>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { createClient } from "../lib/supabase";

  const supabase = createClient();
  const form = document.getElementById("reset-form") as HTMLFormElement;
  const loading = document.getElementById("reset-loading")!;
  const errorDiv = document.getElementById("reset-error")!;
  const errorText = document.getElementById("reset-error-text")!;
  const subtitle = document.getElementById("reset-subtitle")!;
  const messageEl = document.getElementById("reset-message")!;
  const debugEl = document.getElementById("reset-debug")!;

  function debug(msg: string) {
    console.log("[reset-password]", msg);
    debugEl.textContent += msg + "\n";
  }

  function showMessage(text: string, type: "error" | "success") {
    messageEl.textContent = text;
    messageEl.classList.remove("hidden", "bg-red-50", "text-red-700", "bg-emerald-50", "text-emerald-700");
    messageEl.classList.add(type === "error" ? "bg-red-50" : "bg-emerald-50", type === "error" ? "text-red-700" : "text-emerald-700");
  }

  function showError(msg: string) {
    loading.classList.add("hidden");
    form.classList.add("hidden");
    errorText.textContent = msg;
    errorDiv.classList.remove("hidden");
    subtitle.textContent = "Unable to reset password";
    // Show debug info in dev
    if (window.location.hostname === "localhost") {
      debugEl.classList.remove("hidden");
    }
  }

  function showForm() {
    loading.classList.add("hidden");
    errorDiv.classList.add("hidden");
    form.classList.remove("hidden");
    subtitle.textContent = "Enter your new password below";
  }

  async function init() {
    const url = new URL(window.location.href);
    const code = url.searchParams.get("code");
    const hash = window.location.hash;

    debug(`URL: ${url.pathname}${url.search}${hash ? "#..." : ""}`);
    debug(`code param: ${code ? "yes" : "no"}`);
    debug(`hash: ${hash ? hash.substring(0, 50) + "..." : "none"}`);

    // Strategy 1: PKCE code in query params (from Supabase redirect)
    if (code) {
      debug("Exchanging code for session...");
      const { data, error } = await supabase.auth.exchangeCodeForSession(code);
      if (error) {
        debug(`Code exchange error: ${error.message}`);
        // Code exchange failed — might be wrong browser or expired
        showError(`Reset link error: ${error.message}. Please request a new reset link.`);
        return;
      }
      debug(`Code exchanged! Event: ${data.session ? "session" : "no session"}`);
      if (data.session) {
        showForm();
        return;
      }
    }

    // Strategy 2: Hash fragment (implicit flow — access_token in URL hash)
    if (hash && (hash.includes("access_token") || hash.includes("type=recovery"))) {
      debug("Detected hash fragment, waiting for onAuthStateChange...");
      // The Supabase browser client auto-processes hash fragments
      // Wait for onAuthStateChange to fire
      const resolved = await new Promise<boolean>((resolve) => {
        const timeout = setTimeout(() => resolve(false), 5000);
        supabase.auth.onAuthStateChange((event, session) => {
          debug(`Auth event: ${event}`);
          if ((event === "PASSWORD_RECOVERY" || event === "SIGNED_IN") && session) {
            clearTimeout(timeout);
            resolve(true);
          }
        });
      });

      if (resolved) {
        showForm();
        return;
      }
      debug("Hash flow timed out");
    }

    // Strategy 3: Already have a session (e.g., came from callback redirect)
    debug("Checking existing session...");
    const { data } = await supabase.auth.getSession();
    if (data.session) {
      debug("Found existing session");
      showForm();
      return;
    }

    debug("No session found by any method");
    showError("This reset link has expired or is invalid. Please request a new one from the login page.");
  }

  init().catch((err) => {
    debug(`Uncaught error: ${err}`);
    showError(`Something went wrong: ${err.message || err}`);
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const password = (document.getElementById("new-password") as HTMLInputElement).value;
    const confirm = (document.getElementById("confirm-password") as HTMLInputElement).value;

    if (password !== confirm) {
      showMessage("Passwords do not match.", "error");
      return;
    }

    if (password.length < 8) {
      showMessage("Password must be at least 8 characters.", "error");
      return;
    }

    const { error } = await supabase.auth.updateUser({ password });
    if (error) {
      showMessage(error.message, "error");
    } else {
      showMessage("Password updated! Redirecting...", "success");
      setTimeout(() => { window.location.href = "/dashboard"; }, 1500);
    }
  });
</script>
