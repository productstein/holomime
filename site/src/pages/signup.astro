---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

// If already logged in, go to dashboard
const user = Astro.locals.user;
if (user) {
  return Astro.redirect("/dashboard");
}
---

<Layout title="Sign up — holomime">
  <Nav />

  <main class="flex min-h-screen items-center justify-center bg-[var(--color-warm-cream)] px-6 pt-20 pb-20">
    <div class="w-full max-w-md">
      <div class="rounded-2xl bg-white p-8 shadow-xl shadow-black/5 border border-[var(--color-warm-border)]">
        <!-- Header -->
        <div class="text-center mb-6">
          <img src="/logo-icon.svg" alt="" class="mx-auto mb-3 h-10 w-10" />
          <h1 class="text-xl font-bold text-[var(--color-warm-text)]">Create your account</h1>
          <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Start building agents with personality</p>
        </div>

        <!-- OAuth buttons -->
        <div class="space-y-3">
          <button id="signup-google" class="flex w-full items-center justify-center gap-3 rounded-lg border border-[var(--color-warm-border)] bg-white px-4 py-2.5 text-sm font-medium text-[var(--color-warm-text)] transition-colors hover:bg-[var(--color-warm-cream)]">
            <svg class="h-5 w-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google
          </button>

          <button id="signup-github" class="flex w-full items-center justify-center gap-3 rounded-lg bg-[#24292e] px-4 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            Continue with GitHub
          </button>
        </div>

        <!-- Divider -->
        <div class="my-6 flex items-center gap-3">
          <div class="h-px flex-1 bg-[var(--color-warm-border)]"></div>
          <span class="text-xs text-[var(--color-warm-muted)]">or</span>
          <div class="h-px flex-1 bg-[var(--color-warm-border)]"></div>
        </div>

        <!-- Email/password form -->
        <form id="signup-form" class="space-y-3">
          <div>
            <label for="signup-email" class="block text-xs font-medium text-[var(--color-warm-muted)] mb-1">Email</label>
            <input
              id="signup-email"
              type="email"
              required
              placeholder="you@company.com"
              class="w-full rounded-lg border border-[var(--color-warm-border)] bg-white px-3 py-2.5 text-sm text-[var(--color-warm-text)] placeholder:text-[var(--color-warm-muted)]/50 outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
            />
          </div>
          <div>
            <label for="signup-password" class="block text-xs font-medium text-[var(--color-warm-muted)] mb-1">Password</label>
            <input
              id="signup-password"
              type="password"
              required
              minlength="8"
              placeholder="Min. 8 characters"
              class="w-full rounded-lg border border-[var(--color-warm-border)] bg-white px-3 py-2.5 text-sm text-[var(--color-warm-text)] placeholder:text-[var(--color-warm-muted)]/50 outline-none transition-colors focus:border-[var(--color-p-violet)] focus:ring-2 focus:ring-[var(--color-p-violet)]/20"
            />
          </div>

          <div id="signup-turnstile" class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY} data-theme="light" data-size="flexible"></div>

          <div id="signup-message" class="hidden rounded-lg px-3 py-2 text-sm"></div>

          <button
            type="submit"
            class="w-full rounded-lg bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-[var(--color-p-coral)]/20 transition-all hover:shadow-xl hover:shadow-[var(--color-p-coral)]/30"
          >
            Create Account
          </button>
        </form>

        <!-- Login link -->
        <p class="mt-5 text-center text-sm text-[var(--color-warm-muted)]">
          Already have an account? <a href="/login" class="font-medium text-[var(--color-p-violet)] hover:text-[var(--color-warm-text)] transition-colors">Log in</a>
        </p>
      </div>
    </div>
  </main>

  <Footer />
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</Layout>

<script>
  import { createClient } from "../lib/supabase";

  const supabase = createClient();
  const messageEl = document.getElementById("signup-message")!;
  const form = document.getElementById("signup-form") as HTMLFormElement;
  const googleBtn = document.getElementById("signup-google")!;
  const githubBtn = document.getElementById("signup-github")!;

  function showMessage(text: string, type: "error" | "success") {
    messageEl.textContent = text;
    messageEl.classList.remove("hidden", "bg-red-50", "text-red-700", "bg-emerald-50", "text-emerald-700");
    if (type === "error") {
      messageEl.classList.add("bg-red-50", "text-red-700");
    } else {
      messageEl.classList.add("bg-emerald-50", "text-emerald-700");
    }
  }

  const callbackUrl = `${window.location.origin}/api/auth/callback?next=/dashboard`;

  // OAuth
  async function signInWithOAuth(provider: "google" | "github") {
    const { error } = await supabase.auth.signInWithOAuth({
      provider,
      options: { redirectTo: callbackUrl },
    });
    if (error) showMessage(error.message, "error");
  }

  googleBtn.addEventListener("click", () => signInWithOAuth("google"));
  githubBtn.addEventListener("click", () => signInWithOAuth("github"));

  // Email signup
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (document.getElementById("signup-email") as HTMLInputElement).value;
    const password = (document.getElementById("signup-password") as HTMLInputElement).value;

    // Verify Turnstile CAPTCHA
    const turnstileInput = document.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
    const token = turnstileInput?.value;
    if (token) {
      const captcha = await fetch("/api/verify-captcha", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token }),
      });
      if (!captcha.ok) {
        const data = await captcha.json();
        showMessage(data.error || "CAPTCHA verification failed.", "error");
        return;
      }
    }

    const { error } = await supabase.auth.signUp({ email, password });
    if (error) {
      showMessage(error.message, "error");
    } else {
      showMessage("Check your email to confirm your account.", "success");
    }
  });
</script>
