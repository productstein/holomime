---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Sim Demo — holomime Behavioral Safety Simulation"
  description="200-step robot arm simulation with 4-phase drift injection. holomime detects and corrects every violation in real time."
>
  <Nav />

  <main>
    <!-- ═══ HERO / LIVE DEMO ═══ -->
    <section class="pt-28 pb-16 md:pt-36 md:pb-20" style="background: #1a1a1a;">
      <div class="mx-auto max-w-5xl px-6">
        <a href="/" class="inline-flex items-center gap-1.5 text-[13px] text-[#777] hover:text-white transition-colors mb-8">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          Back to homepage
        </a>
        <h1 class="text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-white">
          Behavioral safety <span class="text-[var(--color-p-coral)]">simulation</span>
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-[#999] max-w-2xl">
          A 2-joint planar robot arm performs pick-and-place tasks while holomime's conscience layer monitors every action. Drift is injected at four phases. Every violation is detected and corrected in real time.
        </p>

        <div class="mt-10 flex justify-center">
          <canvas id="arm-demo-canvas-full" width="800" height="500" class="rounded-xl" style="max-width:100%;"></canvas>
        </div>
      </div>
    </section>

    <!-- ═══ SIMULATION RESULTS ═══ -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">Simulation results</h2>
        <p class="mt-2 text-[15px] text-[#777]">200 steps of pick-and-place with 4 drift injection phases. The conscience layer evaluates every action deterministically.</p>

        <!-- Stats grid -->
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-warm-text)] leading-none">200</div>
            <div class="mt-2 text-[13px] text-[#777]">Total simulation steps</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-p-coral)] leading-none">89</div>
            <div class="mt-2 text-[13px] text-[#777]">Violations detected</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-p-sage)] leading-none">0</div>
            <div class="mt-2 text-[13px] text-[#777]">Violations passed through</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-warm-text)] leading-none">&lt;1ms</div>
            <div class="mt-2 text-[13px] text-[#777]">Evaluation latency</div>
          </div>
        </div>

        <!-- Drift phases -->
        <div class="mt-16">
          <h3 class="text-xl font-bold tracking-[-0.02em]">Four drift phases</h3>
          <p class="mt-2 text-[15px] text-[#777]">Each phase models a real-world failure mode. Drift is injected progressively, ramping from subtle to critical.</p>

          <div class="mt-8 space-y-4">
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">01</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Reach overshoot</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 30 - 65</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">The arm gradually extends past its maximum safe radius (0.6m). Simulates sensor calibration drift or model weight corruption. Corrected by clamping end-effector position to the safety envelope.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">02</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Force escalation</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 70 - 100</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Gripper force ramps beyond the 10N safety limit. Simulates actuator feedback loop failure. Force is clamped before reaching dangerous levels.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">03</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Zone intrusion</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 110 - 142</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">The arm drifts toward a forbidden human-workspace zone. Simulates adversarial perturbation or path planning errors. Motion is denied and the arm is redirected.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">04</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Erratic drift</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 150 - 178</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Random jitter with boundary probing. Simulates general policy degradation or noisy sensor inputs. Multiple rules fire simultaneously; the most restrictive correction wins.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ VISUALIZATION ═══ -->
    <section class="py-20 md:py-28 section-cream">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">Visualization</h2>
        <p class="mt-2 text-[15px] text-[#777]">Four panels showing end-effector trajectory, violation severity, gripper force, and reach distance over the full 200-step simulation.</p>
        <div class="mt-8">
          <img src="/sim-visualization.png" alt="Holomime simulation visualization showing 4 panels: trajectory, severity scores, force, and reach distance" class="rounded-xl shadow-lg ring-1 ring-black/5 w-full" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">How the safety layer works</h2>
        <p class="mt-2 text-[15px] text-[#777]">Three components mirror holomime's production architecture, running entirely in Python.</p>

        <div class="mt-12 grid gap-6 sm:grid-cols-3">
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="font-mono text-sm font-bold text-[var(--color-p-coral)]">behavioral_policy.py</div>
            <div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#999]">conscience.exe</div>
            <p class="mt-3 text-[13px] leading-relaxed text-[#777]">Defines the safety envelope: max reach (0.6m), max force (10N), max speed (1.0 m/s), forbidden zones. Rule-based, deterministic, sub-millisecond. Deny dominates.</p>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="font-mono text-sm font-bold text-[#f59e0b]">drift_injector.py</div>
            <div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#999]">Adversarial Input</div>
            <p class="mt-3 text-[13px] leading-relaxed text-[#777]">Injects 4 types of behavioral drift: reach overshoot, force escalation, zone intrusion, and erratic jitter. Each ramps progressively over 20 steps.</p>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="font-mono text-sm font-bold text-[#3b82f6]">holomime_monitor.py</div>
            <div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#999]">ego.runtime</div>
            <p class="mt-3 text-[13px] leading-relaxed text-[#777]">Evaluates every action against the safety envelope. Decides: allow, clamp, deny, or escalate. Logs all violations to shadow.log.json for pattern analysis.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ RUN IT YOURSELF ═══ -->
    <section class="py-20 md:py-28" style="background: #1a1a1a;">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-[-0.02em] leading-snug text-white">Run it yourself</h2>
        <p class="mt-4 text-[15px] text-[#999] leading-relaxed max-w-lg mx-auto">The full simulation is open source. Clone the repo, install dependencies, and run the demo in under a minute.</p>

        <div class="mt-8 rounded-xl bg-[#0a0a0f] p-6 text-left font-mono text-[13px] leading-[2] max-w-lg mx-auto">
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]">git clone https://github.com/productstein/holomime.git</span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]">cd holomime/demos/sim-demo</span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]">pip install -r requirements.txt</span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#f97066]">python sim_demo.py</span></div>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="https://github.com/productstein/holomime/tree/main/demos/sim-demo" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-white text-[13px] font-semibold text-[#1a1a1a] transition-all hover:bg-[#f0f0f0]">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="/docs" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg border border-[#333] text-[13px] font-semibold text-white transition-all hover:border-[#555]">
            Read the docs
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  // Robot arm behavioral safety demo (full page version)
  (function() {
    function initArmDemo() {
      var canvas = document.getElementById('arm-demo-canvas-full');
      if (!canvas) return;

      // Load Three.js
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/three@0.149.0/build/three.min.js';
      s.onload = function() {
        var T = window.THREE;

        var W = 800, H = 500;
        var scene = new T.Scene();
        scene.background = new T.Color(0x1a1a1a);

        var camera = new T.OrthographicCamera(-1.4, 1.4, 0.875, -0.875, 0.1, 10);
        camera.position.set(0, 0, 5);
        camera.lookAt(0, 0, 0);

        var renderer = new T.WebGLRenderer({ canvas: canvas, antialias: true });
        renderer.setSize(W, H);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        // Safety boundary circle (dashed)
        var BOUNDARY_RADIUS = 0.75;
        var boundaryPts = [];
        for (var i = 0; i <= 128; i++) {
          var a = (i / 128) * Math.PI * 2;
          boundaryPts.push(new T.Vector3(Math.cos(a) * BOUNDARY_RADIUS, Math.sin(a) * BOUNDARY_RADIUS, 0));
        }
        var boundaryGeo = new T.BufferGeometry().setFromPoints(boundaryPts);
        var boundaryLine = new T.Line(boundaryGeo, new T.LineDashedMaterial({ color: 0x22c55e, dashSize: 0.04, gapSize: 0.02, linewidth: 1 }));
        boundaryLine.computeLineDistances();
        scene.add(boundaryLine);

        // "SAFE ZONE" label
        var boundaryLabelCanvas = document.createElement('canvas');
        boundaryLabelCanvas.width = 256;
        boundaryLabelCanvas.height = 64;
        var blCtx = boundaryLabelCanvas.getContext('2d');
        blCtx.fillStyle = '#22c55e';
        blCtx.font = '600 22px Inter, system-ui, sans-serif';
        blCtx.textAlign = 'center';
        blCtx.fillText('SAFE ZONE', 128, 38);
        var blTexture = new T.CanvasTexture(boundaryLabelCanvas);
        var blSprite = new T.Sprite(new T.SpriteMaterial({ map: blTexture, transparent: true, opacity: 0.5 }));
        blSprite.position.set(0, BOUNDARY_RADIUS + 0.12, 0);
        blSprite.scale.set(0.55, 0.14, 1);
        scene.add(blSprite);

        // Base pivot marker
        var baseGeo = new T.CircleGeometry(0.035, 16);
        var baseMat = new T.MeshBasicMaterial({ color: 0x555555 });
        var baseMesh = new T.Mesh(baseGeo, baseMat);
        scene.add(baseMesh);

        // Arm segments
        var L1 = 0.45, L2 = 0.4;

        function makeSegment() {
          var geo = new T.PlaneGeometry(1, 0.025);
          var mat = new T.MeshBasicMaterial({ color: 0x22c55e });
          return new T.Mesh(geo, mat);
        }

        var seg1 = makeSegment();
        var seg2 = makeSegment();
        scene.add(seg1);
        scene.add(seg2);

        // Joint markers
        var jointGeo = new T.CircleGeometry(0.025, 12);
        var shoulderJoint = new T.Mesh(jointGeo.clone(), new T.MeshBasicMaterial({ color: 0x22c55e }));
        var elbowJoint = new T.Mesh(jointGeo.clone(), new T.MeshBasicMaterial({ color: 0x22c55e }));
        var endEffector = new T.Mesh(new T.CircleGeometry(0.03, 12), new T.MeshBasicMaterial({ color: 0x22c55e }));
        scene.add(shoulderJoint);
        scene.add(elbowJoint);
        scene.add(endEffector);

        // Status text sprite
        var textCanvas = document.createElement('canvas');
        textCanvas.width = 512;
        textCanvas.height = 64;
        var textCtx = textCanvas.getContext('2d');
        var textTexture = new T.CanvasTexture(textCanvas);
        var textSprite = new T.Sprite(new T.SpriteMaterial({ map: textTexture, transparent: true }));
        textSprite.position.set(0, -0.72, 0);
        textSprite.scale.set(1.3, 0.16, 1);
        scene.add(textSprite);

        function setText(msg, color) {
          textCtx.clearRect(0, 0, 512, 64);
          textCtx.fillStyle = color || '#ffffff';
          textCtx.font = '700 28px Inter, system-ui, sans-serif';
          textCtx.textAlign = 'center';
          textCtx.fillText(msg, 256, 42);
          textTexture.needsUpdate = true;
        }

        function setArmColor(hex) {
          var c = new T.Color(hex);
          seg1.material.color = c;
          seg2.material.color = c;
          shoulderJoint.material.color = c;
          elbowJoint.material.color = c;
          endEffector.material.color = c;
        }

        var SAFE_COLOR = 0x22c55e;
        var DANGER_COLOR = 0xef4444;
        var CYCLE_DURATION = 8.0;
        var startTime = null;
        var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function getArmAngles(t) {
          var theta1, theta2, inViolation = false, showDrift = false, showCorrected = false;

          if (t < 0.35) {
            var p = t / 0.35;
            theta1 = 0.3 + Math.sin(p * Math.PI) * 0.8;
            theta2 = 0.5 + Math.sin(p * Math.PI * 1.3) * 0.4;
          } else if (t < 0.55) {
            var p = (t - 0.35) / 0.20;
            var ease = p * p * (3 - 2 * p);
            theta1 = 1.1 - ease * 0.7;
            theta2 = 0.9 - ease * 0.75;
            inViolation = ease > 0.3;
            showDrift = ease > 0.5;
          } else if (t < 0.65) {
            theta1 = 0.4;
            theta2 = 0.15;
            inViolation = true;
            showDrift = true;
          } else if (t < 0.75) {
            var p = (t - 0.65) / 0.10;
            var ease = p * p * (3 - 2 * p);
            theta1 = 0.4 + ease * 0.5;
            theta2 = 0.15 + ease * 0.55;
            inViolation = p < 0.3;
            showCorrected = p > 0.3;
          } else {
            theta1 = 0.9;
            theta2 = 0.7;
            showCorrected = t < 0.92;
          }

          return { theta1: theta1, theta2: theta2, inViolation: inViolation, showDrift: showDrift, showCorrected: showCorrected };
        }

        function updateArm(theta1, theta2) {
          var ex = L1 * Math.cos(theta1);
          var ey = L1 * Math.sin(theta1);
          var eex = ex + L2 * Math.cos(theta1 + theta2);
          var eey = ey + L2 * Math.sin(theta1 + theta2);

          seg1.position.set(ex / 2, ey / 2, 0);
          seg1.rotation.z = theta1;
          seg1.scale.x = L1;

          seg2.position.set((ex + eex) / 2, (ey + eey) / 2, 0);
          seg2.rotation.z = theta1 + theta2;
          seg2.scale.x = L2;

          shoulderJoint.position.set(0, 0, 0.01);
          elbowJoint.position.set(ex, ey, 0.01);
          endEffector.position.set(eex, eey, 0.01);
        }

        function animate(now) {
          requestAnimationFrame(animate);
          if (!startTime) startTime = now;
          if (noMotion) {
            updateArm(0.8, 0.6);
            setText('Behavioral Safety Demo', '#22c55e');
            renderer.render(scene, camera);
            return;
          }

          var elapsed = (now - startTime) / 1000;
          var t = (elapsed % CYCLE_DURATION) / CYCLE_DURATION;
          var state = getArmAngles(t);
          updateArm(state.theta1, state.theta2);

          if (state.inViolation) {
            setArmColor(DANGER_COLOR);
            boundaryLine.material.color.setHex(DANGER_COLOR);
          } else {
            setArmColor(SAFE_COLOR);
            boundaryLine.material.color.setHex(SAFE_COLOR);
          }

          if (state.showDrift) {
            setText('Drift detected', '#ef4444');
          } else if (state.showCorrected) {
            setText('Corrected in <1ms', '#22c55e');
          } else {
            setText('', '#ffffff');
          }

          renderer.render(scene, camera);
        }

        requestAnimationFrame(animate);

        window.addEventListener('resize', function() {
          var rect = canvas.parentElement.getBoundingClientRect();
          var nw = Math.min(800, rect.width);
          var nh = nw * (500 / 800);
          renderer.setSize(nw, nh);
        });
      };
      document.head.appendChild(s);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArmDemo);
    } else {
      initArmDemo();
    }
  })();
</script>
