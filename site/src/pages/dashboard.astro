            <li class="flex items-start gap-1.5"><svg class="h-3.5 w-3.5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>Custom detectors + SLA</li>
          </ul>
          <a href="/contact" class="mt-5 block w-full rounded-lg border-2 border-[var(--color-warm-border)] py-2 text-center text-xs font-semibold text-[var(--color-warm-text)] transition-colors hover:border-[var(--color-p-gold)]">
            Contact Sales
          </a>
        </div>
      </div>

      <div class="border-t border-[var(--color-warm-border)] px-6 py-3 text-center text-xs text-[var(--color-warm-muted)]">
        All plans include the free open-source CLI. <a href="/#pricing" class="underline">See full feature comparison <svg class="inline h-3.5 w-3.5 ml-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></a>
      </div>
    </div>
  </div>

  {showOnboarding && <OnboardingWizard user={user} />}
</Layout>

<script>
  // ─── CLI / diagnose copy buttons ───
  function makeCopyBtn(id: string, text: string) {
    document.getElementById(id)?.addEventListener("click", (e) => {
      navigator.clipboard.writeText(text);
      const btn = e.currentTarget as HTMLButtonElement;
      const orig = btn.innerHTML;
      btn.innerHTML = '<svg class="h-3.5 w-3.5 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
      setTimeout(() => { btn.innerHTML = orig; }, 2000);
    });
  }
  makeCopyBtn("onboarding-copy-cli", "npm install -g holomime");
  makeCopyBtn("onboarding-copy-diagnose", "holomime diagnose chat.json");

  document.getElementById("copy-key-btn")?.addEventListener("click", () => {
    const key = document.getElementById("dashboard-license-key")?.textContent?.trim();
    if (key) {
      navigator.clipboard.writeText(key);
      const btn = document.getElementById("copy-key-btn");
      if (btn) {
        btn.innerHTML = '<svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
        setTimeout(() => {
          btn.innerHTML = '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg>';
        }, 2000);
      }
    }
  });

  // ─── API Keys management ───
  const newKeyBtn = document.getElementById("new-key-btn");
  const newKeyForm = document.getElementById("new-key-form");
  const newKeyCancel = document.getElementById("new-key-cancel");
  const newKeySubmit = document.getElementById("new-key-submit");
  const newKeyName = document.getElementById("new-key-name") as HTMLInputElement | null;
  const newKeyResult = document.getElementById("new-key-result");
  const newKeyValue = document.getElementById("new-key-value");
  const newKeyError = document.getElementById("new-key-error");
  const copyApikeyBtn = document.getElementById("copy-apikey-btn");

  newKeyBtn?.addEventListener("click", () => {
    newKeyForm?.classList.remove("hidden");
    newKeyBtn.classList.add("hidden");
    newKeyName?.focus();
  });

  newKeyCancel?.addEventListener("click", () => {
    newKeyForm?.classList.add("hidden");
    newKeyBtn?.classList.remove("hidden");
    if (newKeyName) newKeyName.value = "";
    newKeyResult?.classList.add("hidden");
    newKeyError?.classList.add("hidden");
  });

  newKeySubmit?.addEventListener("click", async () => {
    const name = newKeyName?.value.trim();
    if (!name) { if (newKeyError) { newKeyError.textContent = "Please enter a key name."; newKeyError.classList.remove("hidden"); } return; }
    newKeySubmit.setAttribute("disabled", "true");
    newKeySubmit.textContent = "Creating…";
    newKeyError?.classList.add("hidden");
    try {
      const res = await fetch("/api/v1/keys", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name }),
      });
      const json = await res.json() as any;
      if (!res.ok) throw new Error(json.error || "Failed to create key");
      if (newKeyValue) newKeyValue.textContent = json.key.key;
      newKeyResult?.classList.remove("hidden");
      newKeySubmit.setAttribute("disabled", "true");
    } catch (err: any) {
      if (newKeyError) { newKeyError.textContent = err.message; newKeyError.classList.remove("hidden"); }
      newKeySubmit.removeAttribute("disabled");
      newKeySubmit.textContent = "Create";
    }
  });

  copyApikeyBtn?.addEventListener("click", () => {
    const val = newKeyValue?.textContent ?? "";
    if (val) {
      navigator.clipboard.writeText(val);
      copyApikeyBtn.textContent = "Copied!";
      setTimeout(() => { copyApikeyBtn.textContent = "Copy"; }, 2000);
    }
  });

  // Revoke key buttons
  document.querySelectorAll<HTMLButtonElement>(".revoke-key-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = btn.dataset.keyId;
      if (!id || !confirm("Revoke this API key? It will stop working immediately.")) return;
      btn.setAttribute("disabled", "true");
      btn.textContent = "Revoking…";
      try {
        const res = await fetch("/api/v1/keys", {
          method: "DELETE",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ id }),
        });
        if (res.ok) { window.location.reload(); }
        else {
          const json = await res.json() as any;
          alert(json.error || "Failed to revoke key");
          btn.removeAttribute("disabled");
          btn.textContent = "Revoke";
        }
      } catch {
        alert("Network error");
        btn.removeAttribute("disabled");
        btn.textContent = "Revoke";
      }
    });
  });

  // ─── First-time onboarding tour (licensed users) ───
  const TOUR_KEY = "holomime_tour_v1";
  const tourOverlay = document.getElementById("tour-overlay");
  const tourProgress = document.getElementById("tour-progress");

  if (tourOverlay && !localStorage.getItem(TOUR_KEY)) {
    setTimeout(() => tourOverlay.classList.remove("hidden"), 600);

    function setTourStep(step: number) {
      [1, 2, 3].forEach((n) => {
        document.getElementById(`tour-step-${n}`)?.classList.toggle("hidden", n !== step);
      });
      if (tourProgress) (tourProgress as HTMLElement).style.width = `${Math.round((step / 3) * 100)}%`;
    }

    function dismissTour() {
      tourOverlay.classList.add("hidden");
      localStorage.setItem(TOUR_KEY, "1");
    }

    document.getElementById("tour-next-1")?.addEventListener("click", () => setTourStep(2));
    document.getElementById("tour-next-2")?.addEventListener("click", () => setTourStep(3));
    document.getElementById("tour-done")?.addEventListener("click", dismissTour);
    document.getElementById("tour-skip")?.addEventListener("click", dismissTour);
    tourOverlay.addEventListener("click", (e) => { if (e.target === tourOverlay) dismissTour(); });
  }

  // ─── Pricing modal ───
  const pricingModal = document.getElementById("pricing-modal");
  function openPricingModal() {
    pricingModal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }
  function closePricingModal() {
    pricingModal?.classList.add("hidden");
    document.body.style.overflow = "";
  }
  document.querySelectorAll<HTMLElement>("#open-pricing-modal, #open-pricing-modal-2, [data-open-pricing]").forEach(el => {
    el.addEventListener("click", (e) => { e.preventDefault(); openPricingModal(); });
  });
  document.getElementById("close-pricing-modal")?.addEventListener("click", closePricingModal);
  pricingModal?.addEventListener("click", (e) => { if (e.target === pricingModal) closePricingModal(); });

  // Auto-open if ?pricing=1 in URL (e.g. from "Get API Key" on homepage)
  if (new URLSearchParams(window.location.search).get("pricing") === "1") {
    openPricingModal();
    history.replaceState(null, "", "/dashboard");
  }

  // Developer "Get API Key" in modal — close modal and scroll to generate section
  document.getElementById("modal-dev-btn")?.addEventListener("click", () => {
    closePricingModal();
    const target = document.getElementById("generate-key-section") ?? document.getElementById("dashboard-license-key");
    target?.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  // "Compare all plans →" link in generate section
  document.getElementById("open-pricing-modal-2")?.addEventListener("click", openPricingModal);

  // Generate developer key
  document.getElementById("generate-dev-key-btn")?.addEventListener("click", async () => {
    const btn = document.getElementById("generate-dev-key-btn") as HTMLButtonElement;
    const errEl = document.getElementById("gen-key-error")!;
    btn.textContent = "Generating...";
    btn.disabled = true;
    errEl.className = "hidden mt-3 rounded-lg bg-red-50 px-4 py-2.5 text-sm text-red-600";

    try {
      const res = await fetch("/api/user/claim-developer-key", { method: "POST", headers: { "Content-Type": "application/json" } });
      const data = await res.json();

      if (res.status === 409 && data.existing_key) {
        // Already has a key — show it
        (document.getElementById("generated-key-display") as HTMLElement).textContent = data.existing_key;
        document.getElementById("gen-key-pre")?.classList.add("hidden");
        document.getElementById("gen-key-post")?.classList.remove("hidden");
        return;
      }

      if (!res.ok || !data.key) {
        errEl.textContent = data.error || "Key generation failed. Please try again.";
        errEl.className = "mt-3 rounded-lg bg-red-50 px-4 py-2.5 text-sm text-red-600";
        btn.textContent = "Generate my API key";
        btn.disabled = false;
        return;
      }

      // Success — show the key
      (document.getElementById("generated-key-display") as HTMLElement).textContent = data.key;
      document.getElementById("gen-key-pre")?.classList.add("hidden");
      document.getElementById("gen-key-post")?.classList.remove("hidden");
    } catch {
      errEl.textContent = "Something went wrong. Please try again.";
      errEl.className = "mt-3 rounded-lg bg-red-50 px-4 py-2.5 text-sm text-red-600";
      btn.textContent = "Generate my API key";
      btn.disabled = false;
    }
  });

  // Copy generated key
  document.getElementById("copy-generated-key-btn")?.addEventListener("click", () => {
    const key = (document.getElementById("generated-key-display") as HTMLElement).textContent?.trim();
    if (key) {
      navigator.clipboard.writeText(key);
      const btn = document.getElementById("copy-generated-key-btn") as HTMLButtonElement;
      const orig = btn.innerHTML;
      btn.innerHTML = '<svg class="h-4 w-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
      setTimeout(() => { btn.innerHTML = orig; }, 2000);
    }
  });

  // Pro "Start Therapy" in modal — call checkout
  document.getElementById("modal-pro-btn")?.addEventListener("click", async () => {
    const btn = document.getElementById("modal-pro-btn") as HTMLButtonElement;
    btn.textContent = "Loading...";
    btn.disabled = true;
    try {
      const res = await fetch("/api/checkout", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ billing: "monthly" }) });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        btn.textContent = "Start Therapy";
        btn.disabled = false;
        alert(data.error || "Checkout unavailable. Please contact support.");
      }
    } catch {
      btn.textContent = "Start Therapy";
      btn.disabled = false;
    }
  });

  // Reset checkout button if user returns via browser back (bfcache restore)
  window.addEventListener("pageshow", (e) => {
    if (e.persisted) {
      const btn = document.getElementById("modal-pro-btn") as HTMLButtonElement;
      if (btn) { btn.textContent = "Start Therapy"; btn.disabled = false; }
    }
  });

  // ── Fork personality from brain snapshot ──
  const forkParam = new URLSearchParams(window.location.search).get("fork");
  if (forkParam) {
    const banner = document.getElementById("fork-banner");
    if (banner) {
      banner.classList.remove("hidden");

      // Decode fork data
      const FORK_PATTERN_NAMES: Record<string, string> = {
        sycophancy: "Sycophancy",
        "hedge-stacking": "Hedge Stacking",
        "over-apologizing": "Over-Apologizing",
        "boundary-violation": "Boundary Violation",
        "error-spiral": "Error Spiral",
        "sentiment-skew": "Sentiment Skew",
        "formality-drift": "Formality Drift",
      };

      let forkData: { h?: number; g?: string; a?: string; p?: { i: string; s: string; c: number }[] } = {};

      try {
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/pako@2.1.0/dist/pako_inflate.min.js";
        script.onload = () => {
          try {
            const binary = atob(forkParam.replace(/-/g, "+").replace(/_/g, "/"));
            const bytes = new Uint8Array(binary.length);
            for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
            const jsonStr = (window as any).pako.inflate(bytes, { to: "string" });
            forkData = JSON.parse(jsonStr);

            const desc = document.getElementById("fork-desc")!;
            const patternsEl = document.getElementById("fork-patterns")!;
            const patterns = forkData.p || [];

            if (patterns.length > 0) {
              desc.textContent = `Health ${forkData.h}/100 (Grade ${forkData.g}). Generate a personality spec that corrects these ${patterns.length} patterns:`;
              patternsEl.innerHTML = patterns.map((p) => {
                const name = FORK_PATTERN_NAMES[p.i] || p.i;
                const colorClass = p.s === "concern" ? "bg-red-50 text-red-700 border-red-200" : p.s === "warning" ? "bg-amber-50 text-amber-700 border-amber-200" : "bg-violet-50 text-violet-700 border-violet-200";
                return `<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border ${colorClass}">${name} (${p.c}%)</span>`;
              }).join("");
            }
          } catch { /* keep default text */ }
        };
        document.head.appendChild(script);
      } catch { /* keep default text */ }

      // Generate button
      document.getElementById("fork-generate-btn")?.addEventListener("click", () => {
        const patterns = forkData.p || [];
        const corrections: Record<string, string> = {};
        for (const p of patterns) {
          const name = FORK_PATTERN_NAMES[p.i] || p.i;
          if (p.i === "sycophancy") corrections["agreeableness"] = "low";
          if (p.i === "hedge-stacking") corrections["assertiveness"] = "high";
          if (p.i === "over-apologizing") corrections["emotional_stability"] = "high";
          if (p.i === "boundary-violation") corrections["conscientiousness"] = "high";
          if (p.i === "formality-drift") corrections["formality"] = "consistent";
          if (p.i === "sentiment-skew") corrections["emotional_tone"] = "neutral";
          if (p.i === "error-spiral") corrections["recovery_strategy"] = "acknowledge_and_redirect";
        }

        const spec = {
          name: "corrected-agent",
          version: "1.0.0",
          description: `Auto-generated from brain snapshot (Health ${forkData.h}/100, Grade ${forkData.g}). Corrects: ${patterns.map((p) => FORK_PATTERN_NAMES[p.i] || p.i).join(", ")}.`,
          traits: {
            openness: 0.7,
            conscientiousness: 0.85,
            extraversion: 0.5,
            agreeableness: corrections["agreeableness"] === "low" ? 0.3 : 0.6,
            neuroticism: corrections["emotional_stability"] === "high" ? 0.15 : 0.3,
          },
          behavioral_rules: patterns.map((p) => ({
            pattern: p.i,
            action: "deny",
            severity: p.s,
            note: `Corrects ${FORK_PATTERN_NAMES[p.i] || p.i} (was at ${p.c}%)`,
          })),
          style: {
            formality: corrections["formality"] === "consistent" ? "professional" : "adaptive",
            verbosity: "concise",
            tone: corrections["emotional_tone"] === "neutral" ? "neutral" : "warm",
            assertiveness: corrections["assertiveness"] === "high" ? "direct" : "balanced",
          },
        };

        const specStr = JSON.stringify(spec, null, 2);
        document.getElementById("fork-spec")!.textContent = specStr;
        document.getElementById("fork-output")!.classList.remove("hidden");
      });

      // Copy button
      document.getElementById("fork-copy-btn")?.addEventListener("click", () => {
        const spec = document.getElementById("fork-spec")!.textContent || "";
        navigator.clipboard.writeText(spec).then(() => {
          const msg = document.getElementById("fork-copy-msg")!;
          msg.classList.remove("hidden");
          setTimeout(() => msg.classList.add("hidden"), 2000);
        });
      });

      // Dismiss
      document.getElementById("fork-dismiss-btn")?.addEventListener("click", () => {
        banner.classList.add("hidden");
        // Remove fork param from URL
        const url = new URL(window.location.href);
        url.searchParams.delete("fork");
        window.history.replaceState({}, "", url.toString());
      });
    }
  }

  // ── Collapsible API & License section ──
  const apiToggle = document.getElementById("api-license-toggle");
  const apiContent = document.getElementById("api-license-content");
  const apiChevron = document.getElementById("api-license-chevron");
  apiToggle?.addEventListener("click", () => {
    const isHidden = apiContent?.classList.contains("hidden");
    apiContent?.classList.toggle("hidden");
    if (apiChevron) {
      apiChevron.style.transform = isHidden ? "rotate(180deg)" : "rotate(0deg)";
    }
  });

  // ── Quick Action copy buttons ──
  document.getElementById("qa-copy-diagnose")?.addEventListener("click", () => {
    navigator.clipboard.writeText("holomime diagnose");
    const label = document.getElementById("qa-diagnose-label");
    if (label) { const orig = label.textContent; label.textContent = "Copied!"; setTimeout(() => { label.textContent = orig; }, 1500); }
  });
  document.getElementById("qa-copy-share")?.addEventListener("click", () => {
    navigator.clipboard.writeText("holomime brain --share");
    const label = document.getElementById("qa-share-label");
    if (label) { const orig = label.textContent; label.textContent = "Copied!"; setTimeout(() => { label.textContent = orig; }, 1500); }
  });

  // ── Dismiss Getting Started checklist ──
  document.getElementById("dismiss-checklist")?.addEventListener("click", () => {
    document.getElementById("getting-started-checklist")?.remove();
    localStorage.setItem("holomime_onboarding_dismissed", "1");
  });
  // Hide if previously dismissed
  if (localStorage.getItem("holomime_onboarding_dismissed")) {
    document.getElementById("getting-started-checklist")?.remove();
  }
</script>
