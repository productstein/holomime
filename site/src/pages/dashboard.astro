                <span class="rounded-full px-3 py-1 text-xs font-bold text-white" style="background: var(--color-p-gold);">Enterprise</span>
              </div>
              <div class="grid gap-4 sm:grid-cols-3 mb-6">
                <div class="rounded-xl border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4 text-center">
                  <p class="text-2xl font-extrabold text-[var(--color-warm-text)]">{teamMembers.length}</p>
