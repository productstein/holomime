                  <p class="whitespace-nowrap text-white"><span class="text-[var(--color-holo-cyan)]">$</span> holomime activate {license.key}</p>
                  <p class="mt-2 text-emerald-400">  Pro license activated!</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {isEnterprise && orgInfo && (
        <div class="mt-6 rounded-2xl bg-white p-5 sm:p-8 shadow-xl shadow-black/5 border border-[var(--color-warm-border)]">
