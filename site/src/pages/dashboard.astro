                <div class="rounded-xl border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4 text-center">
                  <p class="text-2xl font-extrabold text-[var(--color-warm-text)]">{fleetAgents.length}</p>
                  <p class="mt-1 text-xs text-[var(--color-warm-muted)]">Fleet Agents</p>
                </div>
                <div class="rounded-xl border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4 text-center">
                  <p class="text-2xl font-extrabold text-[var(--color-warm-text)]">{customDetectors.length}</p>
                  <p class="mt-1 text-xs text-[var(--color-warm-muted)]">Custom Detectors</p>
                </div>
              </div>

              {teamMembers.length > 0 ? (
                <div class="rounded-xl border border-[var(--color-warm-border)] overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead class="bg-[var(--color-warm-cream)]">
                      <tr>
                        <th class="px-4 py-2 text-left text-xs font-medium text-[var(--color-warm-muted)] uppercase tracking-wider">Email</th>
                        <th class="px-4 py-2 text-left text-xs font-medium text-[var(--color-warm-muted)] uppercase tracking-wider">Role</th>
                        <th class="px-4 py-2 text-right text-xs font-medium text-[var(--color-warm-muted)] uppercase tracking-wider">Joined</th>
                      </tr>
                    </thead>
                    <tbody>
                      {teamMembers.map((m) => (
                        <tr class="border-t border-[var(--color-warm-border)]">
