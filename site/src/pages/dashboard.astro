            </div>
            <div class="rounded-xl border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4 sm:p-6 text-center">
              <p class="text-2xl sm:text-3xl font-extrabold text-[var(--color-warm-text)]">{usageStats.thisMonth.toLocaleString()}</p>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">This month</p>
            </div>
            <div class="rounded-xl border border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] p-4 sm:p-6 text-center">
              <p class="text-2xl sm:text-3xl font-extrabold text-[var(--color-warm-text)]">{usageStats.byEndpoint.length}</p>
              <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Endpoints used</p>
            </div>
          </div>

          {usageStats.byEndpoint.length > 0 ? (
            <div class="mt-4 rounded-xl border border-[var(--color-warm-border)] overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-[var(--color-warm-cream)]">
                  <tr>
                    <th class="px-4 py-2 text-left text-xs font-medium text-[var(--color-warm-muted)] uppercase tracking-wider">Endpoint</th>
                    <th class="px-4 py-2 text-right text-xs font-medium text-[var(--color-warm-muted)] uppercase tracking-wider">Calls</th>
                  </tr>
                </thead>
                <tbody>
                  {usageStats.byEndpoint.map((row) => (
                    <tr class="border-t border-[var(--color-warm-border)]">
                      <td class="px-4 py-2.5 font-mono text-xs text-[var(--color-warm-text)]">{row.endpoint}</td>
                      <td class="px-4 py-2.5 text-right text-[var(--color-warm-muted)]">{row.count.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="mt-4 text-center text-sm text-[var(--color-warm-muted)]">
              No API calls yet. Use your license key to authenticate API requests.
            </p>
          )}

              <!-- License sub-section (inside collapsible) -->
              <div class="mt-8 pt-6 border-t border-[var(--color-warm-border)]">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
                  <h3 class="text-sm font-semibold text-[var(--color-warm-text)]">License</h3>
                  <div class="flex items-center gap-2">
                    <span class="rounded-full px-3 py-1 text-xs font-bold text-white" style={`background: ${tierColor};`}>
                      {tierLabel}
                    </span>
                    <span class="rounded-full px-3 py-1 text-xs font-semibold text-emerald-700 bg-emerald-50">
                      Active
                    </span>
                  </div>
                </div>

                <div class="flex items-center gap-2">
                  <code id="dashboard-license-key" class="min-w-0 flex-1 truncate rounded-lg bg-[var(--color-holo-dark)] px-3 sm:px-4 py-3 font-mono text-xs sm:text-sm text-[var(--color-holo-cyan)] select-all">
                    {license.key}
                  </code>
                  <button
                    id="copy-key-btn"
                    class="shrink-0 rounded-lg border border-[var(--color-warm-border)] px-3 py-3 text-sm transition-colors hover:border-[var(--color-warm-muted)]"
                    title="Copy to clipboard"
                  >
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
                    </svg>
                  </button>
                </div>

                <p class="mt-4 text-sm text-[var(--color-warm-muted)]">
