  }
  .prose-warm h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .prose-warm .meta {
    font-size: 0.875rem;
    color: var(--color-warm-muted);
    margin-bottom: 2rem;
  }
  .prose-warm h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-warm p {
    margin-bottom: 1rem;
  }
  .prose-warm ul {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }
  .prose-warm li {
    margin-bottom: 0.375rem;
  }
  .prose-warm a {
    color: var(--color-p-violet);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
