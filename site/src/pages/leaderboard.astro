  <script>
    function activateTab(tabName: string) {
      // Update tab buttons
      document.querySelectorAll('.lb-tab').forEach((btn) => {
        const isActive = btn.getAttribute('data-tab') === tabName;
        btn.classList.toggle('text-[var(--color-p-violet)]', isActive);
        btn.classList.toggle('border-[var(--color-p-violet)]', isActive);
        btn.classList.toggle('text-[var(--color-warm-muted)]', !isActive);
        btn.classList.toggle('border-transparent', !isActive);
      });
      // Update tab content
      document.querySelectorAll('.lb-tab-content').forEach((panel) => {
        panel.classList.toggle('hidden', panel.id !== `tab-${tabName}`);
      });
      // Update URL hash without scrolling
      history.replaceState(null, '', `#${tabName}`);
    }

    // Tab click handlers
    document.querySelectorAll('.lb-tab').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        if (tab) activateTab(tab);
      });
    });

    // Activate from URL hash or default to models
    const hash = location.hash.replace('#', '');
    activateTab(['models', 'orchestrators'].includes(hash) ? hash : 'models');
  </script>
