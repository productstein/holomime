    var dustPositions = dustGeo.attributes.position.array;
    function animate() {
      requestAnimationFrame(animate);
      if (!noMotion) {
        humanoidGroup.rotation.y += 0.003;
        // Drift dust particles
        for (var d = 0; d < dustPositions.length; d += 3) {
          dustPositions[d] += dustVel[d];
          dustPositions[d+1] += dustVel[d+1];
          dustPositions[d+2] += dustVel[d+2];
