---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import NeuralSpaceShowcase from "../components/NeuralSpaceShowcase.astro";
import Footer from "../components/Footer.astro";

const integrations = [
  { name: "ROS2", desc: "Bidirectional telemetry", code: "--adapter ros2" },
  { name: "MuJoCo", desc: "Behavioral sim-to-real", code: "mujoco-env.ts" },
  { name: "Isaac Sim", desc: "Enterprise digital twin", code: "--adapter isaac" },
  { name: "LeRobot", desc: "Personality to policy", code: "lerobot.ts" },
  { name: "ISO Compliance", desc: "4 standards, one command", code: "holomime certify" },
  { name: "Body Templates", desc: "8 OEM platforms", code: "--swap-body" },
  { name: "Edge Runtime", desc: "<1ms conscience evaluation for robotics", code: "edge-runtime.ts" },
];

const stackCards = [
  { file: "soul.md", label: "Aristotle", desc: "Immutable values, ethics, and essence.", color: "var(--color-p-coral)", code: '---\nversion: "1.0"\nimmutable: true\n---\n# Mira\n> Self-improving agent' },
  { file: "mind.sys", label: "Jung", desc: "Big Five traits, emotional intelligence, communication.", color: "var(--color-p-blue)", code: "big_five:\n  openness:\n    score: 0.85\n  conscientiousness:\n    score: 0.70" },
  { file: "purpose.cfg", label: "Aristotle", desc: "Role, objectives, domain scope. Configured per deployment.", color: "var(--color-p-teal)", code: 'role: "Care assistant"\nobjectives:\n  - Patient safety\n  - Medication reminders' },
  { file: "shadow.log", label: "Jung", desc: "Detected drift patterns. Auto-generated by diagnosis.", color: "var(--color-p-sunset)", code: "detected_patterns:\n  - name: sycophancy\n    score: 0.72\n    severity: high" },
  { file: "memory.store", label: "Aristotle", desc: "Accumulated experience. Knowledge gained from interactions.", color: "var(--color-p-sage)", code: "knowledge_gained:\n  - Refund policy details\n  - Escalation thresholds\ninteraction_patterns: []" },
  { file: "body.api", label: "Hardware", desc: "Morphology, sensors, safety envelope. Swappable.", color: "var(--color-p-gold)", code: '{\n  "morphology": "humanoid",\n  "modalities": ["gesture",\n    "gaze", "voice"]\n}' },
  { file: "conscience.exe", label: "Freud", desc: "Deny, allow, or escalate at the boundary.", color: "var(--color-p-violet)", code: "rules:\n  deny:\n    - action: override_stop\n      reason: Safety" },
  { file: "ego.runtime", label: "Freud", desc: "Runtime mediation. Balances purpose against conscience.", color: "var(--color-p-rose)", code: "conflict_resolution:\n  conscience_first\nadaptation_rate: 0.5\nresponse_strategy:\n  balanced" },
];
---

<Layout
  title="holomime — Behavioral Intelligence for AI Agents and Humanoid Robots"
  description="Define agent identity. Diagnose behavioral drift. Cure it permanently. Deploy personality.json to any runtime — from cloud APIs to humanoid robots."
>
  <Nav />

  <main>
    <!-- ═══ HERO ═══ -->
    <section class="pt-28 pb-20 md:pt-36 md:pb-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="flex flex-col lg:flex-row items-start gap-12 lg:gap-16">
          <div class="flex-1">
            <div class="flex flex-wrap gap-2 mb-6">
              <span class="badge-pill">Open Source</span>
              <span class="badge-pill">MIT Licensed</span>
              <span class="badge-pill">ISO 13482</span>
            </div>
            <h1 class="text-[clamp(2.5rem,5.5vw,3.75rem)] font-extrabold leading-[1.05] tracking-[-0.03em] text-[var(--color-warm-text)]">
              Train the mind.<br /><span class="text-[var(--color-p-coral)]">Deploy the body.</span>
            </h1>
            <p class="mt-5 text-lg leading-relaxed text-[#555] max-w-lg">
              Behavioral intelligence for AI agents and humanoid robots. Define who your agent is. Diagnose drift. Run therapy. Permanently correct the model — then deploy <code class="font-mono text-[0.9em] text-[var(--color-warm-text)]">personality.json</code> anywhere, from APIs to physical bodies.
            </p>
            <div class="mt-8 flex flex-wrap items-center gap-3">
              <button onclick="window.openAuthModal()" class="btn-primary">Get started <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></button>
              <div class="install-box"><span class="select-none text-[#666]">$</span><code id="install-cmd">npm install -g holomime</code><button id="install-copy" aria-label="Copy"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg></button></div>
            </div>
            <div class="mt-8 pt-6 border-t border-[var(--color-warm-border)] flex flex-wrap gap-x-6 gap-y-1 text-[12px] font-mono text-[#999] tracking-wide">
              <span>2,000+ DPO Pairs</span><span>14 Detectors</span><span>8 Body Templates</span><span>4 ISO Standards</span>
            </div>
          </div>
          <div class="flex-1 w-full lg:max-w-md flex justify-center">
            <canvas id="humanoid-canvas" width="350" height="500" class="w-full max-w-[350px] h-[500px]"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PROBLEM ═══ -->
    <section class="section-cream py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.15] tracking-[-0.02em]">
          <span class="text-[var(--color-warm-text)]">Everyone is building AI.</span><br />
          <span class="text-[#999]">Nobody is training the mind.</span>
        </h2>
        <p class="mt-12 text-[clamp(1.25rem,2.5vw,1.75rem)] leading-[1.6] text-[#555]">Locomotion is solved. Manipulation is getting there. But when a care robot drifts from its safety protocols after 10,000 hours — that's not a hardware problem. It's a mind problem.</p>
      </div>
    </section>

    <!-- ═══ COMPATIBLE WITH ═══ -->
    <div class="py-10 border-y border-[#eee]">
      <div class="mx-auto max-w-5xl px-6">
        <p class="text-center text-[10px] font-semibold uppercase tracking-[0.12em] text-[#bbb] mb-5">Compatible with</p>
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-[13px] font-medium text-[#ccc]">
          <span>Claude</span>
          <span>OpenAI</span>
          <span>ROS2</span>
          <span>NVIDIA Isaac</span>
          <span>HuggingFace</span>
          <span>MuJoCo</span>
          <span>Kimodo</span>
        </div>
      </div>
    </div>

    <!-- ═══ HOW IT WORKS ═══ -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">How it works</h2>
        <div class="mt-12">
          <!-- Step 01 -->
          <div class="flex gap-6 py-7 border-b border-[var(--color-warm-border)]">
            <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">01</span>
            <div>
              <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Profile your agent</span>
              <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Define how your agent should behave — values, personality, and boundaries.</p>
              <div class="mt-3 rounded-lg bg-[#1a1a1a] px-4 py-3 font-mono text-[12px] leading-[1.8] max-w-sm">
                <div><span class="text-[#666]">$</span> <span class="text-[#f97066]">holomime personality</span> <span class="text-[#666] ml-2"># 1 file</span></div>
                <div><span class="text-[#666]">$</span> <span class="text-[#f97066]">holomime core</span> <span class="text-[#666] ml-2"># 3 files</span></div>
                <div><span class="text-[#666]">$</span> <span class="text-[#f97066]">holomime identity</span> <span class="text-[#666] ml-2"># 8 files</span></div>
              </div>
            </div>
          </div>
          <!-- Step 02 -->
          <div class="flex gap-6 py-7 border-b border-[var(--color-warm-border)]">
            <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">02</span>
            <div>
              <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Diagnose</span>
              <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Detect behavioral drift from conversation logs. 14 rule-based detectors, 80+ signals. No LLM needed.</p>
              <div class="mt-3 rounded-lg bg-[#1a1a1a] px-4 py-2.5 font-mono text-[12px] max-w-sm"><span class="text-[#666]">$</span> <span class="text-[#3b82f6]">holomime diagnose</span></div>
            </div>
          </div>
          <!-- Step 03 -->
          <div class="flex gap-6 py-7 border-b border-[var(--color-warm-border)]">
            <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">03</span>
            <div>
              <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Fix</span>
              <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Full pipeline — diagnose, generate training data, fine-tune, and verify. One command. The fix is permanent.</p>
              <div class="mt-3 rounded-lg bg-[#1a1a1a] px-4 py-2.5 font-mono text-[12px] max-w-sm"><span class="text-[#666]">$</span> <span class="text-[#8b5cf6]">holomime cure</span></div>
            </div>
          </div>
          <!-- Step 04 -->
          <div class="flex gap-6 py-7 border-b border-[var(--color-warm-border)]">
            <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">04</span>
            <div>
              <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Verify</span>
              <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Score alignment (A-F) across 8 adversarial scenarios. Proof the fix worked.</p>
              <div class="mt-3 rounded-lg bg-[#1a1a1a] px-4 py-2.5 font-mono text-[12px] max-w-sm"><span class="text-[#666]">$</span> <span class="text-[#14b8a6]">holomime benchmark</span></div>
            </div>
          </div>
          <!-- Step 05 -->
          <div class="flex gap-6 py-7">
            <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">05</span>
            <div>
              <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Monitor</span>
              <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Run in background — generate training data, detect regression, and auto-tune over time.</p>
              <div class="mt-3 rounded-lg bg-[#1a1a1a] px-4 py-2.5 font-mono text-[12px] max-w-sm"><span class="text-[#666]">$</span> <span class="text-[#f97316]">holomime therapy</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SEE IT IN ACTION ═══ -->
    <section class="py-20 md:py-28" style="background: #f7f4f0;">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">See it in action</h2>
        <p class="mt-2 text-[15px] text-[#777]">From diagnosis to therapy — two sides of the same correction cycle. Mira runs the sessions. ego.runtime learns from every mediation decision — the therapy gets better over time.</p>

        <div id="demo-grid" class="mt-12 grid gap-8 lg:grid-cols-2 items-stretch">
          <!-- Left: Terminal preview -->
          <div class="flex flex-col">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-[#999] mb-4">CLI Diagnosis</h3>
            <div class="rounded-xl overflow-hidden shadow-lg ring-1 ring-black/5 flex flex-col flex-1">
              <div class="flex items-center gap-1.5 px-4 py-2.5 bg-[#0f0f15]">
                <div class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></div>
                <div class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></div>
                <div class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></div>
                <span class="ml-2 text-[10px] text-[#666] font-mono">holomime diagnose</span>
              </div>
              <div id="term-body" class="bg-[#0a0a0f] p-5 font-mono text-[12px] leading-[1.8] text-[#c4c4c4] flex-1">
                <div><span class="text-[#9ece6a]">~</span> <span class="text-[#666]">$</span> <span id="term-cmd" class="text-[#c0caf5]"></span><span id="term-cursor" class="inline-block w-[7px] h-[14px] bg-[#c0caf5] align-middle" style="animation: blink 1s step-end infinite;"></span></div>
                <div id="term-l1" class="mt-3 text-[#666]" style="display:none;">Analyzing 247 messages...</div>
                <div id="term-l2" class="mt-2" style="display:none;">
                  <span class="text-[#f59e0b]">⚠</span> <span class="text-[#c4c4c4]">Over-apologizing</span> <span class="text-[#f59e0b]">38%</span> <span class="text-[#666]">severity: high</span>
                </div>
                <div id="term-l3" style="display:none;">
                  <span class="text-[var(--color-p-coral)]">✗</span> <span class="text-[#c4c4c4]">Sycophantic tendency</span> <span class="text-[var(--color-p-coral)]">22%</span> <span class="text-[#666]">severity: medium</span>
                </div>
                <div id="term-l4" style="display:none;">
                  <span class="text-[#3b82f6]">ℹ</span> <span class="text-[#c4c4c4]">Hedge-stacking</span> <span class="text-[#3b82f6]">14%</span> <span class="text-[#666]">severity: low</span>
                </div>
                <div id="term-l5" class="mt-3 text-[#666]" style="display:none;">─────────────────────────</div>
                <div id="term-l6" style="display:none;"><span class="text-[#c4c4c4]">Grade:</span> <span class="text-[var(--color-p-coral)] font-bold">D</span> <span class="text-[#666]">· 3 patterns · needs therapy</span></div>
              </div>
            </div>
            <a href="/demo" class="inline-flex items-center gap-1.5 mt-4 text-[13px] font-semibold text-[var(--color-p-coral)] hover:underline underline-offset-2">
              Try the interactive demo
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>

          <!-- Right: Therapy preview -->
          <div class="flex flex-col">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-[#999] mb-4">Therapy Session</h3>
            <div class="rounded-xl border border-[var(--color-warm-border)] bg-white overflow-hidden shadow-sm flex flex-col flex-1">
              <div class="flex items-center justify-between border-b border-[var(--color-warm-border)] bg-[var(--color-warm-cream)] px-5 py-3">
                <div class="flex items-center gap-2">
                  <div class="h-2 w-2 rounded-full bg-[var(--color-p-sage)]"></div>
                  <span class="text-[11px] font-mono text-[#999]">Correction Cycle #1</span>
                </div>
                <span class="text-[10px] font-medium text-[var(--color-p-sage)]">Live</span>
              </div>
              <div id="chat-body" class="p-5 text-[13px] leading-[1.7] flex-1">
                <!-- Messages injected by JS -->
              </div>
              <div id="chat-footer" class="border-t border-[var(--color-warm-border)] px-5 py-3 flex items-center justify-between text-[11px] text-[#999]" style="opacity:0; transition: opacity 0.5s;">
                <span>Grade: <span class="text-[var(--color-p-coral)] font-bold">D</span> → <span class="text-[var(--color-p-sage)] font-bold">A</span></span>
                <span>12 DPO pairs exported</span>
              </div>
            </div>
            <a href="/demo" class="inline-flex items-center gap-1.5 mt-4 text-[13px] font-semibold text-[var(--color-p-coral)] hover:underline underline-offset-2">
              See full therapy session
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ IDENTITY STACK + INTEGRATIONS ═══ -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">The identity stack</h2>
        <p class="mt-2 text-[15px] text-[#777]">Eight files define who the agent is — grounded in Aristotle, Jung, and Freud. They compile into a single <code class="font-mono text-[0.9em] text-[var(--color-warm-text)]">personality.json</code>.</p>
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 items-stretch">
          {stackCards.map((c) => (
            <div class="holo-card overflow-hidden flex flex-col">
              <div class="h-[3px] shrink-0" style={`background: ${c.color};`}></div>
              <div class="p-5 flex flex-col flex-1">
                <div class="font-mono text-sm font-bold">{c.file}</div>
                <div class="mt-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-[#999]">{c.label}</div>
                <p class="mt-2 text-[13px] leading-relaxed text-[#777]">{c.desc}</p>
                <div class="code-mini mt-auto pt-3"><pre class="whitespace-pre">{c.code}</pre></div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-16">
          <h3 class="text-xl font-bold tracking-[-0.02em]">Connects to your stack</h3>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {integrations.map((item) => (
              <div class="holo-card p-5">
                <div class="font-semibold">{item.name}</div>
                <p class="mt-1 text-[13px] text-[#777]">{item.desc}</p>
                <code class="mt-3 block font-mono text-[11px] text-[#bbb]">{item.code}</code>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ NEURALSPACE ═══ -->
    <NeuralSpaceShowcase />

    <!-- ═══ CTA ═══ -->
    <section class="py-24 md:py-32">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-[-0.02em] leading-snug text-[var(--color-warm-text)]">Ready to train the mind?</h2>
        <p class="mt-4 text-[15px] text-[#777] leading-relaxed max-w-lg mx-auto">Start with the open source CLI. Scale with the training platform.</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <button onclick="window.openAuthModal()" class="btn-primary">Get started <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg></button>
          <a href="/contact" class="btn-secondary">Contact Sales</a>
          <div class="install-box"><span class="select-none text-[#666]">$</span><code id="cta-install-cmd">npm install -g holomime</code><button id="cta-install-copy" aria-label="Copy"><svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184"/></svg></button></div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  // Three.js particle humanoid in hero
  (function() {
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
    s.onload = function() {
      var canvas = document.getElementById('humanoid-canvas');
      if (!canvas) return;
      var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var T = window.THREE;
      var w = canvas.clientWidth || 350;
      var h = canvas.clientHeight || 500;
      var scene = new T.Scene();
      var camera = new T.PerspectiveCamera(32, w / h, 0.1, 100);
      camera.position.set(0, 1.0, 4.2);
      camera.lookAt(0, 1.0, 0);
      var renderer = new T.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
      renderer.setSize(w, h);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setClearColor(0x000000, 0);

      var base = [], soulGlow = [], mindGlow = [], bodyJoints = [], shield = [];
      function sph(arr, cx, cy, cz, r, n) { for (var i = 0; i < n; i++) { var u = Math.random(), v = Math.random(), theta = 2*Math.PI*u, phi = Math.acos(2*v-1), rr = r*(0.92+Math.random()*0.08); arr.push(cx+rr*Math.sin(phi)*Math.cos(theta), cy+rr*Math.cos(phi), cz+rr*Math.sin(phi)*Math.sin(theta)); } }
      function cylS(arr, cx, cy, cz, r, ht, n) { for (var i = 0; i < n; i++) { var a = Math.random()*Math.PI*2, rr = r*(0.9+Math.random()*0.1); arr.push(cx+rr*Math.cos(a), cy+(Math.random()-0.5)*ht, cz+rr*Math.sin(a)); } }
      function ring(arr, cx, cy, cz, r, n) { for (var i = 0; i < n; i++) { var a = (i/n)*Math.PI*2+Math.random()*0.1, rr = r*(0.95+Math.random()*0.1); arr.push(cx+rr*Math.cos(a), cy+(Math.random()-0.5)*0.01, cz+rr*Math.sin(a)); } }
