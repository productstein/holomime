---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="holomime — Behavioral Intelligence for Humanoid Robots"
  description="We train humanoid robot minds through behavioral therapy. The agent is the rehearsal. The robot is the performance."
>

<!-- ═══ GLASSMORPHIC NAV ═══ -->
<nav class="glass-nav fixed top-0 left-0 right-0 z-50">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-8 py-4">
    <a href="/" class="flex items-center gap-2.5 text-[var(--color-text)] font-bold tracking-tight text-lg">
      <img src="/logo-icon.svg" alt="" class="h-6 w-6 invert opacity-80" />
      holomime
    </a>
    <div class="flex items-center gap-8 text-[13px] tracking-wide">
      <a href="/manifesto" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300">Manifesto</a>
      <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300">GitHub</a>
      <a href="/contact" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300">Contact</a>
    </div>
  </div>
</nav>

<main>

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Full-viewport Three.js canvas (particle field + humanoid) -->
    <canvas id="hero-scene" class="absolute inset-0 w-full h-full" style="z-index: 0;"></canvas>

    <!-- Gradient orbs -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden" style="z-index: 1;">
      <div class="gradient-orb-1 absolute w-[600px] h-[600px] rounded-full opacity-[0.06]" style="top: 20%; right: 10%; background: radial-gradient(circle, #f97066 0%, transparent 70%); filter: blur(140px);"></div>
      <div class="gradient-orb-2 absolute w-[500px] h-[500px] rounded-full opacity-[0.04]" style="bottom: 10%; left: 5%; background: radial-gradient(circle, #1a3a6a 0%, transparent 70%); filter: blur(120px);"></div>
    </div>

    <!-- Hero content -->
    <div class="relative mx-auto max-w-7xl px-8 w-full" style="z-index: 2;">
      <div class="max-w-2xl pt-24 lg:pt-0">
        <h1 class="reveal text-[clamp(3rem,7vw,5.5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-[var(--color-text)]">
          Train the mind.
        </h1>
        <h1 class="reveal reveal-d1 text-[clamp(3rem,7vw,5.5rem)] font-extrabold leading-[0.95] tracking-[-0.03em] text-[var(--color-accent)]">
          Deploy the body.
        </h1>

        <p class="reveal reveal-d2 mt-8 text-[17px] leading-[1.7] text-[var(--color-text-secondary)] max-w-lg">
          Behavioral intelligence for humanoid robots. We train AI agents through structured therapy, then deploy them into physical bodies.
        </p>

        <div class="reveal reveal-d3 mt-10 flex items-center gap-4">
          <a href="/manifesto" class="cta-primary relative inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-7 py-3.5 text-[13px] font-semibold tracking-wide text-white">
            Read the manifesto
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-7 py-3.5 text-[13px] font-semibold tracking-wide text-[var(--color-text-secondary)] transition-all duration-300 hover:text-[var(--color-text)] hover:border-[var(--color-text-muted)]">
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ THE PROBLEM ═══ -->
  <div class="section-line"></div>
  <section class="py-28 md:py-36">
    <div class="mx-auto max-w-6xl px-8">
      <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.1] tracking-[-0.02em]">
        <span class="text-[var(--color-text)]">29 humanoid OEMs are building bodies.</span><br />
        <span class="text-[var(--color-text-muted)]">Nobody is training the mind.</span>
      </h2>

      <div class="mt-20 grid grid-cols-3 gap-6 md:gap-12">
        <div>
          <div class="text-[clamp(2.5rem,5vw,4rem)] font-extrabold tracking-tight text-[var(--color-text)]">$6.24B</div>
          <div class="mt-2 text-[13px] text-[var(--color-text-muted)] tracking-wide">Humanoid market 2026</div>
        </div>
        <div>
          <div class="text-[clamp(2.5rem,5vw,4rem)] font-extrabold tracking-tight text-[var(--color-text)]">$165B</div>
          <div class="mt-2 text-[13px] text-[var(--color-text-muted)] tracking-wide">Projected 2034</div>
        </div>
        <div>
          <div class="text-[clamp(2.5rem,5vw,4rem)] font-extrabold tracking-tight text-[var(--color-accent)]">0</div>
          <div class="mt-2 text-[13px] text-[var(--color-text-muted)] tracking-wide">OEMs with behavioral intelligence</div>
        </div>
      </div>

      <p class="mt-20 text-lg leading-[1.8] text-[var(--color-text-secondary)] max-w-2xl">
        Locomotion is solved. Manipulation is getting there. But when a care robot drifts from its safety protocols after 10,000 hours — that's not a hardware problem. It's a mind problem.
      </p>
    </div>
  </section>

  <!-- ═══ HOW IT WORKS ═══ -->
  <div class="section-line"></div>
  <section class="py-28 md:py-36 bg-[var(--color-bg-raised)]">
    <div class="mx-auto max-w-6xl px-8">
      <h2 class="text-2xl font-bold text-[var(--color-text)] md:text-3xl tracking-tight">How robots learn to behave</h2>

      <div class="mt-16">
        <div class="flex items-baseline gap-8 py-7 border-b border-[var(--color-border)]">
          <span class="text-[13px] font-mono text-[var(--color-text-muted)] shrink-0 w-6 tabular-nums">01</span>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-[var(--color-text)]">Build identity</span>
            <span class="text-[var(--color-text-secondary)] text-[15px]">soul.md, psyche.sys, conscience.exe</span>
          </div>
        </div>
        <div class="flex items-baseline gap-8 py-7 border-b border-[var(--color-border)]">
          <span class="text-[13px] font-mono text-[var(--color-text-muted)] shrink-0 w-6 tabular-nums">02</span>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-[var(--color-text)]">Train through therapy</span>
            <span class="text-[var(--color-text-secondary)] text-[15px]">Diagnose drift, run correction sessions, generate DPO pairs</span>
          </div>
        </div>
        <div class="flex items-baseline gap-8 py-7 border-b border-[var(--color-border)]">
          <span class="text-[13px] font-mono text-[var(--color-text-muted)] shrink-0 w-6 tabular-nums">03</span>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-[var(--color-text)]">Fine-tune</span>
            <span class="text-[var(--color-text-secondary)] text-[15px]">Permanently rewire the model. No prompt engineering.</span>
          </div>
        </div>
        <div class="flex items-baseline gap-8 py-7 border-b border-[var(--color-border)]">
          <span class="text-[13px] font-mono text-[var(--color-text-muted)] shrink-0 w-6 tabular-nums">04</span>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-[var(--color-text)]">Deploy to body</span>
            <span class="text-[var(--color-text-secondary)] text-[15px]">Push to hardware via ROS2, gRPC, or MQTT</span>
          </div>
        </div>
        <div class="flex items-baseline gap-8 py-7">
          <span class="text-[13px] font-mono text-[var(--color-text-muted)] shrink-0 w-6 tabular-nums">05</span>
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-semibold text-[var(--color-text)]">Monitor</span>
            <span class="text-[var(--color-text-secondary)] text-[15px]">Detect behavioral drift. Correct autonomously.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ IDENTITY STACK ═══ -->
  <div class="section-line"></div>
  <section class="py-28 md:py-36">
    <div class="mx-auto max-w-6xl px-8">
      <h2 class="text-2xl font-bold text-[var(--color-text)] md:text-3xl tracking-tight">The Identity Stack</h2>
      <p class="mt-3 text-[15px] text-[var(--color-text-secondary)]">Four files define who the robot is. They compile into a single runtime personality.</p>

      <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-16">
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <div class="h-2 w-2 rounded-full bg-[var(--color-accent)]"></div>
            <span class="font-mono text-[13px] font-semibold text-[var(--color-text)] tracking-wide">soul.md</span>
          </div>
          <p class="text-[14px] text-[var(--color-text-muted)] leading-relaxed">What it values</p>
        </div>
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <div class="h-2 w-2 rounded-full bg-[var(--color-text-muted)]"></div>
            <span class="font-mono text-[13px] font-semibold text-[var(--color-text)] tracking-wide">psyche.sys</span>
          </div>
          <p class="text-[14px] text-[var(--color-text-muted)] leading-relaxed">How it thinks</p>
        </div>
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <div class="h-2 w-2 rounded-full bg-[var(--color-text-muted)]"></div>
            <span class="font-mono text-[13px] font-semibold text-[var(--color-text)] tracking-wide">body.api</span>
          </div>
          <p class="text-[14px] text-[var(--color-text-muted)] leading-relaxed">What it inhabits</p>
        </div>
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <div class="h-2 w-2 rounded-full bg-[var(--color-text-muted)]"></div>
            <span class="font-mono text-[13px] font-semibold text-[var(--color-text)] tracking-wide">conscience.exe</span>
          </div>
          <p class="text-[14px] text-[var(--color-text-muted)] leading-relaxed">What it refuses</p>
        </div>
      </div>

      <p class="mt-20 text-xl font-medium text-[var(--color-text-secondary)] tracking-tight">
        We don't know if AI is sentient. But we can give it a conscience.
      </p>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <div class="section-line"></div>
  <section class="py-28 md:py-36 bg-[var(--color-bg-raised)]">
    <div class="mx-auto max-w-6xl px-8 text-center">
      <p class="text-[clamp(1.5rem,3vw,2.25rem)] font-bold text-[var(--color-text)] tracking-tight leading-snug">
        The standard is free.<br />The training infrastructure is the business.
      </p>
      <p class="mt-5 text-[13px] text-[var(--color-text-muted)] tracking-widest uppercase">Open source · MIT licensed</p>

      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="cta-primary relative inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-7 py-3.5 text-[13px] font-semibold tracking-wide text-white">
          Get in touch
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] px-7 py-3.5 text-[13px] font-semibold tracking-wide text-[var(--color-text-secondary)] transition-all duration-300 hover:text-[var(--color-text)] hover:border-[var(--color-text-muted)]">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

</main>

<!-- ═══ FOOTER ═══ -->
<footer class="py-10 border-t border-[var(--color-border)]">
  <div class="mx-auto max-w-7xl px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="font-bold text-[var(--color-text)] text-sm">holomime</span>
      <span class="text-[var(--color-text-muted)] text-[12px]">Behavioral intelligence for humanoid robots</span>
    </div>
    <div class="flex items-center gap-5">
      <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300" aria-label="GitHub">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
      <a href="https://x.com/holomimeIQ" target="_blank" rel="noopener" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300" aria-label="X">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <span class="text-[11px] text-[var(--color-text-muted)]">&copy; {new Date().getFullYear()}</span>
    </div>
  </div>
</footer>

<!-- ═══ THREE.JS: PARTICLE FIELD + HUMANOID ═══ -->
<script is:inline>
(function() {
  var s = document.createElement('script');
  s.src = 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';
  s.onload = function() {
    var canvas = document.getElementById('hero-scene');
    if (!canvas) return;
    var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var T = window.THREE;

    var w = window.innerWidth;
    var h = window.innerHeight;
    var scene = new T.Scene();
    var camera = new T.PerspectiveCamera(35, w / h, 0.1, 200);
    camera.position.set(-1.2, 1.0, 5.5);
    camera.lookAt(0.8, 1.0, 0);

    var renderer = new T.WebGLRenderer({ canvas: canvas, alpha: true, antialias: true });
    renderer.setSize(w, h);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x06060a, 1);

    // ─── PARTICLE FIELD (neural dust) ───
    var dustPts = [];
    var dustVel = [];
    for (var i = 0; i < 3000; i++) {
      var px = (Math.random() - 0.5) * 14;
      var py = (Math.random() - 0.5) * 8;
      var pz = (Math.random() - 0.5) * 10;
      dustPts.push(px, py, pz);
      dustVel.push(
        (Math.random() - 0.5) * 0.002,
        (Math.random() - 0.5) * 0.001,
        (Math.random() - 0.5) * 0.002
      );
    }
    var dustGeo = new T.BufferGeometry();
    dustGeo.setAttribute('position', new T.Float32BufferAttribute(dustPts, 3));
    var dustMat = new T.PointsMaterial({ color: 0xffffff, size: 0.015, sizeAttenuation: true, transparent: true, opacity: 0.25 });
    var dustMesh = new T.Points(dustGeo, dustMat);
    scene.add(dustMesh);

    // ─── HUMANOID (offset to right) ───
    var base = [], soulGlow = [], psycheGlow = [], bodyJoints = [], shield = [];

    function sph(arr, cx, cy, cz, r, n) {
      for (var j = 0; j < n; j++) {
        var u = Math.random(), v = Math.random();
        var theta = 2 * Math.PI * u, phi = Math.acos(2 * v - 1);
        var rr = r * (0.92 + Math.random() * 0.08);
        arr.push(cx + rr * Math.sin(phi) * Math.cos(theta), cy + rr * Math.cos(phi), cz + rr * Math.sin(phi) * Math.sin(theta));
      }
    }
    function cylS(arr, cx, cy, cz, r, ht, n) {
      for (var j = 0; j < n; j++) {
        var a = Math.random() * Math.PI * 2, rr = r * (0.9 + Math.random() * 0.1);
        arr.push(cx + rr * Math.cos(a), cy + (Math.random() - 0.5) * ht, cz + rr * Math.sin(a));
      }
    }
    function ring(arr, cx, cy, cz, r, n) {
      for (var j = 0; j < n; j++) {
        var a = (j / n) * Math.PI * 2 + Math.random() * 0.1, rr = r * (0.95 + Math.random() * 0.1);
        arr.push(cx + rr * Math.cos(a), cy + (Math.random() - 0.5) * 0.01, cz + rr * Math.sin(a));
      }
    }
    function boxS(arr, cx, cy, cz, bw, bh, bd, n) {
      for (var j = 0; j < n; j++) {
        var face = Math.floor(Math.random() * 6), u = Math.random() - 0.5, v = Math.random() - 0.5;
        if (face === 0) arr.push(cx + bw/2, cy + u*bh, cz + v*bd);
        else if (face === 1) arr.push(cx - bw/2, cy + u*bh, cz + v*bd);
        else if (face === 2) arr.push(cx + u*bw, cy + bh/2, cz + v*bd);
        else if (face === 3) arr.push(cx + u*bw, cy - bh/2, cz + v*bd);
        else if (face === 4) arr.push(cx + u*bw, cy + v*bh, cz + bd/2);
        else arr.push(cx + u*bw, cy + v*bh, cz - bd/2);
      }
    }

    // Full body
    sph(base,0,2.15,0,0.20,600);ring(base,0,2.15,0,0.21,40);sph(base,-0.07,2.18,0.16,0.035,60);sph(base,0.07,2.18,0.16,0.035,60);sph(base,0,2.02,0.08,0.06,40);
    cylS(base,0,1.90,0,0.065,0.10,120);ring(base,0,1.95,0,0.07,30);ring(base,0,1.85,0,0.07,30);
    sph(base,-0.32,1.78,0,0.08,150);sph(base,0.32,1.78,0,0.08,150);cylS(base,0,1.78,0,0.04,0.02,60);boxS(base,-0.15,1.78,0,0.30,0.04,0.08,80);boxS(base,0.15,1.78,0,0.30,0.04,0.08,80);
    boxS(base,0,1.58,0,0.42,0.30,0.20,500);boxS(base,0,1.30,0,0.36,0.26,0.18,400);cylS(base,0,1.44,0.10,0.01,0.50,60);ring(base,0,1.65,0,0.18,30);ring(base,0,1.50,0,0.16,30);ring(base,0,1.35,0,0.14,25);cylS(base,-0.20,1.50,0.08,0.03,0.20,40);cylS(base,0.20,1.50,0.08,0.03,0.20,40);
    cylS(base,-0.38,1.58,0,0.055,0.35,200);cylS(base,0.38,1.58,0,0.055,0.35,200);ring(base,-0.38,1.65,0,0.06,25);ring(base,0.38,1.65,0,0.06,25);ring(base,-0.38,1.50,0,0.06,25);ring(base,0.38,1.50,0,0.06,25);
    sph(base,-0.40,1.38,0,0.055,120);sph(base,0.40,1.38,0,0.055,120);ring(base,-0.40,1.38,0,0.06,30);ring(base,0.40,1.38,0,0.06,30);
    cylS(base,-0.42,1.18,0,0.045,0.35,180);cylS(base,0.42,1.18,0,0.045,0.35,180);ring(base,-0.42,1.25,0,0.05,20);ring(base,0.42,1.25,0,0.05,20);ring(base,-0.42,1.10,0,0.05,20);ring(base,0.42,1.10,0,0.05,20);
    boxS(base,-0.43,0.96,0,0.06,0.10,0.04,80);boxS(base,0.43,0.96,0,0.06,0.10,0.04,80);
    cylS(base,-0.44,0.88,0,0.01,0.06,20);cylS(base,-0.42,0.88,0,0.01,0.06,20);cylS(base,-0.46,0.88,0,0.01,0.06,20);cylS(base,0.44,0.88,0,0.01,0.06,20);cylS(base,0.42,0.88,0,0.01,0.06,20);cylS(base,0.46,0.88,0,0.01,0.06,20);
