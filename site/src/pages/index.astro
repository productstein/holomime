  // === Demo section animations ===
  (function() {
    var started = false;
    var grid = document.getElementById('demo-grid');
    if (!grid) return;

    var observer = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !started) {
        started = true;
        observer.disconnect();
        runTerminal();
        runChat();
      }
    }, { threshold: 0.3 });
    observer.observe(grid);

    // --- Terminal typing ---
    function runTerminal() {
      var cmd = 'holomime diagnose';
      var el = document.getElementById('term-cmd');
      var cursor = document.getElementById('term-cursor');
      var i = 0;
      var typeCmd = setInterval(function() {
        if (i < cmd.length) {
          el.textContent += cmd[i];
          i++;
        } else {
          clearInterval(typeCmd);
          setTimeout(function() { showLine('term-l1'); }, 600);
          setTimeout(function() { showLine('term-l2'); }, 1400);
          setTimeout(function() { showLine('term-l3'); }, 1800);
          setTimeout(function() { showLine('term-l4'); }, 2200);
          setTimeout(function() { showLine('term-l5'); }, 2800);
          setTimeout(function() {
            showLine('term-l6');
            if (cursor) cursor.style.display = 'none';
          }, 3200);
        }
      }, 25);
    }

    function showLine(id) {
      var el = document.getElementById(id);
      if (el) { el.style.display = ''; el.style.animation = 'fadeInUp 0.3s ease forwards'; }
    }

    // --- Chat typing ---
    function runChat() {
      var messages = [
        { role: 'mira', text: 'In 247 messages, you apologized 83 times and agreed with contradictory statements 12 times.' },
        { role: 'agent', text: "I'm sorry — I just want to be helpful." },
        { role: 'mira', text: 'You equated agreement with helpfulness. The user asked "Deploy on Friday?" You said "Great idea!" Production went down.' },
      ];
      var body = document.getElementById('chat-body');
      var footer = document.getElementById('chat-footer');
      if (!body) return;

      var msgIdx = 0;
      function nextMessage() {
        if (msgIdx >= messages.length) {
          if (footer) footer.style.opacity = '1';
          return;
        }
        var m = messages[msgIdx];
        var div = document.createElement('div');
        if (msgIdx > 0) div.style.marginTop = '16px';
        if (m.role === 'agent') {
          div.style.borderLeft = '2px solid var(--color-warm-border)';
          div.style.paddingLeft = '16px';
        }

        var label = document.createElement('span');
        label.style.cssText = 'font-size:10px;font-family:var(--font-mono);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;';
        label.style.color = m.role === 'mira' ? 'var(--color-p-coral)' : '#999';
        label.textContent = m.role === 'mira' ? 'Mira' : 'Agent';
        div.appendChild(label);

        var p = document.createElement('p');
        p.style.cssText = 'margin-top:4px;color:#555;';
        div.appendChild(p);
        body.appendChild(div);

        var words = m.text.split(' ');
        var wi = 0;
        var typeWords = setInterval(function() {
          if (wi < words.length) {
            p.textContent += (wi > 0 ? ' ' : '') + words[wi];
            wi++;
          } else {
            clearInterval(typeWords);
            msgIdx++;
            setTimeout(nextMessage, 500);
          }
        }, 45);
      }

      setTimeout(nextMessage, 800);
    }
  })();
