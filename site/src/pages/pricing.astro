---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Pricing from "../components/Pricing.astro";
import Footer from "../components/Footer.astro";

const faqs = [
  {
    q: "Can I switch plans anytime?",
    a: "Yes, upgrades are instant. Downgrades take effect at the next billing cycle.",
  },
  {
    q: "What happens when I hit my API limit?",
    a: "Practitioner tier: you're billed per call, no limits. Practice: truly unlimited.",
  },
  {
    q: "Do you offer annual discounts?",
    a: "Yes, 20% off with annual billing.",
  },
  {
    q: "Is my agent data private?",
    a: "We never use your agent data to train our models. See our privacy policy.",
  },
  {
    q: "What's NeuralSpace?",
    a: "Real-time 3D brain visualization for your agents. Watch behavioral patterns fire across 8 neural regions.",
  },
  {
    q: "Do you offer startup discounts?",
    a: "Yes, contact us for startup and academic pricing.",
  },
  {
    q: "What is the Identity Stack?",
    a: "Eight files that define who your agent is: soul.md (values), mind.sys (personality traits), body.api (hardware profile), and conscience.exe (safety rules). They compile into a single personality.json that any runtime can consume. See the <a href='/docs'>documentation</a> for a full walkthrough.",
  },
  {
    q: "How is therapy different from fine-tuning?",
    a: "Therapy is the diagnostic and correction process — it identifies behavioral drift and generates DPO training pairs. Fine-tuning applies those pairs permanently to the model weights. Therapy is the method; fine-tuning is one of its outputs.",
  },
  {
    q: "What models do you support?",
    a: "Diagnosis works with any model that produces text — OpenAI, Anthropic, Mistral, Llama, etc. Fine-tuning currently supports OpenAI. More providers coming soon.",
  },
  {
    q: "Can I use holomime with physical robots?",
    a: "Yes. Deploy personality.json to hardware via ROS2, gRPC, or MQTT — including end-to-end VLA models like Figure Helix and NVIDIA Kimodo for personality-to-motion mapping. We include 8 OEM body templates (Figure 03, Unitree H1, and more). See the integrations page for setup guides.",
  },
  {
    q: "What is Mira?",
    a: "Mira is our autonomous behavioral therapist. She diagnoses drift patterns, runs structured correction sessions, and generates training data. She also improves herself through self-practice — 414+ DPO pairs and counting. <a href='/demo'>Try the live demo</a> to see her in action.",
  },
  {
    q: "Is holomime open source?",
    a: "The identity stack, CLI, adapters, detectors, and body templates are MIT licensed. The training pipeline — Mira, the DPO corpus, and the therapy engine — is proprietary and available on paid plans.",
  },
];

const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
};

const comparisonRows = [
  {
    feature: "Behavioral Detectors",
    clinic: "8 rule-based",
    practitioner: "8 rule-based",
    practice: "8 + LLM-powered",
    institute: "Custom + LLM",
  },
  {
    feature: "API Calls",
    clinic: "Local only",
    practitioner: "Pay per call ($0.01/diagnose)",
    practice: "Unlimited",
    institute: "Unlimited",
  },
  {
    feature: "Agents",
    clinic: "Unlimited local",
    practitioner: "10",
    practice: "50",
    institute: "Unlimited",
  },
  {
    feature: "NeuralSpace",
    clinic: null,
    practitioner: null,
    practice: true,
    institute: "Fleet view",
  },
  {
    feature: "Voice Monitoring",
    clinic: null,
    practitioner: null,
    practice: null,
    institute: true,
  },
  {
    feature: "Training Data Export",
    clinic: "DPO",
    practitioner: "DPO, RLHF",
    practice: "All formats",
    institute: "All + custom",
  },
  {
    feature: "Webhooks",
    clinic: null,
    practitioner: "3",
    practice: "10",
    institute: "Unlimited",
  },
  {
    feature: "Custom Detectors",
    clinic: "JSON config",
    practitioner: "JSON config",
    practice: "JSON + LLM",
    institute: "Custom + LLM",
  },
  {
    feature: "Therapy Memory",
    clinic: null,
    practitioner: null,
    practice: true,
    institute: true,
  },
  {
    feature: "Knowledge Graph",
    clinic: null,
    practitioner: null,
    practice: true,
    institute: "Fleet-wide",
  },
  {
    feature: "IDE Integration",
    clinic: "VS Code",
    practitioner: "VS Code",
    practice: "VS Code",
    institute: "VS Code + custom",
  },
  {
    feature: "Agent Framework Plugins",
    clinic: "OpenClaw, LangChain, CrewAI",
    practitioner: "OpenClaw, LangChain, CrewAI",
    practice: "OpenClaw, LangChain, CrewAI",
    institute: "All + NemoClaw",
  },
  {
    feature: "Shareable Snapshots",
    clinic: true,
    practitioner: true,
    practice: true,
    institute: true,
  },
  {
    feature: "Self-Awareness Interviews",
    clinic: true,
    practitioner: true,
