---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="500 — Something went wrong | holomime">
  <Nav />
  <main class="flex min-h-[60vh] items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">500</p>
      <h1 class="mt-3 text-4xl font-extrabold text-[var(--color-warm-text)] md:text-5xl">
        Something went wrong.
      </h1>
      <p class="mx-auto mt-4 max-w-md text-[var(--color-warm-muted)]">
        We're looking into it. Please try again in a moment.
      </p>
      <div class="mt-8">
        <a href="/" class="inline-flex items-center gap-2 rounded-full bg-[var(--color-warm-text)] px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-80">
          Back to home
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
