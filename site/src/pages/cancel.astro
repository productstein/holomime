---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Checkout Cancelled — holomime">
  <Nav />
  <main class="flex min-h-screen items-center justify-center pt-20">
    <div class="mx-auto max-w-lg px-6 py-20 text-center">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-500/10">
        <svg class="h-8 w-8 text-yellow-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold">Checkout cancelled</h1>
      <p class="mt-4 text-[var(--color-holo-muted)]">
        No worries! You can always upgrade later. The free tier includes personality profiling, behavioral analysis, and the marketplace.
      </p>

      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/#pricing"
          class="inline-flex items-center rounded-lg bg-[var(--color-holo-cyan)] px-6 py-3 text-sm font-semibold text-[var(--color-holo-dark)] transition-opacity hover:opacity-90"
        >
          Try Again
        </a>
        <a
          href="/"
          class="inline-flex items-center rounded-lg border border-[var(--color-holo-border)] px-6 py-3 text-sm font-medium transition-colors hover:border-[var(--color-holo-muted)]"
        >
          Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
