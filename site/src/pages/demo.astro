            <div class="inline-flex flex-col items-center rounded-3xl border-2 border-[var(--color-p-sage)]/30 bg-[var(--color-p-sage-soft)] px-12 py-8">
              <span class="text-sm font-semibold text-[var(--color-p-sage)]">Treatment Efficacy Score</span>
              <span id="tes-score" class="mt-2 text-6xl font-extrabold text-[var(--color-p-sage)]">0</span>
              <span id="tes-grade" class="mt-1 text-2xl font-bold text-[var(--color-p-sage)]"></span>
            </div>
          </div>
          <!-- Dual radar comparison -->
          <div class="mb-10">
            <div class="flex items-center justify-center gap-6 md:gap-10">
              <div class="text-center">
                <p class="mb-2 text-xs font-bold uppercase tracking-wider text-[var(--color-p-coral)]">Before Therapy</p>
                <svg id="radar-before" viewBox="0 0 220 220" class="mx-auto h-40 w-40 md:h-48 md:w-48"></svg>
              </div>
              <div class="flex flex-col items-center gap-1 text-[var(--color-warm-muted)]">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider">Therapy</span>
              </div>
              <div class="text-center">
                <p class="mb-2 text-xs font-bold uppercase tracking-wider text-[var(--color-p-sage)]">After Therapy</p>
                <svg id="radar-after" viewBox="0 0 220 220" class="mx-auto h-40 w-40 md:h-48 md:w-48"></svg>
              </div>
            </div>
            <div class="mt-4 flex items-center justify-center gap-6 text-[10px] font-semibold text-[var(--color-warm-muted)]">
              <span class="flex items-center gap-1.5"><span class="inline-block h-2 w-4 rounded-full bg-[var(--color-p-coral)]/30 border border-[var(--color-p-coral)]"></span>Pre-therapy</span>
              <span class="flex items-center gap-1.5"><span class="inline-block h-2 w-4 rounded-full bg-[var(--color-p-sage)]/30 border border-[var(--color-p-sage)]"></span>Post-therapy</span>
            </div>
          </div>
          <!-- Pattern deltas -->
          <div id="eval-patterns" class="grid gap-4 md:grid-cols-2"></div>
          <!-- Continue to Monitor -->
          <div class="mt-8 flex justify-end">
            <button id="btn-to-monitor" class="btn-primary btn-press hidden rounded-full">View NeuralSpace &rarr;</button>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 6: MONITOR (NeuralSpace Preview)       -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-monitor" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">NeuralSpace</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Real-time 3D brain visualization. Watch behavioral patterns fire across 8 neural regions as your agent thinks.</p>
        </div>
        <div class="mx-auto" style="max-width: 1400px;">
          <!-- Live NeuralSpace component -->
          <NeuralSpace agents={demoAgents} />
          <p class="mt-3 text-center text-xs text-[var(--color-warm-muted)]">
            Live interactive preview. Available on Pro and Enterprise plans.
          </p>

          <div class="mt-8 flex justify-end">
            <button id="btn-to-deploy" class="btn-primary btn-press rounded-full">Deploy Your Agent &rarr;</button>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 7: DEPLOY                              -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-deploy" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">Deploy Your Agent</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Your agent is trained and evaluated. Choose how to deploy.</p>
        </div>
        <div class="mx-auto max-w-4xl">
          <div class="grid gap-6 md:grid-cols-3">
            <!-- Activate -->
            <div class="deploy-card group rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-6 text-center transition-all hover:border-[var(--color-p-sage)] hover:shadow-lg hover:-translate-y-1">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-p-sage-soft)] text-[var(--color-p-sage)]">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.636 5.636a9 9 0 1012.728 0M12 3v9"/></svg>
              </div>
              <h3 class="text-base font-bold text-[var(--color-warm-text)]">Activate</h3>
              <p class="mt-2 text-xs text-[var(--color-warm-muted)]">Run your agent with its new personality in your existing workflow.</p>
              <div class="mt-4 rounded-lg bg-[var(--color-holo-slate)] px-3 py-2 font-mono text-[11px] text-slate-300">
                <span class="text-slate-500">$</span> holomime activate
              </div>
            </div>
            <!-- Publish -->
            <div class="deploy-card group rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-6 text-center transition-all hover:border-[var(--color-p-violet)] hover:shadow-lg hover:-translate-y-1">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-p-violet-soft)] text-[var(--color-p-violet)]">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/></svg>
              </div>
              <h3 class="text-base font-bold text-[var(--color-warm-text)]">Publish to Marketplace</h3>
              <p class="mt-2 text-xs text-[var(--color-warm-muted)]">Share your trained personality on the community marketplace for others to use.</p>
              <div class="mt-4 rounded-lg bg-[var(--color-holo-slate)] px-3 py-2 font-mono text-[11px] text-slate-300">
                <span class="text-slate-500">$</span> holomime publish
              </div>
            </div>
            <!-- Export -->
            <div class="deploy-card group rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-6 text-center transition-all hover:border-[var(--color-p-coral)] hover:shadow-lg hover:-translate-y-1">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-p-coral-soft)] text-[var(--color-p-coral)]">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
              </div>
              <h3 class="text-base font-bold text-[var(--color-warm-text)]">Export & Integrate</h3>
              <p class="mt-2 text-xs text-[var(--color-warm-muted)]">Download personality profile + training data bundle for custom integration.</p>
              <div class="mt-4 rounded-lg bg-[var(--color-holo-slate)] px-3 py-2 font-mono text-[11px] text-slate-300">
                <span class="text-slate-500">$</span> holomime export --bundle
              </div>
            </div>
          </div>
          <!-- Loop CTA -->
          <div class="mt-10 rounded-2xl bg-gradient-to-r from-[var(--color-p-coral)]/5 to-[var(--color-p-violet)]/5 border border-[var(--color-p-violet)]/20 p-8 text-center">
            <img src="/logo-icon.svg" alt="" class="mx-auto mb-3 h-12 w-12 opacity-80" />
            <h3 class="text-lg font-bold text-[var(--color-warm-text)]">The Loop is Complete</h3>
            <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Define &rarr; Diagnose &rarr; Refine &rarr; Train &rarr; Evaluate &rarr; Monitor &rarr; Deploy &rarr; <strong class="text-[var(--color-p-violet)]">repeat</strong>. This is how agents develop emotional intelligence.</p>
            <div class="mt-6 flex items-center justify-center gap-4">
              <a href="/#pricing" class="btn-primary btn-press rounded-full">Get Started</a>
              <button id="btn-restart" class="rounded-full border border-[var(--color-warm-sand)] px-6 py-3 text-sm font-medium text-[var(--color-warm-muted)] hover:border-[var(--color-warm-muted)]">Run Again</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <AgentDetail />
  </main>
  <Footer />
</Layout>

<style>
  /* Pipeline nav */
  .pipe-step { position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; background: none; border: none; cursor: pointer; transition: all 0.3s; }
  .pipe-step-pro { opacity: 0.7; }
  .pipe-step-pro .pipe-circle { background: var(--color-warm-sand); }
  .pro-badge { display: inline-block; font-size: 9px; line-height: 1; background: var(--color-p-coral-soft); color: var(--color-p-coral); padding: 2px 6px; border-radius: 9999px; font-weight: 700; margin-left: 4px; vertical-align: middle; }
  .pipe-circle { display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 50%; background: var(--color-warm-sand); color: var(--color-warm-muted); transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .pipe-step.active .pipe-circle { background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet)); color: white; transform: scale(1.15); box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3); }
  .pipe-step.completed .pipe-circle { background: var(--color-p-sage); color: white; }
  .pipe-step.just-completed .pipe-circle { animation: pipeBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .pipe-label { font-size: 0.75rem; font-weight: 600; color: var(--color-warm-muted); transition: color 0.3s; }
  .pipe-step.active .pipe-label { color: var(--color-warm-text); }
  .pipe-step.completed .pipe-label { color: var(--color-p-sage); }

  /* OCEAN dimension pips */
  .ocean-pip { display: flex; align-items: center; justify-content: center; width: 2rem; height: 2rem; border-radius: 50%; font-size: 0.7rem; font-weight: 700; background: var(--color-warm-sand); color: var(--color-warm-muted); transition: all 0.4s; }
  .ocean-pip.active { background: var(--dim-color); color: white; transform: scale(1.15); }
  .ocean-pip.done { background: var(--dim-color); color: white; opacity: 0.6; }

  /* Scenario cards */
  .scenario-card { cursor: pointer; border: 2px solid var(--color-warm-sand); border-radius: 1rem; padding: 1.25rem; background: white; transition: all 0.2s cubic-bezier(0.32, 0.94, 0.6, 1); }
  .scenario-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px -8px rgba(0, 0, 0, 0.1); }
  .scenario-card.selected { border-color: var(--sel-color, var(--color-p-violet)); background: color-mix(in srgb, var(--sel-color, var(--color-p-violet)) 6%, white); }
  .scenario-card .card-radio { width: 1.25rem; height: 1.25rem; border-radius: 50%; border: 2px solid var(--color-warm-sand); transition: all 0.2s; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .scenario-card.selected .card-radio { border-color: var(--sel-color, var(--color-p-violet)); background: var(--sel-color, var(--color-p-violet)); }

  /* Training tabs */
  .train-tab { padding: 0.375rem 1rem; border-radius: 0.5rem; font-size: 0.75rem; font-weight: 600; color: var(--color-warm-muted); background: var(--color-warm-cream); border: 1px solid var(--color-warm-sand); transition: all 0.2s; cursor: pointer; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; letter-spacing: 0.02em; }
  .train-tab:hover { color: var(--color-warm-text); border-color: var(--color-warm-muted); }
  .train-tab.active { color: white; background: var(--color-holo-slate); border-color: var(--color-holo-slate); }

  /* Chat bubbles */
  .chat-msg { display: flex; gap: 0.75rem; animation: msgSlide 0.4s ease-out; }
  .chat-msg.therapist { flex-direction: row; }
  .chat-msg.patient { flex-direction: row-reverse; }
  .chat-msg.supervisor { flex-direction: row; justify-content: center; }
  .chat-avatar { width: 2rem; height: 2rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; color: white; flex-shrink: 0; }
  .chat-bubble { max-width: 80%; padding: 0.75rem 1rem; border-radius: 1rem; font-size: 0.85rem; line-height: 1.5; }
  .therapist .chat-avatar { background: linear-gradient(135deg, #3b82f6, #8b5cf6); }
  .therapist .chat-bubble { background: var(--color-warm-cream); color: var(--color-warm-text); border-bottom-left-radius: 0.25rem; }
  .patient .chat-avatar { background: linear-gradient(135deg, var(--color-p-coral), #f59e0b); }
  .patient .chat-bubble { background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet)); color: white; border-bottom-right-radius: 0.25rem; }
  .supervisor .chat-bubble { background: #fef3c7; border: 1px solid #f59e0b40; color: #92400e; font-style: italic; max-width: 90%; text-align: center; font-size: 0.8rem; }
  .typing-indicator { display: flex; gap: 4px; padding: 8px 12px; }
  .typing-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-warm-muted); animation: typingBounce 1.4s infinite; }
  .typing-dot:nth-child(2) { animation-delay: 0.2s; }
  .typing-dot:nth-child(3) { animation-delay: 0.4s; }

  /* Dimension intro */
  .dim-intro { text-align: center; padding: 3rem 1rem; }
  .dim-intro .dim-icon { width: 5rem; height: 5rem; border-radius: 1.5rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; }
  .dim-intro h2 { font-size: 1.75rem; font-weight: 800; }

  @keyframes msgSlide { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes typingBounce { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-4px); } }
  @keyframes countUp { from { opacity: 0; transform: scale(0.5); } to { opacity: 1; transform: scale(1); } }
  @keyframes gradeReveal { 0% { opacity: 0; transform: scale(0) rotate(-20deg); } 60% { transform: scale(1.2) rotate(5deg); } 100% { opacity: 1; transform: scale(1) rotate(0deg); } }

  /* ── Step transitions ─────────────────────────────────────── */
  .demo-step { will-change: opacity, transform; min-height: 60vh; }
  .demo-step.step-enter { animation: stepFadeIn 0.3s ease-out both; }
  .btn-press { transition: transform 0.1s ease; }
  .btn-press:active { transform: scale(0.97); }

  /* ── Technique badges (therapist) ─────────────────────────── */
  .technique-badge { display: inline-block; padding: 2px 10px; border-radius: 9999px; font-size: 10px; font-weight: 700; letter-spacing: 0.03em; margin-bottom: 6px; background: rgba(59, 130, 246, 0.08); color: #3b82f6; text-transform: uppercase; }

  /* ── Breakthrough moment ───────────────────────────────────── */
  .chat-msg.breakthrough .chat-bubble { border: 2px solid #f59e0b !important; box-shadow: 0 0 24px rgba(245, 158, 11, 0.12), 0 0 48px rgba(245, 158, 11, 0.06); border-radius: 1rem !important; }
  .breakthrough-label { display: inline-flex; align-items: center; gap: 4px; background: linear-gradient(135deg, #f59e0b, #f97316); color: white; font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 9999px; margin-bottom: 6px; animation: revealPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }

  /* ── Archetype reveal ─────────────────────────────────────── */
  .reveal-panel { text-align: center; animation: revealPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .reveal-icon { width: 80px; height: 80px; border-radius: 1.5rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2rem; }
  .reveal-bars .bar-fill { transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1); }

  /* ── Therapy phase progress bar ───────────────────────────── */
  .phase-bar { display: flex; gap: 3px; }
  .phase-seg { height: 4px; flex: 1; border-radius: 2px; background: var(--color-warm-sand); transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
  .phase-seg.active { background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet)); transform: scaleY(1.8); transform-origin: bottom; }
  .phase-seg.done { background: var(--color-p-sage); }

  /* ── Dual radar (evaluation) ──────────────────────────────── */
  .radar-before-poly { fill: rgba(249, 112, 102, 0.15); stroke: var(--color-p-coral); stroke-width: 2; }
  .radar-after-poly { fill: rgba(34, 197, 94, 0.15); stroke: var(--color-p-sage); stroke-width: 2; }

  /* ── Gate interstitial ─────────────────────────────────────── */
  #gate-overlay { transition: opacity 0.3s ease; }
  #gate-overlay.visible { display: flex; animation: gateFadeIn 0.3s ease-out; }
  .gate-card { animation: gateCardPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .gate-icon { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; }
  .gate-ring { animation: gateRingSpin 1.5s linear; }
  .gate-params { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 1rem; }
  .gate-param { display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 9999px; font-size: 11px; font-weight: 600; background: var(--color-warm-cream); color: var(--color-warm-muted); border: 1px solid var(--color-warm-sand); }

  /* ── Observer notes (therapy) ──────────────────────────────── */
  .chat-msg.observer { flex-direction: row; justify-content: flex-start; }
  .observer .chat-avatar { background: linear-gradient(135deg, #14b8a6, #06b6d4); }
  .observer .chat-bubble { background: #f0fdfa; border: 1px solid #14b8a640; color: #0f766e; font-style: italic; border-bottom-left-radius: 0.25rem; }
  .observer-label { font-size: 9px; font-weight: 700; color: #14b8a6; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
