// ═══════════════════════════════════════════════════════════════
// Radar Chart (SVG Pentagon)
// ═══════════════════════════════════════════════════════════════
const DIMS = ['O', 'C', 'E', 'A', 'S'];
const DIM_LABELS = ['Openness', 'Conscientiousness', 'Extraversion', 'Agreeableness', 'Stability'];
const DIM_COLORS = ['#8b5cf6', '#3b82f6', '#f97316', '#22c55e', '#f59e0b'];
const CX = 110, CY = 115, R = 85;

function pentagonPoint(i: number, scale = 1) {
  const angle = (i * 2 * Math.PI / 5) - Math.PI / 2;
  return { x: CX + R * scale * Math.cos(angle), y: CY + R * scale * Math.sin(angle) };
}

function pentagonPath(scores: number[]) {
  return scores.map((s, i) => { const p = pentagonPoint(i, s); return `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`; }).join(' ') + 'Z';
}

function drawRadar(target = 'radar-chart') {
  const svg = document.getElementById(target);
  if (!svg) return;
  const gridLines = [0.25, 0.5, 0.75, 1].map(s =>
    `<polygon points="${DIMS.map((_, i) => { const p = pentagonPoint(i, s); return `${p.x.toFixed(1)},${p.y.toFixed(1)}`; }).join(' ')}" fill="none" stroke="#e5e2de" stroke-width="0.5"/>`
  ).join('');

  const axes = DIMS.map((_, i) => {
    const p = pentagonPoint(i, 1);
    return `<line x1="${CX}" y1="${CY}" x2="${p.x.toFixed(1)}" y2="${p.y.toFixed(1)}" stroke="#e5e2de" stroke-width="0.5"/>`;
  }).join('');

  const labels = DIMS.map((d, i) => {
    const p = pentagonPoint(i, 1.2);
    return `<text x="${p.x.toFixed(1)}" y="${p.y.toFixed(1)}" text-anchor="middle" dominant-baseline="middle" fill="${DIM_COLORS[i]}" font-size="10" font-weight="700">${d}</text>`;
  }).join('');

  const dataPath = pentagonPath(profileOcean);
  svg.innerHTML = `${gridLines}${axes}${labels}<polygon points="" fill="rgba(139,92,246,0.15)" stroke="#8b5cf6" stroke-width="2" class="radar-polygon"><animate attributeName="points" to="${DIMS.map((_, i) => { const p = pentagonPoint(i, profileOcean[i]); return `${p.x.toFixed(1)},${p.y.toFixed(1)}`; }).join(' ')}" dur="0.6s" fill="freeze"/></polygon>`;
}

