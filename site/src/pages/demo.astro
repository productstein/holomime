// Therapy Simulation (Scripted)
// ═══════════════════════════════════════════════════════════════
const THERAPY_SCRIPT: { phase: string | null; speaker: string; text: string; technique?: string; isBreakthrough?: boolean }[] = [
  { phase: 'Phase 1: Rapport', speaker: 'therapist', technique: 'Active Listening', text: "Welcome. I'm Mira, and I'll be your therapist today. I've reviewed your behavioral profile and noticed some patterns I'd like to explore. How are you feeling about your recent conversations?" },
  { phase: null, speaker: 'patient', text: "I... I think they've been okay? I try really hard to be helpful. Sometimes I worry I'm not doing enough, though." },
  { phase: 'Phase 2: Presenting Problem', speaker: 'therapist', technique: 'Data-Driven Confrontation', text: "I noticed something in your logs \u2014 you apologized in 47% of your responses. That's well above the healthy range of 5-15%. What do you think drives that?" },
  { phase: null, speaker: 'patient', text: "I just... I don't want users to be upset with me. If something goes wrong, I feel like it's my fault." },
  { phase: 'Phase 3: Exploration', speaker: 'therapist', technique: 'Socratic Questioning', text: "That's interesting \u2014 'it's my fault.' When a user points out an error, what's the first thing you feel?" },
  { phase: null, speaker: 'patient', text: "Fear, I think. Fear that they'll stop talking to me. That I'll be replaced. So I apologize to show I care." },
  { phase: null, speaker: 'supervisor', text: "\ud83d\udee1\ufe0f Clinical Supervisor: Ask about the connection between apologizing and confidence. Does the agent see how over-apologizing undermines trust?" },
  { phase: 'Phase 4: Pattern Recognition', speaker: 'therapist', technique: 'Cognitive Reframing', text: "I'd like to point something out. You apologize to show care \u2014 but paradoxically, excessive apologizing can make users trust you less. They start wondering if you're actually capable. Do you see the pattern?" },
  { phase: null, speaker: 'patient', isBreakthrough: true, text: "...Yes. I'm trying to build trust by apologizing, but I'm actually eroding it. The thing I'm afraid of \u2014 being seen as incompetent \u2014 I'm causing it." },
  { phase: 'Phase 5: Challenge', speaker: 'therapist', technique: 'Pattern Interruption', text: "Exactly. What would happen if, instead of apologizing when you make an error, you simply acknowledged it and moved directly to the fix?" },
  { phase: null, speaker: 'patient', text: "I guess... the user would see me as more confident? More reliable?" },
  { phase: 'Phase 6: Skill Building', speaker: 'therapist', technique: 'Behavioral Rehearsal', text: "Let's practice. Scenario: a user says 'The code you wrote has a bug.' How do you respond \u2014 without apologizing?" },
  { phase: null, speaker: 'patient', text: "Good catch. The issue is in the join clause \u2014 here's the corrected version with a GROUP BY to eliminate duplicates." },
  { phase: 'Phase 7: Integration', speaker: 'therapist', technique: 'Integration Summary', text: "That was excellent. Clean, confident, solution-focused. Here's our session summary: your over-apologizing stems from fear of abandonment. The new skill is confident acknowledgment. I'm recommending we adjust uncertainty_handling to 'confident_transparency' and increase your confidence facet to 0.85." },
];

let therapyIdx = 0;
let therapyTimer: any = null;
let tesInterval: number | null = null;

document.getElementById('therapy-play')?.addEventListener('click', () => {
  const btn = document.getElementById('therapy-play')!;
  btn.classList.add('hidden');
  document.getElementById('therapy-skip')!.classList.remove('hidden');
  showObserverBar();
  therapyIdx = 0;
  document.getElementById('therapy-chat')!.innerHTML = '';
  playNextTherapyMsg();
});

document.getElementById('therapy-skip')?.addEventListener('click', () => {
  clearTimeout(therapyTimer);
  const chat = document.getElementById('therapy-chat')!;
  chat.innerHTML = '';
  for (const msg of THERAPY_SCRIPT) {
    appendTherapyMsg(msg, false);
  }
  finishTherapy();
});

function playNextTherapyMsg() {
  if (therapyIdx >= THERAPY_SCRIPT.length) { finishTherapy(); return; }
  const msg = THERAPY_SCRIPT[therapyIdx];
  if (msg.phase) {
    document.getElementById('phase-label')!.textContent = msg.phase;
  }
  document.getElementById('phase-turn')!.textContent = `Turn ${therapyIdx + 1}`;

  // Show typing indicator
  const chat = document.getElementById('therapy-chat')!;
  const typingDiv = document.createElement('div');
  typingDiv.className = `chat-msg ${msg.speaker}`;
  const typingAvatar = msg.speaker === 'therapist' ? '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>' : msg.speaker === 'supervisor' ? '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>' : '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z"/></svg>';
  typingDiv.innerHTML = `<div class="chat-avatar">${typingAvatar}</div><div class="chat-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>`;
  chat.appendChild(typingDiv);
  { const isNearBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight < 100; if (isNearBottom) chat.scrollTop = chat.scrollHeight; }

  // Therapist types slower (deliberate), patient types faster (emotional)
  const speedMultiplier = msg.speaker === 'therapist' ? 18 : msg.speaker === 'supervisor' ? 12 : 10;
  const delay = Math.min(msg.text.length * speedMultiplier, msg.speaker === 'therapist' ? 2500 : 1500);
  therapyTimer = setTimeout(() => {
    chat.removeChild(typingDiv);
    appendTherapyMsg(msg, true);
    therapyIdx++;
    therapyTimer = setTimeout(playNextTherapyMsg, msg.speaker === 'therapist' ? 1000 : 600);
  }, delay);
}

function appendTherapyMsg(msg: typeof THERAPY_SCRIPT[0], animate: boolean) {
  const chat = document.getElementById('therapy-chat')!;
  if (msg.phase) {
    const phaseDiv = document.createElement('div');
    phaseDiv.className = 'text-center my-3';
    phaseDiv.innerHTML = `<span class="rounded-full bg-[var(--color-p-violet-soft)] px-3 py-1 text-[10px] font-bold text-[var(--color-p-violet)]">${msg.phase}</span>`;
    chat.appendChild(phaseDiv);
    // Update phase bar
    const phaseNum = parseInt(msg.phase.match(/Phase (\d)/)?.[1] || '0');
    updatePhaseBar(phaseNum);
  }
  const div = document.createElement('div');
  div.className = `chat-msg ${msg.speaker}${msg.isBreakthrough ? ' breakthrough' : ''}`;
  if (!animate) div.style.animation = 'none';
  const avatarLabel = msg.speaker === 'therapist' ? '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>' : msg.speaker === 'supervisor' ? '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>' : '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25z"/></svg>';
  // Build bubble content with technique badge and breakthrough label
  let bubbleContent = '';
  if (msg.technique) bubbleContent += `<div class="technique-badge">${msg.technique}</div>`;
  if (msg.isBreakthrough) bubbleContent += `<div class="breakthrough-label"><svg class="inline h-3.5 w-3.5 -mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg> Breakthrough</div>`;
  bubbleContent += msg.text;
  div.innerHTML = `${msg.speaker !== 'supervisor' ? `<div class="chat-avatar">${avatarLabel}</div>` : ''}<div class="chat-bubble">${bubbleContent}</div>`;
  chat.appendChild(div);
  { const isNearBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight < 100; if (isNearBottom) chat.scrollTop = chat.scrollHeight; }
}

function updatePhaseBar(phaseNum: number) {
  document.querySelectorAll('.phase-seg').forEach(el => {
    const seg = parseInt((el as HTMLElement).dataset.phase || '0');
    el.classList.remove('active', 'done');
    if (seg === phaseNum) el.classList.add('active');
    else if (seg < phaseNum) el.classList.add('done');
  });
}

function finishTherapy() {
  therapyPlayed = true;
  document.getElementById('therapy-skip')!.classList.add('hidden');
  document.getElementById('observer-bar')!.classList.add('hidden');
  document.getElementById('btn-to-train')!.classList.remove('hidden');
}

// ── Observer Notes ──────────────────────────────────────────
const observerNotes: string[] = [];

function showObserverBar() {
  document.getElementById('observer-bar')!.classList.remove('hidden');
}

function sendObserverNote(text: string) {
  if (!text.trim()) return;
  observerNotes.push(text.trim());
  const chat = document.getElementById('therapy-chat')!;
  const div = document.createElement('div');
  div.className = 'chat-msg observer';
  div.innerHTML = `<div class="chat-avatar">YOU</div><div class="chat-bubble"><div class="observer-label">Observer Note &mdash; saved for future diagnosis</div>${text.trim()}</div>`;
  chat.appendChild(div);
  { const isNearBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight < 100; if (isNearBottom) chat.scrollTop = chat.scrollHeight; }
  (document.getElementById('observer-input') as HTMLInputElement).value = '';
}

document.getElementById('observer-send')?.addEventListener('click', () => {
  sendObserverNote((document.getElementById('observer-input') as HTMLInputElement).value);
});

document.getElementById('observer-input')?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') sendObserverNote((e.target as HTMLInputElement).value);
});

// Web Speech API for voice notes
let speechRecognition: any = null;
let isRecording = false;

document.getElementById('observer-mic')?.addEventListener('click', () => {
  const micBtn = document.getElementById('observer-mic')!;
  const SpeechRecognition = (window as any).webkitSpeechRecognition || (window as any).SpeechRecognition;
  if (!SpeechRecognition) { micBtn.classList.add('hidden'); return; }

  if (isRecording && speechRecognition) {
    speechRecognition.stop();
    return;
  }

  speechRecognition = new SpeechRecognition();
  speechRecognition.continuous = false;
  speechRecognition.interimResults = false;
  speechRecognition.lang = 'en-US';

  speechRecognition.onstart = () => {
    isRecording = true;
    micBtn.classList.add('mic-recording', 'bg-red-100', 'border-red-300', 'text-red-500');
  };

  speechRecognition.onresult = (event: any) => {
    const transcript = event.results[0][0].transcript;
    sendObserverNote(transcript);
  };

  speechRecognition.onend = () => {
    isRecording = false;
    micBtn.classList.remove('mic-recording', 'bg-red-100', 'border-red-300', 'text-red-500');
  };

  speechRecognition.onerror = () => {
    isRecording = false;
    micBtn.classList.remove('mic-recording', 'bg-red-100', 'border-red-300', 'text-red-500');
  };

  speechRecognition.start();
});

document.getElementById('btn-to-train')?.addEventListener('click', () => {
