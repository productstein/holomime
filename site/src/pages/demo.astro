// Map facets to OCEAN dimensions
const FACET_TO_DIM: Record<string, number> = {
  imagination: 0, intellectual_curiosity: 0, aesthetic_sensitivity: 0, willingness_to_experiment: 0,
  self_discipline: 1, orderliness: 1, goal_orientation: 1, attention_to_detail: 1,
  assertiveness: 2, enthusiasm: 2, sociability: 2, initiative: 2,
  warmth: 3, empathy: 3, cooperation: 3, trust_tendency: 3,
  stress_tolerance: 4, emotional_regulation: 4, confidence: 4, adaptability: 4,
};

function recalcOcean() {
  const dimScores: number[][] = [[], [], [], [], []];
  for (const step of wizSteps) {
    if (step.type !== 'questions' || !step.questions) continue;
    for (const q of step.questions) {
      const choiceIdx = answers[q.id];
      if (choiceIdx === undefined) continue;
      const choice = q.choices[choiceIdx];
      for (const [facet, val] of Object.entries(choice.scores)) {
        const dim = FACET_TO_DIM[facet];
        if (dim !== undefined) dimScores[dim].push(val);
      }
    }
  }
  profileOcean = dimScores.map(arr => arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : 0.5);
  drawRadar();
}

function matchArchetype() {
  let best = ARCHETYPES[0], bestDist = Infinity;
  for (const a of ARCHETYPES) {
    let dist = 0;
    for (let i = 0; i < 5; i++) dist += (profileOcean[i] - a.ocean[i]) ** 2;
    if (dist < bestDist) { bestDist = dist; best = a; }
  }
  matchedArchetype = best;
}

