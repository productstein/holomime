let therapyPlayed = false;

// ═══════════════════════════════════════════════════════════════
// Pipeline Navigation
// ═══════════════════════════════════════════════════════════════
const PIPE_ORDER = ['define', 'diagnose', 'refine', 'train', 'evaluate', 'monitor', 'deploy'];

function updatePipeline() {
  const steps = document.querySelectorAll('.pipe-step');
  const currentIdx = PIPE_ORDER.indexOf(currentPipeStep);
  const progressLine = document.getElementById('pipeline-progress-line')!;
  progressLine.style.width = `${(currentIdx / (PIPE_ORDER.length - 1)) * 100}%`;

  steps.forEach((el) => {
    const step = (el as HTMLElement).dataset.step!;
    const idx = PIPE_ORDER.indexOf(step);
    const wasCompleted = el.classList.contains('completed');
    el.classList.remove('active', 'completed', 'locked', 'just-completed');
    if (step === currentPipeStep) el.classList.add('active');
    else if (completedSteps.has(step)) {
      el.classList.add('completed');
      if (!wasCompleted) { el.classList.add('just-completed'); setTimeout(() => el.classList.remove('just-completed'), 600); }
    }
    else if (idx <= currentIdx || completedSteps.has(PIPE_ORDER[idx - 1])) { /* unlocked but not active */ }
    else el.classList.add('locked');
  });

  document.querySelectorAll('.demo-step').forEach(el => { el.classList.add('hidden'); el.classList.remove('step-enter'); });
  const activeStep = document.getElementById(`step-${currentPipeStep}`);
  if (activeStep) { activeStep.classList.remove('hidden'); void activeStep.offsetHeight; activeStep.classList.add('step-enter'); }
}

document.querySelectorAll('.pipe-step').forEach(el => {
  el.addEventListener('click', () => {
    const step = (el as HTMLElement).dataset.step!;
    if (el.classList.contains('locked')) return;
    currentPipeStep = step;
    updatePipeline();
  });
});

// Gate interstitial data
const GATE_DATA: Record<string, { icon: string; status: string; params: string[] }> = {
