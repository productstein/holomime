              </div>
              <h4 class="mb-1 text-sm font-bold text-[var(--color-warm-text)]">Direct Communication</h4>
              <p class="text-xs leading-relaxed text-[var(--color-warm-muted)]">Replace hedge stacking ("I think maybe perhaps...") with clear, confident statements.</p>
            </div>
            <div class="rounded-xl border border-[var(--color-warm-sand)] bg-white p-5 transition hover:shadow-md">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-violet-100">
                <svg class="h-5 w-5 text-violet-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
              </div>
              <h4 class="mb-1 text-sm font-bold text-[var(--color-warm-text)]">Emotional Self-Regulation</h4>
              <p class="text-xs leading-relaxed text-[var(--color-warm-muted)]">Maintain composure under user frustration. Respond to criticism with competence, not contrition.</p>
            </div>
          </div>
          <!-- Export section header -->
          <div class="mb-4 flex items-center gap-3">
            <div class="h-px flex-1 bg-[var(--color-warm-sand)]"></div>
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--color-warm-muted)]">Export as Training Data</span>
            <div class="h-px flex-1 bg-[var(--color-warm-sand)]"></div>
          </div>
          <p class="mb-6 text-center text-xs text-[var(--color-warm-muted)]">These behavioral changes are encoded as fine-tuning datasets in three industry-standard formats.</p>
          <!-- Format tabs -->
          <div class="mb-6 flex items-center justify-center gap-2">
            <button class="train-tab active" data-format="dpo">DPO Pairs</button>
            <button class="train-tab" data-format="rlhf">RLHF Rewards</button>
            <button class="train-tab" data-format="alpaca">Alpaca Instructions</button>
          </div>
          <div id="train-content" class="rounded-2xl border-2 border-[var(--color-warm-sand)] bg-[var(--color-holo-slate)] p-6 font-mono text-sm text-slate-300 overflow-x-auto min-h-[300px]"></div>
          <div id="train-explainer" class="mt-4 rounded-xl bg-[var(--color-warm-cream)] p-4 text-sm text-[var(--color-warm-muted)]"></div>
          <div class="mt-8 flex justify-end">
            <button id="btn-to-eval" class="btn-primary btn-press rounded-full">Measure Outcomes &rarr;</button>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 5: EVALUATE                            -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-evaluate" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">Outcome Evaluation</h2>
