function showGate(fromStep: string, toStep: string): Promise<void> {
  return new Promise(resolve => {
    const key = `${fromStep}-${toStep}`;
    const data = GATE_DATA[key];
    if (!data) { resolve(); return; }
    const overlay = document.getElementById('gate-overlay')!;
    const content = document.getElementById('gate-content')!;

    // Phase A: animated icon + progress ring + status
    content.innerHTML = `
      <div class="gate-icon" style="background: linear-gradient(135deg, var(--color-p-coral), var(--color-p-violet));">
        <span class="text-white">${data.icon}</span>
      </div>
      <svg class="mx-auto" width="80" height="80" viewBox="0 0 100 100">
        <circle cx="50" cy="50" r="45" fill="none" stroke="#e5e2de" stroke-width="4"/>
        <circle cx="50" cy="50" r="45" fill="none" stroke="url(#gateGrad)" stroke-width="4" stroke-linecap="round" stroke-dasharray="283" class="gate-ring" transform="rotate(-90 50 50)"/>
        <defs><linearGradient id="gateGrad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="var(--color-p-coral)"/><stop offset="100%" stop-color="var(--color-p-violet)"/></linearGradient></defs>
      </svg>
      <p class="mt-4 text-base font-bold text-[var(--color-warm-text)]">${data.status}</p>
      <p class="mt-1 text-xs text-[var(--color-warm-muted)]">Processing pipeline gate...</p>`;

    overlay.classList.remove('hidden');
    overlay.classList.add('visible');

    // Safety timeout: auto-dismiss gate after 5 seconds if something goes wrong
    let dismissed = false;
    const safeDismiss = () => {
      if (dismissed) return;
      dismissed = true;
      overlay.classList.remove('visible');
      overlay.classList.add('hidden');
      resolve();
    };
    const safetyTimeout = setTimeout(safeDismiss, 5000);

    // Phase B: after 800ms, show checkmark + auto-dismiss after 500ms
    setTimeout(() => {
      content.innerHTML = `
        <div class="gate-icon" style="background: var(--color-p-sage-soft);">
          <svg class="h-8 w-8 text-[var(--color-p-sage)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="text-base font-bold text-[var(--color-warm-text)]">Ready</p>
        <div class="gate-params">${data.params.map(p => `<span class="gate-param">${p}</span>`).join('')}</div>`;

      const dismiss = () => { clearTimeout(safetyTimeout); safeDismiss(); };
      const auto = setTimeout(dismiss, 500);
      overlay.addEventListener('click', () => { clearTimeout(auto); dismiss(); }, { once: true });
    }, 800);
  });
}

function advancePipeline() {
  completedSteps.add(currentPipeStep);
  const idx = PIPE_ORDER.indexOf(currentPipeStep);
  if (idx < PIPE_ORDER.length - 1) {
    currentPipeStep = PIPE_ORDER[idx + 1];
    updatePipeline();
    document.getElementById('pipeline-nav')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

