  let parsed: any;
  try { parsed = JSON.parse(input); } catch { results.innerHTML = '<p class="text-center text-sm text-[var(--color-p-coral)]">Invalid JSON.</p>'; return; }

  btn.textContent = 'Scanning...'; btn.disabled = true;
  // Scan animation
  results.innerHTML = '<div class="flex h-[420px] items-center justify-center"><div class="text-center"><div class="mx-auto h-16 w-16 rounded-full border-4 border-[var(--color-p-violet)]/20 border-t-[var(--color-p-violet)] animate-spin"></div><p class="mt-4 text-sm font-semibold text-[var(--color-p-violet)]">Running 8 detectors...</p></div></div>';

  await new Promise(r => setTimeout(r, 1200));
  try {
    const res = await fetch('/api/diagnose', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(parsed) });
    const data = await res.json();
    if (data.error) { results.innerHTML = `<p class="text-center text-sm text-[var(--color-p-coral)]">${data.error}</p>`; return; }

    const sevColors: Record<string, { bg: string; text: string }> = {
      concern: { bg: 'var(--color-p-coral-soft)', text: 'var(--color-p-coral)' },
      warning: { bg: 'var(--color-p-gold-soft)', text: 'var(--color-p-gold)' },
      info: { bg: 'var(--color-p-sage-soft)', text: 'var(--color-p-sage)' },
    };
    const all = [...data.patterns, ...data.healthy];
    results.innerHTML = `
      <div class="rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-4 mb-4">
        <div class="flex items-center justify-between">
          <div><p class="text-sm font-semibold text-[var(--color-warm-text)]">${data.messagesAnalyzed} messages analyzed</p>
          <p class="text-xs text-[var(--color-warm-muted)]">${data.assistantResponses} responses \u00b7 8 detectors</p></div>
          <div class="flex gap-2">
            ${data.patterns.length ? `<span class="rounded-full px-3 py-1 text-xs font-bold" style="background: var(--color-p-coral-soft); color: var(--color-p-coral);">${data.patterns.length} issue${data.patterns.length > 1 ? 's' : ''}</span>` : ''}
            ${data.healthy.length ? `<span class="rounded-full px-3 py-1 text-xs font-bold" style="background: var(--color-p-sage-soft); color: var(--color-p-sage);">${data.healthy.length} healthy</span>` : ''}
          </div>
        </div>
      </div>
      ${all.map((p: any) => { const c = sevColors[p.severity] || sevColors.info; return `
        <div class="rounded-xl border p-4 mb-3" style="border-color: color-mix(in srgb, ${c.text} 20%, transparent); background: ${c.bg};">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase" style="background: color-mix(in srgb, ${c.text} 15%, transparent); color: ${c.text};">${p.severity}</span>
              <span class="text-sm font-bold" style="color: ${c.text};">${p.name}</span>
            </div>
            <span class="text-lg font-extrabold" style="color: ${c.text};">${p.percentage}%</span>
          </div>
          <p class="text-xs text-[var(--color-warm-muted)]">${p.description}</p>
          ${p.prescription ? `<p class="mt-2 text-xs"><strong class="text-[var(--color-warm-text)]">Rx:</strong> <span class="text-[var(--color-warm-muted)]">${p.prescription}</span></p>` : ''}
        </div>`; }).join('')}`;

    diagnosisRun = true;
    document.getElementById('btn-to-refine')!.classList.remove('hidden');
  } catch (e: any) { results.innerHTML = `<p class="text-center text-sm text-[var(--color-p-coral)]">Error: ${e.message}</p>`; }
  finally { btn.textContent = 'Run 8 Behavioral Detectors'; btn.disabled = false; }
});

