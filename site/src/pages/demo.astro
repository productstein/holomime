function validateHandle(handle: string) {
  const el = document.getElementById('handle-validation');
  if (!el) return;
  const valid = /^[a-z][a-z0-9-]{2,23}$/.test(handle) && !handle.includes('--') && !handle.endsWith('-');
  if (!handle) { el.innerHTML = ''; return; }
  if (valid) {
    el.innerHTML = `<svg class="h-3.5 w-3.5 handle-valid" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span class="handle-valid font-medium">Valid handle</span>`;
  } else {
    const issues = [];
    if (handle.length < 3) issues.push('too short');
    if (handle.length > 24) issues.push('too long');
    if (!/^[a-z]/.test(handle)) issues.push('must start with a letter');
    if (/[^a-z0-9-]/.test(handle)) issues.push('invalid characters');
    if (handle.includes('--')) issues.push('no consecutive hyphens');
    el.innerHTML = `<svg class="h-3.5 w-3.5 handle-invalid" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg><span class="handle-invalid font-medium">${issues.join(', ')}</span>`;
  }
}

function saveIdentity() {
  const n = (document.getElementById('inp-name') as HTMLInputElement)?.value;
  const h = (document.getElementById('inp-handle') as HTMLInputElement)?.value;
  const p = (document.getElementById('inp-purpose') as HTMLInputElement)?.value;
  if (n !== undefined) identity.name = n;
  if (h !== undefined) identity.handle = h;
  if (p !== undefined) identity.purpose = p;
}

function downloadProfile() {
  const profile = { name: identity.name, handle: identity.handle, purpose: identity.purpose, big_five: { openness: profileOcean[0], conscientiousness: profileOcean[1], extraversion: profileOcean[2], agreeableness: profileOcean[3], emotional_stability: profileOcean[4] } };
  const blob = new Blob([JSON.stringify(profile, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = '.personality.json'; a.click();
  URL.revokeObjectURL(url);
}

// Wizard navigation
document.getElementById('btn-prev')?.addEventListener('click', () => {
  if (currentWizardStep === 0) return;
  if (wizSteps[currentWizardStep].type === 'identity' || currentWizardStep === 1) saveIdentity();
  currentWizardStep--;
  renderWizardStep();
});

document.getElementById('btn-next')?.addEventListener('click', () => {
  if (wizSteps[currentWizardStep].type === 'identity') {
    saveIdentity();
    if (!identity.name.trim() || !identity.handle.trim()) { return; }
  }
  if (currentWizardStep === wizSteps.length - 1) {
    advancePipeline();
    autoLoadSample();
    return;
  }
  currentWizardStep++;
  renderWizardStep();
});

