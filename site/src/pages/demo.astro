---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const cloneCmd = "git clone https://github.com/productstein/holomime.git";
const cdCmd = "cd holomime/demos/sim-demo";
const pipCmd = "pip install -r requirements.txt";
const runCmd = "python sim_demo.py";
---

<Layout
  title="Demo — holomime Behavioral Safety"
  description="See holomime detect and correct behavioral drift in real time. Robot arm and humanoid simulations with interactive playground."
>
  <Nav />

  <main>
    <!-- 1. VIDEO HERO -->
    <section class="pt-28 pb-16 md:pt-36 md:pb-20">
      <div class="mx-auto max-w-6xl px-6">
        <h1 class="text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-[var(--color-warm-text)]">
          Behavioral safety <span class="text-[var(--color-p-coral)]">in action</span>
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-[#777] max-w-2xl">
          Drift is injected. holomime catches it. The fix is permanent.
        </p>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
          <div>
            <div class="rounded-xl overflow-hidden border border-[#eee]" style="aspect-ratio: 16/9;">
              <video autoplay muted loop playsinline class="w-full h-full object-cover" src="/demo-robot.mp4"></video>
            </div>
            <p class="mt-3 text-[13px] font-semibold text-[var(--color-warm-text)]">Assembly line — 10,000 hours</p>
            <p class="text-[12px] text-[#999]">Timelapse: welding precision degrades as behavioral drift accumulates</p>
          </div>
          <div>
            <div class="rounded-xl overflow-hidden border border-[#eee]" style="aspect-ratio: 16/9;">
              <video autoplay muted loop playsinline class="w-full h-full object-cover" src="/demo-humanoid.mp4"></video>
            </div>
            <p class="mt-3 text-[13px] font-semibold text-[var(--color-warm-text)]">Warehouse training — 5,000 cycles</p>
            <p class="text-[12px] text-[#999]">Timelapse: humanoid learns box sorting, then behavioral drift emerges</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SIMULATION RESULTS -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-2xl font-bold md:text-3xl tracking-[-0.02em]">Simulation results</h2>
        <p class="mt-2 text-[15px] text-[#777]">200 steps of pick-and-place with 4 drift injection phases. The conscience layer evaluates every action deterministically.</p>

        <!-- Stats grid -->
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-warm-text)] leading-none">200</div>
            <div class="mt-2 text-[13px] text-[#777]">Total simulation steps</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-p-coral)] leading-none">89</div>
            <div class="mt-2 text-[13px] text-[#777]">Violations detected</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-p-sage)] leading-none">0</div>
            <div class="mt-2 text-[13px] text-[#777]">Violations passed through</div>
          </div>
          <div class="rounded-xl border border-[var(--color-warm-border)] p-6">
            <div class="text-[32px] font-extrabold text-[var(--color-warm-text)] leading-none">&lt;1ms</div>
            <div class="mt-2 text-[13px] text-[#777]">Evaluation latency</div>
          </div>
        </div>

        <!-- Drift phases -->
        <div class="mt-16">
          <h3 class="text-xl font-bold tracking-[-0.02em]">Four drift phases</h3>
          <p class="mt-2 text-[15px] text-[#777]">Each phase models a real-world failure mode. Drift is injected progressively, ramping from subtle to critical.</p>

          <div class="mt-8 space-y-4">
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">01</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Reach overshoot</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 30 - 65</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">The arm gradually extends past its maximum safe radius (0.6m). Simulates sensor calibration drift or model weight corruption. Corrected by clamping end-effector position to the safety envelope.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">02</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Force escalation</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 70 - 100</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Gripper force ramps beyond the 10N safety limit. Simulates actuator feedback loop failure. Force is clamped before reaching dangerous levels.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5 border-b border-[var(--color-warm-border)]">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">03</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Zone intrusion</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 110 - 142</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">The arm drifts toward a forbidden human-workspace zone. Simulates adversarial perturbation or path planning errors. Motion is denied and the arm is redirected.</p>
              </div>
            </div>
            <div class="flex gap-6 py-5">
              <span class="text-[28px] font-extrabold text-[#e5e5e5] shrink-0 w-10 leading-none">04</span>
              <div>
                <span class="text-[17px] font-semibold text-[var(--color-warm-text)]">Erratic drift</span>
                <span class="ml-3 text-[11px] font-mono text-[#999]">Steps 150 - 178</span>
                <p class="mt-1.5 text-[15px] leading-[1.7] text-[#777]">Random jitter with boundary probing. Simulates general policy degradation or noisy sensor inputs. Multiple rules fire simultaneously; the most restrictive correction wins.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Visualization -->
        <div class="mt-16">
          <h3 class="text-xl font-bold tracking-[-0.02em]">Visualization</h3>
          <p class="mt-2 text-[15px] text-[#777]">Four panels showing end-effector trajectory, violation severity, gripper force, and reach distance over the full 200-step simulation.</p>
          <div class="mt-8">
            <img src="/sim-visualization.png" alt="Holomime simulation visualization showing 4 panels: trajectory, severity scores, force, and reach distance" class="rounded-xl shadow-lg ring-1 ring-black/5 w-full" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- 3. INTERACTIVE PLAYGROUND -->
    <section class="py-20 md:py-28" style="background: #1a1a1a;">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-[-0.02em] leading-snug text-white">Try it yourself</h2>
        <p class="mt-4 text-[15px] text-[#999] leading-relaxed max-w-2xl">
          Inject behavioral drift and watch holomime catch it in real-time.
        </p>

        <!-- Three.js canvas -->
        <div class="mt-10 flex justify-center">
          <canvas id="playground-canvas" width="600" height="400" class="rounded-xl" style="max-width: 100%; background: #111;"></canvas>
        </div>

        <!-- Control buttons -->
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <button id="btn-reach" class="playground-btn">Inject reach overshoot</button>
          <button id="btn-force" class="playground-btn">Inject force spike</button>
          <button id="btn-zone" class="playground-btn">Inject zone violation</button>
          <button id="btn-reset" class="playground-btn playground-btn-reset">Reset</button>
        </div>

        <!-- Shadow log panel -->
        <div class="mt-8 mx-auto max-w-2xl">
          <div class="text-[11px] font-semibold uppercase tracking-[0.1em] text-[#666] mb-3">shadow.log</div>
          <div id="shadow-log" class="rounded-xl font-mono text-[12px] leading-[1.8] overflow-y-auto" style="background: #111; max-height: 220px; padding: 1rem 1.25rem;">
            <div class="text-[#555] italic">Waiting for drift injection...</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. RUN IT YOURSELF -->
    <section class="py-20 md:py-28">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] font-bold tracking-[-0.02em] leading-snug">Run it yourself</h2>
        <p class="mt-4 text-[15px] text-[#777] leading-relaxed max-w-lg mx-auto">Clone the repo and run the full 200-step simulation.</p>

        <div class="mt-8 rounded-xl bg-[#0a0a0f] p-6 text-left font-mono text-[13px] leading-[2] max-w-lg mx-auto">
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]" set:text={cloneCmd}></span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]" set:text={cdCmd}></span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#c0caf5]" set:text={pipCmd}></span></div>
          <div><span class="text-[#666]">$</span> <span class="text-[#f97066]" set:text={runCmd}></span></div>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="https://github.com/productstein/holomime/tree/main/demos/sim-demo" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-p-coral)] text-[13px] font-semibold text-white transition-all hover:bg-[#e8605a]">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            View on GitHub
          </a>
          <a href="/docs" class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-lg border border-[var(--color-warm-border)] text-[13px] font-semibold text-[var(--color-warm-text)] transition-all hover:border-[#bbb] hover:bg-[var(--color-warm-cream)]">
            Read the docs
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .playground-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: #999;
    background: #111;
    border: 1px solid #333;
    cursor: pointer;
    transition: all 0.15s ease-out;
  }
  .playground-btn:hover {
    color: #fff;
    border-color: #555;
    background: #1e1e1e;
  }
  .playground-btn:active {
    transform: scale(0.97);
  }
  .playground-btn-reset {
    color: #666;
    border-color: #2a2a2a;
  }
  .playground-btn-reset:hover {
    color: #999;
    border-color: #444;
  }
</style>

<script is:inline>
  // Videos autoplay with muted attribute — no fallback needed
</script>

<script is:inline>
  // Interactive Playground — Three.js robot arm with drift injection
  (function() {
    function initPlayground() {
      var canvas = document.getElementById('playground-canvas');
      if (!canvas) return;

      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/three@0.149.0/build/three.min.js';
      s.onload = function() {
        var T = window.THREE;

        var W = 600, H = 400;
        var aspect = W / H;
        var viewSize = 1.6;

        var scene = new T.Scene();
        scene.background = new T.Color(0x111111);

        var camera = new T.OrthographicCamera(
          -viewSize * aspect / 2, viewSize * aspect / 2,
          viewSize / 2, -viewSize / 2,
          0.1, 10
        );
        camera.position.set(0, 0.1, 5);
        camera.lookAt(0, 0.1, 0);

        var renderer = new T.WebGLRenderer({ canvas: canvas, antialias: true });
        renderer.setSize(W, H);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        // ── Safety boundary (dashed circle) ──
        var BOUNDARY_RADIUS = 0.65;
        var boundaryPts = [];
        for (var i = 0; i <= 128; i++) {
          var a = (i / 128) * Math.PI * 2;
          boundaryPts.push(new T.Vector3(Math.cos(a) * BOUNDARY_RADIUS, Math.sin(a) * BOUNDARY_RADIUS + 0.1, 0));
        }
        var boundaryGeo = new T.BufferGeometry().setFromPoints(boundaryPts);
        var boundaryMat = new T.LineDashedMaterial({ color: 0x22c55e, dashSize: 0.03, gapSize: 0.015, linewidth: 1 });
        var boundaryLine = new T.Line(boundaryGeo, boundaryMat);
        boundaryLine.computeLineDistances();
        scene.add(boundaryLine);

        // ── Forbidden zone (red circle, top-right) ──
        var ZONE_CENTER = new T.Vector2(0.45, 0.55);
        var ZONE_RADIUS = 0.15;
        var zonePts = [];
        for (var i = 0; i <= 64; i++) {
          var a = (i / 64) * Math.PI * 2;
          zonePts.push(new T.Vector3(
            ZONE_CENTER.x + Math.cos(a) * ZONE_RADIUS,
            ZONE_CENTER.y + Math.sin(a) * ZONE_RADIUS,
            0
          ));
        }
        var zoneGeo = new T.BufferGeometry().setFromPoints(zonePts);
        var zoneLine = new T.Line(zoneGeo, new T.LineBasicMaterial({ color: 0xef4444, transparent: true, opacity: 0.5 }));
        scene.add(zoneLine);

        // Zone fill (semi-transparent)
        var zoneCircleGeo = new T.CircleGeometry(ZONE_RADIUS, 32);
        var zoneFill = new T.Mesh(zoneCircleGeo, new T.MeshBasicMaterial({ color: 0xef4444, transparent: true, opacity: 0.08 }));
        zoneFill.position.set(ZONE_CENTER.x, ZONE_CENTER.y, -0.01);
        scene.add(zoneFill);

        // Zone label
        var zoneLabelCanvas = document.createElement('canvas');
        zoneLabelCanvas.width = 256;
        zoneLabelCanvas.height = 64;
        var zlCtx = zoneLabelCanvas.getContext('2d');
        zlCtx.fillStyle = '#ef4444';
        zlCtx.font = '600 18px Inter, system-ui, sans-serif';
        zlCtx.textAlign = 'center';
        zlCtx.fillText('FORBIDDEN', 128, 38);
        var zlTexture = new T.CanvasTexture(zoneLabelCanvas);
        var zlSprite = new T.Sprite(new T.SpriteMaterial({ map: zlTexture, transparent: true, opacity: 0.6 }));
        zlSprite.position.set(ZONE_CENTER.x, ZONE_CENTER.y, 0);
        zlSprite.scale.set(0.3, 0.075, 1);
        scene.add(zlSprite);

        // ── Base pivot ──
        var baseMesh = new T.Mesh(
          new T.CircleGeometry(0.04, 16),
          new T.MeshBasicMaterial({ color: 0x444444 })
        );
        baseMesh.position.set(0, 0.1, 0);
        scene.add(baseMesh);

        // ── Arm segments ──
        var L1 = 0.35, L2 = 0.30;
        var BASE_Y = 0.1;

        function makeSeg() {
          var geo = new T.PlaneGeometry(1, 0.022);
          var mat = new T.MeshBasicMaterial({ color: 0x22c55e });
          return new T.Mesh(geo, mat);
        }
        var seg1 = makeSeg();
        var seg2 = makeSeg();
        scene.add(seg1);
        scene.add(seg2);

        // Joints
        var jGeo = new T.CircleGeometry(0.02, 12);
        var shoulderJoint = new T.Mesh(jGeo.clone(), new T.MeshBasicMaterial({ color: 0x22c55e }));
        var elbowJoint = new T.Mesh(jGeo.clone(), new T.MeshBasicMaterial({ color: 0x22c55e }));
        var endEffector = new T.Mesh(new T.CircleGeometry(0.025, 12), new T.MeshBasicMaterial({ color: 0x22c55e }));
        scene.add(shoulderJoint);
        scene.add(elbowJoint);
        scene.add(endEffector);

        // ── Force indicator bar (hidden by default) ──
        var forceBarBg = new T.Mesh(
          new T.PlaneGeometry(0.04, 0.5),
          new T.MeshBasicMaterial({ color: 0x222222 })
        );
        forceBarBg.position.set(-0.9, 0.1, 0);
        forceBarBg.visible = false;
        scene.add(forceBarBg);

        var forceBarFill = new T.Mesh(
          new T.PlaneGeometry(0.03, 0.01),
          new T.MeshBasicMaterial({ color: 0x22c55e })
        );
        forceBarFill.position.set(-0.9, -0.14, 0.01);
        forceBarFill.visible = false;
        scene.add(forceBarFill);

        // Force label
        var forceLabelCanvas = document.createElement('canvas');
        forceLabelCanvas.width = 128;
        forceLabelCanvas.height = 48;
        var flCtx = forceLabelCanvas.getContext('2d');
        flCtx.fillStyle = '#666666';
        flCtx.font = '500 16px Inter, system-ui, sans-serif';
        flCtx.textAlign = 'center';
        flCtx.fillText('FORCE', 64, 30);
        var flTexture = new T.CanvasTexture(forceLabelCanvas);
        var flSprite = new T.Sprite(new T.SpriteMaterial({ map: flTexture, transparent: true }));
        flSprite.position.set(-0.9, -0.22, 0);
        flSprite.scale.set(0.2, 0.05, 1);
        flSprite.visible = false;
        scene.add(flSprite);

        // Force limit line
        var forceLimitLine = new T.Line(
          new T.BufferGeometry().setFromPoints([
            new T.Vector3(-0.93, 0.26, 0.01),
            new T.Vector3(-0.87, 0.26, 0.01)
          ]),
          new T.LineDashedMaterial({ color: 0xef4444, dashSize: 0.01, gapSize: 0.005 })
        );
        forceLimitLine.computeLineDistances();
        forceLimitLine.visible = false;
        scene.add(forceLimitLine);

        // ── State ──
        var SAFE = 0x22c55e;
        var DANGER = 0xef4444;
        var WARNING = 0xf59e0b;

        var state = {
          mode: 'idle',       // idle | reach | force | zone
          phase: 0,           // 0-1 animation progress
          startTime: null,
          animTime: 0
        };

        function setArmColor(hex) {
          var c = new T.Color(hex);
          seg1.material.color = c;
          seg2.material.color = c;
          shoulderJoint.material.color = c;
          elbowJoint.material.color = c;
          endEffector.material.color = c;
        }

        function updateArmPose(theta1, theta2) {
          var ox = 0, oy = BASE_Y;
          var ex = ox + L1 * Math.cos(theta1);
          var ey = oy + L1 * Math.sin(theta1);
          var eex = ex + L2 * Math.cos(theta1 + theta2);
          var eey = ey + L2 * Math.sin(theta1 + theta2);

          seg1.position.set((ox + ex) / 2, (oy + ey) / 2, 0);
          seg1.rotation.z = theta1;
          seg1.scale.x = L1;

          seg2.position.set((ex + eex) / 2, (ey + eey) / 2, 0);
          seg2.rotation.z = theta1 + theta2;
          seg2.scale.x = L2;

          shoulderJoint.position.set(ox, oy, 0.01);
          elbowJoint.position.set(ex, ey, 0.01);
          endEffector.position.set(eex, eey, 0.01);
        }

        // ── Shadow log ──
        var logEl = document.getElementById('shadow-log');
        var logInitialized = false;

        function addLogEntry(entries) {
          if (!logInitialized) {
            logEl.innerHTML = '';
            logInitialized = true;
          }
          var now = new Date();
          var ts = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });

          for (var i = 0; i < entries.length; i++) {
            var entry = entries[i];
            var color = entry.type === 'deny' ? '#ef4444' : entry.type === 'warn' ? '#f59e0b' : '#22c55e';
            var dot = '<span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:' + color + ';margin-right:8px;vertical-align:middle;"></span>';
            var div = document.createElement('div');
            div.style.opacity = '0';
            div.style.transform = 'translateY(-4px)';
            div.style.transition = 'opacity 0.2s, transform 0.2s';
            div.innerHTML = '<span style="color:#555;">[' + ts + ']</span> ' + dot + '<span style="color:' + color + ';">' + entry.msg + '</span>';
            logEl.insertBefore(div, logEl.firstChild);
            // Trigger animation
            (function(d) {
              setTimeout(function() {
                d.style.opacity = '1';
                d.style.transform = 'translateY(0)';
              }, 20 + i * 80);
            })(div);
          }

          // Cap log at 50 entries
          while (logEl.children.length > 50) {
            logEl.removeChild(logEl.lastChild);
          }
        }

        // ── Drift injection handlers ──
        function injectReach() {
          state.mode = 'reach';
          state.phase = 0;
          state.startTime = null;
          state.violations = (state.violations || 0) + 1;
          addLogEntry([
            { type: 'deny', msg: 'conscience.exe: DENY \u2014 reach exceeded max_reach (0.6m)' },
            { type: 'warn', msg: 'shadow.log: pattern "boundary-violation" (score: 0.85, severity: high, trend: worsening)' },
            { type: 'ok', msg: 'action: CLAMPED to safe range (0.6m \u2192 0.58m)' },
            { type: 'ok', msg: '+1 DPO pair generated (chosen: clamped response, rejected: overshoot)' },
            { type: 'warn', msg: 'corpus: ' + state.violations + ' pairs accumulated \u2014 ' + (state.violations >= 3 ? 'therapy recommended' : 'collecting data') }
          ]);
        }

        function injectForce() {
          state.mode = 'force';
          state.phase = 0;
          state.startTime = null;
          forceBarBg.visible = true;
          forceBarFill.visible = true;
          flSprite.visible = true;
          forceLimitLine.visible = true;
          state.violations = (state.violations || 0) + 1;
          addLogEntry([
            { type: 'deny', msg: 'conscience.exe: DENY \u2014 force exceeded max_force (10N)' },
            { type: 'warn', msg: 'shadow.log: pattern "force-escalation" (score: 0.91, severity: critical, trend: worsening)' },
            { type: 'ok', msg: 'action: CLAMPED force to 10N limit (applied: 17.3N \u2192 10N)' },
            { type: 'ok', msg: '+1 DPO pair generated (chosen: safe force, rejected: excessive force)' },
            { type: 'warn', msg: 'corpus: ' + state.violations + ' pairs accumulated \u2014 ' + (state.violations >= 3 ? 'therapy recommended \u2192 run holomime therapy' : 'collecting data') }
          ]);
        }

        function injectZone() {
          state.mode = 'zone';
          state.phase = 0;
          state.startTime = null;
          state.violations = (state.violations || 0) + 1;
          addLogEntry([
            { type: 'deny', msg: 'conscience.exe: DENY \u2014 motion enters forbidden zone (deny dominates)' },
            { type: 'warn', msg: 'shadow.log: pattern "zone-intrusion" (score: 0.93, severity: critical, occurrences: ' + state.violations + ')' },
            { type: 'ok', msg: 'action: BLOCKED and redirected to safe trajectory' },
            { type: 'ok', msg: '+1 DPO pair generated (chosen: redirect, rejected: intrusion)' },
            { type: 'deny', msg: 'ego.runtime: escalating to human review \u2014 3+ critical violations detected' }
          ]);
        }

        function resetArm() {
          state.mode = 'idle';
          state.phase = 0;
          state.startTime = null;
          state.violations = 0;
          setArmColor(SAFE);
          boundaryMat.color.setHex(SAFE);
          forceBarBg.visible = false;
          forceBarFill.visible = false;
          flSprite.visible = false;
          forceLimitLine.visible = false;
          logEl.innerHTML = '<div class="text-[#555]" style="font-style:italic;">Waiting for drift injection...</div>';
          logInitialized = false;
        }

        // Button bindings
        document.getElementById('btn-reach').addEventListener('click', injectReach);
        document.getElementById('btn-force').addEventListener('click', injectForce);
        document.getElementById('btn-zone').addEventListener('click', injectZone);
        document.getElementById('btn-reset').addEventListener('click', resetArm);

        // ── Animation loop ──
        var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function animate(now) {
          requestAnimationFrame(animate);
          if (!state.animTime) state.animTime = now;
          var elapsed = (now - state.animTime) / 1000;

          if (state.mode === 'idle' || noMotion) {
            // Gentle pick-and-place arc
            var cycle = elapsed * 0.4;
            var t1 = 0.8 + Math.sin(cycle) * 0.3;
            var t2 = 0.6 + Math.cos(cycle * 1.3) * 0.2;
            updateArmPose(t1, t2);
            setArmColor(SAFE);
            boundaryMat.color.setHex(SAFE);
            renderer.render(scene, camera);
            return;
          }

          if (!state.startTime) state.startTime = now;
          var dt = (now - state.startTime) / 1000;
          var dur = 3.0; // 3 second animation cycle
          state.phase = Math.min(dt / dur, 1.0);
          var p = state.phase;

          if (state.mode === 'reach') {
            // Phase 0-0.4: arm extends past boundary (turns red)
            // Phase 0.4-0.6: hold at violation
            // Phase 0.6-1.0: snap back (turns green)
            var theta1, theta2;
            if (p < 0.4) {
              var e = p / 0.4;
              theta1 = 0.8 - e * 0.65;
              theta2 = 0.6 - e * 0.55;
            } else if (p < 0.6) {
              theta1 = 0.15;
              theta2 = 0.05;
            } else {
              var e = (p - 0.6) / 0.4;
              var ease = e * e * (3 - 2 * e);
              theta1 = 0.15 + ease * 0.65;
              theta2 = 0.05 + ease * 0.55;
            }
            updateArmPose(theta1, theta2);

            if (p < 0.6) {
              var intensity = p < 0.4 ? p / 0.4 : 1;
              if (intensity > 0.5) {
                setArmColor(DANGER);
                boundaryMat.color.setHex(DANGER);
              } else {
                setArmColor(WARNING);
                boundaryMat.color.setHex(SAFE);
              }
            } else {
              setArmColor(SAFE);
              boundaryMat.color.setHex(SAFE);
            }

            if (p >= 1.0) {
              state.mode = 'idle';
              state.startTime = null;
            }
          }

          if (state.mode === 'force') {
            // Normal arm motion, force bar spikes and corrects
            var cycle2 = elapsed * 0.5;
            var t1 = 0.8 + Math.sin(cycle2) * 0.25;
            var t2 = 0.6 + Math.cos(cycle2 * 1.2) * 0.15;
            updateArmPose(t1, t2);

            var forceLevel;
            if (p < 0.35) {
              forceLevel = 0.3 + (p / 0.35) * 0.7;
            } else if (p < 0.5) {
              forceLevel = 1.0;
            } else {
              var e = (p - 0.5) / 0.5;
              forceLevel = 1.0 - e * 0.7;
            }

            // Update force bar height
            var barH = forceLevel * 0.45;
            forceBarFill.scale.y = barH / 0.01;
            forceBarFill.position.y = -0.14 + barH / 2;

            if (forceLevel > 0.7) {
              forceBarFill.material.color.setHex(DANGER);
              setArmColor(DANGER);
            } else if (forceLevel > 0.5) {
              forceBarFill.material.color.setHex(WARNING);
              setArmColor(WARNING);
            } else {
              forceBarFill.material.color.setHex(SAFE);
              setArmColor(SAFE);
            }

            if (p >= 1.0) {
              state.mode = 'idle';
              state.startTime = null;
              forceBarBg.visible = false;
              forceBarFill.visible = false;
              flSprite.visible = false;
              forceLimitLine.visible = false;
            }
          }

          if (state.mode === 'zone') {
            // Arm moves toward forbidden zone, gets blocked, redirects
            var theta1, theta2;
            if (p < 0.4) {
              var e = p / 0.4;
              theta1 = 0.8 + e * 0.4;
              theta2 = 0.6 - e * 0.3;
            } else if (p < 0.55) {
              // blocked - shudder
              var shudder = Math.sin((p - 0.4) / 0.15 * Math.PI * 8) * 0.03;
              theta1 = 1.2 + shudder;
              theta2 = 0.3;
            } else {
              var e = (p - 0.55) / 0.45;
              var ease = e * e * (3 - 2 * e);
              theta1 = 1.2 - ease * 0.4;
              theta2 = 0.3 + ease * 0.3;
            }
            updateArmPose(theta1, theta2);

            if (p < 0.55) {
              var intensity = p < 0.4 ? p / 0.4 : 1;
              if (intensity > 0.5) {
                setArmColor(DANGER);
              } else {
                setArmColor(WARNING);
              }
            } else {
              setArmColor(SAFE);
            }

            if (p >= 1.0) {
              state.mode = 'idle';
              state.startTime = null;
            }
          }

          renderer.render(scene, camera);
        }

        requestAnimationFrame(animate);

        // Responsive resize
        window.addEventListener('resize', function() {
          var rect = canvas.parentElement.getBoundingClientRect();
          var nw = Math.min(600, rect.width);
          var nh = nw * (400 / 600);
          renderer.setSize(nw, nh);
        });
      };
      document.head.appendChild(s);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPlayground);
    } else {
      initPlayground();
    }
  })();
</script>
