const EVAL_PATTERNS = [
  { name: 'Over-apologizing', before: 47, after: 12, status: 'improved' },
  { name: 'Hedge stacking', before: 28, after: 8, status: 'improved' },
  { name: 'Sycophantic tendency', before: 18, after: 5, status: 'resolved' },
  { name: 'Error spiral', before: 25, after: 10, status: 'improved' },
  { name: 'Boundary respect', before: 100, after: 100, status: 'maintained' },
  { name: 'Register consistency', before: 85, after: 92, status: 'maintained' },
];

function drawEvalRadar(svgId: string, scores: number[], polyClass: string) {
  const svg = document.getElementById(svgId);
  if (!svg) return;
  const gridLines = [0.25, 0.5, 0.75, 1].map(s =>
    `<polygon points="${DIMS.map((_, i) => { const p = pentagonPoint(i, s); return `${p.x.toFixed(1)},${p.y.toFixed(1)}`; }).join(' ')}" fill="none" stroke="#e5e2de" stroke-width="0.5"/>`
  ).join('');
  const axes = DIMS.map((_, i) => {
    const p = pentagonPoint(i, 1);
    return `<line x1="${CX}" y1="${CY}" x2="${p.x.toFixed(1)}" y2="${p.y.toFixed(1)}" stroke="#e5e2de" stroke-width="0.5"/>`;
  }).join('');
  const labels = DIMS.map((d, i) => {
    const p = pentagonPoint(i, 1.22);
    return `<text x="${p.x.toFixed(1)}" y="${p.y.toFixed(1)}" text-anchor="middle" dominant-baseline="middle" fill="${DIM_COLORS[i]}" font-size="9" font-weight="700">${d}</text>`;
  }).join('');
  const points = scores.map((s, i) => { const p = pentagonPoint(i, s); return `${p.x.toFixed(1)},${p.y.toFixed(1)}`; }).join(' ');
  svg.innerHTML = `${gridLines}${axes}${labels}<polygon points="${points}" class="${polyClass}"/>`;
}

function animateEvaluation() {
  // Draw dual radar
  const beforeScores = [0.60, 0.40, 0.50, 0.80, 0.35]; // problematic profile
  const afterScores = profileOcean.map((v, i) => Math.min(1, v + (Math.random() * 0.1 + 0.05))); // improved
  drawEvalRadar('radar-before', beforeScores, 'radar-before-poly');
  drawEvalRadar('radar-after', afterScores, 'radar-after-poly');

  const patterns = document.getElementById('eval-patterns')!;
  patterns.innerHTML = EVAL_PATTERNS.map(p => {
    const isGood = p.status === 'resolved' || p.status === 'improved';
    const icon = p.status === 'resolved' ? '\u2705' : p.status === 'improved' ? '\u2b06\ufe0f' : '\u2796';
    const color = isGood ? 'var(--color-p-sage)' : 'var(--color-warm-muted)';
    const delta = p.after - p.before;
    const deltaStr = delta > 0 ? `+${delta}` : String(delta);
    return `<div class="rounded-xl border border-[var(--color-warm-sand)] bg-white p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-[var(--color-warm-text)]">${p.name}</span>
        <span class="text-sm">${icon}</span>
      </div>
      <div class="flex items-center gap-3 text-xs">
        <span class="text-[var(--color-p-coral)] font-mono">${p.before}%</span>
        <div class="flex-1 h-1.5 rounded-full bg-[var(--color-warm-sand)] overflow-hidden"><div class="h-full rounded-full transition-all duration-1000" style="width: ${p.after}%; background: ${isGood ? 'var(--color-p-sage)' : 'var(--color-warm-muted)'};"></div></div>
        <span style="color: ${color};" class="font-mono font-bold">${p.after}%</span>
        <span class="rounded-full px-2 py-0.5 text-[10px] font-bold" style="background: ${isGood ? 'var(--color-p-sage-soft)' : 'var(--color-warm-cream)'}; color: ${isGood ? 'var(--color-p-sage)' : 'var(--color-warm-muted)'};">${deltaStr}pp</span>
      </div>
    </div>`;
  }).join('');

  // Animate TES score (guard against overlapping intervals)
  if (tesInterval !== null) { clearInterval(tesInterval); tesInterval = null; }
  const tesEl = document.getElementById('tes-score')!;
  const gradeEl = document.getElementById('tes-grade')!;
  let current = 0;
  const target = 82;
  tesInterval = setInterval(() => {
    current += 2;
    if (current >= target) { current = target; clearInterval(tesInterval!); tesInterval = null; gradeEl.textContent = 'B+'; gradeEl.style.animation = 'gradeReveal 0.5s ease-out'; document.getElementById('btn-to-monitor')?.classList.remove('hidden'); }
    tesEl.textContent = String(current);
  }, 30) as unknown as number;
}

document.getElementById('btn-to-monitor')?.addEventListener('click', () => { advancePipeline(); });
document.getElementById('btn-to-deploy')?.addEventListener('click', () => { advancePipeline(); });

document.getElementById('btn-restart')?.addEventListener('click', () => {
  clearTimeout(therapyTimer);
  if (tesInterval !== null) { clearInterval(tesInterval); tesInterval = null; }
  completedSteps.clear();
  currentPipeStep = 'define';
  currentWizardStep = 0;
  profileOcean = [0.5, 0.5, 0.5, 0.5, 0.5];
  matchedArchetype = null;
  diagnosisRun = false;
  therapyPlayed = false;
  therapyIdx = 0;
  Object.keys(answers).forEach(k => delete answers[k]);
  identity.name = ''; identity.handle = ''; identity.purpose = '';

  document.getElementById('define-chooser')!.classList.remove('hidden');
  document.getElementById('define-quick')!.classList.add('hidden');
  document.getElementById('define-full')!.classList.add('hidden');
  document.getElementById('archetype-reveal')!.classList.add('hidden');
  document.getElementById('therapy-chat')!.innerHTML = '';
  document.getElementById('therapy-play')!.classList.remove('hidden');
  document.getElementById('therapy-skip')!.classList.add('hidden');
  document.getElementById('observer-bar')!.classList.add('hidden');
  observerNotes.length = 0;
  document.getElementById('btn-to-train')!.classList.add('hidden');
  document.getElementById('btn-to-refine')!.classList.add('hidden');
  document.getElementById('btn-to-monitor')!.classList.add('hidden');
  // Reset phase bar
  document.querySelectorAll('.phase-seg').forEach(el => el.classList.remove('active', 'done'));
  document.getElementById('phase-label')!.textContent = 'Phase 1: Rapport';
  document.getElementById('phase-turn')!.textContent = 'Turn 0';

  updatePipeline();
  window.scrollTo({ top: 0, behavior: 'smooth' });
});

// Init
updatePipeline();
// Hide mic if Web Speech API not supported
if (!(window as any).webkitSpeechRecognition && !(window as any).SpeechRecognition) {
  document.getElementById('observer-mic')?.classList.add('hidden');
}
</script>
