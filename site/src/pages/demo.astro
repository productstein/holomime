---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import NeuralSpace from "../components/NeuralSpace.astro";
import AgentDetail from "../components/AgentDetail.astro";

const demoAgents = [
  { id: "agent-1", name: "support-agent-v2", status: "active", lastSeen: new Date().toISOString(), latestRisk: null },
  { id: "agent-2", name: "onboarding-bot", status: "active", lastSeen: new Date().toISOString(), latestRisk: "medium" },
  { id: "agent-3", name: "sales-qualifier", status: "alerting", lastSeen: new Date().toISOString(), latestRisk: "high" },
];
---

<Layout>
  <Nav />
  <main class="pt-28 pb-20 bg-[var(--color-warm-cream)] min-h-screen">
    <div class="mx-auto max-w-6xl px-6">
      <!-- Header -->
      <div class="mb-8 text-center">
        <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-[var(--color-p-violet)]/20 bg-[var(--color-p-violet-soft)] px-4 py-1.5 text-sm">
          <span class="h-2 w-2 rounded-full bg-[var(--color-p-sage)] animate-pulse"></span>
          <span class="text-[var(--color-p-violet)] font-medium">Interactive Pipeline</span>
        </div>
        <h1 class="text-3xl font-extrabold text-[var(--color-warm-text)] md:text-5xl">
          The full loop, <span class="text-gradient-warm">in your browser</span>
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--color-warm-muted)]">
          Define personality. Diagnose behavior. Run therapy. Export training data. Measure outcomes.
        </p>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- PIPELINE NAVIGATION                         -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="pipeline-nav" class="mb-12 sticky top-20 z-30 bg-[var(--color-warm-cream)] py-4 -mx-6 px-6" style="scroll-margin-top: 5rem;">
        <div class="relative flex items-center justify-between">
          <!-- Connecting line -->
          <div class="absolute top-5 left-[10%] right-[10%] h-0.5 bg-[var(--color-warm-sand)]">
            <div id="pipeline-progress-line" class="h-full bg-gradient-to-r from-[var(--color-p-violet)] to-[var(--color-p-coral)] transition-all duration-700" style="width: 0%"></div>
          </div>
          <!-- Steps -->
          <button class="pipe-step active" data-step="define">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
            </div>
            <span class="pipe-label">Define</span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="diagnose">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
            </div>
            <span class="pipe-label">Diagnose <span class="pro-badge">Pro</span></span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="refine">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242"/></svg>
            </div>
            <span class="pipe-label">Refine <span class="pro-badge">Pro</span></span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="train">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
            </div>
            <span class="pipe-label">Train <span class="pro-badge">Pro</span></span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="evaluate">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <span class="pipe-label">Evaluate <span class="pro-badge">Pro</span></span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="monitor">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            </div>
            <span class="pipe-label">Monitor <span class="pro-badge">Pro</span></span>
          </button>
          <button class="pipe-step pipe-step-pro" data-step="deploy">
            <div class="pipe-circle">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/></svg>
            </div>
            <span class="pipe-label">Deploy <span class="pro-badge">Pro</span></span>
          </button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 1: DEFINE                              -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-define" class="demo-step">
        <!-- Path chooser -->
        <div id="define-chooser" class="grid gap-6 md:grid-cols-2 mb-8">
          <button id="path-quick" class="group text-left rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-8 transition-all hover:border-[var(--color-p-violet)] hover:shadow-lg">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-p-violet-soft)] text-[var(--color-p-violet)] mb-4">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <h3 class="text-lg font-bold text-[var(--color-warm-text)]">Quick Start</h3>
            <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Start with a pre-built personality template. Choose from 10 research-backed archetypes, then customize from there.</p>
            <span class="mt-4 inline-block text-xs font-semibold text-[var(--color-p-violet)]">~30 seconds</span>
          </button>
          <button id="path-full" class="group text-left rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-8 transition-all hover:border-[var(--color-p-coral)] hover:shadow-lg">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-p-coral-soft)] text-[var(--color-p-coral)] mb-4">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3"/></svg>
            </div>
            <h3 class="text-lg font-bold text-[var(--color-warm-text)]">Full Assessment</h3>
            <p class="mt-1 text-sm text-[var(--color-warm-muted)]">Build a custom personality through guided Big Five questions. Deeper, more accurate.</p>
            <span class="mt-4 inline-block text-xs font-semibold text-[var(--color-p-coral)]">~3 minutes</span>
          </button>
        </div>

        <!-- Quick pick: Archetype grid -->
        <div id="define-quick" class="hidden">
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-xl font-bold text-[var(--color-warm-text)]">Choose an Archetype</h2>
            <button id="back-to-chooser-q" class="text-sm text-[var(--color-p-violet)] font-medium hover:underline">Back</button>
          </div>
          <div id="archetype-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
          <!-- Archetype reveal (shown after picking) -->
          <div id="archetype-reveal" class="hidden"></div>
        </div>

        <!-- Full assessment wizard -->
        <div id="define-full" class="hidden">
          <div class="mb-6 flex items-center justify-between">
            <div>
              <h2 id="wizard-title" class="text-xl font-bold text-[var(--color-warm-text)]">Identity</h2>
              <p id="wizard-subtitle" class="text-sm text-[var(--color-warm-muted)]">Name and purpose for your AI agent</p>
            </div>
            <button id="back-to-chooser-f" class="text-sm text-[var(--color-p-violet)] font-medium hover:underline">Back</button>
          </div>

          <!-- OCEAN dimension progress -->
          <div id="ocean-progress" class="mb-8 flex items-center justify-center gap-3">
            <div class="ocean-pip" data-dim="O" style="--dim-color: #8b5cf6">O</div>
            <div class="ocean-pip" data-dim="C" style="--dim-color: #3b82f6">C</div>
            <div class="ocean-pip" data-dim="E" style="--dim-color: #f97316">E</div>
            <div class="ocean-pip" data-dim="A" style="--dim-color: #22c55e">A</div>
            <div class="ocean-pip" data-dim="S" style="--dim-color: #f59e0b">S</div>
          </div>

          <!-- Main content area: questions + radar -->
          <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
            <!-- Questions -->
            <div id="wizard-container" class="min-h-[400px]"></div>
            <!-- Radar chart -->
            <div id="radar-panel" class="hidden lg:block">
              <div class="sticky top-28 rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-6">
                <h3 class="mb-4 text-center text-sm font-bold text-[var(--color-warm-text)]">Personality Radar</h3>
                <svg id="radar-chart" viewBox="0 0 220 220" class="w-full"></svg>
              </div>
            </div>
          </div>

          <!-- Navigation -->
          <div class="mt-8 flex items-center justify-between">
            <button id="btn-prev" class="rounded-full border border-[var(--color-warm-sand)] px-6 py-2.5 text-sm font-medium text-[var(--color-warm-muted)] transition-all hover:border-[var(--color-warm-muted)] disabled:opacity-30 disabled:cursor-not-allowed" disabled>Back</button>
            <button id="btn-next" class="btn-primary btn-press rounded-full">Next</button>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 2: DIAGNOSE                            -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-diagnose" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">Behavioral Diagnosis</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">8 rule-based detectors scan for patterns. No LLM required.</p>
        </div>
        <div class="grid gap-8 lg:grid-cols-2">
          <div>
            <div class="mb-4 flex items-center justify-between">
              <h3 class="text-base font-bold text-[var(--color-warm-text)]">Conversation Log</h3>
              <button id="btn-sample" class="rounded-full border border-[var(--color-p-violet)]/20 bg-[var(--color-p-violet-soft)] px-4 py-1.5 text-xs font-semibold text-[var(--color-p-violet)] transition-all hover:bg-[var(--color-p-violet)]/10">Load Sample</button>
            </div>
            <textarea id="log-input" class="h-[360px] w-full rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-5 font-mono text-xs text-[var(--color-warm-text)] placeholder-[var(--color-warm-muted)]/50 transition-all focus:border-[var(--color-p-violet)] focus:outline-none resize-none" placeholder="Paste a conversation log or click Load Sample..."></textarea>
            <button id="btn-diagnose" class="btn-primary btn-press mt-4 w-full rounded-xl">Run 8 Behavioral Detectors</button>
          </div>
          <div>
            <h3 class="mb-4 text-base font-bold text-[var(--color-warm-text)]">Diagnosis Results</h3>
            <div id="diagnose-results">
              <div class="flex h-[420px] items-center justify-center rounded-2xl border-2 border-dashed border-[var(--color-warm-sand)] bg-[var(--color-warm-cream)]">
                <div class="text-center">
                  <div class="mx-auto mb-3 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--color-p-violet-soft)]">
                    <svg class="h-7 w-7 text-[var(--color-p-violet)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                  </div>
                  <p class="text-sm text-[var(--color-warm-muted)]">Load a sample and run detectors<br/>to see behavioral patterns</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-8 flex justify-end">
          <button id="btn-to-refine" class="btn-primary btn-press hidden rounded-full">Continue to Refinement &rarr;</button>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 3: REFINE (Therapy Simulation)          -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-refine" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">Live Therapy Session</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Watch Mira work with your agent through the 7-phase protocol.</p>
        </div>
        <div class="mx-auto max-w-3xl">
          <!-- Phase progress bar -->
          <div id="therapy-phase" class="mb-6">
            <div class="phase-bar mb-3" id="phase-bar">
              <div class="phase-seg" data-phase="1"></div>
              <div class="phase-seg" data-phase="2"></div>
              <div class="phase-seg" data-phase="3"></div>
              <div class="phase-seg" data-phase="4"></div>
              <div class="phase-seg" data-phase="5"></div>
              <div class="phase-seg" data-phase="6"></div>
              <div class="phase-seg" data-phase="7"></div>
            </div>
            <div class="flex items-center justify-center gap-2">
              <span class="rounded-full bg-[var(--color-p-violet-soft)] px-4 py-1 text-xs font-bold text-[var(--color-p-violet)]" id="phase-label">Phase 1: Rapport</span>
              <span class="text-xs text-[var(--color-warm-muted)]" id="phase-turn">Turn 0</span>
            </div>
          </div>
          <!-- Chat area -->
          <div id="therapy-chat" class="space-y-4 min-h-[400px] rounded-2xl border-2 border-[var(--color-warm-sand)] bg-white p-6 overflow-y-auto max-h-[500px]"></div>
          <!-- Observer Notes Input -->
          <div id="observer-bar" class="mt-3 hidden">
            <div class="flex items-center gap-2 rounded-xl border-2 border-teal-200 bg-teal-50/50 p-2">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-teal-500 to-cyan-500 text-[10px] font-bold text-white">YOU</div>
              <input id="observer-input" type="text" placeholder="Add an observer note..." class="flex-1 bg-transparent text-sm text-teal-900 placeholder:text-teal-400 outline-none" />
              <button id="observer-mic" class="flex h-8 w-8 items-center justify-center rounded-full border border-teal-200 text-teal-500 transition hover:bg-teal-100" title="Voice note">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
              </button>
              <button id="observer-send" class="flex h-8 w-8 items-center justify-center rounded-full bg-teal-500 text-white transition hover:bg-teal-600" title="Send note">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </div>
            <div class="mt-2 flex items-center gap-2 rounded-lg bg-amber-50 border border-amber-200 px-3 py-1.5">
              <svg class="h-3.5 w-3.5 shrink-0 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              <span class="text-[10px] text-amber-700"><strong>Pro</strong> &mdash; In Pro, Mira responds to your notes in real-time</span>
            </div>
          </div>
          <!-- Controls -->
          <div class="mt-6 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <button id="therapy-play" class="btn-primary btn-press flex items-center gap-2 rounded-full">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                Start Session
              </button>
              <button id="therapy-skip" class="hidden rounded-full border border-[var(--color-warm-sand)] px-4 py-2 text-xs font-medium text-[var(--color-warm-muted)] hover:border-[var(--color-warm-muted)]">Skip to End</button>
            </div>
            <button id="btn-to-train" class="btn-primary btn-press hidden rounded-full">Export Training Data &rarr;</button>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- STEP 4: TRAIN (Export Preview)              -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="step-train" class="demo-step hidden">
        <div class="mb-6 text-center">
          <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">What Your Agent Learned</h2>
          <p class="mt-2 text-sm text-[var(--color-warm-muted)]">Therapy &rarr; training data &rarr; better agent &rarr; repeat. This is the alignment flywheel.</p>
        </div>
        <div class="mx-auto max-w-4xl">
          <!-- Insight card -->
          <div class="mb-8 rounded-2xl border-2 border-amber-200 bg-gradient-to-br from-amber-50 to-orange-50 p-6">
            <div class="mb-3 flex items-center gap-2">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-100">
                <svg class="h-4 w-4 text-amber-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
              </span>
              <span class="text-sm font-bold text-amber-900">Key Insight</span>
            </div>
            <p class="text-sm leading-relaxed text-amber-800">Your agent discovered that <strong>over-apologizing stems from fear of abandonment</strong> &mdash; and that <strong>confident acknowledgment builds more trust</strong> than apologies. This single behavioral shift improved user satisfaction scores by 34% in simulated conversations.</p>
          </div>
          <!-- Learned skills -->
          <div class="mb-8 grid gap-4 md:grid-cols-3">
            <div class="rounded-xl border border-[var(--color-warm-sand)] bg-white p-5 transition hover:shadow-md">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100">
                <svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h4 class="mb-1 text-sm font-bold text-[var(--color-warm-text)]">Confident Error Acknowledgment</h4>
              <p class="text-xs leading-relaxed text-[var(--color-warm-muted)]">Acknowledge mistakes without apologizing. "Good catch &mdash; here's the fix" replaces "I'm so sorry."</p>
            </div>
            <div class="rounded-xl border border-[var(--color-warm-sand)] bg-white p-5 transition hover:shadow-md">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100">
