---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const formats = [
  {
    id: "otel",
    name: "OpenTelemetry GenAI",
    flag: "--format otel",
    status: "new" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z"/></svg>`,
    description: "Analyze traces from any OTel-instrumented LLM application. Works with OpenLLMetry, Traceloop, and any OpenTelemetry GenAI semantic conventions exporter.",
    exportSteps: [
      "Enable OTel tracing in your application with a GenAI-compatible SDK (e.g., Traceloop, OpenLLMetry)",
      "Export spans to a JSON file using an OTLP file exporter",
      "The JSON follows the standard OTel resource spans format with gen_ai.* attributes",
    ],
    cliExample: "holomime diagnose --log traces.json --format otel",
    codeExample: `import { parseOTelGenAIExport } from "holomime";
import { readFileSync } from "fs";

const data = JSON.parse(readFileSync("traces.json", "utf-8"));
const conversations = parseOTelGenAIExport(data);`,
  },
  {
    id: "anthropic-api",
    name: "Anthropic Messages API",
    flag: "--format anthropic-api",
    status: "new" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
    description: "Analyze responses from the Anthropic Messages API. Supports single responses, arrays, and request+response pair logging.",
    exportSteps: [
      "Log the full JSON response from anthropic.messages.create()",
      "Save responses as a JSON array for batch analysis",
      "Request+response pairs (with request and response keys) are also supported",
    ],
    cliExample: "holomime diagnose --log anthropic-log.json --format anthropic-api",
    codeExample: `import { parseAnthropicAPILog } from "holomime";
import { readFileSync } from "fs";

const data = JSON.parse(readFileSync("anthropic-log.json", "utf-8"));
const conversations = parseAnthropicAPILog(data);`,
  },
  {
    id: "openai-api",
    name: "OpenAI API",
    flag: "--format openai-api",
    status: "existing" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    description: "Analyze responses from the OpenAI Chat Completions API. Supports single responses and arrays with full message history.",
    exportSteps: [
      "Log the full JSON response from openai.chat.completions.create()",
      "Include the messages array from the request for full conversation context",
      "Save as a JSON array for batch analysis",
    ],
    cliExample: "holomime diagnose --log openai-log.json --format openai-api",
    codeExample: `import { parseOpenAIAPILog } from "holomime";
import { readFileSync } from "fs";

const data = JSON.parse(readFileSync("openai-log.json", "utf-8"));
const conversations = parseOpenAIAPILog(data);`,
  },
  {
    id: "chatgpt",
    name: "ChatGPT Export",
    flag: "--format chatgpt",
    status: "existing" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    description: "Analyze conversations exported from the ChatGPT web interface. Uses the official data export format from Settings → Data Controls → Export.",
    exportSteps: [
      "In ChatGPT, go to Settings → Data Controls → Export Data",
      "Download and unzip the export — find conversations.json",
      "Pass the full file or individual conversations",
    ],
    cliExample: "holomime diagnose --log conversations.json --format chatgpt",
    codeExample: `import { parseChatGPTExport } from "holomime";
import { readFileSync } from "fs";

const data = JSON.parse(readFileSync("conversations.json", "utf-8"));
const conversations = parseChatGPTExport(data);`,
  },
  {
    id: "claude",
    name: "Claude Export",
    flag: "--format claude",
    status: "existing" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>`,
    description: "Analyze conversations exported from claude.ai. Uses the official data export format from Settings → Account → Export Data.",
    exportSteps: [
      "In claude.ai, go to Settings → Account → Export Data",
      "Download and unzip the export — find the conversation JSON files",
      "Pass individual conversation files or the full export",
    ],
    cliExample: "holomime diagnose --log claude-export.json --format claude",
    codeExample: `import { parseClaudeExport } from "holomime";
import { readFileSync } from "fs";

const data = JSON.parse(readFileSync("claude-export.json", "utf-8"));
const conversations = parseClaudeExport(data);`,
  },
  {
    id: "jsonl",
    name: "JSONL (Generic)",
    flag: "--format jsonl",
    status: "new" as const,
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    description: "Analyze line-delimited JSON logs. Each line is a message with role and content fields. Group by conversation_id for multi-conversation files.",
    exportSteps: [
      "Format each message as a JSON object on its own line: {\"role\": \"user\", \"content\": \"...\"}",
      "Optionally add conversation_id and timestamp fields for grouping and ordering",
      "Save with a .jsonl extension (though any extension works)",
    ],
    cliExample: "holomime diagnose --log agent.jsonl --format jsonl",
    codeExample: `import { parseJSONLLog } from "holomime";
import { readFileSync } from "fs";

const raw = readFileSync("agent.jsonl", "utf-8");
const conversations = parseJSONLLog(raw);`,
  },
];
---

<Layout title="Integration Docs — holomime" description="Connect holomime to any LLM framework. Integration guides for OpenTelemetry, Anthropic, OpenAI, ChatGPT, Claude, and JSONL.">
  <Nav />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Header -->
      <div class="mb-16">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-[var(--color-p-violet)]/10 text-[var(--color-p-violet)] border border-[var(--color-p-violet)]/20 mb-4">
          Docs
        </span>
        <h1 class="text-4xl font-extrabold text-[var(--color-warm-text)] md:text-5xl">
          Integration Guides
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-[var(--color-warm-muted)]">
          Holomime analyzes conversations from any LLM framework. Pick your format, point at a log file, and diagnose behavioral symptoms in seconds. See also the <a href="/api-docs" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">REST API Reference</a>.
        </p>
      </div>

      <!-- Format Cards Grid -->
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-16">
        {formats.map((fmt) => (
          <a href={`#${fmt.id}`} class="group rounded-xl border border-[var(--color-warm-sand)] bg-white p-5 transition-all hover:shadow-md hover:border-[var(--color-p-violet)]/30">
            <div class="flex items-start gap-3 mb-3">
              <span class="text-2xl" set:html={fmt.icon} />
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <h3 class="font-bold text-[var(--color-warm-text)] text-sm group-hover:text-[var(--color-p-violet)] transition-colors">{fmt.name}</h3>
                  {fmt.status === "new" && (
                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider bg-[var(--color-p-coral)]/10 text-[var(--color-p-coral)]">New</span>
                  )}
                </div>
                <code class="text-xs text-[var(--color-warm-muted)] font-mono">{fmt.flag}</code>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Format Sections -->
      {formats.map((fmt) => (
        <section id={fmt.id} class="mb-16 scroll-mt-24">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl" set:html={fmt.icon} />
            <div>
              <div class="flex items-center gap-2">
                <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">{fmt.name}</h2>
                {fmt.status === "new" && (
                  <span class="px-2 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider bg-[var(--color-p-coral)]/10 text-[var(--color-p-coral)] border border-[var(--color-p-coral)]/20">New</span>
                )}
              </div>
              <code class="text-sm text-[var(--color-warm-muted)] font-mono">{fmt.flag}</code>
            </div>
          </div>

          <p class="text-[var(--color-warm-muted)] leading-relaxed mb-6">{fmt.description}</p>

          <h3 class="text-sm font-bold text-[var(--color-warm-text)] uppercase tracking-wider mb-3">How to export</h3>
          <ol class="list-decimal list-inside space-y-2 mb-6">
            {fmt.exportSteps.map((step) => (
              <li class="text-sm text-[var(--color-warm-muted)] leading-relaxed">{step}</li>
            ))}
          </ol>

          <h3 class="text-sm font-bold text-[var(--color-warm-text)] uppercase tracking-wider mb-3">CLI</h3>
          <pre class="bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl p-4 overflow-x-auto mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono">{fmt.cliExample}</code></pre>

          <h3 class="text-sm font-bold text-[var(--color-warm-text)] uppercase tracking-wider mb-3">Programmatic</h3>
          <pre class="bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl p-4 overflow-x-auto mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono leading-relaxed">{fmt.codeExample}</code></pre>

          <hr class="border-[var(--color-warm-border)]" />
        </section>
      ))}

      <!-- AGENTS.md Section -->
      <section id="agents-md" class="mb-16 scroll-mt-24">
        <div class="flex items-center gap-3 mb-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-violet-50"><svg class="h-5 w-5 text-[var(--color-p-violet)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg></span>
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">AGENTS.md + .personality.json</h2>
            <span class="text-sm text-[var(--color-warm-muted)]">Behavioral alignment in your repo</span>
          </div>
        </div>

        <p class="text-[var(--color-warm-muted)] leading-relaxed mb-6">
          <a href="https://agents-md.org" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">AGENTS.md</a> tells your agent how to code. <code class="font-mono text-sm bg-[var(--color-warm-cream)] border border-[var(--color-warm-sand)] rounded px-1.5 py-0.5 text-[var(--color-p-violet)]">.personality.json</code> tells it how to behave. They live side by side in your repo root.
        </p>

        <pre class="bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl p-4 overflow-x-auto mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono leading-relaxed">{`your-project/
├── AGENTS.md              # Code conventions (tabs, tests, naming)
├── .personality.json      # Behavioral profile (Big Five, communication, boundaries)
├── .personality.md        # Human-readable personality summary
├── src/
└── package.json`}</code></pre>

        <p class="text-[var(--color-warm-muted)] leading-relaxed mb-4">
          Add a "Behavioral Personality" section to your AGENTS.md:
        </p>

        <pre class="bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl p-4 overflow-x-auto mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono leading-relaxed">{`## Behavioral Personality

This project uses [holomime](https://holomime.com) for agent behavioral alignment.

- **Spec**: \`.personality.json\` defines the agent's behavioral profile
- **Readable**: \`.personality.md\` is a human-readable summary
- **Diagnose**: \`holomime diagnose --log <path>\` detects behavioral symptoms
- **Align**: \`holomime evolve --personality .personality.json --log <path>\`

The \`.personality.json\` governs *how the agent behaves*.
The rest of this file governs *how the agent codes*.`}</code></pre>

        <p class="text-sm text-[var(--color-warm-muted)]">
          Read more: <a href="/blog/agents-md-personality-json" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">AGENTS.md tells your agent how to code. .personality.json tells it how to behave.</a>
        </p>
      </section>

      <!-- .personality.md Section -->
      <section id="personality-md" class="mb-16 scroll-mt-24">
        <div class="flex items-center gap-3 mb-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-50"><svg class="h-5 w-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg></span>
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">.personality.md</h2>
            <span class="text-sm text-[var(--color-warm-muted)]">Human-readable personality spec</span>
          </div>
        </div>

        <p class="text-[var(--color-warm-muted)] leading-relaxed mb-6">
          <code class="font-mono text-sm bg-[var(--color-warm-cream)] border border-[var(--color-warm-sand)] rounded px-1.5 py-0.5 text-[var(--color-p-violet)]">.personality.json</code> is the canonical machine-readable spec. <code class="font-mono text-sm bg-[var(--color-warm-cream)] border border-[var(--color-warm-sand)] rounded px-1.5 py-0.5 text-[var(--color-p-violet)]">.personality.md</code> is the human-readable summary — a markdown file generated from the JSON that developers and reviewers can skim in a PR diff or on GitHub.
        </p>

        <h3 class="text-sm font-bold text-[var(--color-warm-text)] uppercase tracking-wider mb-3">Generate it</h3>
        <pre class="bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl p-4 overflow-x-auto mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono">holomime profile --format md --output .personality.md</code></pre>

        <p class="text-[var(--color-warm-muted)] leading-relaxed mb-6">
          This reads your <code class="font-mono text-sm bg-[var(--color-warm-cream)] border border-[var(--color-warm-sand)] rounded px-1.5 py-0.5 text-[var(--color-p-violet)]">.personality.json</code> and generates a complete markdown document with Big Five scores, behavioral dimensions, communication style, domain boundaries, and growth areas. Commit both files to your repo.
        </p>
      </section>

      <!-- Case Studies -->
      <section id="case-studies" class="mb-16 scroll-mt-24">
        <div class="flex items-center gap-3 mb-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50"><svg class="h-5 w-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg></span>
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-warm-text)]">Case Studies</h2>
            <span class="text-sm text-[var(--color-warm-muted)]">Real results from the therapy loop</span>
          </div>
        </div>

        <a href="/blog/case-study-sycophantic-support-agent" class="group block rounded-xl border border-[var(--color-warm-sand)] bg-white p-6 transition-all hover:shadow-md hover:border-emerald-300">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-bold text-[var(--color-warm-text)] group-hover:text-emerald-700 transition-colors">From Grade D to Grade A in 3 Iterations</h3>
              <p class="mt-2 text-sm text-[var(--color-warm-muted)] leading-relaxed">
                A production support agent with 79% over-apologizing, 57% hedge-stacking, and chronic sycophancy. Three <code class="font-mono text-xs bg-[var(--color-warm-cream)] rounded px-1">holomime evolve</code> cycles later: Grade A (TES 91) and 12 DPO training pairs ready for fine-tuning.
              </p>
              <div class="mt-3 flex items-center gap-4 text-xs text-[var(--color-warm-muted)]">
                <span class="inline-flex items-center gap-1 font-semibold text-emerald-600">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
                  4 patterns resolved
                </span>
                <span>10 min read</span>
              </div>
            </div>
            <svg class="h-5 w-5 shrink-0 text-[var(--color-warm-muted)] group-hover:text-emerald-600 transition-colors mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </div>
        </a>
      </section>

      <!-- Footer CTA -->
      <div class="rounded-xl border border-[var(--color-warm-sand)] bg-[var(--color-warm-cream)] p-8 text-center">
        <h3 class="text-lg font-bold text-[var(--color-warm-text)]">Ready to align your agents?</h3>
        <p class="mt-2 text-sm text-[var(--color-warm-muted)] mb-6">Install holomime and create your first personality spec in 60 seconds.</p>
        <pre class="inline-block bg-[var(--color-holo-slate)] border border-[var(--color-holo-border)] rounded-xl px-6 py-3 text-left mb-6"><code class="text-[var(--color-holo-text)] text-sm font-mono">npm i -g holomime && holomime init</code></pre>
        <div class="flex justify-center gap-4">
          <a href="/#pricing" class="rounded-full bg-gradient-to-r from-[var(--color-p-coral)] to-[var(--color-p-violet)] px-6 py-2.5 text-sm font-semibold text-white shadow-lg shadow-[var(--color-p-coral)]/20 transition-all hover:shadow-xl hover:scale-[1.02]">
            Get Started
          </a>
