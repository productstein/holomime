---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const posts = [
  {
    slug: "a16z-deployment-gap",
    title: "a16z Identified 6 Deployment Gaps in Physical AI. We Built the Solution for 5.",
    description: "Andreessen Horowitz published a detailed analysis of why physical AI stalls between lab demo and production deployment. Their six deployment gaps map almost perfectly to holomime's architecture. Here's the gap-by-gap breakdown.",
    date: "2026-03-28",
    category: "Industry Analysis",
    readTime: "11 min read",
  },
  {
    slug: "hyperagents-self-improving-therapy",
    title: "Hyperagents and the case for self-improving therapy",
    description: "The Hyperagents framework validates what holomime has been building: self-referential agents that modify their own modification procedures. Here's how our architecture maps to the research — and why robotics needs self-improving therapy.",
    date: "2026-03-25",
    category: "Research",
    readTime: "6 min read",
  },
  {
    slug: "why-your-ai-needs-a-shadow",
    title: "Why Your AI Agent Needs a Shadow",
    description: "Everyone's giving their AI a personality. Nobody's watching what happens to it after 10,000 interactions. Here's how the shadow model makes behavioral drift visible — and correctable.",
    date: "2026-03-25",
    category: "Research",
    readTime: "8 min read",
  },
  {
    slug: "train-the-mind-deploy-the-body",
    title: "Train the Mind, Deploy the Body",
    description: "7 robotics integrations. ROS2, MuJoCo, Isaac Sim, LeRobot, ISO compliance. The behavioral intelligence layer for humanoid robots.",
    date: "2026-03-24",
    category: "Vision",
    readTime: "6 min read",
  },
  {
    slug: "identity-stack-humanoid-robots",
    title: "Soul, Mind, Body, Conscience: The Identity Stack for Humanoid Robots",
    description: "29 humanoid OEMs. Zero identity layers. We built one. Eight files give any robot a soul, a mind, and a conscience.",
    date: "2026-03-23",
    category: "Vision",
    readTime: "5 min read",
  },
  {
    slug: "claude-code-skill-plugin",
    title: "holomime is now a Claude Code Skill",
    description: "Six slash commands for behavioral alignment — /holomime:diagnose, :benchmark, :profile, :brain, :session, :autopilot. Install from the plugin marketplace and diagnose your agent mid-conversation.",
    date: "2026-03-18",
    category: "Product",
    readTime: "4 min read",
  },
  {
    slug: "your-agent-can-refer-itself-to-therapy",
    title: "Your Agent Can Refer Itself to Therapy",
    description: "We shipped an MCP server that lets AI agents self-diagnose behavioral drift, run therapy, and track improvement — all from inside their own conversation. One command to set up.",
    date: "2026-03-17",
    category: "Product",
    readTime: "5 min read",
  },
  {
    slug: "holomime-brain-cli",
    title: "Introducing holomime brain: See Inside Your AI Agent's Brain From the Terminal",
    description: "One command turns your terminal into a real-time behavioral observatory. Watch sycophancy fire, hedging stack up, and error spirals form — all rendered as a 3D brain in your browser.",
    date: "2026-03-15",
    category: "Product",
    readTime: "6 min read",
  },
  {
    slug: "therapist-not-debugger",
    title: "Your Agent Needs a Therapist, Not a Debugger",
    description: "The AI industry treats behavioral problems as engineering problems. Here's why the therapy model is technically superior — and the vocabulary mapping that proves it.",
    date: "2026-03-14",
    category: "Vision",
    readTime: "10 min read",
  },
  {
    slug: "neuralspace-inside-your-agents-brain",
    title: "NeuralSpace: What If You Could See Inside Your Agent's Brain?",
    description: "We built a real-time 3D neural visualization for AI agents. Nine brain regions. Live behavioral signals. Fleet-wide monitoring. Here's why it matters and how it works.",
    date: "2026-03-14",
    category: "Product",
    readTime: "12 min read",
  },
  {
    slug: "case-study-sycophantic-support-agent",
    title: "Case Study: From Grade D to Grade A in 3 Iterations",
    description: "We ran holomime evolve against a sycophantic support agent. The diagnosis, the therapy cycles, and the 12 DPO pairs that came out the other side.",
    date: "2026-03-04",
    category: "Case Study",
    readTime: "10 min read",
  },
  {
    slug: "personality-as-soul",
    title: "Personality as Soul: Why .personality.json Is the Missing Layer for Humanoid Robots",
    description: "The same spec that aligns your chat agent's behavior can drive a robot's gestures, gaze, proxemics, and prosody. Here's how Big Five psychology maps to physical motion.",
    date: "2026-03-03",
    category: "Vision",
    readTime: "7 min read",
  },
  {
    slug: "behavioral-intelligence-layer",
    title: "The Behavioral Intelligence Layer for the Agent Era",
    description: "How agents treating agents creates a self-improving behavioral flywheel — and why the data it generates is the real moat.",
    date: "2026-03-03",
    category: "Vision",
    readTime: "8 min read",
  },
  {
    slug: "agents-md-personality-json",
    title: "AGENTS.md tells your agent how to code. .personality.json tells it how to behave.",
    description: "The repo is becoming the single source of truth for agent behavior. AGENTS.md governs code conventions. .personality.json governs behavioral conventions. Here's how they work together.",
    date: "2026-03-02",
    category: "Integration",
    readTime: "6 min read",
  },
];

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Layout title="Blog — holomime" description="Behavioral alignment insights for AI agent developers. Integration guides, engineering deep-dives, and product updates.">
  <Nav />
  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-4xl px-6">
      <!-- Header -->
      <div class="mb-16">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-[var(--color-p-violet)]/10 text-[var(--color-p-violet)] border border-[var(--color-p-violet)]/20 mb-4">
          Blog
        </span>
        <h1 class="text-4xl font-extrabold text-[var(--color-warm-text)] md:text-5xl">
          News & Insights
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-[var(--color-warm-muted)]">
          Integration guides, engineering deep-dives, and updates from the holomime team.
          New here? Read the <a href="/manifesto" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">manifesto</a> or start with the <a href="/docs" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">documentation</a>.
        </p>
      </div>

      <!-- Post Grid -->
      <div class="grid gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group rounded-xl border border-[var(--color-warm-sand)] bg-white p-6 transition-all hover:shadow-md hover:border-[var(--color-p-violet)]/30">
            <div class="flex flex-col sm:flex-row sm:items-start gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium tracking-wider uppercase bg-[var(--color-p-violet)]/10 text-[var(--color-p-violet)] border border-[var(--color-p-violet)]/20">
                    {post.category}
                  </span>
                  <span class="text-xs text-[var(--color-warm-muted)]">{formatDate(post.date)}</span>
                  <span class="text-xs text-[var(--color-warm-muted)]">&middot; {post.readTime}</span>
                </div>
                <h2 class="text-xl font-bold text-[var(--color-warm-text)] group-hover:text-[var(--color-p-violet)] transition-colors leading-snug">
                  {post.title}
                </h2>
                <p class="mt-2 text-sm text-[var(--color-warm-muted)] leading-relaxed">
                  {post.description}
                </p>
              </div>
              <span class="text-sm font-semibold text-[var(--color-p-violet)] group-hover:translate-x-1 transition-transform whitespace-nowrap self-end sm:self-center">
                Read &rarr;
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Newsletter CTA -->
      <div class="mt-16 rounded-xl border border-[var(--color-warm-sand)] bg-[var(--color-warm-cream)] p-8 text-center">
        <h3 class="text-lg font-bold text-[var(--color-warm-text)]">Stay in the loop</h3>
        <p class="mt-2 text-sm text-[var(--color-warm-muted)]">
          Follow us on <a href="https://github.com/productstein/holomime" target="_blank" rel="noopener" class="text-[var(--color-p-violet)] underline underline-offset-2 hover:text-[var(--color-p-coral)]">GitHub</a> for releases and updates.
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
