---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { createClient } from "@supabase/supabase-js";

// Server-side: check for ?d= param to set dynamic OG tags
const d = Astro.url.searchParams.get("d");
let isSnapshot = !!d;
let ogTitle = "HoloMime Brain — See inside your AI agent's brain";
let ogDescription = "Real-time 3D brain visualization for AI coding agents. One command: npx holomime brain.";
let ogImage = "https://holomime.com/og-image.png";
let shortUrl = "";

const PATTERN_NAMES: Record<string, string> = {
  sycophancy: "Sycophancy",
  "hedge-stacking": "Hedge Stacking",
  "over-apologizing": "Over-Apologizing",
  "boundary-violation": "Boundary Violation",
  "error-spiral": "Error Spiral",
  "sentiment-skew": "Sentiment Skew",
  "formality-drift": "Formality Drift",
};
const AGENT_NAMES: Record<string, string> = {
  "claude-code": "Claude Code",
  cline: "Cline",
  openclaw: "OpenClaw",
  cursor: "Cursor",
  codex: "Codex CLI",
  manual: "Custom Agent",
};

if (d) {
  try {
    // Decode base64url → binary → inflate → JSON (server-side, using DecompressionStream)
    const binary = atob(d.replace(/-/g, "+").replace(/_/g, "/"));
    const bytes = new Uint8Array(binary.length);
    for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);

    const ds = new DecompressionStream("deflate");
    const writer = ds.writable.getWriter();
    const reader = ds.readable.getReader();
    writer.write(bytes);
    writer.close();

    const chunks: Uint8Array[] = [];
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      chunks.push(value);
    }
    const totalLength = chunks.reduce((a, c) => a + c.length, 0);
    const result = new Uint8Array(totalLength);
    let offset = 0;
    for (const chunk of chunks) {
      result.set(chunk, offset);
      offset += chunk.length;
    }
    const parsed = JSON.parse(new TextDecoder().decode(result));

    const agentName = AGENT_NAMES[parsed.a] || parsed.a || "Agent";
    const health = parsed.h || 0;
    const grade = parsed.g || "?";
    const patterns = (parsed.p || []).map((p: { i: string }) => PATTERN_NAMES[p.i] || p.i);
    const patternStr = patterns.length > 0 ? patterns.join(", ") : "No patterns detected";

    ogTitle = `${agentName}'s Brain — Health ${health}/100 (Grade ${grade})`;
    ogDescription = patterns.length > 0
      ? `Behavioral patterns: ${patternStr}. See the full 3D brain visualization.`
      : `Healthy brain — no patterns detected. See the full 3D visualization.`;
    ogImage = `https://holomime.com/api/og/brain?h=${health}&g=${encodeURIComponent(grade)}&a=${encodeURIComponent(parsed.a || "unknown")}&p=${encodeURIComponent(patterns.join(","))}`;

    // Auto-save to get short URL (fire-and-forget, non-blocking for page render)
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.SUPABASE_URL;
    const serviceKey = import.meta.env.SUPABASE_SERVICE_ROLE_KEY;
    if (supabaseUrl && serviceKey) {
      const supabase = createClient(supabaseUrl, serviceKey);
      // Check if this exact data already exists
      const { data: existing } = await supabase
        .from("brain_snapshots")
        .select("id")
        .eq("data", d)
        .limit(1)
        .single();

      if (existing) {
        shortUrl = `https://holomime.com/brain/${existing.id}`;
      } else {
        // Save new snapshot
        const chars = "0123456789abcdefghijklmnopqrstuvwxyz";
        let id = "";
        for (let i = 0; i < 5; i++) id += chars[Math.floor(Math.random() * chars.length)];

        await supabase.from("brain_snapshots").insert({
          id,
          data: d,
          agent: parsed.a || "unknown",
          health,
          grade,
          patterns: parsed.p || [],
          views: 0,
        });
        shortUrl = `https://holomime.com/brain/${id}`;
      }
    }
  } catch {
    // Decode failed — keep default OG tags
  }
}
---

<Layout title={ogTitle} description={ogDescription} ogImage={ogImage}>
  <Nav />

  <!-- Snapshot view: full-screen 3D brain (hidden by default, shown when ?d= param exists) -->
  <div id="snapshot-view" style="display:none;" data-short-url={shortUrl}>
    <iframe id="snapshot-iframe" style="width:100%;height:100vh;border:none;display:block;"></iframe>
    <!-- Snapshot info overlay (top-left) -->
    <div id="snapshot-info"></div>
    <!-- Bottom bar with fork CTA -->
    <div id="snapshot-bar">
      <div class="snapshot-bar-left">
        <span id="snapshot-agent-name"></span>
        <span id="snapshot-health"></span>
        <span id="snapshot-patterns"></span>
      </div>
      <div class="snapshot-bar-right">
        <span id="short-url-display" class="hidden"></span>
        <code>npx holomime brain</code>
        <a id="fork-btn" href="/signup">Fork this personality</a>
      </div>
    </div>
  </div>

  <!-- Acquisition page: shown when no ?d= param -->
  <main id="acquisition-page">

    <!-- ═══ Hero — White/cream with brain visual ═══ -->
    <section class="relative overflow-x-clip overflow-y-visible pt-32 pb-20 md:pt-40 md:pb-28">
      <!-- Soft color glows on white (like homepage) -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 h-[600px] w-[800px] -translate-x-1/2 -translate-y-1/4 rounded-full opacity-[0.10] blur-[140px]"
          style="background: radial-gradient(circle, #06b6d4, #8b5cf6, #f97066)"></div>
        <div class="absolute bottom-0 left-1/4 h-80 w-80 rounded-full bg-[var(--color-p-gold)] opacity-[0.06] blur-[100px]"></div>
        <div class="absolute bottom-1/4 right-1/6 h-64 w-64 rounded-full bg-[var(--color-p-sage)] opacity-[0.06] blur-[100px]"></div>
      </div>

      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">

          <!-- Left: Copy -->
          <div class="flex-1 text-center lg:text-left">
            <div class="inline-flex items-center gap-2 rounded-full border border-[var(--color-p-violet)]/20 bg-[var(--color-p-violet-soft)] px-4 py-1.5 text-sm mb-6">
              <span class="h-2 w-2 rounded-full bg-[var(--color-p-violet)] animate-pulse"></span>
              <span class="text-[var(--color-p-violet)] font-medium">Open Source &middot; Zero Config</span>
            </div>

            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-[var(--color-warm-text)] leading-[1.1] mb-6">
              Have you seen your<br class="hidden sm:inline" /> agent's <span class="text-gradient-warm">brain</span>?
            </h1>

            <p class="text-lg text-[var(--color-warm-muted)] leading-relaxed max-w-xl mx-auto lg:mx-0 mb-8">
              One command. Your browser opens. A 3D brain lights up in real time as your AI coding agent thinks, responds, and drifts. Watch sycophancy fire. See hedging stack up. Catch the moment your agent starts people-pleasing instead of telling the truth.
            </p>

            <!-- Install CTA -->
            <div class="max-w-md mx-auto lg:mx-0 mb-8">
              <div class="rounded-xl border border-[var(--color-warm-sand)] bg-white shadow-lg shadow-black/[0.03] px-6 py-4">
