                  </div>
                  <div class="px-3 py-2 space-y-2">
                    <div>
                      <span class="text-[9px] text-[var(--color-warm-muted)] uppercase tracking-wider">Current task</span>
                      <p class="text-[10px] text-[var(--color-warm-text)] leading-tight mt-0.5">Refactoring auth middleware</p>
                    </div>
                    <div>
                      <span class="text-[9px] text-[var(--color-warm-muted)] uppercase tracking-wider">Last response</span>
                      <p class="text-[10px] text-[var(--color-warm-muted)] leading-tight mt-0.5 italic">"I'll update the session handler to use..."</p>
                    </div>
                    <div class="flex items-center gap-3">
                      <div>
                        <span class="text-[9px] text-[var(--color-warm-muted)]">Turns</span>
                        <span class="text-[10px] font-mono text-[var(--color-warm-text)] ml-1">12</span>
                      </div>
                      <div>
                        <span class="text-[9px] text-[var(--color-warm-muted)]">Health</span>
                        <span class="text-[10px] font-mono text-[var(--color-p-sage)] ml-1">87/100</span>
                      </div>
                    </div>
                  </div>
                  <div class="px-3 py-1.5 border-t border-[var(--color-warm-sand)] flex items-center justify-between">
