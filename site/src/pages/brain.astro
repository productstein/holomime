            </div>

            <div class="flex items-center gap-6 lg:justify-start justify-center">
              <a href="#how-it-works" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-p-violet)] hover:underline underline-offset-2">
                How it works
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3"/></svg>
              </a>
              <span class="h-3.5 w-px bg-[var(--color-warm-sand)]"></span>
              <a href="/demo" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-warm-muted)] hover:text-[var(--color-warm-text)] transition-colors">
                Try the platform demo
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </div>

          <!-- Right: Brain with neuron fire orbs, lobe glows, signal popups -->
          <div class="flex-1 flex justify-center lg:justify-start">
