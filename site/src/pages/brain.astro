                  <div class="w-2 h-2 rounded-full bg-[var(--color-p-sage)] shadow-[0_0_6px_2px_rgba(34,197,94,0.3)]"></div>
                  <span class="text-[11px] font-semibold text-[var(--color-warm-muted)] uppercase tracking-wider">One command. Zero config.</span>
                </div>
                <code class="text-lg font-mono text-[var(--color-p-violet)]">npx holomime brain</code>
                <p class="text-xs text-[var(--color-warm-muted)] mt-2">Auto-detects Claude Code, Cline, OpenClaw, Cursor, and Codex.</p>
