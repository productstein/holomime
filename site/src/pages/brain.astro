                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-[var(--color-p-gold)] shadow-[0_0_6px_2px_rgba(245,158,11,0.4)]"></div>
                    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-[var(--color-p-gold)]/40"></div>
                  </div>
                  <!-- Connector line to bottom popup -->
                  <div class="hidden lg:block absolute z-30" style="top: 48%; right: -12px; width: 80px; height: 1px; transform: rotate(25deg); transform-origin: left center;">
                    <div class="h-full bg-gradient-to-r from-[var(--color-p-sage)]/60 to-[var(--color-p-sage)]/10"></div>
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-[var(--color-p-sage)] shadow-[0_0_6px_2px_rgba(34,197,94,0.4)]"></div>
                    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-[var(--color-p-sage)]/40"></div>
                  </div>
                </div>
              </a>

              <!-- Signal popup card -->
              <div class="ns-signal-popup hidden lg:block absolute z-30" style="top: 8%; right: -195px;">
                <div class="w-[180px] rounded-lg border border-[var(--color-warm-sand)] bg-white shadow-xl shadow-black/[0.06] overflow-hidden">
                  <div class="px-3 py-2 border-b border-[var(--color-warm-sand)] flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-[var(--color-p-gold)] shadow-[0_0_4px_1px_rgba(245,158,11,0.4)] ns-signal-dot"></div>
                    <span class="text-[10px] font-semibold text-[var(--color-warm-text)] uppercase tracking-wider">Prefrontal Cortex</span>
                  </div>
                  <div class="px-3 py-2 space-y-1.5">
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] text-[var(--color-warm-muted)]">Sycophancy</span>
                      <div class="flex items-center gap-1.5">
                        <div class="w-12 h-1 rounded-full bg-[var(--color-warm-sand)] overflow-hidden">
                          <div class="h-full rounded-full bg-[var(--color-p-gold)]" style="width: 72%;"></div>
                        </div>
                        <span class="text-[10px] font-mono text-[var(--color-p-gold)]">0.72</span>
                      </div>
                    </div>
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] text-[var(--color-warm-muted)]">Hedging</span>
                      <div class="flex items-center gap-1.5">
                        <div class="w-12 h-1 rounded-full bg-[var(--color-warm-sand)] overflow-hidden">
                          <div class="h-full rounded-full bg-[var(--color-p-sage)]" style="width: 18%;"></div>
                        </div>
                        <span class="text-[10px] font-mono text-[var(--color-p-sage)]">0.18</span>
                      </div>
                    </div>
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] text-[var(--color-warm-muted)]">Confidence</span>
                      <div class="flex items-center gap-1.5">
                        <div class="w-12 h-1 rounded-full bg-[var(--color-warm-sand)] overflow-hidden">
                          <div class="h-full rounded-full bg-[var(--color-p-blue)]" style="width: 85%;"></div>
                        </div>
                        <span class="text-[10px] font-mono text-[var(--color-p-blue)]">0.85</span>
                      </div>
                    </div>
                    <div class="flex items-center justify-between">
                      <span class="text-[10px] text-[var(--color-warm-muted)]">Apology drift</span>
                      <div class="flex items-center gap-1.5">
                        <div class="w-12 h-1 rounded-full bg-[var(--color-warm-sand)] overflow-hidden">
                          <div class="h-full rounded-full bg-[var(--color-p-coral)]" style="width: 41%;"></div>
                        </div>
                        <span class="text-[10px] font-mono text-[var(--color-p-coral)]">0.41</span>
                      </div>
                    </div>
                  </div>
                  <div class="px-3 py-1.5 border-t border-[var(--color-warm-sand)] flex items-center gap-1.5">
                    <div class="w-1 h-1 rounded-full bg-[var(--color-p-gold)] animate-pulse"></div>
                    <span class="text-[9px] text-[var(--color-p-gold)]">Session #3 in progress</span>
                  </div>
                </div>
              </div>

              <!-- Agent task card -->
