    55% { opacity: 0.2; transform: scale(1); }
    70% { opacity: 0; transform: scale(0.92); }
  }

  /* ── Breathe ── */
  .ns-breathe {
    background: radial-gradient(ellipse at 45% 35%, rgba(139,92,246,0.06) 0%, transparent 55%);
    animation: nsBreath 4s ease-in-out infinite;
  }
  @keyframes nsBreath {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ns-neuron, .ns-lobe, .ns-breathe, .ns-signal-popup, .ns-task-popup, .ns-signal-dot, .ns-task-dot { animation: none !important; }
  }
</style>

<script>
  // Pattern ID → human-readable name mapping
  const PATTERN_NAMES: Record<string, string> = {
    'sycophancy': 'Sycophancy',
    'hedge-stacking': 'Hedge Stacking',
    'over-apologizing': 'Over-Apologizing',
    'boundary-violation': 'Boundary Violation',
    'error-spiral': 'Error Spiral',
    'sentiment-skew': 'Sentiment Skew',
    'formality-drift': 'Formality Drift',
  };

  // Health score → color
  function healthColor(h: number): string {
    if (h >= 85) return '#22c55e';
    if (h >= 70) return '#f59e0b';
    if (h >= 50) return '#f97316';
    return '#f97066';
  }

  // Agent ID → display name
  function agentDisplayName(a: string): string {
    const map: Record<string, string> = {
      'claude-code': 'Claude Code',
      'cline': 'Cline',
      'openclaw': 'OpenClaw',
      'cursor': 'Cursor',
      'codex': 'Codex CLI',
      'manual': 'Custom Agent',
    };
    return map[a] || a;
  }

  const params = new URLSearchParams(window.location.search);
  const d = params.get('d');

  if (d) {
    // Hide acquisition page, show snapshot view
    const acq = document.getElementById('acquisition-page');
    const snap = document.getElementById('snapshot-view');
    const footer = document.querySelector('footer');
    const nav = document.querySelector('nav');
    if (acq) acq.style.display = 'none';
    if (footer) footer.style.display = 'none';
    if (nav) (nav as HTMLElement).style.display = 'none';
    if (snap) {
      snap.style.display = 'block';
      const iframe = document.getElementById('snapshot-iframe') as HTMLIFrameElement;
      if (iframe) {
        iframe.src = `/neuralspace/index.html?d=${encodeURIComponent(d)}`;
      }
    }

    // Decode snapshot data to populate the bar and info overlay
    try {
      // base64url → binary → inflate → JSON
      const binary = atob(d.replace(/-/g, '+').replace(/_/g, '/'));
      const bytes = new Uint8Array(binary.length);
      for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);

      // Use pako if available, otherwise try DecompressionStream
      let jsonStr: string;
      if (typeof (window as any).pako !== 'undefined') {
        jsonStr = (window as any).pako.inflate(bytes, { to: 'string' });
      } else {
        // Fallback: load pako dynamically
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/pako@2.1.0/dist/pako_inflate.min.js';
        script.onload = () => {
          const str = (window as any).pako.inflate(bytes, { to: 'string' });
          populateSnapshot(JSON.parse(str));
        };
        document.head.appendChild(script);
        jsonStr = ''; // will be handled by onload
      }

      if (jsonStr) {
        populateSnapshot(JSON.parse(jsonStr));
      }
    } catch (e) {
      // Snapshot decode failed — still show the brain iframe, just without metadata
      console.warn('Could not decode snapshot metadata:', e);
    }

    // Wire up fork button with snapshot data
    const forkBtn = document.getElementById('fork-btn');
    if (forkBtn) {
      forkBtn.setAttribute('href', `/signup?ref=brain&d=${encodeURIComponent(d)}`);
    }

    // Show short URL if available
    const shortUrl = snap?.getAttribute('data-short-url');
    if (shortUrl) {
      const shortDisplay = document.getElementById('short-url-display');
      if (shortDisplay) {
        shortDisplay.textContent = shortUrl.replace('https://', '');
        shortDisplay.classList.remove('hidden');
        shortDisplay.style.cssText = 'font-size:12px;color:rgba(255,255,255,0.4);cursor:pointer;';
        shortDisplay.title = 'Click to copy short URL';
        shortDisplay.addEventListener('click', () => {
          navigator.clipboard.writeText(shortUrl).then(() => {
            shortDisplay.textContent = 'Copied!';
            setTimeout(() => { shortDisplay.textContent = shortUrl.replace('https://', ''); }, 1500);
          });
        });
      }
    }
  }

  function populateSnapshot(data: { h?: number; g?: string; m?: number; a?: string; p?: Array<{ i: string; s: string; c: number }> }) {
    const health = data.h ?? 0;
    const grade = data.g ?? '?';
    const agent = data.a ?? 'unknown';
    const patterns = data.p ?? [];

    // Bottom bar
    const agentEl = document.getElementById('snapshot-agent-name');
    const healthEl = document.getElementById('snapshot-health');
    const patternsEl = document.getElementById('snapshot-patterns');
    if (agentEl) agentEl.textContent = agentDisplayName(agent) + "'s Brain";
    if (healthEl) {
      healthEl.innerHTML = `Health: <span style="color:${healthColor(health)};font-weight:700">${health}/100</span> (${grade})`;
    }
    if (patternsEl && patterns.length > 0) {
      patternsEl.textContent = patterns.length + ' pattern' + (patterns.length > 1 ? 's' : '') + ' detected';
    }

    // Info overlay card
    const infoEl = document.getElementById('snapshot-info');
    if (infoEl) {
      let patternTags = '';
      for (const p of patterns) {
        const name = PATTERN_NAMES[p.i] || p.i;
        patternTags += `<span class="pattern-tag ${p.s}">${name}</span>`;
      }

      infoEl.innerHTML = `
        <div class="info-card">
          <div class="info-label">Snapshot</div>
          <div class="info-agent">${agentDisplayName(agent)}</div>
          <div class="info-health">
            <span class="health-score" style="color:${healthColor(health)}">${health}</span>
            <span class="health-grade">/ 100 &middot; Grade ${grade}</span>
          </div>
          ${patterns.length > 0 ? `
            <div class="info-label" style="margin-top:8px">Detected Patterns</div>
            <div class="info-patterns">${patternTags}</div>
          ` : '<div style="font-size:11px;color:rgba(255,255,255,0.4);margin-top:4px">No behavioral patterns detected</div>'}
        </div>
      `;
      infoEl.classList.add('visible');
    }
  }
</script>
