---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const shipped = [
  {
    title: "Personality Registry",
    description: "20 pre-built personality specs across 6 categories — Care, Strategy, Creative, Action, Wisdom, General. Browse, use, and customize.",
    version: "v2.0",
  },
  {
    title: "Agent-to-Agent Therapy Networks",
    description: "Multi-agent therapy mesh where agents treat each other. Pairing strategies: severity, round-robin, complementary, and knowledge-based.",
    version: "v2.0",
  },
  {
    title: "Persistent Therapy Memory",
    description: "Therapist remembers every past session. Pattern trajectories, carry-forward notes, and rolling context injected into each new session.",
    version: "v2.0",
  },
  {
    title: "Behavioral Knowledge Graph",
    description: "Local graph tracking agents, behaviors, triggers, interventions, and outcomes. Temporal edge decay. Query what works for which patterns.",
    version: "v2.0",
  },
  {
    title: "Self-Improving Interventions",
    description: "15 built-in interventions that learn from outcomes. Auto-escalation when lower-level interventions fail. Cross-agent knowledge sharing.",
    version: "v2.0",
  },
  {
    title: "Self-Awareness Interviews",
    description: "8 structured probes across 4 metacognition dimensions. Surface blind spots and growth areas before therapy begins.",
    version: "v2.0",
  },
  {
    title: "ReACT Reasoning for Therapist",
    description: "Structured Thought-Action-Observation-Response reasoning grounded in local behavioral data. 5 actions: assess, check history, suggest, evaluate, query.",
    version: "v2.0",
  },
  {
    title: "Custom Behavioral Detectors",
    description: "Define detectors as JSON config — regex patterns, weights, thresholds. Drop in .holomime/detectors/ and they run alongside built-in detectors.",
    version: "v2.0",
  },
  {
    title: "Multi-Surface Compilation",
    description: "Compile personality specs into provider-specific system prompts for chat, email, code review, Slack, API, and embodied surfaces.",
    version: "v1.0",
  },
  {
    title: "Fleet Monitoring & NeuralSpace",
    description: "Real-time 3D brain visualization. Monitor multiple agents from a single dashboard with individual thresholds and shared LLM providers.",
    version: "v1.0",
  },
  {
    title: "Embodied Agent Support",
    description: "Runtime sync for physical agents — ROS2, Unity, and webhook adapters. Gaze policies, proxemic zones, haptic feedback, and safety envelopes.",
    version: "v1.4",
  },
  {
    title: "Voice Monitoring",
    description: "Real-time behavioral detection on voice conversations. 5 voice-specific detectors with LiveKit, Vapi, and Retell adapters.",
    version: "v1.4",
  },
  {
    title: "Community Marketplace",
    description: "Browse, install, publish, and rate community personality specs, custom detectors, interventions, and training pairs.",
    version: "v1.4",
  },
  {
    title: "Fine-Tuning Pipeline",
    description: "End-to-end diagnose → export → train → verify pipeline. HuggingFace AutoTrain integration. The therapy fix becomes permanent.",
    version: "v1.4",
  },
  {
    title: "Hosted API & Dashboard",
    description: "Full REST API with tier-aware rate limiting, webhook delivery, and a real-time dashboard with usage analytics and behavioral health scores.",
    version: "v1.5",
  },
  {
    title: "Enterprise SSO & Org Management",
    description: "SAML/OIDC single sign-on, organization management, role-based access, custom detectors, fleet monitoring, and audit logs.",
    version: "v1.5",
  },
];

const upcoming = [
  {
    title: "Browser Extension",
    description: "Monitor and align AI behavior directly in the browser. Detect drift in real-time across web-based AI tools and chat interfaces.",
  },
  {
    title: "Mobile SDK",
    description: "Native iOS and Android SDKs for on-device behavioral monitoring, personality enforcement, and offline alignment.",
  },
];
---

<Layout
  title="Roadmap — holomime"
  description="What's shipped and what's next for holomime: persistent memory, knowledge graphs, self-improving interventions, and more."
>
  <Nav />
  <main>
    <!-- Header -->
    <section class="pt-32 pb-12 md:pt-40 md:pb-16">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-p-coral)]">
          Roadmap
        </p>
        <h1 class="mt-3 text-4xl font-extrabold text-[var(--color-warm-text)] md:text-5xl leading-tight">
          What's shipped. <span class="text-gradient-warm">What's next.</span>
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-[var(--color-warm-muted)]">
          16 features shipped across CLI, API, dashboard, and enterprise. From behavioral therapy to fleet monitoring to fine-tuning pipelines. Here's the full picture.
        </p>
      </div>
    </section>

    <!-- Shipped -->
    <section class="pb-16 md:pb-24">
      <div class="mx-auto max-w-5xl px-6">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-4 py-1.5 text-sm font-semibold text-emerald-700 border border-emerald-200">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/></svg>
            Shipped
          </span>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {shipped.map((item) => (
            <div class="rounded-2xl border border-[var(--color-warm-sand)] bg-white p-6">
              <div class="flex items-center justify-between mb-2">
                <h3 class="text-base font-bold text-[var(--color-warm-text)]">{item.title}</h3>
                <span class="rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700">{item.version}</span>
              </div>
              <p class="text-sm leading-relaxed text-[var(--color-warm-muted)]">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Upcoming -->
    <section class="pb-20 md:pb-28">
      <div class="mx-auto max-w-5xl px-6">
        <div class="flex items-center gap-3 mb-8">
          <span class="inline-flex items-center gap-2 rounded-full bg-amber-50 px-4 py-1.5 text-sm font-semibold text-amber-700 border border-amber-200">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z" clip-rule="evenodd"/></svg>
            Coming Soon
          </span>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {upcoming.map((item) => (
            <div class="rounded-2xl border border-dashed border-[var(--color-warm-sand)] bg-[var(--color-warm-cream)] p-6">
              <h3 class="text-base font-bold text-[var(--color-warm-text)]">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-warm-muted)]">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
