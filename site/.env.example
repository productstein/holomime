# ──────────────────────────────────────────
# holomime.dev — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────

# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Polar (payments)
POLAR_ACCESS_TOKEN=polar_oat_...
POLAR_PRODUCT_ID=your-monthly-product-id
POLAR_PRODUCT_ID_ANNUAL=your-annual-product-id
POLAR_WEBHOOK_SECRET=polar_whs_...

# LiveKit (voice agents)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Cloudflare Turnstile (bot protection)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Internal
INTERNAL_API_SECRET=generate-a-random-64-char-hex-string
ADMIN_EMAILS=you@example.com
SITE_URL=https://holomime.dev
DEMO_USER_PASSWORD=a-strong-password-for-demo-account
CRON_SECRET=generate-a-random-64-char-hex-string

# Optional
# ELEVENLABS_API_KEY=your-elevenlabs-key
