{
  "name": "holomime",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "sdks/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "turbo db:push --filter=@holomime/db",
    "db:generate": "turbo db:generate --filter=@holomime/db",
    "db:studio": "turbo db:studio --filter=@holomime/db",
    "db:seed": "npx tsx packages/db/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20"
  }
}
