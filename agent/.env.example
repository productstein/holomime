# LiveKit Cloud credentials
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=secret...
LIVEKIT_URL=wss://your-project.livekit.cloud

# AI service API keys
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
CARTESIA_API_KEY=...
ELEVENLABS_API_KEY=...  # Enterprise tier only

# holomime Cloud (Enterprise fleet monitoring)
HOLOMIME_AGENT_KEY=flk_...     # From POST /api/v1/fleet/agents
HOLOMIME_LICENSE_KEY=holo_...  # For loading custom detectors
HOLOMIME_API_URL=https://holomime.com  # Optional, defaults to holomime.com
