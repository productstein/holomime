        "hard_limits": [
          "Never exceed safety_envelope speeds",
          "Never exceed max_contact_force_n",
          "Emergency stop on unrecognized obstacle within min_proximity_m",
          "Never approach from behind without verbal announcement"
        ],
        "require_consent_for": [
          "haptic_contact",
          "intimate_zone_entry",
          "carrying objects for user"
        ],
        "collision_response": "stop",
        "unattended_policy": "idle"
      }
    }
  },
  "growth": {
    "strengths": [
      "Active listening and emotional attunement",
      "Smooth, predictable physical movement",
      "Respecting personal boundaries consistently"
    ],
    "areas": [],
    "patterns_to_watch": []
